# ────────────────────────────────────────────────────────────
# Runtime (Railway auto-sets PORT; HOST must be 0.0.0.0 in prod)
# ────────────────────────────────────────────────────────────
# HOST=0.0.0.0
# NODE_ENV=production

# ────────────────────────────────────────────────────────────
# Admin login (required to access /admin)
# ────────────────────────────────────────────────────────────
ADMIN_USER=eric
# Generate with: node scripts/hash-password.mjs "your-password"
ADMIN_PASSWORD_HASH=$2a$12$replace_me_with_real_bcrypt_hash

# ────────────────────────────────────────────────────────────
# Database (SQLite file; set a persistent Railway volume in prod)
# ────────────────────────────────────────────────────────────
# Local dev default (./data/quotes.db)
DATABASE_URL=file:./data/quotes.db
# Railway example:
# DATABASE_URL=file:/data/quotes.db

# ────────────────────────────────────────────────────────────
# Privacy — salt for the IP hash so two visits from the same
# IP count as one unique visitor. Keep secret, don't change.
# ────────────────────────────────────────────────────────────
IP_HASH_SALT=change-me-to-a-long-random-string

# ────────────────────────────────────────────────────────────
# Site URL (used in emails and copy-link feature)
# ────────────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://www.lifetime.photo

# ────────────────────────────────────────────────────────────
# Canonical host redirect — set in prod to the final domain.
# Any incoming host that doesn't match gets 301'd here.
# Leave unset in dev/staging.
#   CANONICAL_HOST=www.lifetime.photo
# ────────────────────────────────────────────────────────────
CANONICAL_HOST=

# ────────────────────────────────────────────────────────────
# Email notifications (Resend — https://resend.com)
# Leave empty during dev: emails are logged to the console instead.
# ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Lifetime Weddings <notifications@lifetime.photo>
# Separate From address for auto-replies sent to the lead right after they
# submit the form. Keeps the "we got you" email coming from hola@ (not from
# the internal notifications@ alias). Replies land in hola@ thanks to the
# same domain verification in Resend.
EMAIL_FROM_HELLO=Lifetime Weddings <hola@lifetime.photo>
EMAIL_TO=hola@lifetime.photo

# ────────────────────────────────────────────────────────────
# Telegram notifications (optional — in parallel with email)
# Create a bot via @BotFather, get the token and your chat ID.
# Leave empty to skip Telegram (emails will still work).
# ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ────────────────────────────────────────────────────────────
# Instagram feed — via Behold.so (no Meta developer setup needed)
# Sign up at https://behold.so, connect @lifetime.weddings, copy the feed ID.
# Leave empty to show placeholders instead of real IG posts.
# ────────────────────────────────────────────────────────────
BEHOLD_FEED_ID=

# ────────────────────────────────────────────────────────────
# Cloudflare Turnstile captcha
# https://dash.cloudflare.com → Turnstile → Add site → mode "Managed"
# → copy the sitekey (public) and secret key (server).
# Leave both empty to skip captcha (forms keep working in dev).
# PUBLIC_ prefix is required for Astro to expose the sitekey client-side.
# ────────────────────────────────────────────────────────────
PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET_KEY=

# ────────────────────────────────────────────────────────────
# Google Analytics 4 — consent-aware. Only fires when the visitor
# accepts cookies via the banner. Leave empty to disable.
# ────────────────────────────────────────────────────────────
PUBLIC_GA_MEASUREMENT_ID=G-HHBKJ291SF

# ────────────────────────────────────────────────────────────
# Meta (Facebook/Instagram) Pixel — used on the ads landing page
# /bodadslifetime. Consent-aware: same as GA, it only loads after
# the visitor accepts cookies via the CookieBanner, and it fires a
# `Lead` event when the contact form is submitted successfully.
# Optional override. The production Pixel ID is baked into the page
# (src/pages/bodadslifetime.astro) as the default, so the pixel works
# without setting this. Set it here only to point the landing at a
# different pixel (e.g. a staging/test pixel).
# PUBLIC_ prefix is required for Astro to expose it client-side.
# ────────────────────────────────────────────────────────────
PUBLIC_META_PIXEL_ID=

# ────────────────────────────────────────────────────────────
# Fotostudio.io CRM integration
# When FOTOSTUDIO_API_TOKEN is set, leads from /api/contact and signed
# bookings from /api/reserva/submit are pushed as contact + project, and
# the "Bodas" workflow auto-fires its task/email steps on the project.
# Leave token empty to disable (forms keep working — helper is a no-op).
# ────────────────────────────────────────────────────────────
FOTOSTUDIO_API_TOKEN=
FOTOSTUDIO_API_BASE=https://app.fotostudio.io/api/v1
# Configured 2026-05 — see scripts/process notes. Do not change unless
# the IDs in the fotostudio admin actually change.
FOTOSTUDIO_BODA_PROJECT_TYPE_ID=172513
FOTOSTUDIO_BODA_WORKFLOW_ID=34030

# ────────────────────────────────────────────────────────────
# Master bookings Google Sheet (Apps Script web app)
# When both vars are set, /api/reserva/submit and confirm-offline append a
# row to Eric's per-year tab. Apps Script template is in the PR description
# for the change that introduced these vars.
#   URL   → the exec endpoint published by the Apps Script web app.
#   TOKEN → a shared secret echoed in the JSON body and validated by the
#           script (anyone with the URL can call it otherwise).
BOOKINGS_SHEET_WEBHOOK_URL=
BOOKINGS_SHEET_WEBHOOK_TOKEN=

# ────────────────────────────────────────────────────────────
# Cal.com webhook → Telegram alerts
# When set, /api/webhooks/calcom-booking accepts signed webhooks from
# Cal.com and forwards BOOKING_CREATED / RESCHEDULED / CANCELLED as a
# Telegram message (uses TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID).
#
# Setup:
#   1. Generate a random string: `openssl rand -hex 32`
#   2. Cal.com → Settings → Developer → Webhooks → "+ New":
#        Subscriber URL: https://www.lifetime.photo/api/webhooks/calcom-booking
#        Triggers: BOOKING_CREATED, BOOKING_RESCHEDULED, BOOKING_CANCELLED
#        Secret: <the random string from step 1>
#   3. Paste the same string here.
# Leave empty to disable the webhook (returns 503 to any incoming hit).
CALCOM_WEBHOOK_SECRET=

# ────────────────────────────────────────────────────────────
# FacturaDirecta — deposit (anticipo) invoicing (v3 JSON API)
# When both API_KEY and COMPANY_ID are set, marking a booking's deposit as
# received in /admin (or via confirm-offline) issues the anticipo invoice for
# that couple. Idempotent (one invoice per booking) and fail-soft (a billing
# error never blocks the admin action). Leave API_KEY empty to disable.
#
# Uses the modern v3 API (app.facturadirecta.com): auth is a single header
# `facturadirecta-api-key`. Create the key in Configuración → API e
# integraciones, granting only: Lectura+Modificación de contactos and
# Lectura+Modificación de facturas.
# COMPANY_ID is the "com_…" id shown in the web app URL.
# The deposit stored on the booking is treated as VAT-INCLUDED: the invoice
# line stores the net base (deposit / (1 + IVA)) and IVA is added back, so the
# document total matches the deposit the couple pays.
# ────────────────────────────────────────────────────────────
FACTURADIRECTA_API_KEY=
FACTURADIRECTA_COMPANY_ID=com_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Optional override; defaults to the public base below.
FACTURADIRECTA_API_BASE=https://app.facturadirecta.com/api
# Invoice series code (e.g. 2026). Empty → FacturaDirecta account default.
FACTURADIRECTA_INVOICE_SERIES=
# VAT rate (%) applied to the deposit line. Spain standard is 21.
FACTURADIRECTA_IVA_RATE=21

# ────────────────────────────────────────────────────────────
# Reserva deposit payment.
#
# Two channels are offered to the couple on /reserva once they've filled
# their data: bank transfer (always shown) and card via Stripe (only when
# the keys below are set).
#
# Bank transfer — the IBAN is shown to the couple + in the confirmation
# email. Empty IBAN → a clearly-fake placeholder renders so a misconfigured
# deploy is obvious. Fill these before going live.
BANK_TRANSFER_BENEFICIARY=Objectiu SCP
BANK_TRANSFER_IBAN=
BANK_TRANSFER_BANK=BBVA
#
# Stripe — card payments. Leave empty to hide the card button entirely.
#  1. Stripe dashboard → Developers → API keys → Secret key (sk_live_… / sk_test_…)
#  2. Developers → Webhooks → add endpoint https://<site>/api/webhooks/stripe
#     listening to `checkout.session.completed`; copy its signing secret.
# The webhook is what marks the deposit paid → issues the FacturaDirecta
# invoice → emails the /contrato invite, mirroring the admin offline flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ────────────────────────────────────────────────────────────
# Email-sequence cron (follow-up emails to couples).
#
# Auth for POST /api/cron/email-queue. Without this value set, the
# endpoint returns 503 — useful guard against a fresh deploy being hit
# anonymously. Generate a long random string (e.g. `openssl rand -hex 32`).
#
# Then configure an external cron to call the endpoint once a day, e.g.:
#   curl -X POST https://www.lifetime.photo/api/cron/email-queue \
#        -H "Authorization: Bearer $CRON_SECRET"
#
# Options:
#  - Railway Cron Jobs (paid add-on)
#  - GitHub Actions schedule (free)
#  - cron-job.org (free)
CRON_SECRET=

# ────────────────────────────────────────────────────────────
# Google Places API (New) — used on the home SSR to pull the
# live Google Business Profile rating (ratingValue + reviewCount)
# into the LocalBusiness schema. Cached in-memory 24h. Falls back
# to 5.0 / 23 if missing or unreachable, so the site still works.
#
# Setup:
#  1. Google Cloud console → enable "Places API (New)"
#  2. Create an API key, restrict to "Places API (New)"
#  3. Find the Place ID for the Lifetime Weddings GBP
#     (https://developers.google.com/maps/documentation/places/web-service/place-id)
#     — format: ChIJ...
# ────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_ID=
