---
import BaseLayout from '~/layouts/BaseLayout.astro';
import VideosPage from '~/components/VideosPage.astro';
import { videos, videoThumb, videoEmbed, videoWatch } from '~/data/videos';
import { useTranslations } from '~/i18n/ui';
import { SITE } from '~/data/site';
import { breadcrumbJsonLd, ID } from '~/lib/seo';

const lang = 'ca' as const;
const t = useTranslations(lang);

// One VideoObject per trailer. Gives Google everything it needs to show
// the clip enriched in search and in the Videos tab.
const videoBlocks = videos.map((v) => ({
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: `Tràiler de boda · ${v.coupleName}`,
  description: `Tràiler de boda de ${v.coupleName} a ${v.venue}.`,
  thumbnailUrl: [videoThumb(v.youtubeId)],
  uploadDate: v.date,
  contentUrl: videoWatch(v.youtubeId),
  embedUrl: videoEmbed(v.youtubeId),
  publisher: { '@id': ID.business },
}));

const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/` },
    { name: t('schema.breadcrumb.videos'), url: `${SITE.url}/videos` },
  ]),
  ...videoBlocks,
];
---

<BaseLayout
  lang={lang}
  title="Vídeos de boda · Tràilers reals | Lifetime Weddings"
  description="Tràilers de bodes filmades per Lifetime Weddings a Tarragona, Reus i arreu de Catalunya. Estil documental, sense posats forçats."
  canonicalPath="/videos"
  jsonLd={jsonLd}
>
  <VideosPage lang={lang} />
</BaseLayout>
