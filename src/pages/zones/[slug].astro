---
// Zone-specific landing page. SEO target: "fotògraf de boda + [zone]".
// Pairs with venue landings (/venues/[slug]) and wedding galleries
// (/bodas/[slug]) — the page leans on both to maximise internal
// linking and authority distribution.
//
// Sections:
//   1. Hero with zone-specific H1 + CTA
//   2. Social-proof bar (shared with venue landings)
//   3. Why we're the local option (3 points)
//   4. Real weddings in the zone (curated grid → /bodas/[slug])
//   5. Known venues (cards → /venues/[slug])
//   6. Coverage area (no surcharge list)
//   7. Scarcity strip (20 weddings/year)
//   8. FAQ with FAQPage schema
//   9. Final peak-end CTA
//
// Catalan only for now.

export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import { ZONES } from '~/data/zones';
import { VENUES } from '~/data/venues';
import { WEDDINGS, weddingCover } from '~/data/weddings';
import { SITE, WHATSAPP_BASE } from '~/data/site';
import { useTranslations } from '~/i18n/ui';
import { breadcrumbJsonLd, zoneServiceJsonLd, faqPageJsonLd } from '~/lib/seo';
import { getGbpRating } from '~/lib/gbp-rating';

export function getStaticPaths() {
  return ZONES.map((z) => ({ params: { slug: z.slug }, props: { zone: z } }));
}

const { zone } = Astro.props;
const lang = 'ca' as const;
const t = useTranslations(lang);

// Curated wedding grid for the zone — filter by location match. We only
// show weddings that actually have photos (photoSlug + cover) — legacy
// rows without imagery would render as empty cards. They're acknowledged
// in copy below the grid.
const zoneWeddings = WEDDINGS.filter(
  (w) => w.location === zone.weddingLocationMatch && !!w.photoSlug,
).map((w) => ({ wedding: w, cover: weddingCover(w) }));
const zoneWeddingsTotal = WEDDINGS.filter((w) => w.location === zone.weddingLocationMatch).length;
const zoneWeddingsLegacy = zoneWeddingsTotal - zoneWeddings.length;

// Known venues — full venue objects + their cover for the cross-link
// cards. Skip any slug that doesn't resolve.
const zoneVenues = zone.knownVenueSlugs
  .map((slug) => {
    const venue = VENUES.find((v) => v.slug === slug);
    if (!venue) return null;
    const w = WEDDINGS.find((w) => w.slug === venue.realWeddingSlug);
    return { venue, cover: w ? weddingCover(w) : null };
  })
  .filter((x): x is NonNullable<typeof x> => x !== null);

// Live Google rating (fail-soft fallback).
const rating = await getGbpRating();

// JSON-LD bundle.
const canonicalUrl = `${SITE.url}/zones/${zone.slug}`;
const jsonLd = [
  zoneServiceJsonLd({
    zoneName: zone.name,
    areaServed: zone.coverageList,
    canonicalUrl,
  }),
  faqPageJsonLd(zone.faqs),
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/` },
    { name: 'Zones', url: `${SITE.url}/zones/${zone.slug}` },
    { name: zone.name, url: canonicalUrl },
  ]),
];

// Hero cover: use the first wedding cover from the zone as a representative
// image, fallback to /og-default. Visually warmer than a stock photo.
const heroCover = zoneWeddings[0]?.cover ?? '/og-default.jpg';

// Pre-filled WhatsApp message.
const waMessage = encodeURIComponent(
  `Hola! Ens casem a la zona de ${zone.name} i estem mirant fotògrafs.`,
);
const waLink = `${WHATSAPP_BASE}&text=${waMessage}`;
---

<BaseLayout
  lang={lang}
  title={zone.metaTitle}
  description={zone.metaDescription}
  canonicalPath={`/zones/${zone.slug}`}
  jsonLd={jsonLd}
  ogImage={heroCover ?? '/og-default.jpg'}
>
  <!-- Hero -->
  <section class="relative h-[70vh] min-h-[480px] overflow-hidden">
    <img
      src={heroCover}
      alt={`Fotografia de boda a ${zone.name}`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1920"
      height="1280"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/35 to-black/75"></div>
    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">
        {zone.eyebrow}
      </p>
      <h1 class="font-display text-3xl md:text-5xl font-bold max-w-4xl leading-tight">
        {zone.h1}
      </h1>
      <p class="mt-5 max-w-2xl text-base md:text-lg leading-relaxed opacity-95">
        {zone.subtitle}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a
          href={waLink}
          target="_blank"
          rel="noopener"
          class="inline-block bg-gold text-ink border-2 border-gold px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors"
        >
          Mira si tenim la vostra data lliure
        </a>
        <a
          href="/quiz"
          class="inline-block border-2 border-white/80 text-white px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-white/10 transition-colors"
        >
          Quiz d'1 minut
        </a>
      </div>
    </div>
  </section>

  <!-- Social proof bar -->
  <section class="bg-ink text-white py-6 px-6 border-y border-gold/20">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row gap-4 sm:gap-10 items-center justify-center text-center text-sm">
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">+150</span>
        <span class="opacity-85">bodes documentades</span>
      </div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">{rating.ratingValue.toFixed(1)}★</span>
        <span class="opacity-85">a Google · {rating.reviewCount} ressenyes</span>
      </div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">2</span>
        <span class="opacity-85">germans · foto + vídeo en un sol equip</span>
      </div>
    </div>
  </section>

  <!-- Why local -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">
        Per què som l'opció local per a una boda a {zone.name}
      </h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">
        {zone.whyLocalIntro}
      </p>
      <ol class="space-y-6">
        {zone.whyLocalPoints.map((p, i) => (
          <li class="flex gap-4">
            <span class="font-display text-2xl text-gold font-bold flex-shrink-0">
              {i + 1}.
            </span>
            <div class="flex-1">
              <p class="font-display text-lg font-bold text-ink mb-1">
                {p.label}
              </p>
              <p class="text-ink/80 leading-relaxed">{p.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </Section>

  <!-- Real weddings in the zone -->
  {zoneWeddings.length > 0 && (
    <Section bg="cream">
      <div class="max-w-6xl mx-auto px-2">
        <div class="text-center mb-10 md:mb-12">
          <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">
            Bodes reals al Camp de {zone.name}
          </h2>
          <p class="text-ink/70 max-w-xl mx-auto leading-relaxed">
            Una mostra del que hem fet els darrers anys. Cada miniatura porta al reportatge complet.
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
          {zoneWeddings.map(({ wedding, cover }) => (
            <a
              href={`/bodas/${wedding.slug}`}
              class="group block bg-white border border-ink/10 hover:border-gold transition-colors overflow-hidden"
            >
              {cover && (
                <div class="aspect-square overflow-hidden bg-cream">
                  <img
                    src={cover}
                    alt={`Boda de ${wedding.couple}${wedding.venue !== '—' ? ` a ${wedding.venue}` : ''}`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    width="800"
                    height="800"
                  />
                </div>
              )}
              <div class="p-3 md:p-4">
                <p class="font-display text-base md:text-lg font-bold leading-tight group-hover:text-gold transition-colors">
                  {wedding.couple}
                </p>
                {wedding.venue !== '—' && (
                  <p class="text-xs text-ink/60 mt-1">{wedding.venue}</p>
                )}
              </div>
            </a>
          ))}
        </div>
        {zoneWeddingsLegacy > 0 && (
          <p class="text-center text-sm text-ink/65 mt-10 italic">
            I {zoneWeddingsLegacy} reportatges més a {zone.name} ciutat, Reus, Salou, Cambrils i comarca — totalitzem {zoneWeddingsTotal}+ bodes a la zona.
          </p>
        )}
      </div>
    </Section>
  )}

  <!-- Known venues -->
  {zoneVenues.length > 0 && (
    <Section>
      <div class="max-w-6xl mx-auto px-2">
        <div class="text-center mb-10 md:mb-12">
          <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">
            Venues de {zone.name} que ja coneixem
          </h2>
          <p class="text-ink/70 max-w-2xl mx-auto leading-relaxed">
            Si ja teniu venue triat i és un d'aquests, parlem ja: en tenim una landing dedicada amb consells fotogràfics específics i FAQs per a cada un.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
          {zoneVenues.map(({ venue, cover }) => (
            <a
              href={`/venues/${venue.slug}`}
              class="group block bg-white border border-ink/10 hover:border-gold transition-colors overflow-hidden"
            >
              {cover && (
                <div class="aspect-[4/3] overflow-hidden bg-cream">
                  <img
                    src={cover}
                    alt={`${venue.name} · cobertura de boda per Lifetime Weddings`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    width="800"
                    height="600"
                  />
                </div>
              )}
              <div class="p-4">
                <p class="font-display text-base font-bold leading-tight group-hover:text-gold transition-colors">
                  {venue.name}
                </p>
                <p class="mt-2 text-xs font-bold tracking-[0.14em] uppercase text-gold">
                  Veure landing →
                </p>
              </div>
            </a>
          ))}
        </div>
        <p class="text-center text-sm text-ink/65 mt-10 max-w-xl mx-auto leading-relaxed">
          El vostre venue no és aquí? Probablement el coneixem igual. Demaneu-nos i us ho confirmem.
        </p>
      </div>
    </Section>
  )}

  <!-- Coverage area -->
  <Section bg="cream">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">
        Cobertura sense recàrrec a {zone.name} i comarques
      </h2>
      <p class="text-ink/75 leading-relaxed mb-8">
        {zone.coverageIntro}
      </p>
      <ul class="grid grid-cols-2 gap-x-6 gap-y-2 mb-8">
        {zone.coverageList.map((place) => (
          <li class="flex items-start gap-2 text-ink/85">
            <span class="text-gold mt-0.5">·</span>
            <span>{place}</span>
          </li>
        ))}
      </ul>
      <p class="text-sm text-ink/65 italic leading-relaxed">
        {zone.coverageNote}
      </p>
    </div>
  </Section>

  <!-- Scarcity strip — honest, real cap -->
  <section class="bg-white py-8 md:py-10 px-6 border-y border-ink/10">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-ink/85 leading-relaxed text-base md:text-lg">
        <span class="font-bold">Acceptem un màxim de 20 bodes l'any</span>
        per poder dedicar-nos a cadascuna sense pressa. Si teniu la data,
        comproveu-la com més aviat millor.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <Section bg="cream">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-8">
        Preguntes habituals sobre la nostra cobertura a {zone.name}
      </h2>
      <dl class="space-y-6">
        {zone.faqs.map((f) => (
          <div class="border-b border-ink/10 pb-6">
            <dt class="font-display text-lg font-bold text-ink mb-2">
              {f.question}
            </dt>
            <dd class="text-ink/80 leading-relaxed whitespace-pre-line">{f.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </Section>

  <!-- Final CTA — peak-end -->
  <Section>
    <div class="max-w-2xl mx-auto px-2 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-5">
        {zone.finalCtaH2}
      </h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">
        {zone.finalCtaBody}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={waLink}
          target="_blank"
          rel="noopener"
          class="inline-block bg-gold text-ink border-2 border-gold px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors"
        >
          WhatsApp directe
        </a>
        <a
          href="/quiz"
          class="inline-block border-2 border-ink text-ink px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors"
        >
          Quiz d'1 minut amb pressupost
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>
