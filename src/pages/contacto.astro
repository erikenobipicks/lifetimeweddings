---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactForm from '~/components/sections/ContactForm.astro';
import Section from '~/components/Section.astro';
import { SITE } from '~/data/site';
import { useTranslations } from '~/i18n/ui';

const lang = 'ca' as const;
const t = useTranslations(lang);
---

<BaseLayout
  lang={lang}
  title="Contacta amb Lifetime Weddings | Fotògrafs de bodes a Tarragona"
  description="Parlem de la vostra boda. Resposta en menys de 24h. Reus, Tarragona, Lleida, Barcelona i arreu del món."
  canonicalPath="/contacto"
>
  <Section bg="cream" class="pt-32">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Parlem…</h1>
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-4">Foto i vídeo de bodes</p>
      <p class="text-ink/75 leading-relaxed max-w-xl mx-auto">
        Esteu buscant fotògraf i videògraf professional per a la vostra boda? Deixeu-nos les vostres dades i ens posarem en contacte ben aviat.
      </p>
    </div>
  </Section>

  <ContactForm lang={lang} compact />

  <Section>
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">{t('contact.where.title')}</h2>
      <p class="text-ink/75 leading-relaxed mb-6">{t('contact.where.desc')}</p>
      <address class="not-italic space-y-1 text-ink/80">
        <p><strong>{SITE.address.street}</strong> · {SITE.address.city} ({SITE.address.region})</p>
        <p>
          <a href={`mailto:${SITE.email}`} class="text-gold hover:underline">{SITE.email}</a>
          <span class="mx-2 opacity-50">·</span>
          <a href={`tel:${SITE.phone}`} class="text-gold hover:underline">{SITE.phoneDisplay}</a>
        </p>
      </address>
    </div>
  </Section>
</BaseLayout>
