---
// Public cancellation-agreement signing page. States:
//   - booking missing / not cancelled  → 404 "no disponible"
//   - already signed                   → confirmation
//   - cancelled, not signed            → show document + e-sign
export const prerender = false;

import BaseLayout from '~/layouts/BaseLayout.astro';
import type { Lang } from '~/i18n/ui';
import { getBookingBySlug } from '~/lib/bookings/repository';
import { buildCancellationHtml } from '~/lib/contracts/cancellation';
import SignatureCapture from '~/components/SignatureCapture.astro';

const slug = Astro.params.slug!;
const booking = await getBookingBySlug(slug);
const lang: Lang = booking ? booking.preferredLanguage : 'ca';

const available = booking && booking.cancelledAt;
const signed = booking && booking.cancellationSignedAt;

if (!available) {
  Astro.response.status = 404;
}

const html = available ? buildCancellationHtml(booking!) : '';

const TX = {
  ca: {
    title: 'Acord de cancel·lació',
    intro: 'Si us plau, llegiu l’acord i confirmeu la cancel·lació signant a baix.',
    checkbox: 'He llegit i accepto l’acord de cancel·lació.',
    submit: 'Signar la cancel·lació',
    submitting: 'Signant…',
    successTitle: 'Cancel·lació signada',
    successBody: 'Gràcies. Hem registrat la vostra signatura. Rebreu una còpia per correu.',
    signedTitle: 'Aquest acord ja està signat',
    signedBody: 'La cancel·lació ja consta com a signada. No cal fer res més.',
    naTitle: 'Enllaç no disponible',
    naBody: 'Aquest enllaç de cancel·lació no és vàlid o ja no està actiu.',
    err: 'Hi ha hagut un error. Torna-ho a provar.',
    signMissing: 'Si us plau, escriviu el nom i signeu al requadre abans de continuar.',
  },
  es: {
    title: 'Acuerdo de cancelación',
    intro: 'Por favor, lee el acuerdo y confirma la cancelación firmando abajo.',
    checkbox: 'He leído y acepto el acuerdo de cancelación.',
    submit: 'Firmar la cancelación',
    submitting: 'Firmando…',
    successTitle: 'Cancelación firmada',
    successBody: 'Gracias. Hemos registrado tu firma. Recibirás una copia por correo.',
    signedTitle: 'Este acuerdo ya está firmado',
    signedBody: 'La cancelación ya consta como firmada. No hace falta nada más.',
    naTitle: 'Enlace no disponible',
    naBody: 'Este enlace de cancelación no es válido o ya no está activo.',
    err: 'Ha habido un error. Inténtalo de nuevo.',
    signMissing: 'Por favor, escribe tu nombre y firma en el recuadro antes de continuar.',
  },
  en: {
    title: 'Cancellation agreement',
    intro: 'Please read the agreement and confirm the cancellation by signing below.',
    checkbox: 'I have read and accept the cancellation agreement.',
    submit: 'Sign the cancellation',
    submitting: 'Signing…',
    successTitle: 'Cancellation signed',
    successBody: 'Thank you. Your signature has been recorded. You will receive a copy by email.',
    signedTitle: 'This agreement is already signed',
    signedBody: 'The cancellation is already recorded as signed. Nothing else is needed.',
    naTitle: 'Link not available',
    naBody: 'This cancellation link is not valid or no longer active.',
    err: 'Something went wrong. Please try again.',
    signMissing: 'Please type your name and sign in the box before continuing.',
  },
} as const;
const t = TX[lang] ?? TX.ca;
---

<BaseLayout title={t.title} description={t.title} lang={lang} noindex={true} chromeless={true}>
  <section class="px-6 md:px-12 py-12 md:py-20 bg-cream text-ink min-h-screen">
    <div class="max-w-3xl mx-auto">
      {!available ? (
        <div class="bg-white border border-ink/10 p-8 text-center">
          <h1 class="font-display text-2xl font-bold mb-3">{t.naTitle}</h1>
          <p class="text-ink/75">{t.naBody}</p>
        </div>
      ) : signed ? (
        <div class="bg-white border border-emerald-300 p-8">
          <h1 class="font-display text-2xl font-bold mb-3">{t.signedTitle}</h1>
          <p class="text-ink/75">{t.signedBody}</p>
        </div>
      ) : (
        <>
          <h1 class="font-display text-3xl md:text-4xl font-bold mb-3">{t.title}</h1>
          <p class="text-ink/75 leading-relaxed mb-8">{t.intro}</p>

          <div id="cx-status" class="hidden mb-8" role="status" aria-live="polite"></div>

          <article class="contract-body bg-white border border-ink/10 p-6 md:p-10 mb-8 max-h-[60vh] overflow-y-auto" set:html={html} />

          <form id="cx-form" novalidate class="bg-white border border-ink/10 p-6 md:p-8">
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" name="accepted" required class="h-5 w-5 mt-0.5 accent-gold flex-shrink-0" />
              <span class="text-sm font-semibold">{t.checkbox} *</span>
            </label>

            <SignatureCapture lang={lang} />

            <div class="mt-6">
              <button type="submit" id="cx-submit" class="inline-flex items-center justify-center bg-gold text-ink font-bold px-8 py-4 hover:bg-ink hover:text-white transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                {t.submit}
              </button>
            </div>
          </form>
        </>
      )}
    </div>
  </section>

  <style>
    .contract-body :global(h1) { font-size: 1.25rem; font-weight: 700; text-align: center; margin: 0 0 1rem; }
    .contract-body :global(p) { font-size: 0.9rem; line-height: 1.6; margin: 0 0 0.6rem; }
    .contract-body :global(strong) { font-weight: 700; }
    .contract-body :global(em) { color: #7d6944; }
  </style>

  <script
    is:inline
    define:vars={{ slug, successTitle: t.successTitle, successBody: t.successBody, submitting: t.submit, submittingLabel: t.submitting, errGeneric: t.err, signMissing: t.signMissing }}
  >
    (() => {
      const form = document.getElementById('cx-form');
      const status = document.getElementById('cx-status');
      const submitBtn = document.getElementById('cx-submit');
      if (!form || !status || !submitBtn) return;
      function showStatus(kind, title, body) {
        const colors = kind === 'ok'
          ? 'bg-emerald-50 border-emerald-300 text-emerald-900'
          : 'bg-red-50 border-red-300 text-red-900';
        status.className = `mb-8 p-5 border ${colors}`;
        status.innerHTML = `<p class="font-display text-lg font-bold mb-2">${title}</p><p class="text-sm leading-relaxed">${body}</p>`;
        status.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      form.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        if (!form.reportValidity()) return;
        const nameEl = form.querySelector('input[name="signerName"]');
        const sigEl = form.querySelector('input[name="signatureImage"]');
        const signerName = nameEl ? nameEl.value.trim() : '';
        const signatureImage = sigEl ? sigEl.value : '';
        if (!signerName || !signatureImage) {
          showStatus('err', '⚠', signMissing);
          return;
        }
        submitBtn.disabled = true;
        const old = submitBtn.textContent;
        submitBtn.textContent = submittingLabel;
        try {
          const res = await fetch('/api/cancellacio/accept', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug, signerName, signatureImage }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.status === 200 && data.ok) {
            form.style.display = 'none';
            document.querySelector('.contract-body')?.classList.remove('max-h-[60vh]');
            showStatus('ok', successTitle, successBody);
            return;
          }
          if (res.status === 409) { window.location.reload(); return; }
          throw new Error(data.error || 'failed');
        } catch (e) {
          showStatus('err', '⚠', errGeneric);
          submitBtn.disabled = false;
          submitBtn.textContent = old;
        }
      });
    })();
  </script>
</BaseLayout>
