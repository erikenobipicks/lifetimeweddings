---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import WeddingGalleryChunk from '~/components/WeddingGalleryChunk.astro';
import { WEDDINGS, weddingCover, weddingGallery } from '~/data/weddings';
import { VENUES } from '~/data/venues';
import { useTranslations } from '~/i18n/ui';
import { SITE, WHATSAPP_BASE } from '~/data/site';
import { breadcrumbJsonLd, imageGalleryJsonLd } from '~/lib/seo';

export function getStaticPaths() {
  return WEDDINGS.map((w) => ({ params: { slug: w.slug }, props: { wedding: w } }));
}

const { wedding } = Astro.props;
const lang = 'ca' as const;
const t = useTranslations(lang);
const cover = weddingCover(wedding);
const gallery = weddingGallery(wedding);
// Hero cover in largest size for above-the-fold quality.
const coverLarge = gallery[0]?.variants.lg ?? cover;
const totalPhotos = gallery.length;
const hasVenue = wedding.venue && wedding.venue !== '—';
const hasLocation = wedding.location && wedding.location !== '—';

// If we have a dedicated venue landing for this wedding's venue, use
// the venue name as a contextual internal link. Boosts the landing's
// inbound equity and gives the visitor a path to deeper content.
const venueLanding = VENUES.find((v) => v.realWeddingSlug === wedding.slug) ?? null;

/** Alt text for gallery image i (1-indexed position). Never empty. */
function galleryAlt(i: number): string {
  const nn = String(i).padStart(2, '0');
  const count = String(totalPhotos).padStart(2, '0');
  if (hasVenue && hasLocation) {
    return `Boda de ${wedding.couple} a ${wedding.venue} · ${wedding.location} · Foto ${nn} de ${count}`;
  }
  if (hasVenue) {
    return `Boda de ${wedding.couple} a ${wedding.venue} · Foto ${nn} de ${count}`;
  }
  return `Boda de ${wedding.couple} · Lifetime Weddings · Foto ${nn} de ${count}`;
}

// Split the gallery into ~3 equal chunks so the page can intersperse a
// short intro paragraph and a mid-page CTA between blocks of photos.
// Single-photo galleries collapse to one chunk and the CTA still renders
// — the visitor never sees an empty section.
function chunkGallery<T>(arr: T[], n: number): T[][] {
  if (arr.length === 0) return [];
  const size = Math.ceil(arr.length / n);
  const out: T[][] = [];
  for (let i = 0; i < arr.length; i += size) {
    out.push(arr.slice(i, i + size));
  }
  return out;
}
const chunks = chunkGallery(gallery, 3);
const chunkStart = (idx: number): number =>
  chunks.slice(0, idx).reduce((sum, c) => sum + c.length, 0);

// Pre-filled WhatsApp link mentioning the couple, so we know which
// gallery the lead came from without asking.
const waMessage = encodeURIComponent(
  `Hola! Hem vist la boda de ${wedding.couple} al vostre web. Ens casem i tenim ganes de saber si tenim disponibilitat.`,
);
const waLink = `${WHATSAPP_BASE}&text=${waMessage}`;

const pageUrl = `${SITE.url}/bodas/${wedding.slug}`;
const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/` },
    { name: t('schema.breadcrumb.bodas'), url: `${SITE.url}/#portfolio` },
    { name: wedding.couple, url: pageUrl },
  ]),
  ...(gallery.length > 0
    ? [
        imageGalleryJsonLd({
          pageUrl,
          name: hasVenue
            ? `Boda de ${wedding.couple} a ${wedding.venue}`
            : `Boda de ${wedding.couple}`,
          description: hasVenue && hasLocation
            ? `Galeria de la boda de ${wedding.couple} a ${wedding.venue} (${wedding.location}).`
            : `Galeria de la boda de ${wedding.couple}.`,
          contentLocation: hasVenue
            ? { name: wedding.venue, addressLocality: hasLocation ? wedding.location : undefined }
            : undefined,
          photos: gallery.map((img, i) => ({
            contentUrl: img.variants.lg,
            thumbnailUrl: img.variants.sm,
            width: img.width,
            height: img.height,
            caption: galleryAlt(i + 1),
          })),
        }),
      ]
    : []),
];
---

<BaseLayout
  lang={lang}
  title={wedding.venue && wedding.venue !== '—'
    ? `${wedding.couple} · ${wedding.venue} · Lifetime Weddings`
    : `${wedding.couple} · Lifetime Weddings`}
  description={wedding.venue && wedding.venue !== '—'
    ? `Galeria de la boda de ${wedding.couple} a ${wedding.venue} (${wedding.location}).`
    : `Galeria de la boda de ${wedding.couple}.`}
  canonicalPath={`/bodas/${wedding.slug}`}
  jsonLd={jsonLd}
  ogImage={cover ?? '/og-default.jpg'}
  ogType="article"
>
  {cover && (
    <section class="relative h-[60vh] min-h-[420px] overflow-hidden">
      <picture>
        <source type="image/webp" srcset={coverLarge.replace(/\.jpe?g$/, '.webp')} />
        <img
          src={coverLarge}
          alt={wedding.venue && wedding.venue !== '—' ? `${wedding.couple} · ${wedding.venue}` : wedding.couple}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1920"
          height="1280"
        />
      </picture>
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
        <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">Bodes</p>
        <h1 class="font-display text-4xl md:text-5xl font-bold">{wedding.couple}</h1>
        <p class="mt-3 opacity-90">
          {venueLanding ? (
            <a href={`/venues/${venueLanding.slug}`} class="border-b border-gold/60 hover:text-gold transition-colors">{wedding.venue}</a>
          ) : (
            wedding.venue !== '—' ? wedding.venue : ''
          )}
          {wedding.venue !== '—' && wedding.location !== '—' ? ' · ' : ''}
          {wedding.location !== '—' ? wedding.location : ''}
        </p>
      </div>
    </section>
  )}

  {gallery.length === 0 ? (
    <Section>
      <div class="max-w-2xl mx-auto text-center text-ink/75 leading-relaxed">
        <p>Galeria en preparació.</p>
      </div>
    </Section>
  ) : (
    <>
      {/* Intro paragraph — short context beat right under the hero so the
          page doesn't open with a wall of photos. */}
      <Section>
        <div class="max-w-2xl mx-auto px-2 text-center">
          <p class="text-ink/85 leading-relaxed text-base md:text-lg">
            {hasVenue && hasLocation
              ? <>Una jornada documentada a <span class="font-semibold">{wedding.venue}</span>, {wedding.location}. {totalPhotos} fotografies de la boda de <span class="font-semibold">{wedding.couple}</span> — sense posats, captant el dia tal com va passar.</>
              : hasVenue
                ? <>Una jornada documentada a <span class="font-semibold">{wedding.venue}</span>. {totalPhotos} fotografies de la boda de <span class="font-semibold">{wedding.couple}</span> — sense posats, captant el dia tal com va passar.</>
                : <>{totalPhotos} fotografies de la boda de <span class="font-semibold">{wedding.couple}</span> — sense posats, captant el dia tal com va passar.</>}
          </p>
        </div>
      </Section>

      {/* Chunk 1 */}
      <Section>
        <WeddingGalleryChunk
          photos={chunks[0]}
          startIndex={0}
          pageUrl={pageUrl}
          galleryAlt={galleryAlt}
          photoLabel={(i) => `Foto ${i}`}
          pinterestLabel="Desa a Pinterest"
        />
      </Section>

      {/* Mid CTA — only renders if there's more than one chunk; otherwise
          we'd be CTA-ing a visitor who's barely seen anything. */}
      {chunks.length > 1 && (
        <section class="bg-cream py-12 md:py-16 px-6 border-y border-ink/10">
          <div class="max-w-2xl mx-auto text-center">
            {venueLanding ? (
              <p class="text-ink/85 leading-relaxed text-base md:text-lg mb-5">
                Us caseu a <span class="font-semibold">{wedding.venue}</span>? Tenim una <a href={`/venues/${venueLanding.slug}`} class="border-b border-gold text-ink font-semibold hover:text-gold transition-colors">pàgina dedicada a la nostra cobertura aquí</a> amb consells fotogràfics específics i FAQs.
              </p>
            ) : (
              <p class="text-ink/85 leading-relaxed text-base md:text-lg mb-5">
                Vols una boda documentada així? Acceptem un màxim de 20 bodes l'any — mira si tenim la teva data lliure.
              </p>
            )}
            <a
              href={waLink}
              target="_blank"
              rel="noopener"
              class="inline-block bg-ink text-white border-2 border-ink px-7 py-3 text-sm font-bold tracking-[0.14em] uppercase hover:bg-gold hover:border-gold transition-colors"
            >
              WhatsApp directe
            </a>
          </div>
        </section>
      )}

      {/* Chunk 2 */}
      {chunks[1] && (
        <Section>
          <WeddingGalleryChunk
            photos={chunks[1]}
            startIndex={chunkStart(1)}
            pageUrl={pageUrl}
            galleryAlt={galleryAlt}
            photoLabel={(i) => `Foto ${i}`}
            pinterestLabel="Desa a Pinterest"
          />
        </Section>
      )}

      {/* Chunk 3 */}
      {chunks[2] && (
        <Section>
          <WeddingGalleryChunk
            photos={chunks[2]}
            startIndex={chunkStart(2)}
            pageUrl={pageUrl}
            galleryAlt={galleryAlt}
            photoLabel={(i) => `Foto ${i}`}
            pinterestLabel="Desa a Pinterest"
          />
        </Section>
      )}

      {/* Final venue reference (if applicable) + booking CTA */}
      <Section bg="cream">
        <div class="max-w-2xl mx-auto px-2 text-center">
          {venueLanding && (
            <>
              <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">
                Sobre el venue
              </p>
              <p class="text-ink/85 leading-relaxed text-base md:text-lg mb-8">
                Si {wedding.venue} és el vostre venue, mireu la <a href={`/venues/${venueLanding.slug}`} class="border-b border-gold text-ink font-semibold hover:text-gold transition-colors">cobertura específica que fem aquí</a> — FAQs, consells fotogràfics i el que aporta visualment aquest espai.
              </p>
            </>
          )}
          <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">
            Vols una boda així?
          </h2>
          <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">
            Anem en parella — foto + vídeo en un sol equip. Acceptem un màxim de 20 bodes l'any.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href={waLink}
              target="_blank"
              rel="noopener"
              class="inline-block bg-gold text-ink border-2 border-gold px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors"
            >
              WhatsApp directe
            </a>
            <a
              href="/quiz"
              class="inline-block border-2 border-ink text-ink px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors"
            >
              Quiz d'1 minut
            </a>
          </div>
        </div>
      </Section>
    </>
  )}
</BaseLayout>
