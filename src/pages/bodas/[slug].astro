---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import { WEDDINGS, weddingCover, weddingGallery } from '~/data/weddings';
import { useTranslations } from '~/i18n/ui';
import { SITE } from '~/data/site';
import { breadcrumbJsonLd, weddingCaseJsonLd } from '~/lib/seo';
import { getWeddingCase } from '~/lib/weddings-rich';
import WeddingCaseRich from '~/components/weddings/WeddingCaseRich.astro';

export function getStaticPaths() {
  return WEDDINGS.map((w) => ({ params: { slug: w.slug }, props: { wedding: w } }));
}

const { wedding } = Astro.props;
const lang = 'ca' as const;
const t = useTranslations(lang);

// These pages are prerendered in both dev and prod, so query params are not
// observable here. For live preview of the rich template during write-up,
// use the dev-only SSR route /_preview-weddings/[lang]/[slug].
const caseResult = (await getWeddingCase(wedding.slug, lang))!;

const cover = weddingCover(wedding);
const gallery = weddingGallery(wedding);
const coverLarge = gallery[0]?.variants.lg ?? cover;
const totalPhotos = gallery.length;
const hasVenue = wedding.venue && wedding.venue !== '—';
const hasLocation = wedding.location && wedding.location !== '—';

/** Alt text for gallery image i (1-indexed position). Never empty. */
function galleryAlt(i: number): string {
  const nn = String(i).padStart(2, '0');
  const count = String(totalPhotos).padStart(2, '0');
  if (hasVenue && hasLocation) {
    return `Boda de ${wedding.couple} a ${wedding.venue} · ${wedding.location} · Foto ${nn} de ${count}`;
  }
  if (hasVenue) {
    return `Boda de ${wedding.couple} a ${wedding.venue} · Foto ${nn} de ${count}`;
  }
  return `Boda de ${wedding.couple} · Lifetime Weddings · Foto ${nn} de ${count}`;
}

const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/` },
    { name: t('schema.breadcrumb.bodas'), url: `${SITE.url}/#portfolio` },
    { name: wedding.couple, url: `${SITE.url}/bodas/${wedding.slug}` },
  ]),
  ...(caseResult.mode === 'rich'
    ? weddingCaseJsonLd({
        legacy: caseResult.legacy,
        rich: caseResult.entry.data,
        lang,
        canonicalPath: `/bodas/${wedding.slug}`,
      })
    : []),
];

// Rich mode overrides title/description from the collection's SEO block.
const richTitle = caseResult.mode === 'rich' ? caseResult.entry.data.seo?.title?.[lang] : undefined;
const richDesc = caseResult.mode === 'rich' ? caseResult.entry.data.seo?.description?.[lang] : undefined;
const pageTitle =
  richTitle ??
  (hasVenue
    ? `${wedding.couple} · ${wedding.venue} · Lifetime Weddings`
    : `${wedding.couple} · Lifetime Weddings`);
const pageDesc =
  richDesc ??
  (hasVenue
    ? `Galeria de la boda de ${wedding.couple} a ${wedding.venue} (${wedding.location}).`
    : `Galeria de la boda de ${wedding.couple}.`);
---

<BaseLayout
  lang={lang}
  title={pageTitle}
  description={pageDesc}
  canonicalPath={`/bodas/${wedding.slug}`}
  jsonLd={jsonLd}
  ogImage={cover ?? '/og-default.jpg'}
>
  {caseResult.mode === 'rich' ? (
    <WeddingCaseRich
      lang={lang}
      legacy={caseResult.legacy}
      entry={caseResult.entry}
    />
  ) : (
    <>
      {cover && (
        <section class="relative h-[60vh] min-h-[420px] overflow-hidden">
          <img
            src={coverLarge}
            alt={hasVenue ? `${wedding.couple} · ${wedding.venue}` : wedding.couple}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            width="1920"
            height="1280"
          />
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
            <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">Bodes</p>
            <h1 class="font-display text-4xl md:text-5xl font-bold">{wedding.couple}</h1>
            <p class="mt-3 opacity-90">{wedding.venue !== '—' ? wedding.venue : ''} {wedding.venue !== '—' && wedding.location !== '—' ? '·' : ''} {wedding.location !== '—' ? wedding.location : ''}</p>
          </div>
        </section>
      )}

      {gallery.length > 0 ? (
        <Section>
          <div class="max-w-6xl mx-auto">
            <div class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-3">
              {gallery.map((img, i) => {
                const span = img.orientation === 'landscape' ? 'md:col-span-2' : '';
                return (
                  <a
                    href={img.variants.lg}
                    target="_blank"
                    rel="noopener"
                    class:list={['block overflow-hidden group', span]}
                    aria-label={`Foto ${i + 1}`}
                  >
                    <img
                      src={img.variants.md}
                      srcset={`${img.variants.sm} 640w, ${img.variants.md} 1200w, ${img.variants.lg} 1920w`}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                      alt={galleryAlt(i + 1)}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading={i < 2 ? 'eager' : 'lazy'}
                      fetchpriority={i === 0 ? 'high' : 'auto'}
                      decoding="async"
                      width={img.width}
                      height={img.height}
                    />
                  </a>
                );
              })}
            </div>
          </div>
        </Section>
      ) : (
        <Section>
          <div class="max-w-2xl mx-auto text-center text-ink/75 leading-relaxed">
            <p>Galeria en preparació.</p>
          </div>
        </Section>
      )}
    </>
  )}
</BaseLayout>
