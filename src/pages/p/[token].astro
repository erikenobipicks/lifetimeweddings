---
import '~/styles/global.css';
import Section from '~/components/Section.astro';
import QuoteTracker from '~/components/QuoteTracker.astro';
import WhatsAppFloat from '~/components/WhatsAppFloat.astro';
import VideoEmbed from '~/components/reserva/VideoEmbed.astro';
import VideoCallCTA from '~/components/reserva/VideoCallCTA.astro';
import { getQuoteByToken, recordView, verifyQuotePassword, getLeadByQuoteId, getLatestQuoteResponse } from '~/lib/quotes';
import { PACKS, getComposedSubpacks } from '~/data/packs';
import { QUOTE_TESTIMONIALS } from '~/data/quoteTestimonials';
import { SHOWCASES } from '~/data/showcases';
import { WEDDINGS } from '~/data/weddings';
import { recommendShowcase } from '~/lib/matcher';
import ExternalGalleryEmbed from '~/components/quote/ExternalGalleryEmbed.astro';
import InteractiveConfigurator from '~/components/quote/InteractiveConfigurator.astro';
import AtmosphericPhoto from '~/components/quote/AtmosphericPhoto.astro';
import { SITE, waLink } from '~/data/site';
import Icon from '~/components/Icon.astro';
import { videos } from '~/data/videos';
import { useTranslations, type Lang } from '~/i18n/ui';
import fraunceRomanUrl from '@fontsource-variable/fraunces/files/fraunces-latin-full-normal.woff2?url';
import interRomanUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';

function iconForType(t: 'photo' | 'video' | 'combo') {
  return t === 'photo' ? 'camera' : t === 'video' ? 'video' : 'diamond';
}

const token = String(Astro.params.token ?? '');
const quote = await getQuoteByToken(token);

// Locale picked up from the quote row (admin-set at creation, defaulted from
// the lead when present). Falls back to 'ca' for missing / archived quotes
// so the 404 / expired messages still render with sensible copy.
const lang: Lang = quote?.preferredLanguage ?? 'ca';
const t = useTranslations(lang);

// 404 behaviour
if (!quote || quote.archived) {
  Astro.response.status = 404;
}

// Expiration
const expired = quote?.expiresAt ? new Date(quote.expiresAt) < new Date() : false;

// Password challenge flow
let needsPassword = false;
let passwordError: string | null = null;
if (quote && !quote.archived && !expired && quote.hasPassword) {
  const cookieName = `qp_${token}`;
  const unlocked = Astro.cookies.get(cookieName)?.value === '1';
  if (Astro.request.method === 'POST') {
    const form = await Astro.request.formData();
    const pw = String(form.get('password') ?? '');
    if (await verifyQuotePassword(token, pw)) {
      Astro.cookies.set(cookieName, '1', { path: `/p/${token}`, httpOnly: true, sameSite: 'lax' });
    } else {
      passwordError = t('quote.password.error');
      needsPassword = true;
    }
  } else if (!unlocked) {
    needsPassword = true;
  }
}

// Record the view once we pass all checks
if (quote && !quote.archived && !expired && !needsPassword) {
  const headers = Astro.request.headers;
  const ip =
    headers.get('x-forwarded-for')?.split(',')[0]?.trim() ||
    headers.get('x-real-ip') ||
    (Astro as any).clientAddress ||
    undefined;
  const ua = headers.get('user-agent') ?? undefined;
  // We need a session id from the cookie for de-dupe. Generate if absent.
  const sidCookie = `qs_${token}`;
  let sid = Astro.cookies.get(sidCookie)?.value;
  if (!sid) {
    sid = Math.random().toString(36).slice(2) + Date.now().toString(36);
    Astro.cookies.set(sidCookie, sid, { path: `/p/${token}`, httpOnly: true, sameSite: 'lax', maxAge: 60 * 60 * 24 });
  }
  await recordView(token, { userAgent: ua, ip, sessionId: sid });
}

const packs = quote ? PACKS.filter((p) => quote.packIds.includes(p.id)) : [];

// Latest interactive configurator submission, if any. Drives the
// "we've already received your configuration" banner + pre-checks the
// inputs to mirror what the couple last sent us.
const latestResponse = quote && !quote.archived && !expired && !needsPassword
  ? await getLatestQuoteResponse(quote.id)
  : null;

// Featured-photography resolution. Priority order:
//   1. Real wedding override (quote.flagshipWeddingSlug) — most personal.
//   2. Showcase override (quote.flagshipShowcaseSlug) — themed gallery.
//   3. Lead-based recommendation (auto from quiz answers).
// The lead is also reused below to personalise the hero (venue + date).
const lead = quote && !quote.archived && !expired && !needsPassword
  ? await getLeadByQuoteId(quote.id)
  : null;
let showcaseSlug: string | null = null;
let weddingFeatured: typeof WEDDINGS[number] | null = null;
if (quote && !quote.archived) {
  if (quote.flagshipWeddingSlug) {
    weddingFeatured = WEDDINGS.find((w) => w.slug === quote.flagshipWeddingSlug) ?? null;
  }
  if (!weddingFeatured) {
    if (quote.flagshipShowcaseSlug) {
      showcaseSlug = quote.flagshipShowcaseSlug;
    } else {
      if (lead?.ceremonyType && lead?.location) {
        showcaseSlug = recommendShowcase({
          location: lead.location,
          ceremonyType: lead.ceremonyType,
          serviceInterest: lead.serviceInterest ?? 'both',
          budgetRange: lead.budgetRange ?? 'mid',
        });
      }
    }
  }
}
const showcase = showcaseSlug ? SHOWCASES.find((s) => s.slug === showcaseSlug) : null;

// Personalised hero subtitle built from the lead: "{venue} · {location} ·
// {long date}". Each piece is optional; when none exist (e.g. a manually
// created quote with no lead) we fall back to the generic hero body.
const heroDetail: string | null = (() => {
  if (!lead) return null;
  const parts: string[] = [];
  if (lead.venueName) parts.push(lead.venueName);
  if (lead.location && lead.location !== lead.venueName) parts.push(lead.location);
  const d = lead.weddingDate;
  if (d) {
    const locale = lang === 'es' ? 'es-ES' : lang === 'en' ? 'en-GB' : 'ca-ES';
    const iso = /^\d{4}-\d{2}-\d{2}$/.test(d) ? new Date(`${d}T12:00:00Z`) : null;
    parts.push(
      iso
        ? iso.toLocaleDateString(locale, { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Europe/Madrid' })
        : d,
    );
  }
  return parts.length ? parts.join(' · ') : null;
})();


// WhatsApp pre-filled message for the closing block. Uses the videocall
// intent so Ferran sees at a glance the couple wants a short call.
function waForVideocall(): string {
  if (!quote) return waLink('Hola!');
  return waLink(t('quote.wa.videocallMessage').replace('{name}', quote.coupleName));
}

// Flagship trailer for the video embed. Resolution order:
//   1. quote.flagshipVideoId (admin override at creation time) → look up
//      in catalog.
//   2. Hard-coded default (Elena i Jordi) if no override OR the stored
//      id doesn't match any current entry in src/data/videos.ts (defensive
//      — covers the case where a video gets retired from the catalog while
//      a quote still references its id).
const DEFAULT_FLAGSHIP = {
  youtubeId: 'gXpPjD_APAE',
  coupleName: 'Elena i Jordi',
  venue: 'Montferri · Masia San Antonio',
};
const overrideId = quote?.flagshipVideoId;
const overrideHit = overrideId ? videos.find((v) => v.youtubeId === overrideId) : null;
const flagshipVideo = overrideHit
  ? { youtubeId: overrideHit.youtubeId, coupleName: overrideHit.coupleName, venue: overrideHit.venue }
  : DEFAULT_FLAGSHIP;

// Quote validity line shown discreetly near the total. Only rendered when
// the quote has an expiry; short numeric date in the couple's locale.
const validUntilText: string | null = (() => {
  if (!quote?.expiresAt) return null;
  const d = new Date(quote.expiresAt);
  if (isNaN(d.getTime())) return null;
  const locale = lang === 'es' ? 'es-ES' : lang === 'en' ? 'en-GB' : 'ca-ES';
  const date = d.toLocaleDateString(locale, {
    day: '2-digit', month: '2-digit', year: '2-digit', timeZone: 'Europe/Madrid',
  });
  return t('quote.validity').replace('{date}', date);
})();

// Honest scarcity line under the final CTA — "only one wedding a day".
// Personalised with the couple's date when the lead has it, generic
// otherwise.
const scarcityNote: string = (() => {
  const d = lead?.weddingDate;
  if (d) {
    const iso = /^\d{4}-\d{2}-\d{2}$/.test(d) ? new Date(`${d}T12:00:00Z`) : null;
    if (iso && !isNaN(iso.getTime())) {
      const locale = lang === 'es' ? 'es-ES' : lang === 'en' ? 'en-GB' : 'ca-ES';
      const date = iso.toLocaleDateString(locale, {
        day: '2-digit', month: '2-digit', year: '2-digit', timeZone: 'Europe/Madrid',
      });
      return t('quote.scarcity.withDate').replace('{date}', date);
    }
  }
  return t('quote.scarcity.noDate');
})();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{quote ? `${t('quote.hero.eyebrow')} · ${quote.coupleName}` : t('quote.notFound.title')}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    {/* Fonts self-hosted via @fontsource-variable; @font-face rules ship
        in global.css (imported above in the frontmatter). */}
    <link rel="preload" as="font" type="font/woff2" href={fraunceRomanUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interRomanUrl} crossorigin />
  </head>
  <body
    class="bg-cream text-ink font-sans antialiased"
    data-service-interest={quote?.serviceInterest ?? 'both'}
  >
    {/* Service-interest filter: photo-only couples don't see the video
        trailer; video-only couples don't see the FotoStudio gallery
        embed. Wrappers carry data-service so the CSS rule below picks
        them. 'both' / 'undecided' show everything. */}
    <style is:global>
      body[data-service-interest="photo"] [data-service="video"] { display: none; }
      body[data-service-interest="video"] [data-service="photo"] { display: none; }
    </style>
    {!quote || quote.archived ? (
      <Section class="min-h-screen flex items-center justify-center">
        <div class="text-center max-w-md mx-auto">
          <h1 class="font-display text-4xl font-bold mb-4">{t('quote.notFound.title')}</h1>
          <p class="text-ink/70">{t('quote.notFound.body')} <a href={`mailto:${SITE.email}`} class="text-gold-deep underline">{SITE.email}</a>.</p>
        </div>
      </Section>
    ) : expired ? (
      <Section class="min-h-screen flex items-center justify-center">
        <div class="text-center max-w-md mx-auto">
          <h1 class="font-display text-4xl font-bold mb-4">{t('quote.expired.title')}</h1>
          <p class="text-ink/70">{t('quote.expired.body')} <a href={`mailto:${SITE.email}`} class="text-gold-deep underline">{SITE.email}</a>.</p>
        </div>
      </Section>
    ) : needsPassword ? (
      <Section class="min-h-screen flex items-center justify-center">
        <form method="POST" class="max-w-sm w-full bg-white p-8 border border-black/10">
          <h1 class="font-display text-2xl font-bold mb-2 text-center">{t('quote.password.title')}</h1>
          <p class="text-ink/70 text-sm mb-6 text-center">{t('quote.password.body')}</p>
          {passwordError && <p class="mb-4 p-2 bg-red-50 border border-red-200 text-red-700 text-sm">{passwordError}</p>}
          <input type="password" name="password" required autofocus
                 class="w-full px-3 py-2 border border-black/15 focus:border-gold focus:outline-none mb-4" />
          <button type="submit"
                  class="w-full bg-ink text-white py-3 text-xs font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors">
            {t('quote.password.submit')}
          </button>
        </form>
      </Section>
    ) : (
      <>
        <!-- Hero. Atmospheric B&W photo as background with a vertical
             gradient (lighter at the centre, darker at the edges) so the
             first impression feels more luminous while the gold eyebrow +
             white title stay legible. `eager` because this is the LCP. -->
        <section class="relative py-24 md:py-32 px-6 text-center text-white overflow-hidden bg-ink">
          <div class="absolute inset-0 z-0">
            <AtmosphericPhoto
              slot="hero-yes"
              alt=""
              fill
              mode="cover"
              eager
              sizes="100vw"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-ink/60 via-ink/45 to-ink/75"></div>
          </div>
          <div class="relative z-10">
            <img src="/logos/logo-circle-white.png" alt="" aria-hidden="true" class="w-24 mx-auto mb-6 opacity-95" />
            <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('quote.hero.eyebrow')}</p>
            <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">{quote.coupleName}</h1>
            {heroDetail ? (
              <p class="text-sm md:text-base font-medium tracking-wide text-white/90 mb-4">{heroDetail}</p>
            ) : null}
            <p class="max-w-xl mx-auto opacity-90">{t('quote.hero.body')}</p>
          </div>
        </section>

        {/* Personal intro: the operator's note when present, otherwise a
            warm default that uses the couple's name so the page never opens
            with a generic wall. */}
        <Section>
          <div class="max-w-2xl mx-auto bg-white border-l-4 border-gold p-6">
            <p class="text-xs font-bold tracking-[0.2em] uppercase text-gold-deep mb-3">{t('quote.notes.eyebrow')}</p>
            <p class="text-ink/85 leading-relaxed whitespace-pre-wrap">
              {quote.notes ? quote.notes : t('quote.intro.default').replace('{name}', quote.coupleName)}
            </p>
          </div>
        </Section>

        <!-- Flagship trailer first — let the couple feel the work in
             motion before they see a number. Tagged data-service="video"
             so photo-only couples skip it via the global filter. -->
        <div data-service="video">
          <VideoEmbed
            lang={lang}
            youtubeId={flagshipVideo.youtubeId}
            coupleName={flagshipVideo.coupleName}
            venue={flagshipVideo.venue}
          />
        </div>

        {/* Real-wedding override — most personal proof, shown right after
            the film. Takes priority over showcase. Links to the full
            case-study at /bodas/<slug>. */}
        {weddingFeatured && (
          <Section>
            <div class="max-w-2xl mx-auto text-center">
              <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-3">{t('quote.showcase.eyebrow')}</p>
              <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">{weddingFeatured.couple}</h2>
              <p class="text-ink/75 mb-6">{weddingFeatured.venue} · {weddingFeatured.location}</p>
              <a
                href={`${lang === 'ca' ? '' : `/${lang}`}/bodas/${weddingFeatured.slug}`}
                class="inline-block border-2 border-ink bg-ink text-white px-8 py-3 text-xs font-bold tracking-[0.15em] uppercase hover:bg-gold hover:text-ink hover:border-gold transition-colors"
              >
                {t('quote.showcase.cta')}
              </a>
            </div>
          </Section>
        )}

        {/* Showcase link */}
        {showcase && (
          <Section>
            <div class="max-w-2xl mx-auto text-center">
              <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-3">{t('quote.showcase.eyebrow')}</p>
              <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">{showcase.title[lang]}</h2>
              <p class="text-ink/75 mb-6">{showcase.description[lang]}</p>
              <a
                href={`/showcase/${showcase.slug}`}
                class="inline-block border-2 border-ink bg-ink text-white px-8 py-3 text-xs font-bold tracking-[0.15em] uppercase hover:bg-gold hover:text-ink hover:border-gold transition-colors"
              >
                {t('quote.showcase.cta')}
              </a>
            </div>
          </Section>
        )}

        {/* External gallery (FotoStudio etc.) — iframe with auto-fallback
            to a "open in new tab" CTA when the host blocks embedding.
            Tagged data-service="photo" since FotoStudio is photo-only;
            the video-only filter hides it. */}
        {quote.flagshipExternalGalleryUrl && (
          <div data-service="photo">
            <ExternalGalleryEmbed lang={lang} url={quote.flagshipExternalGalleryUrl} />
          </div>
        )}

        <!-- Single cinematic break before the "why us" + price blocks.
             We keep just one full-bleed atmospheric photo so the proposal
             reads as tailored, not like a generic photo catalogue. -->
        <section class="bg-ink">
          <AtmosphericPhoto
            slot="moment-couple-blur"
            alt=""
            aspect="3 / 2"
            mode="cover"
            sizes="100vw"
            class="max-h-[70vh]"
          />
        </section>

        <!-- Value pillars: three columns answering "why us" right
             before the price block. The couple has spent the page
             feeling the work; this rounds off the "why" before the
             numbers. -->
        <section class="px-6 md:px-12 py-16 md:py-20 bg-white">
          <div class="max-w-5xl mx-auto">
            <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-3 text-center">
              {t('quote.values.eyebrow')}
            </p>
            <h2 class="font-display text-2xl md:text-3xl font-bold text-center mb-12 max-w-2xl mx-auto">
              {t('quote.values.heading')}
            </h2>
            <div class="grid sm:grid-cols-3 gap-8 md:gap-10">
              {[1, 2, 3].map((n) => (
                <div class="text-center sm:text-left">
                  <p class="font-display text-2xl text-gold-deep mb-3">{`0${n}`}</p>
                  <h3 class="font-bold text-ink mb-2 leading-snug">
                    {t(`quote.values.p${n}.title` as any)}
                  </h3>
                  <p class="text-sm text-ink/75 leading-relaxed">
                    {t(`quote.values.p${n}.body` as any)}
                  </p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- Packs (price visible). Now placed AFTER the visual examples
             so the couple has seen the quality before the number. -->
        <Section bg="cream">
          <div class="max-w-5xl mx-auto">
            <h2 class="font-display text-3xl font-bold text-center mb-12">{t('quote.packs.heading')}</h2>
            <div class="grid md:grid-cols-2 gap-6">
              {packs.map((p) => {
                const subpacks = getComposedSubpacks(p);
                return (
                  <article class="bg-white p-7 border border-black/10">
                    <div class="text-gold-deep mb-3"><Icon name={iconForType(p.type) as any} size={28} /></div>
                    {p.subtitle ? (
                      <>
                        <p class="text-sm italic text-ink/55 mb-1 font-display">{p.name[lang]}</p>
                        <h3 class="font-display text-xl font-bold mb-3 leading-tight">{p.subtitle[lang]}</h3>
                      </>
                    ) : (
                      <h3 class="font-display text-xl font-bold mb-3">{p.name[lang]}</h3>
                    )}
                    <p class="text-3xl font-display font-bold text-gold-deep mb-5">{p.price}</p>
                    <p class="text-xs font-bold tracking-[0.12em] uppercase text-ink/70 mb-3">{t('quote.packs.includes')}</p>
                    {subpacks.length > 0 ? (
                      <>
                        {subpacks.map((sp) => (
                          <div class="mb-5 last:mb-4">
                            <p class="text-[0.78rem] font-bold tracking-wide text-ink mb-2 flex items-center gap-2">
                              <Icon name={iconForType(sp.type) as any} size={14} />
                              <span>{sp.name[lang]}</span>
                            </p>
                            <ul class="space-y-2 text-sm text-ink/80 pl-1">
                              {sp.includes[lang].map((it) => (
                                <li class="flex gap-2"><span class="text-gold-deep">✓</span><span>{it}</span></li>
                              ))}
                            </ul>
                          </div>
                        ))}
                        {p.includes[lang].length > 0 && (
                          <div class="mt-4 pt-4 border-t border-black/10">
                            <p class="text-[0.78rem] font-bold tracking-wide text-gold-deep mb-2">{t('quote.combo.extras.heading')}</p>
                            <ul class="space-y-2 text-sm text-ink/80 pl-1">
                              {p.includes[lang].map((it) => (
                                <li class="flex gap-2"><span class="text-gold-deep">✓</span><span>{it}</span></li>
                              ))}
                            </ul>
                          </div>
                        )}
                      </>
                    ) : (
                      <ul class="space-y-2 text-sm text-ink/80">
                        {p.includes[lang].map((it) => (
                          <li class="flex gap-2"><span class="text-gold-deep">✓</span><span>{it}</span></li>
                        ))}
                      </ul>
                    )}
                  </article>
                );
              })}
            </div>
          </div>
        </Section>

        {/* Social proof — real testimonials only. Rendered right before the
            configurator so it answers the "can we trust paying up front?"
            objection just as the couple is about to commit. Hidden entirely
            until QUOTE_TESTIMONIALS holds real reviews. */}
        {QUOTE_TESTIMONIALS.length > 0 && (
          <Section>
            <div class="max-w-5xl mx-auto text-center">
              <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-3">{t('quote.testimonials.eyebrow')}</p>
              <h2 class="font-display text-2xl md:text-3xl font-bold mb-10">{t('quote.testimonials.heading')}</h2>
              <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 text-left">
                {QUOTE_TESTIMONIALS.map((tm) => (
                  <figure class="bg-white border-l-4 border-gold p-6 flex flex-col">
                    <blockquote class="text-ink/85 leading-relaxed italic flex-1">“{tm.quote}”</blockquote>
                    <figcaption class="mt-5">
                      <p class="font-bold text-ink">{tm.author}</p>
                      <div class="mt-1.5 flex items-center gap-2">
                        <span class="text-gold-deep tracking-tight" aria-label={`${tm.rating} / 5`}>
                          {'★'.repeat(tm.rating)}
                        </span>
                        <a
                          href={SITE.googleReviewsUrl}
                          target="_blank"
                          rel="noopener"
                          class="inline-flex items-center gap-1 text-xs text-ink/60 hover:text-ink/90 transition-colors"
                        >
                          <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" aria-hidden="true">
                            <path fill="#4285F4" d="M23.49 12.27c0-.79-.07-1.54-.19-2.27H12v4.51h6.47a5.4 5.4 0 0 1-2.4 3.58v3h3.86c2.26-2.09 3.56-5.17 3.56-8.82z"/>
                            <path fill="#34A853" d="M12 24c3.24 0 5.95-1.08 7.93-2.91l-3.86-3c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96H1.29v3.09A12 12 0 0 0 12 24z"/>
                            <path fill="#FBBC05" d="M5.27 14.29a7.2 7.2 0 0 1 0-4.58V6.62H1.29a12 12 0 0 0 0 10.76l3.98-3.09z"/>
                            <path fill="#EA4335" d="M12 4.75c1.77 0 3.35.61 4.6 1.8l3.42-3.42A12 12 0 0 0 12 0 12 12 0 0 0 1.29 6.62l3.98 3.09C6.22 6.86 8.87 4.75 12 4.75z"/>
                          </svg>
                          Google
                        </a>
                      </div>
                    </figcaption>
                  </figure>
                ))}
              </div>
            </div>
          </Section>
        )}

        <!-- Interactive configurator. Replaces the static extras catalog:
             same info (packs + combos + extras) but the couple can tick
             what they want, see the total update live, and send their
             configuration back to us. -->
        <InteractiveConfigurator
          lang={lang}
          token={quote.token}
          initialPackIds={quote.packIds}
          lastResponse={latestResponse}
          adminDiscountCents={quote.adminDiscountCents}
          closedAt={quote.closedAt}
          serviceInterest={quote.serviceInterest}
          validUntilText={validUntilText}
        />

        <!-- FAQ. Mirrors the two FAQ pages in the tarifes PDF so couples get
             the most common answers without having to ask us by email. -->
        <Section bg="cream">
          <div class="max-w-2xl mx-auto">
            <h2 class="font-display text-2xl md:text-3xl font-bold text-center mb-8">{t('quote.faq.heading')}</h2>
            <div class="space-y-3">
              {[1, 2, 3, 4, 5, 6, 7].map((n) => (
                <details class="group bg-white border border-black/10 open:border-gold/40">
                  <summary class="cursor-pointer list-none flex items-center justify-between gap-4 px-5 py-4 font-bold text-ink hover:text-gold transition-colors">
                    <span>{t(`quote.faq.q${n}.q` as any)}</span>
                    <span class="text-gold-deep text-xl leading-none group-open:rotate-45 transition-transform">+</span>
                  </summary>
                  <div class="px-5 pb-5 -mt-1 text-ink/80 leading-relaxed">{t(`quote.faq.q${n}.a` as any)}</div>
                </details>
              ))}
            </div>
          </div>
        </Section>

        {/* Single closing block — videocall (primary) + WhatsApp + email,
            personalised with the couple's name. Replaces the old duplicate
            "videocall" + generic CTA pair (and the extra closer photo). */}
        <VideoCallCTA
          lang={lang}
          coupleName={quote.coupleName}
          whatsappLink={waForVideocall()}
          emailHref={`mailto:${SITE.email}`}
          scarcityNote={scarcityNote}
        />

        <footer class="bg-ink text-white/60 py-6 text-center text-xs border-t border-white/10">
          <p>© Lifetime Weddings · <a href={`mailto:${SITE.email}`} class="text-gold hover:underline">{SITE.email}</a> · <a href={`tel:${SITE.phone}`} class="text-gold hover:underline">{SITE.phoneDisplay}</a></p>
        </footer>

        {/* Floating WhatsApp button — same component + number as the public
            site, so the couple can reach us at any scroll depth without
            hunting for the closing CTA. */}
        <WhatsAppFloat lang={lang} />

        <QuoteTracker token={quote.token} />
      </>
    )}
  </body>
</html>
