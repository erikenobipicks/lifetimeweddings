---
export const prerender = true;
import { NOVIOS } from '~/data/novios';
import { PHOTOS, type Photo } from '~/data/photos.generated';

export function getStaticPaths() {
  return NOVIOS.map((n) => ({ params: { slug: n.slug }, props: { site: n } }));
}

const { site } = Astro.props;
const lang = site.lang;
const names = `${site.couple.a} & ${site.couple.b}`;

// ── Photos ────────────────────────────────────────────────────────
// Pull the couple's images from the generated manifest. Explicit picks
// in the data (by id suffix) win; otherwise auto-select by orientation.
const set = PHOTOS[site.photoSet];
const images: Photo[] = set?.images ?? [];
const byId = (suffix?: string) =>
  suffix ? images.find((im) => im.id.endsWith(`/${suffix}`)) : undefined;
const landscapes = images.filter((im) => im.orientation !== 'portrait');
const portraits = images.filter((im) => im.orientation === 'portrait');

const heroImg = byId(site.photos?.hero) ?? landscapes[0] ?? images[0];
const storyImg = byId(site.photos?.story) ?? portraits[0] ?? images[1] ?? heroImg;

// Gallery mosaic: 4 slots. Use explicit picks first, then fill from the
// remaining photos (avoiding hero/story) keeping a landscape-heavy mix.
const usedIds = new Set([heroImg?.id, storyImg?.id]);
const explicitGallery = (site.photos?.gallery ?? [])
  .map((s) => byId(s))
  .filter((im): im is Photo => Boolean(im));
explicitGallery.forEach((im) => usedIds.add(im.id));
const fillPool = [...landscapes, ...portraits].filter((im) => !usedIds.has(im.id));
const galleryImgs = [...explicitGallery, ...fillPool].slice(0, 4);

// The manifest stores .jpg variant paths; matching .webp files sit next
// to them (produced by the same photo script), so we can offer a webp
// <source> by swapping the extension.
const webp = (p: string) => p.replace(/\.jpg$/, '.webp');

const captions = site.gallery.captions ?? [];
---

<!doctype html>
<html lang={lang}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />
<title>{names} · {site.dateLabel}</title>
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Work+Sans:wght@300;400;500;600&display=swap"
  rel="stylesheet"
/>
<style>
  :root{
    --cream:#F3EEE1;
    --cream-2:#E9E0CC;
    --ink:#2B2A22;
    --ink-soft:#55523F;
    --olive:#535E3D;
    --olive-dark:#3A4229;
    --wine:#7A2E2E;
    --gold:#B98A3E;
    --terracotta:#B15E3B;
    --white:#FFFDF8;
    --display:'Fraunces', serif;
    --body:'Work Sans', sans-serif;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{font-family:var(--body); background:var(--cream); color:var(--ink); line-height:1.6; font-weight:300; overflow-x:hidden;}
  h1,h2,h3{font-family:var(--display); font-weight:500; color:var(--ink);}
  a{color:inherit;}
  img{display:block; max-width:100%;}
  picture{display:block;}

  .eyebrow{font-family:var(--body); text-transform:uppercase; letter-spacing:0.28em; font-size:0.7rem; font-weight:600; color:var(--gold);}
  .wrap{max-width:1100px; margin:0 auto; padding:0 6vw;}

  /* HERO */
  .hero{position:relative; min-height:100svh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; color:var(--white); overflow:hidden;}
  .hero-bg{position:absolute; inset:0; z-index:0;}
  .hero-bg img{width:100%; height:100%; object-fit:cover; object-position:center 30%;}
  .hero-bg::after{content:""; position:absolute; inset:0; background:linear-gradient(180deg, rgba(42,41,30,0.35) 0%, rgba(42,41,30,0.55) 55%, rgba(42,41,30,0.85) 100%);}
  .hero-content{position:relative; z-index:1; padding-top:4rem;}
  .hero .eyebrow{color:var(--cream); opacity:0.85; margin-bottom:1.4rem;}
  .hero h1{font-size:clamp(3.2rem, 10vw, 7rem); font-style:italic; font-weight:400; line-height:1; letter-spacing:0.01em; color:var(--white);}
  .hero h1 span{display:block; font-style:normal; font-weight:300; font-size:0.35em; letter-spacing:0.15em; margin:0.6em 0; opacity:0.9;}
  .hero .date{margin-top:1.6rem; font-size:1.05rem; letter-spacing:0.08em;}
  .hero .place{margin-top:0.3rem; font-size:0.9rem; letter-spacing:0.15em; text-transform:uppercase; opacity:0.75;}
  .countdown{display:flex; gap:clamp(1rem, 4vw, 2.6rem); margin-top:3rem; position:relative; z-index:1;}
  .countdown div{text-align:center;}
  .countdown .num{font-family:var(--display); font-size:clamp(1.8rem, 5vw, 2.8rem); font-weight:500; line-height:1;}
  .countdown .lab{display:block; margin-top:0.4rem; font-size:0.62rem; letter-spacing:0.2em; text-transform:uppercase; opacity:0.7;}
  .scroll-cue{position:absolute; bottom:2.2rem; left:50%; transform:translateX(-50%); z-index:1; width:1px; height:44px; background:rgba(255,253,248,0.5);}
  .scroll-cue::after{content:""; position:absolute; top:0; left:-3px; width:7px; height:7px; border-radius:50%; background:var(--gold); animation:cue 2.2s ease-in-out infinite;}
  @keyframes cue{ 0%{top:0; opacity:1;} 90%{top:38px; opacity:0;} 100%{top:38px; opacity:0;} }

  section{padding:6.5rem 0;}
  .head{text-align:center; max-width:640px; margin:0 auto 3.6rem;}
  .head .eyebrow{margin-bottom:0.9rem;}
  .head h2{font-size:clamp(2.1rem, 5vw, 2.9rem); font-weight:500;}
  .divider{width:64px; height:1px; background:var(--gold); margin:1.6rem auto 0;}

  .intro{padding:5rem 0 2rem; text-align:center;}
  .intro p{max-width:620px; margin:0 auto; font-size:1.2rem; font-style:italic; font-family:var(--display); font-weight:400; color:var(--ink-soft); line-height:1.7;}

  .story{background:var(--white);}
  .story-grid{display:grid; grid-template-columns:1fr 1fr; gap:4.5rem; align-items:center;}
  .story-photo{border-radius:2px; overflow:hidden; aspect-ratio:4/5;}
  .story-photo img{width:100%; height:100%; object-fit:cover;}
  .story-beats{display:flex; flex-direction:column; gap:2.1rem;}
  .beat{display:grid; grid-template-columns:64px 1fr; gap:1.2rem;}
  .beat .yr{font-family:var(--display); font-style:italic; color:var(--gold); font-size:1.05rem; padding-top:0.15rem;}
  .beat h3{font-size:1.15rem; margin-bottom:0.35rem; font-weight:500;}
  .beat p{color:var(--ink-soft); font-size:0.96rem;}

  .day{background:var(--olive-dark); color:var(--cream); position:relative;}
  .day .eyebrow{color:var(--gold);}
  .day .head h2{color:var(--cream);}
  .day .divider{background:var(--gold);}
  .timeline{position:relative; max-width:640px; margin:0 auto;}
  .vine-svg{position:absolute; left:18px; top:0; height:100%; width:36px;}
  .vine-svg path{fill:none; stroke:var(--gold); stroke-width:1.4; stroke-linecap:round; stroke-dasharray:1000; stroke-dashoffset:1000; transition:stroke-dashoffset 2.4s ease;}
  .vine-svg.grow path{stroke-dashoffset:0;}
  .vine-svg .leaf{fill:var(--gold); opacity:0; transform-origin:center; transition:opacity 0.6s ease 1.6s;}
  .vine-svg.grow .leaf{opacity:1;}
  .stop{position:relative; padding:0 0 3.2rem 76px;}
  .stop:last-child{padding-bottom:0;}
  .stop .time{font-family:var(--display); font-style:italic; color:var(--gold); font-size:1.1rem; display:block; margin-bottom:0.3rem;}
  .stop h3{color:var(--cream); font-size:1.3rem; margin-bottom:0.4rem; font-weight:500;}
  .stop p{color:#D8D3BD; font-size:0.93rem; max-width:400px;}

  .place-grid{display:grid; grid-template-columns:1fr 1fr; gap:2.4rem;}
  .place-card{background:var(--white); border:1px solid var(--cream-2); padding:2.6rem 2.2rem;}
  .place-card .icon{width:54px; height:54px; margin-bottom:1.6rem;}
  .place-card h3{font-size:1.4rem; margin-bottom:0.7rem;}
  .place-card p{color:var(--ink-soft); font-size:0.95rem; margin-bottom:1.1rem;}
  .place-card .addr{font-size:0.82rem; letter-spacing:0.03em; color:var(--olive); font-weight:500; border-top:1px solid var(--cream-2); padding-top:1rem;}

  .gallery{background:var(--white);}
  .gal-grid{display:grid; grid-template-columns:repeat(6, 1fr); grid-auto-rows:14vw; gap:0.6rem;}
  .gal-grid figure{position:relative; overflow:hidden; margin:0;}
  .gal-grid img{width:100%; height:100%; object-fit:cover; transition:transform 0.6s ease;}
  .gal-grid figure:hover img{transform:scale(1.05);}
  .gal-grid figcaption{position:absolute; left:0; right:0; bottom:0; padding:0.8rem 1rem; font-size:0.72rem; letter-spacing:0.05em; color:var(--white); background:linear-gradient(0deg, rgba(42,41,30,0.65), transparent); opacity:0; transition:opacity 0.4s ease;}
  .gal-grid figure:hover figcaption{opacity:1;}
  .g1{grid-column:1/4; grid-row:1/3;}
  .g2{grid-column:4/7; grid-row:1/2;}
  .g3{grid-column:4/6; grid-row:2/3;}
  .g4{grid-column:6/7; grid-row:2/3;}

  .rsvp{background:var(--cream-2);}
  .rsvp-box{max-width:560px; margin:0 auto; background:var(--white); padding:3rem clamp(1.6rem, 5vw, 3.4rem); border:1px solid rgba(0,0,0,0.05);}
  .field{margin-bottom:1.4rem;}
  .field label{display:block; font-size:0.78rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:0.5rem;}
  .field input, .field select, .field textarea{width:100%; border:none; border-bottom:1px solid #cfc7ac; background:transparent; padding:0.6rem 0.1rem; font-family:var(--body); font-size:0.98rem; color:var(--ink);}
  .field input:focus, .field select:focus, .field textarea:focus{outline:none; border-bottom-color:var(--gold);}
  .field textarea{resize:vertical; min-height:80px;}
  .row2{display:grid; grid-template-columns:1fr 1fr; gap:1.4rem;}
  .btn{display:inline-block; margin-top:0.8rem; background:var(--olive); color:var(--white); border:none; padding:0.95rem 2.2rem; font-family:var(--body); font-size:0.85rem; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; transition:background 0.3s ease; width:100%;}
  .btn:hover{background:var(--olive-dark);}
  .thanks{display:none; text-align:center; padding:1rem 0;}
  .thanks.show{display:block;}
  .thanks h3{font-size:1.6rem; margin-bottom:0.6rem; font-style:italic; font-weight:400;}
  .thanks p{color:var(--ink-soft); font-size:0.95rem;}

  .info-grid{display:grid; grid-template-columns:repeat(3, 1fr); gap:2.4rem; text-align:center;}
  .info-grid .item{padding:0 1rem;}
  .info-grid .icon{width:40px; height:40px; margin:0 auto 1.2rem;}
  .info-grid h3{font-size:1.1rem; margin-bottom:0.7rem;}
  .info-grid p{color:var(--ink-soft); font-size:0.92rem;}

  footer{background:var(--ink); color:var(--cream); text-align:center; padding:4.5rem 0 3rem;}
  footer h2{color:var(--cream); font-style:italic; font-weight:400; font-size:2rem; margin-bottom:0.6rem;}
  footer .hashtag{color:var(--gold); letter-spacing:0.1em; font-size:0.85rem; margin-bottom:2rem;}
  footer .fine{font-size:0.78rem; opacity:0.55; max-width:460px; margin:2.4rem auto 0; line-height:1.6;}

  @media(max-width:820px){
    .story-grid{grid-template-columns:1fr; gap:2.6rem;}
    .story-photo{aspect-ratio:16/10;}
    .place-grid{grid-template-columns:1fr;}
    .info-grid{grid-template-columns:1fr; gap:2.6rem;}
    .row2{grid-template-columns:1fr;}
    .gal-grid{grid-template-columns:repeat(2,1fr); grid-auto-rows:38vw;}
    .g1{grid-column:1/3; grid-row:1/2;}
    .g2{grid-column:1/2; grid-row:2/3;}
    .g3{grid-column:2/3; grid-row:2/3;}
    .g4{grid-column:1/3; grid-row:3/4;}
    section{padding:4.5rem 0;}
    .countdown{gap:1.2rem;}
  }
  @media(prefers-reduced-motion:reduce){
    html{scroll-behavior:auto;}
    .vine-svg path, .vine-svg .leaf, .gal-grid img, .btn{transition:none;}
    .scroll-cue::after{animation:none;}
  }
</style>
</head>
<body>

<header class="hero">
  {heroImg && (
    <div class="hero-bg">
      <picture>
        <source type="image/webp" srcset={webp(heroImg.variants.lg)} />
        <img src={heroImg.variants.lg} alt={`${names} — preboda`} fetchpriority="high" />
      </picture>
    </div>
  )}
  <div class="hero-content">
    <p class="eyebrow">{site.eyebrow}</p>
    <h1>{site.couple.a} <span>&amp;</span> {site.couple.b}</h1>
    <p class="date">{site.dateLabel}</p>
    <p class="place">{site.place}</p>
    <div class="countdown" id="countdown" data-target={site.dateISO}>
      <div><span class="num" id="cd-d">00</span><span class="lab">Dies</span></div>
      <div><span class="num" id="cd-h">00</span><span class="lab">Hores</span></div>
      <div><span class="num" id="cd-m">00</span><span class="lab">Minuts</span></div>
      <div><span class="num" id="cd-s">00</span><span class="lab">Segons</span></div>
    </div>
  </div>
  <div class="scroll-cue"></div>
</header>

<section class="intro">
  <div class="wrap"><p>{site.intro}</p></div>
</section>

<section class="story">
  <div class="wrap">
    <div class="head">
      <p class="eyebrow">{site.story.eyebrow}</p>
      <h2>{site.story.heading}</h2>
      <div class="divider"></div>
    </div>
    <div class="story-grid">
      <div class="story-photo">
        {storyImg && (
          <picture>
            <source type="image/webp" srcset={webp(storyImg.variants.md)} />
            <img src={storyImg.variants.md} alt={`${names}`} loading="lazy" />
          </picture>
        )}
      </div>
      <div class="story-beats">
        {site.story.beats.map((b) => (
          <div class="beat">
            <span class="yr">{b.year}</span>
            <div>
              <h3>{b.title}</h3>
              <p>{b.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="day" id="dia">
  <div class="wrap">
    <div class="head">
      <p class="eyebrow">{site.day.eyebrow}</p>
      <h2>{site.day.heading}</h2>
      <div class="divider"></div>
    </div>
    <div class="timeline">
      <svg class="vine-svg" id="vine" viewBox="0 0 36 560" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 0 C 6 60, 30 120, 18 180 S 6 300, 18 360 S 30 480, 18 560" />
        <g class="leaf"><ellipse cx="10" cy="70" rx="7" ry="3.4" transform="rotate(-35 10 70)"/></g>
        <g class="leaf"><ellipse cx="27" cy="185" rx="7" ry="3.4" transform="rotate(35 27 185)"/></g>
        <g class="leaf"><ellipse cx="9" cy="330" rx="7" ry="3.4" transform="rotate(-30 9 330)"/></g>
        <g class="leaf"><ellipse cx="26" cy="475" rx="7" ry="3.4" transform="rotate(30 26 475)"/></g>
      </svg>
      {site.day.stops.map((s) => (
        <div class="stop">
          <span class="time">{s.time}</span>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="place">
  <div class="wrap">
    <div class="head">
      <p class="eyebrow">{site.venues.eyebrow}</p>
      <h2>{site.venues.heading}</h2>
      <div class="divider"></div>
    </div>
    <div class="place-grid">
      {site.venues.cards.map((c) => (
        <div class="place-card">
          {c.kind === 'ceremony' ? (
            <svg class="icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M32 6 L20 22 H44 Z" stroke="var(--gold)" stroke-width="1.6"/>
              <rect x="24" y="22" width="16" height="4" stroke="var(--gold)" stroke-width="1.6"/>
              <path d="M14 58 C14 40, 22 28, 32 28 C42 28, 50 40, 50 58 Z" stroke="var(--gold)" stroke-width="1.6"/>
              <line x1="32" y1="28" x2="32" y2="58" stroke="var(--gold)" stroke-width="1.2"/>
              <line x1="6" y1="58" x2="58" y2="58" stroke="var(--gold)" stroke-width="1.6"/>
            </svg>
          ) : (
            <svg class="icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 26 L32 10 L56 26" stroke="var(--gold)" stroke-width="1.6"/>
              <rect x="10" y="26" width="44" height="30" stroke="var(--gold)" stroke-width="1.6"/>
              <line x1="10" y1="34" x2="54" y2="34" stroke="var(--gold)" stroke-width="1"/>
              <line x1="10" y1="42" x2="54" y2="42" stroke="var(--gold)" stroke-width="1"/>
              <line x1="10" y1="50" x2="54" y2="50" stroke="var(--gold)" stroke-width="1"/>
              <line x1="20" y1="26" x2="20" y2="56" stroke="var(--gold)" stroke-width="1"/>
              <line x1="32" y1="26" x2="32" y2="56" stroke="var(--gold)" stroke-width="1"/>
              <line x1="44" y1="26" x2="44" y2="56" stroke="var(--gold)" stroke-width="1"/>
            </svg>
          )}
          <h3>{c.title}</h3>
          <p>{c.text}</p>
          <p class="addr">{c.addr}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="gallery">
  <div class="wrap">
    <div class="head">
      <p class="eyebrow">{site.gallery.eyebrow}</p>
      <h2>{site.gallery.heading}</h2>
      <div class="divider"></div>
    </div>
    <div class="gal-grid">
      {galleryImgs.map((im, i) => (
        <figure class={`g${i + 1}`}>
          <picture>
            <source type="image/webp" srcset={webp(im.variants.md)} />
            <img src={im.variants.md} alt={`${names} — preboda ${i + 1}`} loading="lazy" />
          </picture>
          {captions[i] && <figcaption>{captions[i]}</figcaption>}
        </figure>
      ))}
    </div>
  </div>
</section>

<section class="rsvp" id="rsvp">
  <div class="wrap">
    <div class="head">
      <p class="eyebrow">{site.rsvp.eyebrow}</p>
      <h2>{site.rsvp.heading}</h2>
      <div class="divider"></div>
    </div>
    <div class="rsvp-box">
      <form id="rsvp-form">
        <div class="field">
          <label for="nom">{site.rsvp.nameLabel}</label>
          <input type="text" id="nom" required placeholder={site.rsvp.namePlaceholder} />
        </div>
        <div class="row2">
          <div class="field">
            <label for="assist">{site.rsvp.attendingLabel}</label>
            <select id="assist">
              {site.rsvp.attendingOptions.map((o) => <option>{o}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="acomp">{site.rsvp.guestsLabel}</label>
            <input type="number" id="acomp" min="0" value="0" />
          </div>
        </div>
        <div class="field">
          <label for="alergies">{site.rsvp.dietLabel}</label>
          <input type="text" id="alergies" placeholder={site.rsvp.dietPlaceholder} />
        </div>
        <div class="field">
          <label for="missatge">{site.rsvp.messageLabel}</label>
          <textarea id="missatge" placeholder={site.rsvp.messagePlaceholder}></textarea>
        </div>
        <button type="submit" class="btn">{site.rsvp.submit}</button>
      </form>
      <div class="thanks" id="thanks">
        <h3>{site.rsvp.thanksHeading}</h3>
        <p>{site.rsvp.thanksText}</p>
      </div>
    </div>
  </div>
</section>

<section class="info">
  <div class="wrap">
    <div class="head">
      <p class="eyebrow">{site.info.eyebrow}</p>
      <h2>{site.info.heading}</h2>
      <div class="divider"></div>
    </div>
    <div class="info-grid">
      {site.info.items.map((it) => (
        <div class="item">
          {it.icon === 'dress' && (
            <svg class="icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 4 C12 4 8 12 8 18 C8 28 20 36 20 36 C20 36 32 28 32 18 C32 12 28 4 20 4 Z" stroke="var(--olive)" stroke-width="1.4"/><circle cx="20" cy="17" r="4" stroke="var(--olive)" stroke-width="1.4"/></svg>
          )}
          {it.icon === 'bed' && (
            <svg class="icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="12" width="28" height="20" rx="1" stroke="var(--olive)" stroke-width="1.4"/><path d="M6 18 H34" stroke="var(--olive)" stroke-width="1.4"/><path d="M13 12 V8 M27 12 V8" stroke="var(--olive)" stroke-width="1.4"/></svg>
          )}
          {it.icon === 'gift' && (
            <svg class="icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 36 C20 36 6 26 6 15 C6 9 11 6 15 6 C18 6 20 9 20 9 C20 9 22 6 25 6 C29 6 34 9 34 15 C34 26 20 36 20 36 Z" stroke="var(--olive)" stroke-width="1.4"/></svg>
          )}
          <h3>{it.title}</h3>
          <p>{it.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<footer>
  <div class="wrap">
    <h2>{names}</h2>
    {site.hashtag && <p class="hashtag">{site.hashtag}</p>}
    <p style="opacity:0.75; font-size:0.9rem;">{site.footerContact} <a href={`mailto:${site.email}`}>{site.email}</a></p>
    {site.demo && site.footerNote && <p class="fine">{site.footerNote}</p>}
  </div>
</footer>

<script is:inline>
  (() => {
    // Countdown
    const cd = document.getElementById('countdown');
    const target = new Date(cd?.dataset.target || '').getTime();
    const elD = document.getElementById('cd-d');
    const elH = document.getElementById('cd-h');
    const elM = document.getElementById('cd-m');
    const elS = document.getElementById('cd-s');
    function tick(){
      const dist = target - Date.now();
      if (isNaN(target)) return;
      if (dist < 0){ if (cd) cd.innerHTML = '<div><span class="num">Avui!</span></div>'; return; }
      const d = Math.floor(dist / 86400000);
      const h = Math.floor((dist % 86400000) / 3600000);
      const m = Math.floor((dist % 3600000) / 60000);
      const s = Math.floor((dist % 60000) / 1000);
      if (elD) elD.textContent = String(d);
      if (elH) elH.textContent = String(h).padStart(2,'0');
      if (elM) elM.textContent = String(m).padStart(2,'0');
      if (elS) elS.textContent = String(s).padStart(2,'0');
    }
    tick();
    setInterval(tick, 1000);

    // Vine grow on scroll
    const vine = document.getElementById('vine');
    const dia = document.getElementById('dia');
    if (vine && dia && 'IntersectionObserver' in window){
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting){ vine.classList.add('grow'); io.disconnect(); } });
      }, { threshold: 0.25 });
      io.observe(dia);
    } else if (vine){ vine.classList.add('grow'); }

    // RSVP mock submit (no backend yet — swap for a POST when ready)
    const form = document.getElementById('rsvp-form');
    form?.addEventListener('submit', function(e){
      e.preventDefault();
      form.style.display = 'none';
      document.getElementById('thanks')?.classList.add('show');
    });
  })();
</script>

</body>
</html>
