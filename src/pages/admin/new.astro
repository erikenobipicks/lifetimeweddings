---
import AdminLayout from '~/layouts/AdminLayout.astro';
import { createQuote, getLeadById, linkLeadToQuote } from '~/lib/quotes';
import { PACKS, EXTRAS, getComposedSubpacks } from '~/data/packs';
import { recommendPacks } from '~/lib/matcher';
import { publicVideos, fullVideos } from '~/data/videos';
import { SHOWCASES } from '~/data/showcases';
import { WEDDINGS } from '~/data/weddings';
import { externalGalleries } from '~/data/external-galleries';

// Support ?lead=<id> deep-link from Telegram/email so the form comes
// pre-filled with the lead's name/email and the recommended packs ticked.
const leadId = Number(Astro.url.searchParams.get('lead'));
const lead = Number.isFinite(leadId) && leadId > 0 ? await getLeadById(leadId) : null;

let error: string | null = null;
let createdToken: string | null = null;
let createdQuoteId: number | null = null;
let createdQuoteEmail: string | null = null;
let postedLeadId: number | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const coupleName = String(form.get('couple_name') ?? '').trim();
  const coupleEmail = String(form.get('couple_email') ?? '').trim();
  const packIds = form.getAll('packs').map(String);
  const notes = String(form.get('notes') ?? '').trim();
  const password = String(form.get('password') ?? '').trim();
  const expiresAt = String(form.get('expires_at') ?? '').trim();
  const flagshipVideoId = String(form.get('flagship_video_id') ?? '').trim();
  const flagshipShowcaseSlug = String(form.get('flagship_showcase_slug') ?? '').trim();
  const flagshipWeddingSlug = String(form.get('flagship_wedding_slug') ?? '').trim();
  const flagshipExternalGalleryUrl = String(form.get('flagship_external_gallery_url') ?? '').trim();
  const langRaw = String(form.get('preferred_language') ?? '').trim();
  const preferredLanguage: 'ca' | 'es' | 'en' =
    langRaw === 'es' || langRaw === 'en' ? langRaw : 'ca';
  const siRaw = String(form.get('service_interest') ?? '').trim();
  const serviceInterest: 'photo' | 'video' | 'both' | 'undecided' =
    siRaw === 'photo' || siRaw === 'video' || siRaw === 'undecided' ? siRaw : 'both';
  const linkLeadId = Number(form.get('lead_id') ?? '');
  postedLeadId = Number.isFinite(linkLeadId) && linkLeadId > 0 ? linkLeadId : null;

  if (!coupleName) {
    error = 'Cal el nom de la parella.';
  } else if (packIds.length === 0) {
    error = 'Selecciona almenys un pack.';
  } else {
    const q = await createQuote({
      coupleName,
      coupleEmail: coupleEmail || undefined,
      packIds,
      notes: notes || undefined,
      password: password || undefined,
      expiresAt: expiresAt ? new Date(expiresAt).toISOString() : undefined,
      createdBy: Astro.locals.user,
      flagshipVideoId: flagshipVideoId || undefined,
      flagshipShowcaseSlug: flagshipShowcaseSlug || undefined,
      flagshipWeddingSlug: flagshipWeddingSlug || undefined,
      flagshipExternalGalleryUrl: flagshipExternalGalleryUrl || undefined,
      preferredLanguage,
      serviceInterest,
    });
    if (postedLeadId) {
      try { await linkLeadToQuote(postedLeadId, q.id); } catch { /* non-fatal */ }
    }
    createdToken = q.token;
    createdQuoteId = q.id;
    createdQuoteEmail = q.coupleEmail ?? null;
  }
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;

// Pre-fill values: form resubmission errors preserve user input; lead deep-link
// populates from DB; otherwise everything is blank.
const initialName = lead?.coupleName ?? '';
const initialEmail = lead?.email ?? '';
const initialLanguage: 'ca' | 'es' | 'en' = lead?.preferredLanguage ?? 'ca';
// Service interest pre-fill from the lead's quiz answer; falls back to
// 'both' (the most permissive default — better the couple sees too many
// options than too few).
const initialServiceInterest: 'photo' | 'video' | 'both' | 'undecided' =
  lead?.serviceInterest === 'photo' ? 'photo'
  : lead?.serviceInterest === 'video' ? 'video'
  : 'both';
const recommendedPackIds: string[] = lead
  ? recommendPacks({
      weddingDate: lead.weddingDate ?? undefined,
      location: lead.location ?? 'tarragona',
      ceremonyType: lead.ceremonyType ?? 'civil',
      serviceInterest: lead.serviceInterest ?? 'both',
      budgetRange: lead.budgetRange ?? 'mid',
    })
  : [];

const LABELS: Record<string, string> = {
  tarragona: 'Tarragona/Reus', barcelona: 'Barcelona', lleida: 'Lleida/Girona',
  other_cat: 'Catalunya', international: 'Internacional',
  civil: 'Civil', religious: 'Religiosa', symbolic: 'Simbòlica',
  photo: 'Foto', video: 'Vídeo', both: 'Foto+Vídeo',
  low: '< 1.500 €', mid: '1.500-2.500 €', high: '2.500-3.500 €', premium: '> 3.500 €',
};
---

<AdminLayout title="Nou pressupost">
  <h1 class="font-display text-2xl sm:text-3xl font-bold mb-6 sm:mb-8">Nou pressupost</h1>

  {lead && !createdToken && (
    <div class="mb-8 bg-cream border border-gold/40 p-5">
      <p class="text-xs font-bold tracking-widest uppercase text-gold mb-3">Respostes del quiz · lead #{lead.id}</p>
      <dl class="grid sm:grid-cols-2 gap-2 text-sm mb-3">
        <div><dt class="inline text-ink/60">Parella:</dt> <dd class="inline font-bold">{lead.coupleName}</dd></div>
        <div><dt class="inline text-ink/60">Email:</dt> <dd class="inline">{lead.email}</dd></div>
        {lead.phone && <div><dt class="inline text-ink/60">Tel:</dt> <dd class="inline">{lead.phone}</dd></div>}
        {lead.weddingDate && <div><dt class="inline text-ink/60">Data:</dt> <dd class="inline">{lead.weddingDate}</dd></div>}
        {lead.location && <div><dt class="inline text-ink/60">Lloc:</dt> <dd class="inline">{LABELS[lead.location] ?? lead.location}</dd></div>}
        {lead.venueName && <div><dt class="inline text-ink/60">Finca:</dt> <dd class="inline font-bold">{lead.venueName}</dd></div>}
        {lead.ceremonyType && <div><dt class="inline text-ink/60">Cerimònia:</dt> <dd class="inline">{LABELS[lead.ceremonyType] ?? lead.ceremonyType}</dd></div>}
        {lead.serviceInterest && <div><dt class="inline text-ink/60">Servei:</dt> <dd class="inline">{LABELS[lead.serviceInterest] ?? lead.serviceInterest}</dd></div>}
        {lead.budgetRange && <div><dt class="inline text-ink/60">Pressupost:</dt> <dd class="inline">{LABELS[lead.budgetRange] ?? lead.budgetRange}</dd></div>}
      </dl>
      <p class="text-xs text-ink/60">🤖 Packs pre-marcats segons la recomanació automàtica. Marca/desmarca els que vulguis abans de crear l'enllaç.</p>
    </div>
  )}

  {createdToken && (
    <div class="mb-8 bg-white border border-gold p-6">
      <p class="text-sm font-bold tracking-widest uppercase text-gold mb-2">✓ Creat</p>
      <p class="mb-3 text-ink/80">
        {createdQuoteEmail
          ? `Aquest és l'enllaç únic. Envia'l directament a ${createdQuoteEmail} o copia'l:`
          : "Aquest és l'enllaç únic. Copia'l i envia'l a la parella:"}
      </p>
      <div class="flex flex-wrap gap-2">
        <input
          readonly
          value={`${siteUrl}/p/${createdToken}`}
          class="flex-1 min-w-[180px] px-3 py-2 border border-black/15 bg-cream font-mono text-sm"
          id="token-url"
        />
        <button
          type="button"
          data-copy={`${siteUrl}/p/${createdToken}`}
          class="bg-ink text-white px-4 py-2 text-xs font-bold tracking-widest uppercase hover:bg-gold transition-colors whitespace-nowrap"
        >
          Copiar
        </button>
        {createdQuoteEmail && createdQuoteId && (
          <button
            type="button"
            data-send-quote
            data-quote-id={createdQuoteId}
            data-email={createdQuoteEmail}
            class="bg-gold text-white px-4 py-2 text-xs font-bold tracking-widest uppercase hover:brightness-110 transition whitespace-nowrap"
          >
            📧 Enviar
          </button>
        )}
      </div>
      {createdQuoteEmail && (
        <p class="text-[0.7rem] text-ink/50 mt-2" data-send-feedback></p>
      )}
      <div class="mt-4 flex gap-3 text-xs">
        <a href="/admin" class="text-gold underline">← Tornar al llistat</a>
        <a href="/admin/new" class="text-gold underline">+ Crear-ne un altre</a>
      </div>
    </div>
  )}

  {error && <p class="mb-6 p-3 bg-red-50 border border-red-200 text-red-700 text-sm">{error}</p>}

  <form method="POST" class="max-w-2xl space-y-6 bg-white p-6 border border-black/10">
    {lead && <input type="hidden" name="lead_id" value={lead.id} />}

    <div>
      <label for="couple_name" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Nom de la parella *</label>
      <input id="couple_name" name="couple_name" required value={initialName}
             class="w-full px-3 py-2 border border-black/15 focus:border-gold focus:outline-none"
             placeholder="Luis & Craig" />
    </div>

    <div>
      <label for="couple_email" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Email (opcional)</label>
      <input id="couple_email" name="couple_email" type="email" value={initialEmail}
             class="w-full px-3 py-2 border border-black/15 focus:border-gold focus:outline-none" />
    </div>

    <div>
      <p class="text-xs font-bold tracking-widest uppercase mb-2">Servei que volen</p>
      <p class="text-[0.7rem] text-ink/55 mb-3 -mt-1">Filtra què veurà la parella al configurador interactiu del pressupost. Si dubten, deixa "encara dubten" — així veuen tot.</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        {[
          { v: 'photo',     label: '📸 Foto' },
          { v: 'video',     label: '🎬 Vídeo' },
          { v: 'both',      label: '💍 Foto + vídeo' },
          { v: 'undecided', label: '🤔 Encara dubten' },
        ].map((opt) => (
          <label class="block">
            <input
              type="radio"
              name="service_interest"
              value={opt.v}
              checked={initialServiceInterest === opt.v}
              class="sr-only peer"
            />
            <span class="block text-xs font-bold tracking-widest uppercase text-center px-3 py-2 border border-black/15 cursor-pointer hover:border-gold peer-checked:bg-ink peer-checked:text-white peer-checked:border-ink transition-colors">
              {opt.label}
            </span>
          </label>
        ))}
      </div>
    </div>

    <div>
      <p class="text-xs font-bold tracking-widest uppercase mb-3">Packs a mostrar *</p>
      <p class="text-[0.7rem] text-ink/55 mb-3 -mt-2">Clica el ▾ per veure el detall que veurà la parella al pressupost.</p>
      <div class="space-y-2">
        {PACKS.map((p) => {
          const subpacks = getComposedSubpacks(p);
          return (
            <details class="border border-black/10 bg-white open:border-gold/40">
              <summary class="cursor-pointer list-none flex items-start gap-3 p-3 hover:bg-cream">
                <input type="checkbox" name="packs" value={p.id}
                       checked={recommendedPackIds.includes(p.id)}
                       onclick="event.stopPropagation()"
                       class="mt-1 accent-gold" />
                <span class="flex-1">
                  <span class="font-bold">{p.name.ca}</span>
                  <span class="block text-xs text-ink/60">{p.type} · {p.price}</span>
                </span>
                <span class="text-ink/40 text-sm leading-none mt-1 select-none">▾</span>
              </summary>
              <div class="px-4 pb-4 -mt-1 border-t border-black/5 pt-3 space-y-3">
                {subpacks.length > 0 ? (
                  <>
                    {subpacks.map((sp) => (
                      <div>
                        <p class="text-[0.7rem] font-bold uppercase tracking-wide text-ink/70 mb-1">{sp.name.ca}</p>
                        <ul class="space-y-1.5 text-sm text-ink/80">
                          {sp.includes.ca.map((it) => (
                            <li class="flex gap-2"><span class="text-gold shrink-0">✓</span><span>{it}</span></li>
                          ))}
                        </ul>
                      </div>
                    ))}
                    {p.includes.ca.length > 0 && (
                      <div class="pt-2 border-t border-black/5">
                        <p class="text-[0.7rem] font-bold uppercase tracking-wide text-gold mb-1">I junts:</p>
                        <ul class="space-y-1.5 text-sm text-ink/80">
                          {p.includes.ca.map((it) => (
                            <li class="flex gap-2"><span class="text-gold shrink-0">✓</span><span>{it}</span></li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </>
                ) : (
                  <ul class="space-y-1.5 text-sm text-ink/80">
                    {p.includes.ca.map((it) => (
                      <li class="flex gap-2"><span class="text-gold shrink-0">✓</span><span>{it}</span></li>
                    ))}
                  </ul>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </div>

    <details class="border border-black/10 bg-cream/40">
      <summary class="cursor-pointer px-4 py-3 text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold select-none">
        ＋ Extres disponibles (referència)
      </summary>
      <div class="px-4 pb-4 pt-2">
        <p class="text-[0.7rem] text-ink/55 mb-3">Aquests extres ja surten al pressupost de la parella. Si vols afegir-ne algun al missatge personalitzat, copia el text d'aquí.</p>
        <ul class="divide-y divide-black/5 text-sm">
          {EXTRAS.map((x) => (
            <li class="flex items-start justify-between gap-3 py-2">
              <div class="flex-1">
                <p class="text-ink">{x.name.ca}</p>
                {x.note && <p class="text-[0.7rem] text-ink/55 mt-0.5">{x.note.ca}</p>}
              </div>
              <p class="font-bold text-gold whitespace-nowrap">{x.price}</p>
            </li>
          ))}
        </ul>
      </div>
    </details>

    <div>
      <label for="notes" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Notes personals (opcional)</label>
      <textarea id="notes" name="notes" rows="3"
                class="w-full px-3 py-2 border border-black/15 focus:border-gold focus:outline-none resize-y"
                placeholder="Missatge personalitzat que veurà la parella a la pàgina…"></textarea>
    </div>

    <details class="border border-black/10 bg-cream/40">
      <summary class="cursor-pointer px-4 py-3 text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold select-none">
        ⚙ Opcions avançades
      </summary>
      <div class="px-4 pb-4 pt-2 grid md:grid-cols-2 gap-4">
        <div>
          <label for="expires_at" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Caduca</label>
          <input id="expires_at" name="expires_at" type="date"
                 class="w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
          <p class="text-[0.7rem] text-ink/50 mt-1">L'enllaç deixarà de funcionar després d'aquesta data.</p>
        </div>
        <div>
          <label for="password" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Contrasenya</label>
          <input id="password" name="password"
                 class="w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none"
                 placeholder="Deixa-ho en blanc" />
          <p class="text-[0.7rem] text-ink/50 mt-1">Capa extra de seguretat si voleu que la parella introdueixi una paraula per obrir el pressupost.</p>
        </div>
        <div>
          <label for="preferred_language" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Idioma</label>
          <select id="preferred_language" name="preferred_language"
                  class="w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="ca" selected={initialLanguage === 'ca'}>Català</option>
            <option value="es" selected={initialLanguage === 'es'}>Castellano</option>
            <option value="en" selected={initialLanguage === 'en'}>English</option>
          </select>
          <p class="text-[0.7rem] text-ink/50 mt-1">L'idioma en què veurà la parella la pàgina del pressupost. Si ve d'un lead, ja ve pre-seleccionat.</p>
        </div>
        <div class="md:col-span-2">
          <label for="flagship_video_id" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Vídeo destacat</label>
          <select id="flagship_video_id" name="flagship_video_id"
                  class="w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="">— Per defecte (Elena i Jordi) —</option>
            <optgroup label="Tràilers">
              {publicVideos.map((v) => (
                <option value={v.youtubeId}>{v.coupleName} · {v.venue}</option>
              ))}
            </optgroup>
            {fullVideos.length > 0 && (
              <optgroup label="Bodes senceres (ocultes a YouTube)">
                {fullVideos.map((v) => (
                  <option value={v.youtubeId}>
                    {v.coupleName} · {v.venue}{v.adminNote ? ` · ${v.adminNote}` : ''}
                  </option>
                ))}
              </optgroup>
            )}
          </select>
          <p class="text-[0.7rem] text-ink/50 mt-1">Els tràilers són curts; les bodes senceres són la versió completa que envies un cop la parella està enganxada (després d'una videocall, per exemple). En blanc → per defecte.</p>
        </div>

        <div class="md:col-span-2">
          <label for="flagship_wedding_slug" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Galeria de fotos destacada — Boda real</label>
          <select id="flagship_wedding_slug" name="flagship_wedding_slug"
                  class="w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="">— Cap (deixar automàtic) —</option>
            {WEDDINGS.map((w) => (
              <option value={w.slug}>{w.couple} · {w.venue} · {w.location}</option>
            ))}
          </select>
          <p class="text-[0.7rem] text-ink/50 mt-1">Si tries una boda real, la parella la veurà com a referència al pressupost. Té prioritat sobre el showcase.</p>
        </div>

        <div class="md:col-span-2">
          <label for="flagship_showcase_slug" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Galeria de fotos destacada — Showcase temàtic</label>
          <select id="flagship_showcase_slug" name="flagship_showcase_slug"
                  class="w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="">— Cap (deixar automàtic) —</option>
            {SHOWCASES.map((s) => (
              <option value={s.slug}>{s.title.ca}</option>
            ))}
          </select>
          <p class="text-[0.7rem] text-ink/50 mt-1">Alternativa al \"boda real\": un tipus de boda genèric. Si deixes les dues en blanc, es dedueix del lead (si n'hi ha).</p>
        </div>

        <div class="md:col-span-2">
          <label for="flagship_external_gallery_url" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Galeria externa</label>
          {externalGalleries.length > 0 && (
            <select
              id="flagship_external_gallery_picker"
              data-gallery-picker
              class="w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none mb-2"
            >
              <option value="">— Trieu una galeria del catàleg, o enganxeu URL a sota —</option>
              {externalGalleries.map((g) => (
                <option value={g.url}>
                  {g.coupleName} · {g.venue}{g.adminNote ? ` · ${g.adminNote}` : ''}
                </option>
              ))}
            </select>
          )}
          <input id="flagship_external_gallery_url" name="flagship_external_gallery_url" type="url"
                 placeholder="https://gallery.fotostudio.io/objectiu-fotografs/..."
                 class="w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
          <p class="text-[0.7rem] text-ink/50 mt-1">Si poses una URL de galeria de FotoStudio (o similar), s'incrusta a la pàgina del pressupost. Si la galeria no es deixa embedar, surt un botó per obrir-la en una pestanya nova automàticament.</p>
        </div>
      </div>
    </details>

    <button type="submit"
            class="bg-ink text-white px-8 py-3 text-xs font-bold tracking-widest uppercase hover:bg-gold transition-colors">
      Crear i generar enllaç
    </button>
  </form>
</AdminLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.copy!);
        const old = btn.textContent;
        btn.textContent = '✓ Copiat';
        setTimeout(() => (btn.textContent = old), 1500);
      } catch {
        prompt('Copia:', btn.dataset.copy!);
      }
    });
  });

  // Mirrors the same data-send-quote handler on /admin/<id> so creating
  // from a lead → email is one click without leaving the page.
  document.querySelectorAll<HTMLButtonElement>('[data-send-quote]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const quoteId = Number(btn.dataset.quoteId);
      const email = btn.dataset.email ?? '';
      const feedback = document.querySelector<HTMLElement>('[data-send-feedback]');
      if (!confirm(`Enviar l'enllaç del pressupost a ${email}?`)) return;
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = 'Enviant…';
      try {
        const res = await fetch('/api/admin/send-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quoteId }),
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        btn.textContent = '✓ Enviat';
        if (feedback) {
          feedback.textContent = `Enviat a ${email} · ` + new Date().toLocaleString('ca-ES');
          feedback.style.color = '#c9a96e';
        }
      } catch (err) {
        console.error(err);
        btn.textContent = old ?? '📧 Enviar';
        if (feedback) {
          feedback.textContent = 'Error enviant. Torna-ho a provar.';
          feedback.style.color = '#b91c1c';
        }
      } finally {
        setTimeout(() => { btn.disabled = false; }, 2000);
      }
    });
  });

  // External-gallery picker → URL input. The hidden source of truth is the
  // URL input (what the server reads); the picker is just a shortcut that
  // pastes the catalogue URL when selected. Manual URLs still work.
  const galleryPicker = document.querySelector<HTMLSelectElement>('[data-gallery-picker]');
  const galleryUrl = document.querySelector<HTMLInputElement>('#flagship_external_gallery_url');
  if (galleryPicker && galleryUrl) {
    galleryPicker.addEventListener('change', () => {
      if (galleryPicker.value) galleryUrl.value = galleryPicker.value;
    });
  }
</script>
