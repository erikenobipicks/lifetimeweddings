---
// Admin listing of material-delivery landing pages ("entregues").
import AdminLayout from '~/layouts/AdminLayout.astro';
import { listDeliveries, setDeliveryArchived, deleteDelivery } from '~/lib/deliveries';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') ?? '');
  const id = String(form.get('id') ?? '');
  if (id) {
    try {
      if (action === 'archive') await setDeliveryArchived(id, true);
      else if (action === 'reactivate') await setDeliveryArchived(id, false);
      else if (action === 'delete') await deleteDelivery(id);
      return Astro.redirect(`/admin/deliveries?ok=${action}d`);
    } catch (err) {
      console.error('[admin.deliveries.action] failed', { action, id, err });
      const msg = err instanceof Error ? err.message : 'error desconegut';
      return Astro.redirect(`/admin/deliveries?error=${encodeURIComponent(msg)}`);
    }
  }
}

const includeArchived = Astro.url.searchParams.get('archived') === '1';
const okFlag = Astro.url.searchParams.get('ok');
const errorMsg = Astro.url.searchParams.get('error');
const deliveries = await listDeliveries({ includeArchived });

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;

function fmtDate(d: Date): string {
  return d.toLocaleDateString('ca-ES', { timeZone: 'Europe/Madrid', day: '2-digit', month: '2-digit', year: 'numeric' });
}
---

<AdminLayout title="Entregues">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4 sm:mb-6">
    <h1 class="font-display text-2xl sm:text-3xl font-bold">Entregues de material</h1>
    <div class="flex items-center gap-3">
      <a
        href={includeArchived ? '/admin/deliveries' : '/admin/deliveries?archived=1'}
        class="text-xs font-bold tracking-widest uppercase text-ink/70 hover:text-gold transition-colors whitespace-nowrap"
      >
        {includeArchived ? '✕ Ocultar arxivades' : '📦 Mostrar arxivades'}
      </a>
      <a
        href="/admin/deliveries/new"
        class="bg-ink text-white px-5 py-2.5 text-xs font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors whitespace-nowrap"
      >
        + Nova entrega
      </a>
    </div>
  </div>

  {okFlag && (
    <div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm">
      ✓ Fet.
    </div>
  )}
  {errorMsg && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-900 text-sm">
      <strong>Error:</strong> {errorMsg}
    </div>
  )}

  {deliveries.length === 0 ? (
    <p class="text-ink/70 text-center py-16">
      Encara no hi ha cap entrega. <a href="/admin/deliveries/new" class="text-gold underline">Crea'n una</a>.
    </p>
  ) : (
    <>
    {/* Mobile cards */}
    <ul class="md:hidden space-y-3">
      {deliveries.map((d) => (
        <li class:list={['bg-white border border-line', d.archived && 'opacity-60']}>
          <div class="p-4">
            <p class="font-bold leading-tight">{d.coupleName1} i {d.coupleName2}</p>
            <p class="text-[0.7rem] text-ink/70">{fmtDate(d.weddingDate)}{d.venueName && ` · ${d.venueName}`}</p>
            <div class="flex flex-wrap items-center gap-1.5 mt-2">
              <span class:list={['text-[0.6rem] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded-sm', d.youtubeVideoId ? 'bg-emerald-100 text-emerald-800' : 'bg-ink/10 text-ink/50']}>🎬 Vídeo</span>
              <span class:list={['text-[0.6rem] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded-sm', d.swisstransferUrl ? 'bg-emerald-100 text-emerald-800' : 'bg-ink/10 text-ink/50']}>📥 Descàrrega</span>
              <span class:list={['text-[0.6rem] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded-sm', d.galleryUrl ? 'bg-emerald-100 text-emerald-800' : 'bg-ink/10 text-ink/50']}>📷 Galeria</span>
              {d.archived && <span class="text-[0.6rem] bg-ink/10 text-ink/70 px-1.5 py-0.5 rounded-sm">ARXIVADA</span>}
            </div>
          </div>
          <div class="flex border-t border-line">
            <a href={`/admin/deliveries/${d.id}`} class="flex-1 text-center text-gold text-[0.7rem] font-bold tracking-widest uppercase px-4 py-3 hover:bg-cream">
              Editar →
            </a>
            <button type="button" data-copy={`${siteUrl}/entrega/${d.slug}`} class="flex-1 text-center text-ink/70 text-[0.7rem] font-bold tracking-widest uppercase px-4 py-3 border-l border-line hover:bg-cream">
              Copiar enllaç
            </button>
          </div>
        </li>
      ))}
    </ul>

    <div class="hidden md:block overflow-x-auto bg-white border border-line">
      <table class="w-full text-sm">
        <thead class="bg-cream text-[0.7rem] font-bold tracking-widest uppercase">
          <tr>
            <th class="text-left px-4 py-3">Parella</th>
            <th class="text-left px-4 py-3">Data boda</th>
            <th class="text-center px-4 py-3">Vídeo</th>
            <th class="text-center px-4 py-3">Descàrrega</th>
            <th class="text-center px-4 py-3">Galeria</th>
            <th class="text-right px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {deliveries.map((d) => (
            <tr class:list={['border-t border-line hover:bg-cream/50', d.archived && 'opacity-50']}>
              <td class="px-4 py-3">
                <a href={`/admin/deliveries/${d.id}`} class="font-bold hover:text-gold">{d.coupleName1} i {d.coupleName2}</a>
                {d.archived && <span class="text-[0.65rem] bg-ink/10 text-ink/70 px-1.5 py-0.5 ml-1">ARXIVADA</span>}
              </td>
              <td class="px-4 py-3 text-ink/70">{fmtDate(d.weddingDate)}{d.venueName && <div class="text-xs text-ink/70">{d.venueName}</div>}</td>
              <td class="px-4 py-3 text-center">{d.youtubeVideoId ? '✓' : '—'}</td>
              <td class="px-4 py-3 text-center">{d.swisstransferUrl ? '✓' : '—'}</td>
              <td class="px-4 py-3 text-center">{d.galleryUrl ? '✓' : '—'}</td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                <button type="button" data-copy={`${siteUrl}/entrega/${d.slug}`} class="text-gold text-xs font-bold tracking-widest uppercase hover:underline mr-3">
                  Copiar
                </button>
                <a href={`/admin/deliveries/${d.id}`} class="text-ink/70 text-xs font-bold tracking-widest uppercase hover:text-gold">
                  Editar →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    </>
  )}
</AdminLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy!;
      try {
        await navigator.clipboard.writeText(text);
        const old = btn.textContent;
        btn.textContent = '✓ Copiat';
        setTimeout(() => (btn.textContent = old), 1500);
      } catch {
        prompt('Copia aquest enllaç:', text);
      }
    });
  });
</script>
