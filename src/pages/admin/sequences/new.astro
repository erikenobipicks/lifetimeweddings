---
// Admin: create a new email sequence template.
import AdminLayout from '~/layouts/AdminLayout.astro';

const params = Astro.url.searchParams;
const error = params.get('error');
function v(name: string): string { return params.get(`v_${name}`) ?? ''; }
---

<AdminLayout title="Nova plantilla">
  <div class="mb-6">
    <a href="/admin/sequences" class="text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold">← Tornar al llistat</a>
    <h1 class="font-display text-2xl sm:text-3xl font-bold mt-1">Nova plantilla d'email</h1>
  </div>

  {error && (
    <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-800 text-sm"><strong>Error:</strong> {error}</div>
  )}

  <form method="POST" action="/api/admin/sequences/create" class="space-y-8 bg-white border border-black/10 p-6 md:p-8 max-w-3xl">
    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Identificació</legend>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Slug intern *</span>
        <span class="block text-[11px] text-ink/50 mb-1">Sense espais, minúscules. Ex: <code class="bg-cream px-1">timeline-6-mesos</code></span>
        <input name="slug" required pattern="[a-z0-9-]+" maxlength="80" value={v('slug')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none" />
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" name="enabled" value="1" checked class="h-5 w-5 accent-gold" />
        <span class="text-sm">Activa (envia automàticament quan toca)</span>
      </label>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Quan s'envia</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Tipus de disparador *</span>
          <select name="triggerKind" required class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="days_after_deposit">Dies després del dipòsit pagat</option>
            <option value="days_before_wedding">Dies abans de la boda</option>
            <option value="days_after_wedding">Dies després de la boda</option>
          </select>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Dies (positiu) *</span>
          <input type="number" name="triggerOffsetDays" required min="0" max="3650" value={v('triggerOffsetDays') || '180'} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Formulari associat (opcional)</span>
          <span class="block text-[11px] text-ink/50 mb-1">Si tries un formulari, l'email portarà un enllaç únic a <code class="bg-cream px-1">/formulari/&lt;token&gt;</code>. Si no en tries cap, és només informatiu.</span>
          <select name="formKind" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="">— Cap (només informatiu) —</option>
            <option value="wedding_details">Informació de la boda (preparatius, persones clau...)</option>
            <option value="timeline">Timeline del dia</option>
            <option value="guest_list">Llista de convidats</option>
            <option value="music">Música</option>
          </select>
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Assumpte</legend>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Català *</span>
        <input name="subjectCa" required maxlength="200" value={v('subjectCa')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
      </label>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Castellà *</span>
        <input name="subjectEs" required maxlength="200" value={v('subjectEs')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
      </label>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">English *</span>
        <input name="subjectEn" required maxlength="200" value={v('subjectEn')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
      </label>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Cos de l'email (HTML)</legend>
      <p class="text-sm text-ink/65 -mt-2">Variables disponibles: <code class="bg-cream px-1">{`{coupleName1}`}</code>, <code class="bg-cream px-1">{`{coupleName2}`}</code>, <code class="bg-cream px-1">{`{weddingDate}`}</code>, <code class="bg-cream px-1">{`{venueName}`}</code>, <code class="bg-cream px-1">{`{packName}`}</code>, <code class="bg-cream px-1">{`{c1FullName}`}</code>, <code class="bg-cream px-1">{`{c2FullName}`}</code>, <code class="bg-cream px-1">{`{formUrl}`}</code> (només si has triat formulari).</p>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Català *</span>
        <textarea name="bodyHtmlCa" required rows="10" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('bodyHtmlCa')}</textarea>
      </label>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Castellà *</span>
        <textarea name="bodyHtmlEs" required rows="10" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('bodyHtmlEs')}</textarea>
      </label>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">English *</span>
        <textarea name="bodyHtmlEn" required rows="10" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('bodyHtmlEn')}</textarea>
      </label>
    </fieldset>

    <div class="flex items-center gap-4 pt-4 border-t border-black/10">
      <button type="submit" class="bg-ink text-white px-6 py-3 text-xs font-bold tracking-widest uppercase hover:bg-gold transition-colors">Crear plantilla</button>
      <a href="/admin/sequences" class="text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold">Cancel·lar</a>
    </div>
  </form>
</AdminLayout>
