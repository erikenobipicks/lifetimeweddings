---
import AdminLayout from '~/layouts/AdminLayout.astro';
import { listQuotes, getQuoteStats } from '~/lib/quotes';

const showArchived = Astro.url.searchParams.get('arxivats') === '1';
const okFlag = Astro.url.searchParams.get('ok');
const quotes = await listQuotes({ includeArchived: showArchived });
const stats = await Promise.all(quotes.map((q) => getQuoteStats(q.id)));

function fmt(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('ca-ES', { timeZone: 'Europe/Madrid', dateStyle: 'short', timeStyle: 'short' });
}

function humanSecs(n: number): string {
  if (n < 60) return `${n}s`;
  const m = Math.floor(n / 60);
  const s = n % 60;
  return `${m}m${s ? ` ${s}s` : ''}`;
}

function tempLabel(stats: { views: number; totalTimeSeconds: number; maxScroll: number }): { icon: string; color: string } {
  if (stats.views === 0) return { icon: '⚪', color: 'text-gray-500' };
  if (stats.totalTimeSeconds >= 180 || stats.maxScroll >= 80) return { icon: '🔥', color: 'text-red-600' };
  if (stats.totalTimeSeconds >= 30) return { icon: '🙂', color: 'text-amber-600' };
  return { icon: '❄️', color: 'text-blue-500' };
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;
---

<AdminLayout title="Pressupostos">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
    <h1 class="font-display text-2xl sm:text-3xl font-bold">Pressupostos</h1>
    <a href="/admin/new" class="self-start sm:self-auto bg-ink text-white px-5 py-2.5 text-xs font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors whitespace-nowrap">+ Nou pressupost</a>
  </div>

  {okFlag === 'deleted' && (
    <div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm">
      ✓ Pressupost eliminat definitivament.
    </div>
  )}

  <div class="flex flex-wrap items-center gap-3 mb-6">
    <input
      type="text"
      id="search-input"
      placeholder="Cercar per nom o email..."
      class="flex-1 min-w-0 sm:min-w-[200px] px-3 py-2 border border-line bg-white text-sm focus:border-gold focus:outline-none"
    />
    <a
      href={showArchived ? '/admin' : '/admin?arxivats=1'}
      class="text-xs font-bold tracking-widest uppercase text-ink/70 hover:text-gold transition-colors whitespace-nowrap"
    >
      {showArchived ? '✕ Ocultar arxivats' : '📦 Mostrar arxivats'}
    </a>
  </div>

  {quotes.length === 0 ? (
    <p class="text-ink/70 text-center py-16">Encara no hi ha cap pressupost. <a href="/admin/new" class="text-gold underline">Crea'n un</a>.</p>
  ) : (
    <>
    {/* Mobile cards: tap the row to open detail. Below md: the table version
        below takes over with the full activity columns. */}
    <ul class="md:hidden space-y-3" id="quotes-cards">
      {quotes.map((q, i) => {
        const s = stats[i];
        const t = tempLabel(s);
        return (
          <li
            class:list={['bg-white border border-line', q.archived && 'opacity-60']}
            data-search={`${q.coupleName} ${q.coupleEmail ?? ''}`.toLowerCase()}
          >
            <a href={`/admin/${q.id}`} class="block p-4 hover:bg-cream/50">
              <div class="flex items-start justify-between gap-3 mb-2">
                <div class="min-w-0 flex-1">
                  <p class="font-bold leading-tight flex items-center gap-2">
                    <span class={`text-base ${t.color}`}>{t.icon}</span>
                    <span class="truncate">{q.coupleName}</span>
                  </p>
                  {q.coupleEmail && <p class="text-[0.7rem] text-ink/70 truncate ml-7">{q.coupleEmail}</p>}
                </div>
                {q.archived && <span class="shrink-0 text-[0.6rem] bg-ink/10 text-ink/70 px-1.5 py-0.5 rounded-sm">ARXIVAT</span>}
              </div>
              <div class="grid grid-cols-3 gap-2 text-[0.7rem] text-ink/70 ml-7">
                <div><span class="text-ink/70">Visites</span><br/><strong class="text-ink">{s.views}</strong></div>
                <div><span class="text-ink/70">Temps</span><br/><strong class="text-ink">{humanSecs(s.totalTimeSeconds)}</strong></div>
                <div><span class="text-ink/70">Scroll</span><br/><strong class="text-ink">{s.maxScroll}%</strong></div>
              </div>
              <p class="text-[0.7rem] text-ink/70 mt-3 ml-7">Creat {fmt(q.createdAt)}</p>
            </a>
            <div class="flex border-t border-line">
              <button
                type="button"
                data-copy={`${siteUrl}/p/${q.token}`}
                class="flex-1 text-center text-gold text-[0.7rem] font-bold tracking-widest uppercase px-4 py-3 hover:bg-cream"
              >
                Copiar
              </button>
              <form
                method="POST"
                action={`/admin/${q.id}`}
                class="flex-1 border-l border-line"
                onsubmit={`return confirm('⚠ Eliminar el pressupost de ${q.coupleName.replace(/'/g, "\\'")} DEFINITIVAMENT?\\n\\nNo es podrà recuperar.')`}
              >
                <input type="hidden" name="action" value="delete" />
                <button
                  type="submit"
                  class="w-full text-center text-red-600 text-[0.7rem] font-bold tracking-widest uppercase px-4 py-3 hover:bg-red-50"
                >
                  🗑 Eliminar
                </button>
              </form>
            </div>
          </li>
        );
      })}
    </ul>

    <div class="hidden md:block overflow-x-auto bg-white border border-line">
      <table class="w-full text-sm" id="quotes-table">
        <thead class="bg-cream text-[0.7rem] font-bold tracking-widest uppercase">
          <tr>
            <th class="text-left px-4 py-3">Estat</th>
            <th class="text-left px-4 py-3">Parella</th>
            <th class="text-left px-4 py-3">Enviat</th>
            <th class="text-left px-4 py-3">1a obertura</th>
            <th class="text-right px-4 py-3">Visites</th>
            <th class="text-right px-4 py-3">Temps</th>
            <th class="text-right px-4 py-3">Scroll</th>
            <th class="text-right px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {quotes.map((q, i) => {
            const s = stats[i];
            const t = tempLabel(s);
            return (
              <tr class:list={['border-t border-line hover:bg-cream/50', q.archived && 'opacity-50']} data-search={`${q.coupleName} ${q.coupleEmail ?? ''}`.toLowerCase()}>
                <td class={`px-4 py-3 text-lg ${t.color}`}>{t.icon}</td>
                <td class="px-4 py-3">
                  <a href={`/admin/${q.id}`} class="font-bold hover:text-gold">{q.coupleName}</a>
                  {q.coupleEmail && <div class="text-xs text-ink/70">{q.coupleEmail}</div>}
                  {q.archived && <span class="text-[0.65rem] bg-ink/10 text-ink/70 px-1.5 py-0.5 ml-1">ARXIVAT</span>}
                </td>
                <td class="px-4 py-3 text-ink/70">{fmt(q.createdAt)}</td>
                <td class="px-4 py-3 text-ink/70">{fmt(s.firstViewAt)}</td>
                <td class="px-4 py-3 text-right font-bold">{s.views}</td>
                <td class="px-4 py-3 text-right">{humanSecs(s.totalTimeSeconds)}</td>
                <td class="px-4 py-3 text-right">{s.maxScroll}%</td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <button
                    type="button"
                    data-copy={`${siteUrl}/p/${q.token}`}
                    class="text-gold text-xs font-bold tracking-widest uppercase hover:underline mr-3"
                    title="Copiar enllaç"
                  >
                    Copiar
                  </button>
                  <form
                    method="POST"
                    action={`/admin/${q.id}`}
                    class="inline"
                    onsubmit={`return confirm('⚠ Eliminar el pressupost de ${q.coupleName.replace(/'/g, "\\'")} DEFINITIVAMENT?\\n\\nNo es podrà recuperar.')`}
                  >
                    <input type="hidden" name="action" value="delete" />
                    <button
                      type="submit"
                      class="text-red-600 text-xs font-bold tracking-widest uppercase hover:underline"
                      title="Eliminar definitivament"
                    >
                      🗑
                    </button>
                  </form>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    </>
  )}
</AdminLayout>

<script>
  // Copy links
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy!;
      try {
        await navigator.clipboard.writeText(text);
        const old = btn.textContent;
        btn.textContent = '✓ Copiat';
        setTimeout(() => (btn.textContent = old), 1500);
      } catch {
        prompt('Copia aquest enllaç:', text);
      }
    });
  });

  // Search filter — operates on both the table rows (desktop) and the
  // card list (mobile) so the visible set stays in sync regardless of
  // which layout the user is on.
  const input = document.getElementById('search-input') as HTMLInputElement;
  const rows = document.querySelectorAll<HTMLElement>('#quotes-table tbody tr, #quotes-cards li');
  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    rows.forEach((row) => {
      const hay = row.dataset.search ?? '';
      row.style.display = !q || hay.includes(q) ? '' : 'none';
    });
  });
</script>
