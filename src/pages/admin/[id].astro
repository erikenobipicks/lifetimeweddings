---
import AdminLayout from '~/layouts/AdminLayout.astro';
import {
  getQuoteById,
  getQuoteStats,
  getQuoteEvents,
  archiveQuote,
  deleteQuote,
  getLeadByQuoteId,
  listQuoteResponses,
  setAdminDiscount,
  closeQuote,
  reopenQuote,
} from '~/lib/quotes';
import { PACKS, EXTRAS } from '~/data/packs';
import { calculateSelectionTotals, formatEuros } from '~/lib/pricing';

const id = Number(Astro.params.id);
if (!Number.isFinite(id)) return Astro.redirect('/admin');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') ?? '');
  if (action === 'archive') {
    await archiveQuote(id);
    return Astro.redirect('/admin');
  }
  if (action === 'delete') {
    try {
      await deleteQuote(id);
      return Astro.redirect('/admin?ok=deleted');
    } catch (err) {
      console.error('[admin.quotes.delete] failed', { quoteId: id, err });
      const msg = err instanceof Error ? err.message : 'error desconegut';
      return Astro.redirect(`/admin/${id}?error=${encodeURIComponent('No s\'ha pogut eliminar: ' + msg)}`);
    }
  }
  if (action === 'set-discount') {
    // Operator-granted discount. Stored as cents; UI takes euros so we
    // parse permissively (commas + dots) before storing.
    const raw = String(form.get('discount_euros') ?? '').trim();
    const reason = String(form.get('discount_reason') ?? '').trim();
    const euros = Number(raw.replace(/\./g, '').replace(',', '.'));
    const cents = Number.isFinite(euros) && euros > 0 ? Math.round(euros * 100) : 0;
    await setAdminDiscount(id, cents, reason || null);
    return Astro.redirect(`/admin/${id}?ok=discount`);
  }
  if (action === 'clear-discount') {
    await setAdminDiscount(id, 0, null);
    return Astro.redirect(`/admin/${id}?ok=discount-cleared`);
  }
  if (action === 'close-quote') {
    await closeQuote(id);
    return Astro.redirect(`/admin/${id}?ok=closed`);
  }
  if (action === 'reopen-quote') {
    await reopenQuote(id);
    return Astro.redirect(`/admin/${id}?ok=reopened`);
  }
}

const quote = await getQuoteById(id);
if (!quote) return Astro.redirect('/admin');

const stats = await getQuoteStats(quote.id);
const events = await getQuoteEvents(quote.id, 100);
const lead = await getLeadByQuoteId(quote.id);
const responses = await listQuoteResponses(quote.id);
const latestResponse = responses[0] ?? null;
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;
const errorMsg = Astro.url.searchParams.get('error');
const okMsg = Astro.url.searchParams.get('ok');
const url = `${siteUrl}/p/${quote.token}`;

const packs = PACKS.filter((p) => quote.packIds.includes(p.id));

// Pre-compute the latest response's totals so the operator sees the
// breakdown without re-doing the math (matches what the couple saw).
const latestTotals = latestResponse
  ? calculateSelectionTotals(latestResponse.packIds, latestResponse.extraIds, quote.adminDiscountCents)
  : null;
function labelForPack(pid: string): string {
  return PACKS.find((p) => p.id === pid)?.name.ca ?? pid;
}
function priceForPackStr(pid: string): string {
  return PACKS.find((p) => p.id === pid)?.price ?? '—';
}
function labelForExtra(xid: string): string {
  return EXTRAS.find((e) => e.id === xid)?.name.ca ?? xid;
}
function priceForExtraStr(xid: string): string {
  return EXTRAS.find((e) => e.id === xid)?.price ?? '—';
}

function fmt(iso: string | null | undefined): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('ca-ES', { timeZone: 'Europe/Madrid', dateStyle: 'short', timeStyle: 'short' });
}

function humanSecs(n: number): string {
  if (n < 60) return `${n}s`;
  const m = Math.floor(n / 60);
  const s = n % 60;
  return `${m}m${s ? ` ${s}s` : ''}`;
}
---

<AdminLayout title={quote.coupleName}>
  {errorMsg && (
    <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-900 text-sm">
      <strong class="font-bold">Error:</strong> {errorMsg}
    </div>
  )}
  {okMsg && (
    <div class="mb-6 px-4 py-3 bg-green-50 border border-green-200 text-green-900 text-sm">
      <strong class="font-bold">✓</strong> {okMsg === 'discount' ? 'Descompte aplicat.' : okMsg === 'discount-cleared' ? 'Descompte eliminat.' : okMsg === 'closed' ? 'Pressupost tancat.' : okMsg === 'reopened' ? 'Pressupost reobert.' : 'Fet.'}
    </div>
  )}
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-6 sm:mb-8">
    <div class="min-w-0">
      <p class="text-xs font-bold tracking-widest uppercase text-gold mb-1">Pressupost</p>
      <h1 class="font-display text-2xl sm:text-3xl font-bold break-words">{quote.coupleName}</h1>
      {quote.coupleEmail && <p class="text-ink/60 break-all">{quote.coupleEmail}</p>}
    </div>
    <a href="/admin" class="text-xs text-ink/60 hover:text-gold whitespace-nowrap">← Tornar</a>
  </div>

  <div class="bg-white border border-black/10 p-5 mb-8">
    <p class="text-xs font-bold tracking-widest uppercase mb-2">Enllaç</p>
    <div class="flex flex-wrap gap-2">
      <input readonly value={url} class="flex-1 min-w-[180px] px-3 py-2 border border-black/15 bg-cream font-mono text-sm" />
      <button type="button" data-copy={url} class="bg-ink text-white px-4 py-2 text-xs font-bold tracking-widest uppercase hover:bg-gold transition-colors whitespace-nowrap">Copiar</button>
      {quote.coupleEmail && (
        <button
          type="button"
          data-send-quote
          data-quote-id={quote.id}
          data-email={quote.coupleEmail}
          class="bg-gold text-white px-4 py-2 text-xs font-bold tracking-widest uppercase hover:brightness-110 transition"
        >
          📧 Enviar
        </button>
      )}
    </div>
    {quote.coupleEmail && (
      <p class="text-[0.7rem] text-ink/50 mt-2" data-send-feedback></p>
    )}
    <div class="mt-3 text-xs text-ink/60 flex flex-wrap gap-4">
      <span>Creat: <strong>{fmt(quote.createdAt)}</strong></span>
      {quote.createdBy && <span>per <strong>{quote.createdBy}</strong></span>}
      {quote.expiresAt && <span>Caduca: <strong>{fmt(quote.expiresAt)}</strong></span>}
      {quote.hasPassword && <span>🔒 Protegit amb contrasenya</span>}
    </div>
  </div>

  <div class="grid md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white p-5 border border-black/10 text-center">
      <p class="text-xs font-bold tracking-widest uppercase text-ink/60">Visites</p>
      <p class="font-display text-4xl font-bold">{stats.views}</p>
    </div>
    <div class="bg-white p-5 border border-black/10 text-center">
      <p class="text-xs font-bold tracking-widest uppercase text-ink/60">Visitants únics</p>
      <p class="font-display text-4xl font-bold">{stats.uniqueVisitors}</p>
    </div>
    <div class="bg-white p-5 border border-black/10 text-center">
      <p class="text-xs font-bold tracking-widest uppercase text-ink/60">Temps màx.</p>
      <p class="font-display text-4xl font-bold">{humanSecs(stats.totalTimeSeconds)}</p>
    </div>
    <div class="bg-white p-5 border border-black/10 text-center">
      <p class="text-xs font-bold tracking-widest uppercase text-ink/60">Scroll màx.</p>
      <p class="font-display text-4xl font-bold">{stats.maxScroll}%</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 mb-8">
    <div class="bg-white border border-black/10 p-5">
      <p class="text-xs font-bold tracking-widest uppercase mb-3">Packs inclosos</p>
      <ul class="space-y-2 text-sm">
        {packs.map((p) => (
          <li><strong>{p.name.ca}</strong> — <span class="text-gold">{p.price}</span></li>
        ))}
      </ul>
    </div>
    <div class="bg-white border border-black/10 p-5">
      <p class="text-xs font-bold tracking-widest uppercase mb-3">Notes personals</p>
      <p class="text-sm text-ink/80 whitespace-pre-wrap">{quote.notes || '—'}</p>
    </div>
  </div>

  {latestResponse && latestTotals && (
    <div class="bg-white border-2 border-gold p-5 mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase text-gold mb-1">Resposta del client</p>
          <p class="text-xs text-ink/60">Última configuració rebuda · {fmt(latestResponse.createdAt)}{responses.length > 1 && ` · ${responses.length} respostes en total`}</p>
        </div>
        <div class="text-right">
          <p class="text-xs text-ink/55 uppercase tracking-widest">Total que veuen ells</p>
          <p class="font-display text-3xl font-bold text-gold">{formatEuros(latestTotals.totalCents)}</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <div>
          <p class="text-[0.7rem] font-bold uppercase tracking-widest text-ink/60 mb-2">Packs triats</p>
          {latestResponse.packIds.length === 0 ? (
            <p class="text-sm text-ink/55 italic">— cap —</p>
          ) : (
            <ul class="text-sm space-y-1">
              {latestResponse.packIds.map((pid) => (
                <li class="flex justify-between gap-3">
                  <span>{labelForPack(pid)}</span>
                  <span class="text-gold whitespace-nowrap">{priceForPackStr(pid)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
        <div>
          <p class="text-[0.7rem] font-bold uppercase tracking-widest text-ink/60 mb-2">Extres triats</p>
          {latestResponse.extraIds.length === 0 ? (
            <p class="text-sm text-ink/55 italic">— cap —</p>
          ) : (
            <ul class="text-sm space-y-1">
              {latestResponse.extraIds.map((xid) => (
                <li class="flex justify-between gap-3">
                  <span>{labelForExtra(xid)}</span>
                  <span class="text-gold whitespace-nowrap">{priceForExtraStr(xid)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>

      {latestResponse.message && (
        <div class="mb-4 p-3 bg-cream border-l-4 border-gold">
          <p class="text-[0.7rem] font-bold uppercase tracking-widest text-ink/60 mb-1">Missatge de la parella</p>
          <p class="text-sm text-ink/85 whitespace-pre-wrap">{latestResponse.message}</p>
        </div>
      )}

      <div class="text-xs text-ink/60 space-y-0.5 mb-1">
        <p><span class="text-ink/50">Subtotal (packs):</span> <strong>{formatEuros(latestTotals.packsCents)}</strong></p>
        <p><span class="text-ink/50">Subtotal (extres):</span> <strong>{formatEuros(latestTotals.extrasCents)}</strong></p>
        {quote.adminDiscountCents > 0 && (
          <p><span class="text-ink/50">Descompte aplicat:</span> <strong class="text-gold">−{formatEuros(quote.adminDiscountCents)}</strong></p>
        )}
      </div>

      {responses.length > 1 && (
        <details class="mt-4 pt-3 border-t border-black/10">
          <summary class="text-xs text-ink/60 cursor-pointer hover:text-gold select-none">
            Veure les {responses.length - 1} respostes anteriors
          </summary>
          <ul class="mt-3 space-y-2 text-xs">
            {responses.slice(1).map((r) => (
              <li class="flex justify-between gap-3 border-b border-black/5 pb-2">
                <span class="text-ink/60">{fmt(r.createdAt)} · {r.packIds.length} pack(s) · {r.extraIds.length} extra(s)</span>
                <span class="text-gold font-bold">{formatEuros(r.totalCents)}</span>
              </li>
            ))}
          </ul>
        </details>
      )}
    </div>
  )}

  {/* Discount + close controls. Visible regardless of whether a response
      came in — Eric may want to apply a referral discount up front. */}
  <div class="bg-white border border-black/10 p-5 mb-8">
    <p class="text-xs font-bold tracking-widest uppercase mb-3">Descompte i estat</p>
    {quote.adminDiscountCents > 0 ? (
      <div class="mb-4 p-3 bg-gold/10 border border-gold/40 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <p class="text-sm"><strong>Descompte actiu:</strong> <span class="text-gold font-bold">−{formatEuros(quote.adminDiscountCents)}</span></p>
          {quote.adminDiscountReason && <p class="text-xs text-ink/65 mt-1">{quote.adminDiscountReason}</p>}
        </div>
        <form method="POST">
          <input type="hidden" name="action" value="clear-discount" />
          <button type="submit" class="text-xs text-red-600 hover:underline">Treure descompte</button>
        </form>
      </div>
    ) : (
      <p class="text-sm text-ink/65 mb-3">No hi ha cap descompte aplicat. Útil per regals, recomanats o ofertes especials.</p>
    )}
    <form method="POST" class="grid sm:grid-cols-[180px_1fr_auto] gap-3 items-end">
      <input type="hidden" name="action" value="set-discount" />
      <div>
        <label for="discount_euros" class="block text-[0.7rem] font-bold uppercase tracking-widest text-ink/60 mb-1">Descompte (€)</label>
        <input
          id="discount_euros"
          name="discount_euros"
          type="text"
          inputmode="decimal"
          placeholder="100"
          value={quote.adminDiscountCents > 0 ? (quote.adminDiscountCents / 100).toString() : ''}
          class="w-full px-3 py-2 border border-black/15 focus:border-gold focus:outline-none"
        />
      </div>
      <div>
        <label for="discount_reason" class="block text-[0.7rem] font-bold uppercase tracking-widest text-ink/60 mb-1">Motiu (opcional, només per a tu)</label>
        <input
          id="discount_reason"
          name="discount_reason"
          type="text"
          placeholder="Ex: recomanació de l'Anna López"
          value={quote.adminDiscountReason ?? ''}
          class="w-full px-3 py-2 border border-black/15 focus:border-gold focus:outline-none"
        />
      </div>
      <button
        type="submit"
        class="bg-gold text-white px-4 py-2 text-xs font-bold tracking-widest uppercase hover:brightness-110 whitespace-nowrap"
      >
        Aplicar
      </button>
    </form>

    <div class="mt-5 pt-4 border-t border-black/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-sm">
        {quote.closedAt ? (
          <span><span class="font-bold text-ink">Pressupost tancat</span> · <span class="text-ink/60">{fmt(quote.closedAt)}</span></span>
        ) : (
          <span class="text-ink/60">Pressupost obert — la parella encara pot enviar configuracions.</span>
        )}
      </p>
      {quote.closedAt ? (
        <form method="POST">
          <input type="hidden" name="action" value="reopen-quote" />
          <button type="submit" class="text-xs bg-ink text-white px-4 py-2 font-bold tracking-widest uppercase hover:bg-gold transition-colors">↻ Reobrir</button>
        </form>
      ) : (
        <form method="POST" onsubmit="return confirm('Tancar el pressupost?\n\nLa parella encara veurà la pàgina i la seva última configuració, però no podrà enviar-ne de noves.')">
          <input type="hidden" name="action" value="close-quote" />
          <button type="submit" class="text-xs bg-ink text-white px-4 py-2 font-bold tracking-widest uppercase hover:bg-gold transition-colors">🔒 Tancar pressupost</button>
        </form>
      )}
    </div>
  </div>

  {lead && (
    <div class="bg-white border border-black/10 p-5 mb-8">
      <p class="text-xs font-bold tracking-widest uppercase mb-3">Respostes del quiz</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
        {lead.weddingDate && (
          <div><span class="text-ink/60">Data boda:</span> <strong>{lead.weddingDate}</strong></div>
        )}
        {lead.location && (
          <div><span class="text-ink/60">Lloc:</span> <strong>{lead.location}</strong></div>
        )}
        {lead.ceremonyType && (
          <div><span class="text-ink/60">Cerimònia:</span> <strong>{lead.ceremonyType}</strong></div>
        )}
        {lead.serviceInterest && (
          <div><span class="text-ink/60">Servei:</span> <strong>{lead.serviceInterest}</strong></div>
        )}
        {lead.budgetRange && (
          <div><span class="text-ink/60">Pressupost:</span> <strong>{lead.budgetRange}</strong></div>
        )}
        {lead.phone && (
          <div><span class="text-ink/60">Telèfon:</span> <strong>{lead.phone}</strong></div>
        )}
      </div>
    </div>
  )}

  <div class="bg-white border border-black/10 mb-8">
    <p class="px-5 py-3 text-xs font-bold tracking-widest uppercase border-b border-black/10">Historial d'esdeveniments</p>
    {events.length === 0 ? (
      <p class="p-5 text-ink/60 text-sm">Encara no hi ha activitat.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="text-[0.7rem] font-bold tracking-widest uppercase bg-cream/50">
          <tr>
            <th class="text-left px-4 py-2">Quan</th>
            <th class="text-left px-4 py-2">Tipus</th>
            <th class="text-right px-4 py-2">Temps</th>
            <th class="text-right px-4 py-2">Scroll</th>
            <th class="text-left px-4 py-2">User-Agent</th>
          </tr>
        </thead>
        <tbody>
          {events.map((e) => (
            <tr class="border-t border-black/5">
              <td class="px-4 py-2 text-ink/70">{fmt(e.createdAt)}</td>
              <td class="px-4 py-2">
                {e.kind === 'view' ? (
                  <span class="text-red-600 font-bold">👁️ view</span>
                ) : (
                  <span class="text-blue-600">⏱️ heartbeat</span>
                )}
              </td>
              <td class="px-4 py-2 text-right">{humanSecs(e.timeOnPage)}</td>
              <td class="px-4 py-2 text-right">{e.maxScroll}%</td>
              <td class="px-4 py-2 text-xs text-ink/50 truncate max-w-xs" title={e.userAgent ?? ''}>{e.userAgent ?? '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-black/10 pt-6">
    <form method="POST" onsubmit="return confirm('Arxivar aquest pressupost? No es veurà al llistat però es pot recuperar.')">
      <input type="hidden" name="action" value="archive" />
      <button type="submit" class="text-xs text-ink/60 hover:text-gold underline">📦 Arxivar</button>
    </form>
    <form method="POST" onsubmit="return confirm('⚠ ELIMINAR aquest pressupost DEFINITIVAMENT?\n\nNo es podrà recuperar.\nFes-ho servir només per netejar proves.')">
      <input type="hidden" name="action" value="delete" />
      <button type="submit" class="text-xs text-red-600 font-bold hover:underline">🗑 Eliminar definitivament</button>
    </form>
  </div>
</AdminLayout>

<script>
  // Send the quote link to the couple's email
  document.querySelectorAll<HTMLButtonElement>('[data-send-quote]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const quoteId = Number(btn.dataset.quoteId);
      const email = btn.dataset.email ?? '';
      const feedback = document.querySelector<HTMLElement>('[data-send-feedback]');
      if (!confirm(`Enviar l'enllaç del pressupost a ${email}?`)) return;
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = 'Enviant…';
      try {
        const res = await fetch('/api/admin/send-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quoteId }),
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        btn.textContent = '✓ Enviat';
        if (feedback) {
          feedback.textContent = `Enviat a ${email} · ` + new Date().toLocaleString('ca-ES');
          feedback.style.color = '#c9a96e';
        }
      } catch (err) {
        console.error(err);
        btn.textContent = old ?? '📧 Enviar';
        if (feedback) {
          feedback.textContent = 'Error enviant. Torna-ho a provar.';
          feedback.style.color = '#b91c1c';
        }
      } finally {
        setTimeout(() => { btn.disabled = false; }, 2000);
      }
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.copy!);
        const old = btn.textContent;
        btn.textContent = '✓ Copiat';
        setTimeout(() => (btn.textContent = old), 1500);
      } catch {
        prompt('Copia:', btn.dataset.copy!);
      }
    });
  });
</script>
