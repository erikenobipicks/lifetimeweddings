---
import AdminLayout from '~/layouts/AdminLayout.astro';
import {
  getQuoteById,
  getQuoteStats,
  getQuoteEvents,
  archiveQuote,
  deleteQuote,
  getLeadByQuoteId,
  listQuoteResponses,
  setAdminDiscount,
  closeQuote,
  reopenQuote,
  setServiceInterest,
  setPreferredLanguage,
  skipQuoteFollowUp,
  restoreQuoteFollowUp,
  markQuoteRejected,
  unmarkQuoteRejected,
  type ServiceInterest,
} from '~/lib/quotes';
import type { Lang } from '~/i18n/ui';
import { PACKS, EXTRAS } from '~/data/packs';
import { calculateSelectionTotals, formatEuros } from '~/lib/pricing';
import { eurosStringToCents } from '~/lib/payments/money';

/** Format a cent amount for the euros <input> so it round-trips losslessly
 *  through eurosStringToCents: plain integer when round, else comma-decimal
 *  (Spanish). Avoids the old bug where "150.5" was re-parsed as 1505. */
function discountInputValue(cents: number): string {
  if (cents <= 0) return '';
  return cents % 100 === 0 ? String(cents / 100) : (cents / 100).toFixed(2).replace('.', ',');
}

const id = Number(Astro.params.id);
if (!Number.isFinite(id)) return Astro.redirect('/admin');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') ?? '');
  if (action === 'archive') {
    await archiveQuote(id);
    return Astro.redirect('/admin');
  }
  if (action === 'delete') {
    try {
      await deleteQuote(id);
      return Astro.redirect('/admin?ok=deleted');
    } catch (err) {
      console.error('[admin.quotes.delete] failed', { quoteId: id, err });
      const msg = err instanceof Error ? err.message : 'error desconegut';
      return Astro.redirect(`/admin/${id}?error=${encodeURIComponent('No s\'ha pogut eliminar: ' + msg)}`);
    }
  }
  if (action === 'set-discount') {
    // Operator-granted discount. Stored as cents; UI takes euros so we
    // parse permissively (commas + dots) before storing.
    const raw = String(form.get('discount_euros') ?? '').trim();
    const reason = String(form.get('discount_reason') ?? '').trim();
    // Spanish/US-aware parser (shared with the booking money math). Returns
    // NaN on junk; empty or unparseable → no discount. Fixes the old bug where
    // a dot-decimal prefill like "150.5" was parsed as 1505 €.
    const parsed = raw ? eurosStringToCents(raw) : 0;
    const cents = Number.isFinite(parsed) && parsed > 0 ? parsed : 0;
    await setAdminDiscount(id, cents, reason || null);
    return Astro.redirect(`/admin/${id}?ok=discount`);
  }
  if (action === 'clear-discount') {
    await setAdminDiscount(id, 0, null);
    return Astro.redirect(`/admin/${id}?ok=discount-cleared`);
  }
  if (action === 'close-quote') {
    await closeQuote(id);
    return Astro.redirect(`/admin/${id}?ok=closed`);
  }
  if (action === 'reopen-quote') {
    await reopenQuote(id);
    return Astro.redirect(`/admin/${id}?ok=reopened`);
  }
  if (action === 'skip-followup') {
    await skipQuoteFollowUp(id);
    return Astro.redirect(`/admin/${id}?ok=followup-skipped`);
  }
  if (action === 'restore-followup') {
    await restoreQuoteFollowUp(id);
    return Astro.redirect(`/admin/${id}?ok=followup-restored`);
  }
  if (action === 'reject-quote') {
    await markQuoteRejected(id);
    return Astro.redirect(`/admin/${id}?ok=rejected`);
  }
  if (action === 'unreject-quote') {
    await unmarkQuoteRejected(id);
    return Astro.redirect(`/admin/${id}?ok=unrejected`);
  }
  if (action === 'set-language') {
    const lRaw = String(form.get('preferred_language') ?? '');
    const l: Lang = lRaw === 'es' || lRaw === 'en' ? lRaw : 'ca';
    await setPreferredLanguage(id, l);
    return Astro.redirect(`/admin/${id}?ok=language-updated`);
  }
  if (action === 'set-service-interest') {
    const siRaw = String(form.get('service_interest') ?? '');
    const si: ServiceInterest = siRaw === 'photo' || siRaw === 'video' || siRaw === 'undecided'
      ? siRaw
      : 'both';
    await setServiceInterest(id, si);
    return Astro.redirect(`/admin/${id}?ok=service-updated`);
  }
}

const quote = await getQuoteById(id);
if (!quote) return Astro.redirect('/admin');

const stats = await getQuoteStats(quote.id);
const events = await getQuoteEvents(quote.id, 100);
const lead = await getLeadByQuoteId(quote.id);
const responses = await listQuoteResponses(quote.id);
const latestResponse = responses[0] ?? null;
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;
const errorMsg = Astro.url.searchParams.get('error');
const okMsg = Astro.url.searchParams.get('ok');
const url = `${siteUrl}/p/${quote.token}`;

const packs = PACKS.filter((p) => quote.packIds.includes(p.id));

// Follow-up reminder eligibility. The button is shown only when there's
// an email + a "sent" stamp; we surface the state ("already sent" /
// "send now" / "still early" / "skipped") so Eric doesn't accidentally
// re-fire and so the cron-disabled state is visible.
const followUpState: 'never_sent' | 'already_sent' | 'skipped' | 'ready' | 'too_early' = (() => {
  if (!quote.coupleEmail) return 'never_sent';
  if (quote.followUpSentAt) return 'already_sent';
  if (quote.followUpSkippedAt) return 'skipped';
  if (!quote.sentAt) return 'never_sent';
  const ageDays = (Date.now() - new Date(quote.sentAt).getTime()) / (1000 * 60 * 60 * 24);
  return ageDays >= 7 ? 'ready' : 'too_early';
})();
const daysSinceSent = quote.sentAt
  ? Math.floor((Date.now() - new Date(quote.sentAt).getTime()) / (1000 * 60 * 60 * 24))
  : null;

// Pre-compute the latest response's totals so the operator sees the
// breakdown without re-doing the math (matches what the couple saw).
const latestTotals = latestResponse
  ? calculateSelectionTotals(latestResponse.packIds, latestResponse.extraIds, quote.adminDiscountCents)
  : null;
function labelForPack(pid: string): string {
  return PACKS.find((p) => p.id === pid)?.name.ca ?? pid;
}
function priceForPackStr(pid: string): string {
  return PACKS.find((p) => p.id === pid)?.price ?? '—';
}
function labelForExtra(xid: string): string {
  return EXTRAS.find((e) => e.id === xid)?.name.ca ?? xid;
}
function priceForExtraStr(xid: string): string {
  return EXTRAS.find((e) => e.id === xid)?.price ?? '—';
}

function fmt(iso: string | null | undefined): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('ca-ES', { timeZone: 'Europe/Madrid', dateStyle: 'short', timeStyle: 'short' });
}

function humanSecs(n: number): string {
  if (n < 60) return `${n}s`;
  const m = Math.floor(n / 60);
  const s = n % 60;
  return `${m}m${s ? ` ${s}s` : ''}`;
}
---

<AdminLayout title={quote.coupleName}>
  {errorMsg && (
    <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-900 text-sm">
      <strong class="font-bold">Error:</strong> {errorMsg}
    </div>
  )}
  {okMsg && (
    <div class="mb-6 px-4 py-3 bg-green-50 border border-green-200 text-green-900 text-sm">
      <strong class="font-bold">✓</strong> {okMsg === 'discount' ? 'Descompte aplicat.' : okMsg === 'discount-cleared' ? 'Descompte eliminat.' : okMsg === 'closed' ? 'Pressupost tancat.' : okMsg === 'reopened' ? 'Pressupost reobert.' : okMsg === 'service-updated' ? 'Servei actualitzat. La parella veurà el configurador filtrat segons aquesta elecció.' : okMsg === 'language-updated' ? 'Idioma actualitzat. La parella veurà la pàgina del pressupost en aquest idioma.' : okMsg === 'followup-skipped' ? 'Recordatori desactivat — el cron ja no l\'enviarà a aquesta parella.' : okMsg === 'followup-restored' ? 'Recordatori restaurat — el cron tornarà a considerar-lo.' : okMsg === 'rejected' ? 'Pressupost marcat com a rebutjat.' : okMsg === 'unrejected' ? 'Rebuig desfet.' : 'Fet.'}
    </div>
  )}
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-6 sm:mb-8">
    <div class="min-w-0">
      <p class="text-xs font-bold tracking-widest uppercase text-gold mb-1">Pressupost</p>
      <h1 class="font-display text-2xl sm:text-3xl font-bold break-words">
        {quote.coupleName}
        {quote.rejectedAt && (
          <span class="align-middle ml-2 inline-block text-[0.6rem] font-bold tracking-widest uppercase px-2 py-1 rounded-sm bg-rose-100 text-rose-700">Rebutjat</span>
        )}
      </h1>
      {quote.coupleEmail && <p class="text-ink/70 break-all">{quote.coupleEmail}</p>}
    </div>
    <a href="/admin" class="text-xs text-ink/70 hover:text-gold whitespace-nowrap">← Tornar</a>
  </div>

  <div class="bg-white border border-line p-5 mb-8">
    <p class="text-xs font-bold tracking-widest uppercase mb-2">Enllaç</p>
    <div class="flex flex-wrap gap-2">
      <input readonly value={url} class="flex-1 min-w-[180px] px-3 py-2 border border-line bg-cream font-mono text-sm" />
      <button type="button" data-copy={url} class="bg-ink text-white px-4 py-2 text-xs font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors whitespace-nowrap">Copiar</button>
      {quote.coupleEmail && (
        <button
          type="button"
          data-send-quote
          data-quote-id={quote.id}
          data-email={quote.coupleEmail}
          class="bg-gold text-ink px-4 py-2 text-xs font-bold tracking-widest uppercase hover:brightness-110 transition"
        >
          📧 Enviar
        </button>
      )}
      {(followUpState === 'ready' || followUpState === 'too_early') && (
        <>
          <button
            type="button"
            data-send-followup
            data-quote-id={quote.id}
            data-email={quote.coupleEmail}
            disabled={followUpState === 'too_early'}
            title={followUpState === 'too_early'
              ? `Es recomanen 7 dies abans del recordatori (en falten ${7 - (daysSinceSent ?? 0)}). Pots disparar-lo igualment si vols.`
              : `Recordatori suau · enllaç enviat fa ${daysSinceSent} dies`}
            class:list={[
              'px-4 py-2 text-xs font-bold tracking-widest uppercase transition border whitespace-nowrap',
              followUpState === 'ready'
                ? 'border-gold text-gold hover:bg-gold hover:text-ink'
                : 'border-ink/15 text-ink/40 cursor-not-allowed',
            ]}
          >
            {followUpState === 'ready'
              ? `📧 Recordatori (${daysSinceSent}d)`
              : `📧 Recordatori (encara és aviat · ${daysSinceSent ?? 0}d)`}
          </button>
          <form method="POST" class="inline" onsubmit="return confirm('Saltar el recordatori automàtic per a aquesta parella?\n\nEl cron ja no els enviarà l\\'email \"checking in\". Útil si ja us han recontactat.')">
            <input type="hidden" name="action" value="skip-followup" />
            <button
              type="submit"
              class="px-4 py-2 text-xs font-bold tracking-widest uppercase transition border border-ink/15 text-ink/70 hover:border-ink/40 hover:text-ink whitespace-nowrap"
              title="Desactivar el recordatori automàtic (útil si la parella ja ha recontactat)"
            >
              🔕 Saltar
            </button>
          </form>
        </>
      )}
      {followUpState === 'skipped' && (
        <span class="flex items-center gap-2 text-xs text-ink/70 px-3 py-2 border border-line bg-cream/50 whitespace-nowrap">
          🔕 Recordatori desactivat {quote.followUpSkippedAt ? `· ${fmt(quote.followUpSkippedAt)}` : ''}
          <form method="POST" class="inline">
            <input type="hidden" name="action" value="restore-followup" />
            <button
              type="submit"
              class="text-gold hover:underline ml-1"
              title="Reactivar el recordatori automàtic"
            >
              ↻ Restaurar
            </button>
          </form>
        </span>
      )}
      {followUpState === 'already_sent' && (
        <span class="text-xs text-ink/70 px-3 py-2 border border-line bg-cream/50 whitespace-nowrap">
          ✓ Recordatori enviat {quote.followUpSentAt ? `· ${fmt(quote.followUpSentAt)}` : ''}
        </span>
      )}
      <a
        href={`/admin/bookings/new?quote=${quote.id}`}
        title="Obre el formulari de nova reserva amb les dades d'aquesta parella precarregades"
        class="border border-ink text-ink px-4 py-2 text-xs font-bold tracking-widest uppercase hover:bg-ink hover:text-white transition whitespace-nowrap"
      >
        → Crear reserva
      </a>
    </div>
    {quote.coupleEmail && (
      <>
        <p class="text-[0.7rem] text-ink/70 mt-2" data-send-feedback></p>
        <p class="text-[0.7rem] text-ink/70" data-followup-feedback></p>
      </>
    )}
    <div class="mt-3 text-xs text-ink/70 flex flex-wrap gap-4">
      <span>Creat: <strong>{fmt(quote.createdAt)}</strong></span>
      {quote.sentAt && <span>Enviat: <strong>{fmt(quote.sentAt)}</strong></span>}
      {quote.createdBy && <span>per <strong>{quote.createdBy}</strong></span>}
      {quote.expiresAt && <span>Caduca: <strong>{fmt(quote.expiresAt)}</strong></span>}
      {quote.hasPassword && <span>🔒 Protegit amb contrasenya</span>}
    </div>
  </div>

  <div class="grid md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white p-5 border border-line text-center">
      <p class="text-xs font-bold tracking-widest uppercase text-ink/70">Visites</p>
      <p class="font-display text-4xl font-bold">{stats.views}</p>
    </div>
    <div class="bg-white p-5 border border-line text-center">
      <p class="text-xs font-bold tracking-widest uppercase text-ink/70">Visitants únics</p>
      <p class="font-display text-4xl font-bold">{stats.uniqueVisitors}</p>
    </div>
    <div class="bg-white p-5 border border-line text-center">
      <p class="text-xs font-bold tracking-widest uppercase text-ink/70">Temps màx.</p>
      <p class="font-display text-4xl font-bold">{humanSecs(stats.totalTimeSeconds)}</p>
    </div>
    <div class="bg-white p-5 border border-line text-center">
      <p class="text-xs font-bold tracking-widest uppercase text-ink/70">Scroll màx.</p>
      <p class="font-display text-4xl font-bold">{stats.maxScroll}%</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 mb-8">
    <div class="bg-white border border-line p-5">
      <p class="text-xs font-bold tracking-widest uppercase mb-3">Packs inclosos</p>
      <ul class="space-y-2 text-sm">
        {packs.map((p) => (
          <li><strong>{p.name.ca}</strong> — <span class="text-gold">{p.price}</span></li>
        ))}
      </ul>
    </div>
    <div class="bg-white border border-line p-5">
      <p class="text-xs font-bold tracking-widest uppercase mb-3">Notes personals</p>
      <p class="text-sm text-ink/80 whitespace-pre-wrap">{quote.notes || '—'}</p>
    </div>
  </div>

  {latestResponse && latestTotals && (
    <div class="bg-white border-2 border-gold p-5 mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase text-gold mb-1">Resposta del client</p>
          <p class="text-xs text-ink/70">Última configuració rebuda · {fmt(latestResponse.createdAt)}{responses.length > 1 && ` · ${responses.length} respostes en total`}</p>
        </div>
        <div class="text-right">
          <p class="text-xs text-ink/70 uppercase tracking-widest">Total que veuen ells</p>
          <p class="font-display text-3xl font-bold text-gold">{formatEuros(latestTotals.totalCents)}</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 mb-4">
        <div>
          <p class="text-[0.7rem] font-bold uppercase tracking-widest text-ink/70 mb-2">Packs triats</p>
          {latestResponse.packIds.length === 0 ? (
            <p class="text-sm text-ink/70 italic">— cap —</p>
          ) : (
            <ul class="text-sm space-y-1">
              {latestResponse.packIds.map((pid) => (
                <li class="flex justify-between gap-3">
                  <span>{labelForPack(pid)}</span>
                  <span class="text-gold whitespace-nowrap">{priceForPackStr(pid)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
        <div>
          <p class="text-[0.7rem] font-bold uppercase tracking-widest text-ink/70 mb-2">Extres triats</p>
          {latestResponse.extraIds.length === 0 ? (
            <p class="text-sm text-ink/70 italic">— cap —</p>
          ) : (
            <ul class="text-sm space-y-1">
              {latestResponse.extraIds.map((xid) => (
                <li class="flex justify-between gap-3">
                  <span>{labelForExtra(xid)}</span>
                  <span class="text-gold whitespace-nowrap">{priceForExtraStr(xid)}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>

      {latestResponse.message && (
        <div class="mb-4 p-3 bg-cream border-l-4 border-gold">
          <p class="text-[0.7rem] font-bold uppercase tracking-widest text-ink/70 mb-1">Missatge de la parella</p>
          <p class="text-sm text-ink/85 whitespace-pre-wrap">{latestResponse.message}</p>
        </div>
      )}

      <div class="text-xs text-ink/70 space-y-0.5 mb-1">
        <p><span class="text-ink/70">Subtotal (packs):</span> <strong>{formatEuros(latestTotals.packsCents)}</strong></p>
        <p><span class="text-ink/70">Subtotal (extres):</span> <strong>{formatEuros(latestTotals.extrasCents)}</strong></p>
        {quote.adminDiscountCents > 0 && (
          <p><span class="text-ink/70">Descompte aplicat:</span> <strong class="text-gold">−{formatEuros(quote.adminDiscountCents)}</strong></p>
        )}
      </div>

      {responses.length > 1 && (
        <details class="mt-4 pt-3 border-t border-line">
          <summary class="text-xs text-ink/70 cursor-pointer hover:text-gold select-none">
            Veure les {responses.length - 1} respostes anteriors
          </summary>
          <ul class="mt-3 space-y-2 text-xs">
            {responses.slice(1).map((r) => (
              <li class="flex justify-between gap-3 border-b border-line pb-2">
                <span class="text-ink/70">{fmt(r.createdAt)} · {r.packIds.length} pack(s) · {r.extraIds.length} extra(s)</span>
                <span class="text-gold font-bold">{formatEuros(r.totalCents)}</span>
              </li>
            ))}
          </ul>
        </details>
      )}
    </div>
  )}

  {/* Service interest — what filter the configurator on /p/<token> uses.
      Defaults to what the lead's quiz answer said; editable here if the
      couple changes their mind. */}
  <div class="bg-white border border-line p-5 mb-8">
    <p class="text-xs font-bold tracking-widest uppercase mb-1">Què volen</p>
    <p class="text-[0.7rem] text-ink/70 mb-3">Filtra el configurador interactiu del pressupost. Si dubten, "encara dubten" — així veuen tot.</p>
    <form method="POST" class="grid grid-cols-2 sm:grid-cols-4 gap-2">
      <input type="hidden" name="action" value="set-service-interest" />
      {[
        { v: 'photo',     label: '📸 Foto' },
        { v: 'video',     label: '🎬 Vídeo' },
        { v: 'both',      label: '💍 Foto + vídeo' },
        { v: 'undecided', label: '🤔 Encara dubten' },
      ].map((opt) => (
        <label class="block">
          <input
            type="radio"
            name="service_interest"
            value={opt.v}
            checked={quote.serviceInterest === opt.v}
            onchange="this.form.requestSubmit()"
            class="sr-only peer"
          />
          <span class="block text-xs font-bold tracking-widest uppercase text-center px-3 py-2 border border-line cursor-pointer hover:border-gold peer-checked:bg-ink peer-checked:text-white peer-checked:border-ink transition-colors">
            {opt.label}
          </span>
        </label>
      ))}
    </form>
  </div>

  {/* Language the couple sees the /p/<token> quote page in. Set at creation
      (from the lead or the new-quote form); editable here for manual /
      personalised quotes where Eric wants to pick it after the fact. */}
  <div class="bg-white border border-line p-5 mb-8">
    <p class="text-xs font-bold tracking-widest uppercase mb-1">Idioma</p>
    <p class="text-[0.7rem] text-ink/70 mb-3">L'idioma en què la parella veurà la pàgina del pressupost.</p>
    <form method="POST" class="grid grid-cols-3 gap-2">
      <input type="hidden" name="action" value="set-language" />
      {[
        { v: 'ca', label: 'Català' },
        { v: 'es', label: 'Castellano' },
        { v: 'en', label: 'English' },
      ].map((opt) => (
        <label class="block">
          <input
            type="radio"
            name="preferred_language"
            value={opt.v}
            checked={quote.preferredLanguage === opt.v}
            onchange="this.form.requestSubmit()"
            class="sr-only peer"
          />
          <span class="block text-xs font-bold tracking-widest uppercase text-center px-3 py-2 border border-line cursor-pointer hover:border-gold peer-checked:bg-ink peer-checked:text-white peer-checked:border-ink transition-colors">
            {opt.label}
          </span>
        </label>
      ))}
    </form>
  </div>

  {/* Discount + close controls. Visible regardless of whether a response
      came in — Eric may want to apply a referral discount up front. */}
  <div class="bg-white border border-line p-5 mb-8">
    <p class="text-xs font-bold tracking-widest uppercase mb-3">Descompte i estat</p>
    {quote.adminDiscountCents > 0 ? (
      <div class="mb-4 p-3 bg-gold/10 border border-gold/40 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <div>
          <p class="text-sm"><strong>Descompte actiu:</strong> <span class="text-gold font-bold">−{formatEuros(quote.adminDiscountCents)}</span></p>
          {quote.adminDiscountReason && <p class="text-xs text-ink/65 mt-1">{quote.adminDiscountReason}</p>}
        </div>
        <form method="POST">
          <input type="hidden" name="action" value="clear-discount" />
          <button type="submit" class="text-xs text-red-600 hover:underline">Treure descompte</button>
        </form>
      </div>
    ) : (
      <p class="text-sm text-ink/65 mb-3">No hi ha cap descompte aplicat. Útil per regals, recomanats o ofertes especials.</p>
    )}
    <form method="POST" class="grid sm:grid-cols-[180px_1fr_auto] gap-3 items-end">
      <input type="hidden" name="action" value="set-discount" />
      <div>
        <label for="discount_euros" class="block text-[0.7rem] font-bold uppercase tracking-widest text-ink/70 mb-1">Descompte (€)</label>
        <input
          id="discount_euros"
          name="discount_euros"
          type="text"
          inputmode="decimal"
          placeholder="100"
          value={discountInputValue(quote.adminDiscountCents)}
          class="w-full px-3 py-2 border border-line focus:border-gold focus:outline-none"
        />
      </div>
      <div>
        <label for="discount_reason" class="block text-[0.7rem] font-bold uppercase tracking-widest text-ink/70 mb-1">Motiu (opcional, només per a tu)</label>
        <input
          id="discount_reason"
          name="discount_reason"
          type="text"
          placeholder="Ex: recomanació de l'Anna López"
          value={quote.adminDiscountReason ?? ''}
          class="w-full px-3 py-2 border border-line focus:border-gold focus:outline-none"
        />
      </div>
      <button
        type="submit"
        class="bg-gold text-ink px-4 py-2 text-xs font-bold tracking-widest uppercase hover:brightness-110 whitespace-nowrap"
      >
        Aplicar
      </button>
    </form>

    <div class="mt-5 pt-4 border-t border-line flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-sm">
        {quote.closedAt ? (
          <span><span class="font-bold text-ink">Pressupost tancat</span> · <span class="text-ink/70">{fmt(quote.closedAt)}</span></span>
        ) : (
          <span class="text-ink/70">Pressupost obert — la parella encara pot enviar configuracions.</span>
        )}
      </p>
      {quote.closedAt ? (
        <form method="POST">
          <input type="hidden" name="action" value="reopen-quote" />
          <button type="submit" class="text-xs bg-ink text-white px-4 py-2 font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors">↻ Reobrir</button>
        </form>
      ) : (
        <form method="POST" onsubmit="return confirm('Tancar el pressupost?\n\nLa parella encara veurà la pàgina i la seva última configuració, però no podrà enviar-ne de noves.')">
          <input type="hidden" name="action" value="close-quote" />
          <button type="submit" class="text-xs bg-ink text-white px-4 py-2 font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors">🔒 Tancar pressupost</button>
        </form>
      )}
    </div>
  </div>

  {lead && (
    <div class="bg-white border border-line p-5 mb-8">
      <p class="text-xs font-bold tracking-widest uppercase mb-3">Respostes del quiz</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 text-sm">
        {lead.weddingDate && (
          <div><span class="text-ink/70">Data boda:</span> <strong>{lead.weddingDate}</strong></div>
        )}
        {lead.location && (
          <div><span class="text-ink/70">Lloc:</span> <strong>{lead.location}</strong></div>
        )}
        {lead.ceremonyType && (
          <div><span class="text-ink/70">Cerimònia:</span> <strong>{lead.ceremonyType}</strong></div>
        )}
        {lead.serviceInterest && (
          <div><span class="text-ink/70">Servei:</span> <strong>{lead.serviceInterest}</strong></div>
        )}
        {lead.budgetRange && (
          <div><span class="text-ink/70">Pressupost:</span> <strong>{lead.budgetRange}</strong></div>
        )}
        {lead.phone && (
          <div><span class="text-ink/70">Telèfon:</span> <strong>{lead.phone}</strong></div>
        )}
      </div>
    </div>
  )}

  <div class="bg-white border border-line mb-8">
    <p class="px-5 py-3 text-xs font-bold tracking-widest uppercase border-b border-line">Historial d'esdeveniments</p>
    {events.length === 0 ? (
      <p class="p-5 text-ink/70 text-sm">Encara no hi ha activitat.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="text-[0.7rem] font-bold tracking-widest uppercase bg-cream/50">
          <tr>
            <th class="text-left px-4 py-2">Quan</th>
            <th class="text-left px-4 py-2">Tipus</th>
            <th class="text-right px-4 py-2">Temps</th>
            <th class="text-right px-4 py-2">Scroll</th>
            <th class="text-left px-4 py-2">User-Agent</th>
          </tr>
        </thead>
        <tbody>
          {events.map((e) => (
            <tr class="border-t border-line">
              <td class="px-4 py-2 text-ink/70">{fmt(e.createdAt)}</td>
              <td class="px-4 py-2">
                {e.kind === 'view' ? (
                  <span class="text-red-600 font-bold">👁️ view</span>
                ) : (
                  <span class="text-blue-600">⏱️ heartbeat</span>
                )}
              </td>
              <td class="px-4 py-2 text-right">{humanSecs(e.timeOnPage)}</td>
              <td class="px-4 py-2 text-right">{e.maxScroll}%</td>
              <td class="px-4 py-2 text-xs text-ink/70 truncate max-w-xs" title={e.userAgent ?? ''}>{e.userAgent ?? '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-line pt-6">
    {quote.rejectedAt ? (
      <form method="POST">
        <input type="hidden" name="action" value="unreject-quote" />
        <button type="submit" class="text-xs text-ink/70 hover:text-gold underline">↩︎ Desfer rebuig</button>
      </form>
    ) : (
      <form method="POST" onsubmit="return confirm('Marcar aquest pressupost com a REBUTJAT?\n\nLa parella ha confirmat que no accepten. Deixarà de rebre el recordatori automàtic i sortirà amb l\\'etiqueta \"Rebutjat\".')">
        <input type="hidden" name="action" value="reject-quote" />
        <button type="submit" class="text-xs text-red-600 hover:underline">✕ Marcar rebutjat</button>
      </form>
    )}
    <form method="POST" onsubmit="return confirm('Arxivar aquest pressupost? No es veurà al llistat però es pot recuperar.')">
      <input type="hidden" name="action" value="archive" />
      <button type="submit" class="text-xs text-ink/70 hover:text-gold underline">📦 Arxivar</button>
    </form>
    <form method="POST" onsubmit="return confirm('⚠ ELIMINAR aquest pressupost DEFINITIVAMENT?\n\nNo es podrà recuperar.\nFes-ho servir només per netejar proves.')">
      <input type="hidden" name="action" value="delete" />
      <button type="submit" class="text-xs text-red-600 font-bold hover:underline">🗑 Eliminar definitivament</button>
    </form>
  </div>
</AdminLayout>

<script>
  // Send the quote link to the couple's email
  document.querySelectorAll<HTMLButtonElement>('[data-send-quote]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const quoteId = Number(btn.dataset.quoteId);
      const email = btn.dataset.email ?? '';
      const feedback = document.querySelector<HTMLElement>('[data-send-feedback]');
      if (!confirm(`Enviar l'enllaç del pressupost a ${email}?`)) return;
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = 'Enviant…';
      try {
        const res = await fetch('/api/admin/send-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quoteId }),
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        btn.textContent = '✓ Enviat';
        if (feedback) {
          feedback.textContent = `Enviat a ${email} · ` + new Date().toLocaleString('ca-ES');
          feedback.style.color = '#c9a96e';
        }
      } catch (err) {
        console.error(err);
        btn.textContent = old ?? '📧 Enviar';
        if (feedback) {
          feedback.textContent = 'Error enviant. Torna-ho a provar.';
          feedback.style.color = '#b91c1c';
        }
      } finally {
        setTimeout(() => { btn.disabled = false; }, 2000);
      }
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.copy!);
        const old = btn.textContent;
        btn.textContent = '✓ Copiat';
        setTimeout(() => (btn.textContent = old), 1500);
      } catch {
        prompt('Copia:', btn.dataset.copy!);
      }
    });
  });

  // Manual 7-day follow-up reminder. Same body as the cron path; the
  // server stamps follow_up_sent_at on success so the cron skips this
  // quote next tick. UI confirms before sending and surfaces ok/err.
  document.querySelectorAll<HTMLButtonElement>('[data-send-followup]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      if (btn.disabled) return;
      const quoteId = Number(btn.dataset.quoteId);
      const email = btn.dataset.email ?? '';
      const feedback = document.querySelector<HTMLElement>('[data-followup-feedback]');
      if (!confirm(`Enviar el recordatori suau a ${email}?\n\nÉs un sol enviament — un cop fet no es repetirà des del cron.`)) return;
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = 'Enviant…';
      try {
        const res = await fetch(`/api/admin/quotes/${quoteId}/follow-up`, { method: 'POST' });
        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          throw new Error(body.error ?? `HTTP ${res.status}`);
        }
        btn.textContent = '✓ Recordatori enviat';
        if (feedback) {
          feedback.textContent = `Recordatori enviat a ${email} · ` + new Date().toLocaleString('ca-ES');
          feedback.style.color = '#c9a96e';
        }
        // Recharge after a moment so the page state ("ja enviat" badge)
        // reflects the new follow_up_sent_at.
        setTimeout(() => window.location.reload(), 1200);
      } catch (err) {
        console.error('[followup] failed', err);
        btn.textContent = old ?? '📧 Recordatori';
        btn.disabled = false;
        if (feedback) {
          feedback.textContent = 'Error enviant el recordatori. Mira els logs.';
          feedback.style.color = '#b91c1c';
        }
      }
    });
  });
</script>
