---
import AdminLayout from '~/layouts/AdminLayout.astro';
import { listLeads, deleteLead, createLead } from '~/lib/quotes';
import type { Lang } from '~/i18n/ui';

// Hard-delete / manual-create via form POST to this same URL. Same pattern
// as /admin/[id] (the quote detail page) so the front-end can use a plain
// <form> with hidden inputs — no JS handler needed.
let createError: string | null = null;
// Preserve posted values on validation failure so the operator doesn't have
// to retype everything (e.g. a missing required email).
let formValues: Record<string, string> = {};
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') ?? '');
  if (action === 'delete') {
    const idRaw = Number(form.get('id') ?? '');
    if (Number.isFinite(idRaw) && idRaw > 0) {
      try {
        await deleteLead(idRaw);
        return Astro.redirect('/admin/leads?ok=deleted');
      } catch (err) {
        console.error('[admin.leads.delete] failed', { id: idRaw, err });
        const msg = err instanceof Error ? err.message : 'error desconegut';
        return Astro.redirect(`/admin/leads?error=${encodeURIComponent('No s\'ha pogut eliminar: ' + msg)}`);
      }
    }
  } else if (action === 'create') {
    const get = (k: string) => String(form.get(k) ?? '').trim();
    formValues = {
      coupleName: get('coupleName'),
      email: get('email'),
      phone: get('phone'),
      weddingDate: get('weddingDate'),
      venueName: get('venueName'),
      location: get('location'),
      ceremonyType: get('ceremonyType'),
      serviceInterest: get('serviceInterest'),
      budgetRange: get('budgetRange'),
      preferredLanguage: get('preferredLanguage') || 'ca',
      notes: get('notes'),
    };
    if (!formValues.coupleName || !formValues.email) {
      createError = 'Cal el nom de la parella i un email de contacte.';
    } else {
      try {
        const { lead, deduplicated } = await createLead({
          coupleName: formValues.coupleName,
          email: formValues.email,
          phone: formValues.phone || undefined,
          weddingDate: formValues.weddingDate || undefined,
          venueName: formValues.venueName || undefined,
          location: formValues.location || undefined,
          ceremonyType: formValues.ceremonyType || undefined,
          serviceInterest: formValues.serviceInterest || undefined,
          budgetRange: formValues.budgetRange || undefined,
          preferredLanguage: formValues.preferredLanguage as Lang,
          notes: formValues.notes || undefined,
        });
        return Astro.redirect(
          `/admin/leads?ok=${deduplicated ? 'deduplicated' : 'created'}#lead-${lead.id}`,
        );
      } catch (err) {
        console.error('[admin.leads.create] failed', { err });
        const msg = err instanceof Error ? err.message : 'error desconegut';
        createError = `No s'ha pogut crear el lead: ${msg}`;
      }
    }
  }
}

const leads = await listLeads();
const okFlag = Astro.url.searchParams.get('ok');
const errorMsg = Astro.url.searchParams.get('error');

function fmt(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('ca-ES', { timeZone: 'Europe/Madrid', dateStyle: 'short', timeStyle: 'short' });
}

const labels: Record<string, string> = {
  tarragona: 'Tarragona/Reus', barcelona: 'Barcelona', lleida: 'Lleida/Girona',
  other_cat: 'Catalunya', international: 'Internacional',
  civil: 'Civil', religious: 'Religiosa', symbolic: 'Simbòlica',
  photo: '📸 Foto', video: '🎬 Vídeo', both: '💍 Ambdós',
  low: '< 1.500 €', mid: '1.500-2.500 €', high: '2.500-3.500 €', premium: '> 3.500 €',
};
---

<AdminLayout title="Leads">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4 sm:mb-6">
    <h1 class="font-display text-2xl sm:text-3xl font-bold">Leads (quiz)</h1>
    <div class="flex items-center gap-3 text-xs">
      <span class="text-ink/70">{leads.length} leads</span>
      <button
        type="button"
        data-test-telegram
        class="border border-line px-3 py-1.5 font-bold tracking-widest uppercase text-ink/70 hover:border-gold hover:text-gold transition-colors whitespace-nowrap"
        title="Envia un missatge de prova al chat de Telegram configurat"
      >
        🧪 Test Telegram
      </button>
      <button
        type="button"
        data-toggle-new-lead
        class="bg-ink text-white px-3 py-1.5 font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors whitespace-nowrap"
      >
        + Nou lead
      </button>
    </div>
  </div>
  <p id="tg-feedback" class="hidden mb-4 px-3 py-2 text-xs border"></p>

  {okFlag === 'deleted' && (
    <div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm">
      ✓ Lead eliminat.
    </div>
  )}
  {okFlag === 'created' && (
    <div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm">
      ✓ Lead creat. Ja el pots convertir en pressupost des de la fila.
    </div>
  )}
  {okFlag === 'deduplicated' && (
    <div class="mb-4 px-4 py-3 bg-amber-50 border border-amber-200 text-amber-900 text-sm">
      ⚠ Ja hi havia un lead amb aquest email en les últimes 24h — s'ha reutilitzat en lloc de duplicar-lo.
    </div>
  )}
  {errorMsg && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-900 text-sm">
      <strong>Error:</strong> {errorMsg}
    </div>
  )}

  {/* Manual lead creation. Hidden by default (toggled by "+ Nou lead");
      auto-opens when a submit left it with an error so the operator's
      input + the message are both visible. */}
  <div id="new-lead-form" class:list={['bg-white border border-line p-5 md:p-6 mb-6', !createError && 'hidden']}>
    <h2 class="font-display text-lg font-bold mb-1">Nou lead manual</h2>
    <p class="text-sm text-ink/70 mb-4">
      Per a consultes rebudes per email, WhatsApp o telèfon (no venen del quiz). Només el nom i l'email són obligatoris.
    </p>
    {createError && (
      <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-900 text-sm">{createError}</div>
    )}
    <form method="POST" class="space-y-4">
      <input type="hidden" name="action" value="create" />
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Nom de la parella *</span>
          <input name="coupleName" required value={formValues.coupleName ?? ''} class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Email *</span>
          <input name="email" type="email" required value={formValues.email ?? ''} class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Telèfon</span>
          <input name="phone" value={formValues.phone ?? ''} class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Data de la boda</span>
          <input name="weddingDate" type="date" value={formValues.weddingDate ?? ''} class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Finca / lloc (text lliure)</span>
          <input name="venueName" value={formValues.venueName ?? ''} placeholder="Ex: El Catllar" class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Zona</span>
          <select name="location" class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none">
            <option value="">— Sense triar —</option>
            <option value="tarragona" selected={formValues.location === 'tarragona'}>Tarragona/Reus</option>
            <option value="barcelona" selected={formValues.location === 'barcelona'}>Barcelona</option>
            <option value="lleida" selected={formValues.location === 'lleida'}>Lleida/Girona</option>
            <option value="other_cat" selected={formValues.location === 'other_cat'}>Catalunya (altres)</option>
            <option value="international" selected={formValues.location === 'international'}>Internacional</option>
          </select>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Tipus de cerimònia</span>
          <select name="ceremonyType" class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none">
            <option value="">— Sense triar —</option>
            <option value="civil" selected={formValues.ceremonyType === 'civil'}>Civil</option>
            <option value="religious" selected={formValues.ceremonyType === 'religious'}>Religiosa</option>
            <option value="symbolic" selected={formValues.ceremonyType === 'symbolic'}>Simbòlica</option>
          </select>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Interès</span>
          <select name="serviceInterest" class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none">
            <option value="">— Sense triar —</option>
            <option value="photo" selected={formValues.serviceInterest === 'photo'}>📸 Foto</option>
            <option value="video" selected={formValues.serviceInterest === 'video'}>🎬 Vídeo</option>
            <option value="both" selected={formValues.serviceInterest === 'both'}>💍 Ambdós</option>
            <option value="undecided" selected={formValues.serviceInterest === 'undecided'}>🤔 Encara no ho saben</option>
          </select>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Pressupost aprox.</span>
          <select name="budgetRange" class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none">
            <option value="">— Sense triar —</option>
            <option value="low" selected={formValues.budgetRange === 'low'}>&lt; 1.500 €</option>
            <option value="mid" selected={formValues.budgetRange === 'mid'}>1.500-2.500 €</option>
            <option value="high" selected={formValues.budgetRange === 'high'}>2.500-3.500 €</option>
            <option value="premium" selected={formValues.budgetRange === 'premium'}>&gt; 3.500 €</option>
          </select>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Idioma</span>
          <select name="preferredLanguage" class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none">
            <option value="ca" selected={(formValues.preferredLanguage ?? 'ca') === 'ca'}>Català</option>
            <option value="es" selected={formValues.preferredLanguage === 'es'}>Castellà</option>
            <option value="en" selected={formValues.preferredLanguage === 'en'}>Anglès</option>
          </select>
        </label>
      </div>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Notes / missatge original</span>
        <textarea name="notes" rows="5" placeholder="Enganxa aquí el missatge original de la consulta." class="mt-1 w-full px-3 py-2 border border-line bg-white focus:border-gold focus:outline-none resize-y">{formValues.notes ?? ''}</textarea>
      </label>
      <button type="submit" class="bg-ink text-white px-5 py-2.5 text-xs font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors">
        Crear lead
      </button>
    </form>
  </div>

  {leads.length === 0 ? (
    <p class="text-ink/70 text-center py-16">Encara no hi ha leads del quiz.</p>
  ) : (
    <>
    {/* Mobile cards. The primary action ("+ Pressupost" or "Veure
        pressupost") is a full-width tappable button at the bottom of
        the card, matching the bookings/quotes pattern. */}
    <ul class="md:hidden space-y-3">
      {leads.map((l) => (
        <li id={`lead-${l.id}`} class="bg-white border border-line scroll-mt-24">
          <div class="p-4">
            <p class="font-bold leading-tight">{l.coupleName}</p>
            <p class="text-[0.7rem] text-ink/70 truncate">{l.email}</p>
            {l.phone && <p class="text-[0.7rem] text-ink/70">{l.phone}</p>}
            <div class="grid grid-cols-2 gap-x-3 gap-y-2 text-[0.7rem] mt-3">
              {l.serviceInterest && <div><span class="text-ink/70">Servei:</span><br/><strong>{labels[l.serviceInterest] ?? l.serviceInterest}</strong></div>}
              {l.ceremonyType && <div><span class="text-ink/70">Cerimònia:</span><br/><strong>{labels[l.ceremonyType] ?? l.ceremonyType}</strong></div>}
              {l.location && <div><span class="text-ink/70">Lloc:</span><br/><strong>{labels[l.location] ?? l.location}</strong>{l.venueName && <span class="block text-ink/70">{l.venueName}</span>}</div>}
              {l.budgetRange && <div><span class="text-ink/70">Pressupost:</span><br/><strong>{labels[l.budgetRange] ?? l.budgetRange}</strong></div>}
              {l.weddingDate && <div><span class="text-ink/70">Data boda:</span><br/><strong>{l.weddingDate}</strong></div>}
              <div><span class="text-ink/70">Rebut:</span><br/><strong>{fmt(l.createdAt)}</strong></div>
            </div>
            {l.notes && (
              <details class="mt-3">
                <summary class="text-[0.7rem] font-bold tracking-widest uppercase text-gold cursor-pointer">Notes / missatge</summary>
                <p class="text-xs text-ink/80 whitespace-pre-wrap mt-2 leading-relaxed">{l.notes}</p>
              </details>
            )}
          </div>
          <div class="flex border-t border-line">
            {l.quoteId ? (
              <a href={`/admin/${l.quoteId}`} class="flex-1 text-center text-gold text-[0.7rem] font-bold tracking-widest uppercase px-4 py-3 hover:bg-cream">
                Veure pressupost →
              </a>
            ) : (
              <a href={`/admin/new?lead=${l.id}`} class="flex-1 text-center bg-ink text-white text-[0.7rem] font-bold tracking-widest uppercase px-4 py-3 hover:bg-gold hover:text-ink transition-colors">
                + Pressupost
              </a>
            )}
            <form
              method="POST"
              class="border-l border-line"
              onsubmit={`return confirm('⚠ Eliminar el lead de ${l.coupleName.replace(/'/g, "\\'")}?\\n\\nNo es podrà recuperar.')`}
            >
              <input type="hidden" name="action" value="delete" />
              <input type="hidden" name="id" value={l.id} />
              <button
                type="submit"
                class="text-red-600 text-[0.7rem] font-bold tracking-widest uppercase px-4 py-3 hover:bg-red-50"
                title="Eliminar definitivament"
              >
                🗑
              </button>
            </form>
          </div>
        </li>
      ))}
    </ul>

    <div class="hidden md:block overflow-x-auto bg-white border border-line">
      <table class="w-full text-sm">
        <thead class="bg-cream text-[0.7rem] font-bold tracking-widest uppercase">
          <tr>
            <th class="text-left px-4 py-3">Parella</th>
            <th class="text-left px-4 py-3">Servei</th>
            <th class="text-left px-4 py-3">Cerimònia</th>
            <th class="text-left px-4 py-3">Lloc</th>
            <th class="text-left px-4 py-3">Pressupost</th>
            <th class="text-left px-4 py-3">Data boda</th>
            <th class="text-left px-4 py-3">Rebut</th>
            <th class="text-right px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {leads.map((l) => (
            <tr id={`lead-${l.id}`} class="border-t border-line hover:bg-cream/50 scroll-mt-24">
              <td class="px-4 py-3">
                <span class="font-bold">{l.coupleName}</span>
                <div class="text-xs text-ink/70">{l.email}</div>
                {l.phone && <div class="text-xs text-ink/70">{l.phone}</div>}
                {l.notes && (
                  <details class="mt-1">
                    <summary class="text-[0.65rem] font-bold tracking-widest uppercase text-gold cursor-pointer">Notes</summary>
                    <p class="text-xs text-ink/80 whitespace-pre-wrap mt-1 leading-relaxed max-w-md">{l.notes}</p>
                  </details>
                )}
              </td>
              <td class="px-4 py-3">{labels[l.serviceInterest ?? ''] ?? l.serviceInterest}</td>
              <td class="px-4 py-3">{labels[l.ceremonyType ?? ''] ?? l.ceremonyType}</td>
              <td class="px-4 py-3">
                {labels[l.location ?? ''] ?? l.location}
                {l.venueName && <div class="text-xs text-ink/70">{l.venueName}</div>}
              </td>
              <td class="px-4 py-3">{labels[l.budgetRange ?? ''] ?? l.budgetRange}</td>
              <td class="px-4 py-3 text-ink/70">{l.weddingDate ?? '—'}</td>
              <td class="px-4 py-3 text-ink/70">{fmt(l.createdAt)}</td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                {l.quoteId ? (
                  <a
                    href={`/admin/${l.quoteId}`}
                    class="text-gold text-xs font-bold tracking-widest uppercase hover:underline mr-3"
                  >
                    Veure pressupost
                  </a>
                ) : (
                  <a
                    href={`/admin/new?lead=${l.id}`}
                    class="inline-block bg-ink text-white text-xs font-bold tracking-widest uppercase px-3 py-1.5 hover:bg-gold hover:text-ink transition-colors mr-3"
                    title="Crea un pressupost pre-rellenat amb les dades d'aquest lead"
                  >
                    + Pressupost
                  </a>
                )}
                <form
                  method="POST"
                  class="inline"
                  onsubmit={`return confirm('⚠ Eliminar el lead de ${l.coupleName.replace(/'/g, "\\'")}?\\n\\nNo es podrà recuperar.')`}
                >
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={l.id} />
                  <button
                    type="submit"
                    class="text-red-600 text-xs font-bold tracking-widest uppercase hover:underline"
                    title="Eliminar definitivament"
                  >
                    🗑
                  </button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    </>
  )}
</AdminLayout>

<script is:inline>
  // Toggle the manual "Nou lead" form. Left open automatically (no
  // `hidden` class) when a submit came back with a validation error, so
  // the button just needs to flip state on click either way.
  (() => {
    const btn = document.querySelector('[data-toggle-new-lead]');
    const panel = document.getElementById('new-lead-form');
    if (!btn || !panel) return;
    btn.addEventListener('click', () => {
      panel.classList.toggle('hidden');
      if (!panel.classList.contains('hidden')) {
        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  })();
</script>

<script is:inline>
  // Test Telegram delivery. Surfaces the exact error (not_configured /
  // http_error / network_error) inline so the operator can fix Railway
  // env vars without digging through logs.
  (() => {
    const btn = document.querySelector('[data-test-telegram]');
    const feedback = document.getElementById('tg-feedback');
    if (!btn || !feedback) return;

    function show(kind, text) {
      feedback.className =
        'mb-4 px-3 py-2 text-xs border ' +
        (kind === 'ok'
          ? 'bg-emerald-50 border-emerald-300 text-emerald-900'
          : 'bg-red-50 border-red-300 text-red-900');
      feedback.textContent = text;
      feedback.classList.remove('hidden');
    }

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      const old = btn.textContent;
      btn.textContent = 'Enviant…';
      try {
        const res = await fetch('/api/admin/test-telegram', { method: 'POST' });
        const data = await res.json().catch(() => ({}));
        if (data.ok) {
          show('ok', '✓ Missatge enviat. Revisa el chat de Telegram.');
        } else if (data.reason === 'not_configured') {
          show(
            'err',
            "⚠ Falten env vars a Railway: TELEGRAM_BOT_TOKEN i/o TELEGRAM_CHAT_ID. Mira la consola del servidor per detalls.",
          );
        } else if (data.reason === 'http_error') {
          show(
            'err',
            '⚠ Telegram ha rebutjat la petició. Resposta: ' + (data.detail || '(sense detall)'),
          );
        } else if (data.reason === 'network_error') {
          show('err', '⚠ Error de xarxa al contactar amb Telegram: ' + (data.detail || ''));
        } else {
          show('err', '⚠ Error desconegut: ' + JSON.stringify(data));
        }
      } catch (err) {
        show('err', '⚠ Error al cridar l\'endpoint: ' + err);
      } finally {
        btn.disabled = false;
        btn.textContent = old;
      }
    });
  })();
</script>
