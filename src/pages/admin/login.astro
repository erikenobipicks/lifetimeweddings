---
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifyCredentials, createSession, isAuthConfigured, getUser } from '~/lib/auth';
import { clientIp } from '~/lib/captcha';

// ─── Brute-force throttle ──────────────────────────────────────────────
// In-memory per-IP attempt counter. Resets on every deploy (acceptable —
// an attacker mid-session loses progress; the legitimate operator after
// a deploy gets 5 fresh attempts). For a single-Railway-instance studio
// this is the right shape; if we ever scale out, move into the DB.
//
// Failed attempts increment; a successful login clears the IP's record.
const LOGIN_MAX_ATTEMPTS = 5;
const LOGIN_WINDOW_MS = 15 * 60 * 1000;
type Attempts = { count: number; resetAt: number };
const loginAttempts: Map<string, Attempts> =
  (globalThis as any).__loginAttempts ?? new Map();
// Persist across HMR reloads in dev so we can verify limit behaviour.
(globalThis as any).__loginAttempts = loginAttempts;

let lastPrune = 0;
function maybePrune() {
  const now = Date.now();
  if (now - lastPrune < 5 * 60 * 1000) return;
  lastPrune = now;
  for (const [ip, rec] of loginAttempts) {
    if (rec.resetAt <= now) loginAttempts.delete(ip);
  }
}

function tooManyAttempts(ip: string): { blocked: boolean; retryInMin?: number } {
  const now = Date.now();
  const rec = loginAttempts.get(ip);
  if (!rec || rec.resetAt <= now) return { blocked: false };
  if (rec.count >= LOGIN_MAX_ATTEMPTS) {
    return { blocked: true, retryInMin: Math.ceil((rec.resetAt - now) / 60000) };
  }
  return { blocked: false };
}

function recordFailedAttempt(ip: string) {
  const now = Date.now();
  const rec = loginAttempts.get(ip);
  if (!rec || rec.resetAt <= now) {
    loginAttempts.set(ip, { count: 1, resetAt: now + LOGIN_WINDOW_MS });
  } else {
    rec.count += 1;
  }
}

function clearAttempts(ip: string) {
  loginAttempts.delete(ip);
}

let error: string | null = null;

// Already logged in? Go to dashboard.
const existing = await getUser(Astro.cookies);
if (existing) return Astro.redirect('/admin');

if (Astro.request.method === 'POST') {
  maybePrune();
  const ip = clientIp(Astro.request) ?? 'unknown';
  const limit = tooManyAttempts(ip);
  if (limit.blocked) {
    // Soft 429: render the form again with a clear "espera N min" message.
    // Don't reveal whether credentials would be valid even if not blocked.
    Astro.response.status = 429;
    error = `Massa intents. Torna a provar d'aquí a ~${limit.retryInMin} min.`;
  } else {
    const form = await Astro.request.formData();
    const user = String(form.get('user') ?? '');
    const password = String(form.get('password') ?? '');
    if (await verifyCredentials(user, password)) {
      clearAttempts(ip);
      await createSession(Astro.cookies, user);
      return Astro.redirect('/admin');
    }
    recordFailedAttempt(ip);
    error = 'Usuari o contrasenya incorrectes.';
  }
}
---

<AdminLayout title="Entrar">
  <div class="max-w-sm mx-auto mt-10 bg-white p-8 border border-black/10">
    <h1 class="font-display text-2xl font-bold mb-6 text-center">Entrar</h1>

    {!isAuthConfigured() && (
      <div class="mb-4 p-3 bg-yellow-50 border border-yellow-200 text-yellow-800 text-xs">
        ⚠️ <strong>ADMIN_PASSWORD_HASH</strong> no configurat. Mira el README per generar un hash i afegir-lo a <code>.env</code>.
      </div>
    )}

    {error && <p class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 text-sm">{error}</p>}

    <form method="POST" class="space-y-4">
      <div>
        <label for="user" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Usuari</label>
        <input id="user" name="user" required autocomplete="username"
               class="w-full px-3 py-2 border border-black/15 focus:border-gold focus:outline-none" />
      </div>
      <div>
        <label for="password" class="block text-xs font-bold tracking-widest uppercase mb-1.5">Contrasenya</label>
        <input id="password" name="password" type="password" required autocomplete="current-password"
               class="w-full px-3 py-2 border border-black/15 focus:border-gold focus:outline-none" />
      </div>
      <button type="submit"
              class="w-full bg-ink text-white py-3 text-xs font-bold tracking-widest uppercase hover:bg-gold transition-colors">
        Entrar
      </button>
    </form>
  </div>
</AdminLayout>
