---
// Admin: form to create a new booking proposal.
// All fields render in a single tall page (this is internal tooling — UX
// optimisation goes to the /reserva pages, not here). On submit posts to
// /api/admin/bookings/create which redirects either to the new detail page
// or back here with ?error=... preserving values.
import AdminLayout from '~/layouts/AdminLayout.astro';
import { publicVideos, fullVideos } from '~/data/videos';
import { PACKS, EXTRAS, getComposedSubpacks } from '~/data/packs';
import { getQuoteById, getLeadByQuoteId, listQuoteResponses } from '~/lib/quotes';
import type { Lang } from '~/i18n/ui';

const params = Astro.url.searchParams;
const error = params.get('error');
// Preserved values from a failed submit: keys prefixed v_<fieldname>.
// Falls back to the ?quote= prefill (built below) so a failed resubmit
// never loses what the operator already corrected.
function v(name: string): string {
  return params.get(`v_${name}`) ?? prefill[name] ?? '';
}

// Parse a formatted EUR string like "1.290 €" or "545 €" to a number.
// PACKS/EXTRAS store prices as display strings — the booking form needs
// euros to seed the numeric inputs.
function eurosFromPriceString(s: string): number {
  const cleaned = s.replace(/[^\d,.-]/g, '').replace(/\.(?=\d{3}\b)/g, '').replace(',', '.');
  const n = Number.parseFloat(cleaned);
  return Number.isFinite(n) ? n : 0;
}

// For combos: build a "fully expanded" includes list per language by
// stitching each sub-pack's includes with its name as a header line,
// then appending the combo's own bullets under "I junts:" / "Y juntos:"
// / "And together:". Mirrors the breakdown the renderer produces on
// /p/<token> so the FotoStudio quote text matches what couples see.
const COMBO_TOGETHER_HEADER: Record<Lang, string> = {
  ca: 'I junts:',
  es: 'Y juntos:',
  en: 'And together:',
};

function expandedIncludes(pack: typeof PACKS[number]): Record<Lang, string[]> {
  const subs = getComposedSubpacks(pack);
  if (subs.length === 0) {
    return pack.includes;
  }
  const out = { ca: [] as string[], es: [] as string[], en: [] as string[] };
  (['ca', 'es', 'en'] as const).forEach((lang) => {
    subs.forEach((sp, i) => {
      if (i > 0) out[lang].push('');
      out[lang].push(`— ${sp.name[lang]} —`);
      out[lang].push(...sp.includes[lang]);
    });
    if (pack.includes[lang].length > 0) {
      out[lang].push('');
      out[lang].push(COMBO_TOGETHER_HEADER[lang]);
      out[lang].push(...pack.includes[lang]);
    }
  });
  return out;
}

// Support ?quote=<id> deep-link from the quote detail page (/admin/[id])
// so the booking form comes pre-filled: couple data from the quote, wedding
// details from the linked lead, and the pack/extras from the couple's own
// configurator response when they submitted one (latest response wins over
// the quote's pack list — it's what they actually picked).
const quoteIdParam = Number(params.get('quote'));
const sourceQuote =
  Number.isFinite(quoteIdParam) && quoteIdParam > 0 ? await getQuoteById(quoteIdParam) : null;
const sourceLead = sourceQuote ? await getLeadByQuoteId(sourceQuote.id) : null;
const sourceResponses = sourceQuote ? await listQuoteResponses(sourceQuote.id) : [];

const prefill: Record<string, string> = {};
if (sourceQuote) {
  // Quotes store the couple as a single string ("Laura i Marc") — split on
  // the usual connectors; if it doesn't split, everything lands on Nom 1
  // and the operator fills Nom 2 (it's a required field anyway).
  const [n1, n2] = sourceQuote.coupleName.split(/\s+(?:i|y|e|and|&|\+)\s+/i);
  prefill.coupleName1 = (n1 ?? '').trim();
  prefill.coupleName2 = (n2 ?? '').trim();
  if (sourceQuote.coupleEmail) prefill.coupleEmailPrimary = sourceQuote.coupleEmail;
  prefill.preferredLanguage = sourceQuote.preferredLanguage;
  if (sourceQuote.flagshipVideoId) prefill.flagshipVideoId = sourceQuote.flagshipVideoId;
  if (sourceLead?.phone) prefill.couplePhonePrimary = sourceLead.phone;
  if (sourceLead?.weddingDate && /^\d{4}-\d{2}-\d{2}$/.test(sourceLead.weddingDate)) {
    prefill.weddingDate = sourceLead.weddingDate;
  }
  if (sourceLead?.venueName) prefill.venueName = sourceLead.venueName;

  const noteLines = [`Creat des del pressupost #${sourceQuote.id} · /p/${sourceQuote.token}`];
  if (sourceQuote.adminDiscountCents > 0) {
    const eur = (sourceQuote.adminDiscountCents / 100).toFixed(0);
    noteLines.push(
      `Descompte aplicat al pressupost: ${eur} €${sourceQuote.adminDiscountReason ? ` (${sourceQuote.adminDiscountReason})` : ''}`,
    );
  }
  if (sourceQuote.notes) noteLines.push(sourceQuote.notes);
  prefill.internalNotes = noteLines.join('\n');

  const latestResponse = [...sourceResponses].sort((a, b) =>
    b.createdAt.localeCompare(a.createdAt),
  )[0];
  const chosenPackIds = latestResponse?.packIds?.length
    ? latestResponse.packIds
    : sourceQuote.packIds;
  const lang = sourceQuote.preferredLanguage;
  // Only auto-fill the pack when the choice is unambiguous; with several
  // packs on the table the operator decides which one becomes the proposal.
  if (chosenPackIds.length === 1) {
    const p = PACKS.find((x) => x.id === chosenPackIds[0]);
    if (p) {
      const priceEuros = eurosFromPriceString(p.price);
      prefill.packName = p.name[lang];
      prefill.packIncludes = expandedIncludes(p)[lang].join('\n');
      prefill.packPriceEuros = String(priceEuros);
      prefill.depositEuros = String(Math.round(priceEuros * 0.3));
    }
  }
  if (latestResponse?.extraIds?.length) {
    prefill.packAddons = latestResponse.extraIds
      .map((xid) => EXTRAS.find((x) => x.id === xid))
      .filter((x): x is (typeof EXTRAS)[number] => Boolean(x))
      .map((x) => `${x.name[lang]} | ${eurosFromPriceString(x.price)}`)
      .join('\n');
  }
}

// Pre-built JSON the client script consumes. Trilingual snapshots of each
// pack's includes + parsed numeric price so the picker can fill the form
// according to the language the operator picked above.
const packCatalog = PACKS.map((p) => ({
  id: p.id,
  name: p.name,
  includes: expandedIncludes(p),
  priceEuros: eurosFromPriceString(p.price),
}));
const extrasCatalog = EXTRAS.map((x) => ({
  id: x.id,
  name: x.name,
  priceEuros: eurosFromPriceString(x.price),
}));
---

<AdminLayout title="Nova reserva">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <h1 class="font-display text-2xl sm:text-3xl font-bold">Nova reserva</h1>
    <a href="/admin/bookings" class="text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold whitespace-nowrap">← Tornar al llistat</a>
  </div>

  {error && (
    <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-800 text-sm">
      <strong class="font-bold">Error:</strong> {error}
    </div>
  )}

  {sourceQuote && (
    <div class="mb-6 px-4 py-3 bg-cream border border-gold/40 text-sm">
      Formulari precarregat des del pressupost
      <a href={`/admin/${sourceQuote.id}`} class="text-gold underline font-bold">#{sourceQuote.id} · {sourceQuote.coupleName}</a>.
      {sourceResponses.length > 0
        ? ' El pack i els extres venen de la configuració que la parella va enviar des de /p.'
        : ' La parella no ha enviat cap configuració — revisa el pack manualment.'}
      Comprova noms, data, venue i preus abans de crear.
    </div>
  )}

  <form method="POST" action="/api/admin/bookings/create" class="space-y-10 bg-white border border-black/10 p-6 md:p-8">

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Parella</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Nom 1 *</span>
          <input name="coupleName1" required value={v('coupleName1')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Nom 2 *</span>
          <input name="coupleName2" required value={v('coupleName2')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Email principal *</span>
          <input type="email" name="coupleEmailPrimary" required value={v('coupleEmailPrimary')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
          <span class="block text-[10px] text-ink/45 mt-1">Cal per enviar el link de /reserva, la confirmació i els formularis de seguiment.</span>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Telèfon</span>
          <input name="couplePhonePrimary" value={v('couplePhonePrimary')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Idioma de la pàgina *</span>
          <select id="preferredLanguageField" name="preferredLanguage" required class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            {[['ca','Català'],['es','Castellano'],['en','English']].map(([code,label]) => (
              <option value={code} selected={v('preferredLanguage') === code || (!v('preferredLanguage') && code === 'ca')}>{label}</option>
            ))}
          </select>
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Boda</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Data *</span>
          <input type="date" name="weddingDate" required value={v('weddingDate')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Venue *</span>
          <input name="venueName" required value={v('venueName')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Ciutat</span>
          <input name="venueCity" value={v('venueCity')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Adreça</span>
          <input name="venueAddress" value={v('venueAddress')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Pack</legend>
      <div class="bg-cream/60 border border-gold/30 p-4 md:p-5">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Carregar des d'un pack del catàleg</span>
          <span class="block text-[11px] text-ink/55 mb-1.5">Omple el nom, els ítems inclosos i el preu/dipòsit (30 %) segons l'idioma de la pàgina. Pots editar-ho després.</span>
          <select id="pack-picker" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="">— Personalitzat (no carregar) —</option>
            {PACKS.map((p) => (
              <option value={p.id}>{p.name.ca} · {p.price}</option>
            ))}
          </select>
        </label>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Nom del pack *</span>
          <input id="packNameField" name="packName" required value={v('packName')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Descripció</span>
          <textarea name="packDescription" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('packDescription')}</textarea>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Què inclou</span>
          <span class="block text-[11px] text-ink/50 mb-1">una línia per ítem</span>
          <textarea id="packIncludesField" name="packIncludes" rows="6" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('packIncludes')}</textarea>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Què no inclou</span>
          <span class="block text-[11px] text-ink/50 mb-1">una línia per ítem</span>
          <textarea name="packExcludes" rows="6" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('packExcludes')}</textarea>
        </label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Add-ons</span>
          <span class="block text-[11px] text-ink/50 mb-1">una línia per ítem · format <code class="bg-cream px-1">Nom | preu_en_euros</code> · ex: <code class="bg-cream px-1">Àlbum 30x30 | 390</code></span>
          <textarea id="packAddonsField" name="packAddons" rows="4" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('packAddons')}</textarea>
        </label>
        <div class="block md:col-span-2 bg-cream/60 border border-gold/30 p-4 md:p-5">
          <p class="text-xs font-bold tracking-widest uppercase text-ink/70">Extres del catàleg</p>
          <p class="text-[11px] text-ink/55 mb-3">Marca'n els que vols incloure i s'afegiran sols a la llista d'add-ons de dalt. Marca <strong>🎁 Regal</strong> per afegir-lo a cost 0 €.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            {EXTRAS.map((x) => (
              <div class="flex items-start gap-2 py-1.5 px-2 hover:bg-white">
                <input id={`extra-${x.id}`} type="checkbox" data-extra-id={x.id} class="extra-toggle mt-1 accent-gold cursor-pointer" />
                <label for={`extra-${x.id}`} class="flex-1 text-sm cursor-pointer">
                  <span class="text-ink">{x.name.ca}</span>
                  <span class="block text-[11px] text-gold font-bold">{x.price}</span>
                </label>
                <label class={`gift-toggle-wrap text-[11px] inline-flex items-center gap-1 px-1.5 py-0.5 rounded cursor-pointer select-none border border-transparent hover:border-gold/40`} data-gift-wrap-for={x.id}>
                  <input type="checkbox" data-gift-id={x.id} class="gift-toggle accent-gold" />
                  <span>🎁 Regal</span>
                </label>
              </div>
            ))}
          </div>
        </div>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Inversió total (€) *</span>
          <input id="packPriceField" name="packPriceEuros" required inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 1500, 1.500, 1500,00 o 1.500,00" value={v('packPriceEuros')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Dipòsit (€) *</span>
          <input id="depositField" name="depositEuros" required inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 500, 500,00 o 1.500,00" value={v('depositEuros')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Termes de pagament</span>
          <input id="paymentTermsField" name="paymentTerms" value={v('paymentTerms')} placeholder="50% en signar, 50% un mes abans" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>

        <div class="block md:col-span-2 bg-cream/60 border border-gold/30 p-4 md:p-5">
          <p class="text-xs font-bold tracking-widest uppercase text-ink/70 mb-1">💶 Calculadora de pagament</p>
          <p class="text-[11px] text-ink/55 mb-3">Suma automàticament <strong>Inversió total + add-ons</strong>. La part en <strong>efectiu</strong> es queda fora de la factura (estalvi del 21 % sobre aquell tram). Apreta el botó <strong>↻</strong> al costat d'un camp per completar-lo amb el que falta. <em>Inserir text al pla de pagament</em> copia el desglossament al camp de dalt.</p>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
            <label class="block">
              <span class="text-[11px] font-bold tracking-wide uppercase text-ink/60">Reserva (€)</span>
              <div class="mt-1 flex">
                <input id="paySchedule0" data-pay-slot="0" type="number" min="0" step="1" class="pay-input flex-1 min-w-0 px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
                <button type="button" data-fill-slot="0" title="Completar amb la diferència" class="pay-fill px-2 border border-l-0 border-black/15 bg-cream hover:bg-gold hover:text-white text-sm transition-colors">↻</button>
              </div>
            </label>
            <label class="block">
              <span class="text-[11px] font-bold tracking-wide uppercase text-ink/60">2n pagament (€)</span>
              <div class="mt-1 flex">
                <input id="paySchedule1" data-pay-slot="1" type="number" min="0" step="1" class="pay-input flex-1 min-w-0 px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
                <button type="button" data-fill-slot="1" title="Completar amb la diferència" class="pay-fill px-2 border border-l-0 border-black/15 bg-cream hover:bg-gold hover:text-white text-sm transition-colors">↻</button>
              </div>
            </label>
            <label class="block">
              <span class="text-[11px] font-bold tracking-wide uppercase text-ink/60">3r pagament (€)</span>
              <div class="mt-1 flex">
                <input id="paySchedule2" data-pay-slot="2" type="number" min="0" step="1" class="pay-input flex-1 min-w-0 px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
                <button type="button" data-fill-slot="2" title="Completar amb la diferència" class="pay-fill px-2 border border-l-0 border-black/15 bg-cream hover:bg-gold hover:text-white text-sm transition-colors">↻</button>
              </div>
            </label>
            <label class="block">
              <span class="text-[11px] font-bold tracking-wide uppercase text-ink/60">En efectiu (€)</span>
              <div class="mt-1 flex">
                <input id="payCash" data-pay-slot="cash" type="number" min="0" step="1" class="pay-input flex-1 min-w-0 px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
                <button type="button" data-fill-slot="cash" title="Completar amb la diferència" class="pay-fill px-2 border border-l-0 border-black/15 bg-cream hover:bg-gold hover:text-white text-sm transition-colors">↻</button>
              </div>
              <span class="block text-[10px] text-ink/45 mt-0.5">tram fora de factura (estalvi IVA)</span>
            </label>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-xs bg-white border border-black/10 p-3">
            <div>
              <p class="text-ink/55">Inversió pack</p>
              <p id="calcPackTotal" class="font-bold text-ink">0 €</p>
            </div>
            <div>
              <p class="text-ink/55">Suma add-ons</p>
              <p id="calcAddonsTotal" class="font-bold text-ink">0 €</p>
            </div>
            <div>
              <p class="text-ink/55">Total amb IVA</p>
              <p id="calcGrossTotal" class="font-bold text-ink">0 €</p>
            </div>
            <div>
              <p class="text-ink/55">Total a cobrar <span class="text-[10px]">(amb efectiu)</span></p>
              <p id="calcNetTotal" class="font-bold text-gold">0 €</p>
            </div>
            <div class="col-span-2 md:col-span-4 text-[10px] text-ink/55 border-t border-black/5 pt-2">
              Base imposable: <span id="calcBase">0 €</span> · IVA 21 %: <span id="calcVat">0 €</span> · Estalvi efectiu: <span id="calcCashSaving">0 €</span>
              · Pagaments programats: <span id="calcScheduled">0 €</span>
              <span id="calcRemaining" class="ml-2 font-bold"></span>
            </div>
          </div>

          <button type="button" id="insertPaymentPlanBtn" class="mt-3 inline-block bg-ink text-white px-3 py-2 text-[11px] font-bold tracking-widest uppercase hover:bg-gold transition-colors">
            Inserir text al pla de pagament
          </button>
        </div>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Personalització</legend>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Intro personalitzada</span>
        <span class="block text-[11px] text-ink/50 mb-1">opcional, sobre l'intro standard del hero</span>
        <textarea name="customIntro" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('customIntro')}</textarea>
      </label>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Notes internes</span>
        <span class="block text-[11px] text-ink/50 mb-1">només per a tu — referrer, acords especials, context. <strong>Mai es mostra a la parella</strong>.</span>
        <textarea name="internalNotes" rows="3" placeholder="ex: ve de part de Maria & Joan (boda 2024) · descompte 10%" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('internalNotes')}</textarea>
      </label>
      <div class="border-t border-black/10 pt-4">
        <p class="text-xs font-bold tracking-widest uppercase text-ink/60 mb-3">Testimoni de referència (opcional)</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="block md:col-span-2">
            <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Quote</span>
            <textarea name="testimonialQuote" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('testimonialQuote')}</textarea>
          </label>
          <label class="block">
            <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Autor</span>
            <input name="testimonialAuthor" value={v('testimonialAuthor')} placeholder="ex: Cristina i Daniel" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Context</span>
            <input name="testimonialContext" value={v('testimonialContext')} placeholder="ex: Mas la Boella, Tarragona" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
          </label>
        </div>
      </div>
      <div class="border-t border-black/10 pt-4">
        <label class="block max-w-md">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Vídeo destacat</span>
          <span class="block text-[11px] text-ink/50 mb-1">opcional · si es deixa buit, s'usa el vídeo per defecte (Elena i Jordi)</span>
          <select name="flagshipVideoId" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="">— Per defecte (Elena i Jordi) —</option>
            <optgroup label="Tràilers">
              {publicVideos.map((vid) => (
                <option value={vid.youtubeId} selected={v('flagshipVideoId') === vid.youtubeId}>
                  {vid.coupleName} · {vid.venue}
                </option>
              ))}
            </optgroup>
            {fullVideos.length > 0 && (
              <optgroup label="Bodes senceres (ocultes a YouTube)">
                {fullVideos.map((vid) => (
                  <option value={vid.youtubeId} selected={v('flagshipVideoId') === vid.youtubeId}>
                    {vid.coupleName} · {vid.venue}{vid.adminNote ? ` · ${vid.adminNote}` : ''}
                  </option>
                ))}
              </optgroup>
            )}
          </select>
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-1">Caramel / Incentiu</legend>
      <p class="text-[11px] text-ink/50 -mt-2 mb-3">opcional · apareix a la proposta per motivar la parella a confirmar. Si queda buit, no es mostra res.</p>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Missatge del caramel</span>
        <span class="block text-[11px] text-ink/50 mb-1">Ex: "Us regalareu una sessió preboda a la llum daurada del delta de l'Ebre, sense cost addicional."</span>
        <textarea name="incentiveBody" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('incentiveBody')}</textarea>
      </label>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Preu original (€) — per tatxar</span>
          <span class="block text-[11px] text-ink/50 mb-1">opcional · si és més gran que la inversió, es mostra tatxat</span>
          <input name="incentiveOriginalPriceEuros" inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 3500 o 3.500,00" value={v('incentiveOriginalPriceEuros')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Data límit de l'oferta</span>
          <span class="block text-[11px] text-ink/50 mb-1">opcional · "vàlid si reserveu abans del…"</span>
          <input type="date" name="incentiveDeadline" value={v('incentiveDeadline')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
      </div>
    </fieldset>

    <fieldset>
      <legend class="font-display text-xl font-bold mb-3">Vigència</legend>
      <label class="block max-w-sm">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Vàlid fins (opcional)</span>
        <input type="date" name="expiresAt" value={v('expiresAt')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
      </label>
    </fieldset>

    <div class="flex items-center gap-4 pt-4 border-t border-black/10">
      <button type="submit" class="bg-ink text-white px-6 py-3 text-xs font-bold tracking-widest uppercase hover:bg-gold transition-colors">
        Crear (estat: draft)
      </button>
      <a href="/admin/bookings" class="text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold">Cancel·lar</a>
    </div>
  </form>

  <script id="pack-catalog-data" type="application/json" set:html={JSON.stringify(packCatalog)} />
  <script id="extras-catalog-data" type="application/json" set:html={JSON.stringify(extrasCatalog)} />
</AdminLayout>

<script>
  type Lang = 'ca' | 'es' | 'en';
  interface PackCatalogItem {
    id: string;
    name: Record<Lang, string>;
    includes: Record<Lang, string[]>;
    priceEuros: number;
  }
  interface ExtraCatalogItem {
    id: string;
    name: Record<Lang, string>;
    priceEuros: number;
  }

  const packs: PackCatalogItem[] = JSON.parse(
    document.getElementById('pack-catalog-data')!.textContent || '[]',
  );
  const extras: ExtraCatalogItem[] = JSON.parse(
    document.getElementById('extras-catalog-data')!.textContent || '[]',
  );

  const picker = document.getElementById('pack-picker') as HTMLSelectElement | null;
  const langSel = document.getElementById('preferredLanguageField') as HTMLSelectElement | null;
  const nameField = document.getElementById('packNameField') as HTMLInputElement | null;
  const includesField = document.getElementById('packIncludesField') as HTMLTextAreaElement | null;
  const priceField = document.getElementById('packPriceField') as HTMLInputElement | null;
  const depositField = document.getElementById('depositField') as HTMLInputElement | null;
  const addonsField = document.getElementById('packAddonsField') as HTMLTextAreaElement | null;

  function currentLang(): Lang {
    const v = (langSel?.value as Lang) || 'ca';
    return v === 'es' || v === 'en' || v === 'ca' ? v : 'ca';
  }

  // Apply a pack catalog entry to the form. Overwrites Name + Includes +
  // Price + Deposit (defaulting to 30 % rounded to whole euros, matching
  // the FAQ payment plan we publish on /p/<token>).
  function applyPack(packId: string) {
    if (!packId) return;
    const p = packs.find((x) => x.id === packId);
    if (!p) return;
    const lang = currentLang();
    if (nameField) nameField.value = p.name[lang];
    if (includesField) includesField.value = p.includes[lang].join('\n');
    if (priceField) priceField.value = String(p.priceEuros);
    if (depositField) depositField.value = String(Math.round(p.priceEuros * 0.3));
    // Recompute the calculator since we just rewrote the price.
    recalcPayment();
  }

  picker?.addEventListener('change', () => applyPack(picker.value));
  // Re-trigger the picker when the language flips so the includes get
  // rewritten in the new language without having to re-pick the pack.
  langSel?.addEventListener('change', () => {
    if (picker?.value) applyPack(picker.value);
  });

  // ─── Extras checkboxes ─────────────────────────────────────────────────
  // Toggle appends/removes "Name | euros" lines in the add-ons textarea.
  // Matching is done by the price-suffix part of the line so renaming the
  // extra in the textarea after-the-fact doesn't break the remove.
  function extraLine(x: ExtraCatalogItem, lang: Lang): string {
    return `${x.name[lang]} | ${x.priceEuros}`;
  }

  function appendLine(textarea: HTMLTextAreaElement, line: string) {
    const cur = textarea.value.replace(/\s+$/, '');
    textarea.value = cur ? `${cur}\n${line}` : line;
  }

  function removeLine(textarea: HTMLTextAreaElement, predicate: (l: string) => boolean) {
    textarea.value = textarea.value
      .split(/\r?\n/)
      .filter((l) => !predicate(l))
      .join('\n');
  }

  // For each extra: lookup its gift-toggle (the small 🎁 checkbox in the
  // same row) so the line we write — and remove — knows whether to use
  // the regular price or 0 €.
  function giftToggleFor(extraId: string): HTMLInputElement | null {
    return document.querySelector<HTMLInputElement>(`input.gift-toggle[data-gift-id="${extraId}"]`);
  }

  // Build the line we'd write for an extra, with or without the gift mark.
  function lineFor(x: ExtraCatalogItem, lang: Lang, asGift: boolean): string {
    return asGift ? `🎁 ${x.name[lang]} (regal) | 0` : `${x.name[lang]} | ${x.priceEuros}`;
  }

  // Remove ANY existing line for this extra (gift or not) — matches both
  // the gift form ("🎁 …| 0") and the paid form ("…| <priceEuros>"). We
  // detect via the price suffix or the leading 🎁 + extra name (CA fallback)
  // so trailing manual edits inside the textarea don't break the remove.
  function removeAnyLineFor(textarea: HTMLTextAreaElement, x: ExtraCatalogItem) {
    const paidSuffix = `| ${x.priceEuros}`;
    const giftSuffix = `| 0`;
    const caGiftPrefix = `🎁 ${x.name.ca}`;
    const esGiftPrefix = `🎁 ${x.name.es}`;
    const enGiftPrefix = `🎁 ${x.name.en}`;
    removeLine(textarea, (l) => {
      const t = l.trim();
      if (t.endsWith(paidSuffix)) return true;
      if (t.endsWith(giftSuffix) && (
        t.startsWith(caGiftPrefix) || t.startsWith(esGiftPrefix) || t.startsWith(enGiftPrefix)
      )) return true;
      return false;
    });
  }

  function applyExtra(extraId: string) {
    if (!addonsField) return;
    const x = extras.find((e) => e.id === extraId);
    if (!x) return;
    const cb = document.querySelector<HTMLInputElement>(`input.extra-toggle[data-extra-id="${extraId}"]`);
    const gift = giftToggleFor(extraId);
    removeAnyLineFor(addonsField, x);
    if (cb?.checked) {
      appendLine(addonsField, lineFor(x, currentLang(), gift?.checked === true));
    }
    recalcPayment();
  }

  document.querySelectorAll<HTMLInputElement>('.extra-toggle').forEach((cb) => {
    cb.addEventListener('change', () => applyExtra(cb.dataset.extraId!));
  });
  document.querySelectorAll<HTMLInputElement>('.gift-toggle').forEach((g) => {
    g.addEventListener('change', () => {
      const id = g.dataset.giftId!;
      // If gifting an unticked extra, tick it implicitly so the line gets
      // written. Untick the gift toggle alone does NOT remove the extra —
      // it just flips it back to the paid price.
      const cb = document.querySelector<HTMLInputElement>(`input.extra-toggle[data-extra-id="${id}"]`);
      if (cb && !cb.checked && g.checked) cb.checked = true;
      applyExtra(id);
    });
  });

  // ─── Payment calculator ────────────────────────────────────────────────
  // gross = pack + addons (IVA included on the invoice we'd issue).
  // cash slice sits OUTSIDE that invoice — couple pays it in cash, we
  // don't invoice it, they save the 21 % VAT we'd have charged on top.
  //   cashSaving = cash * 0.21
  //   net (what they actually hand over) = gross - cashSaving
  //   sched0 + sched1 + sched2 + cash = net
  //     ⇒  sched_sum = gross - cash * 1.21
  //     ⇒  cash = (gross - sched_sum) / 1.21
  // The ↻ buttons solve the missing slot from the other three using
  // those identities.
  const pricePackInput = document.getElementById('packPriceField') as HTMLInputElement | null;
  const addonsTextarea = document.getElementById('packAddonsField') as HTMLTextAreaElement | null;
  const cashInput = document.getElementById('payCash') as HTMLInputElement | null;
  const sched0 = document.getElementById('paySchedule0') as HTMLInputElement | null;
  const sched1 = document.getElementById('paySchedule1') as HTMLInputElement | null;
  const sched2 = document.getElementById('paySchedule2') as HTMLInputElement | null;
  const elPack = document.getElementById('calcPackTotal');
  const elAddons = document.getElementById('calcAddonsTotal');
  const elGross = document.getElementById('calcGrossTotal');
  const elNet = document.getElementById('calcNetTotal');
  const elBase = document.getElementById('calcBase');
  const elVat = document.getElementById('calcVat');
  const elCashSav = document.getElementById('calcCashSaving');
  const elScheduled = document.getElementById('calcScheduled');
  const elRemaining = document.getElementById('calcRemaining');
  const insertBtn = document.getElementById('insertPaymentPlanBtn');

  function parseEuros(s: string | null | undefined): number {
    if (!s) return 0;
    const n = parseFloat(String(s).replace(',', '.'));
    return Number.isFinite(n) ? n : 0;
  }

  function fmt(n: number): string {
    return `${n.toLocaleString('ca-ES', { minimumFractionDigits: 0, maximumFractionDigits: 2 })} €`;
  }

  function sumAddons(): number {
    if (!addonsTextarea) return 0;
    return addonsTextarea.value
      .split(/\r?\n/)
      .map((l) => l.match(/\|\s*(\d+(?:[.,]\d+)?)\s*$/))
      .reduce((acc, m) => acc + (m ? parseEuros(m[1]) : 0), 0);
  }

  function paymentState() {
    const pack = parseEuros(pricePackInput?.value);
    const addons = sumAddons();
    const gross = pack + addons;
    const cash = Math.max(0, parseEuros(cashInput?.value));
    const cashSaving = cash * 0.21;
    const net = gross - cashSaving;
    const s = [
      parseEuros(sched0?.value),
      parseEuros(sched1?.value),
      parseEuros(sched2?.value),
    ];
    const scheduled = s[0] + s[1] + s[2];
    const paid = scheduled + cash;
    // Invoiced portion only — the cash slice falls outside the invoice.
    const invoiced = Math.max(0, gross - cash * 1.21);
    const base = invoiced / 1.21;
    const vat = invoiced - base;
    return { pack, addons, gross, cash, cashSaving, net, s, scheduled, paid, base, vat };
  }

  function recalcPayment() {
    const st = paymentState();
    if (elPack) elPack.textContent = fmt(st.pack);
    if (elAddons) elAddons.textContent = fmt(st.addons);
    if (elGross) elGross.textContent = fmt(st.gross);
    if (elNet) elNet.textContent = fmt(st.net);
    if (elBase) elBase.textContent = fmt(st.base);
    if (elVat) elVat.textContent = fmt(st.vat);
    if (elCashSav) elCashSav.textContent = fmt(st.cashSaving);
    if (elScheduled) elScheduled.textContent = fmt(st.scheduled);
    if (elRemaining) {
      const diff = st.net - st.paid;
      if (st.gross === 0) {
        elRemaining.textContent = '';
        elRemaining.className = 'ml-2 font-bold';
      } else if (Math.abs(diff) < 1) {
        elRemaining.textContent = '✓ quadra';
        elRemaining.className = 'ml-2 font-bold text-green-700';
      } else if (diff > 0) {
        elRemaining.textContent = `Falta ${fmt(diff)}`;
        elRemaining.className = 'ml-2 font-bold text-amber-700';
      } else {
        elRemaining.textContent = `Sobra ${fmt(-diff)}`;
        elRemaining.className = 'ml-2 font-bold text-red-700';
      }
    }
  }

  // Compute the value that would make `slot` close the equation given
  // the current values of the other three. For sched slots this is
  // `gross - cash*1.21 - other_scheds`. For the cash slot it's
  // `(gross - sched_sum) / 1.21`. Result is clamped at 0 and rounded
  // to whole euros (matches how Eric writes the FotoStudio quotes).
  function solveSlot(slot: '0' | '1' | '2' | 'cash'): number {
    const st = paymentState();
    if (slot === 'cash') {
      const v = (st.gross - st.scheduled) / 1.21;
      return Math.max(0, Math.round(v));
    }
    const idx = Number(slot);
    const otherScheds = st.s.reduce((acc, x, i) => (i === idx ? acc : acc + x), 0);
    const v = st.gross - st.cash * 1.21 - otherScheds;
    return Math.max(0, Math.round(v));
  }

  function generatePaymentText(): string {
    const st = paymentState();
    const r = Math.round(st.s[0]);
    const p2 = Math.round(st.s[1]);
    const p3 = Math.round(st.s[2]);
    const cash = Math.round(st.cash);
    const lines: string[] = [];
    if (r > 0) lines.push(`Reserva: ${r} €`);
    if (p2 > 0) lines.push(`2n pagament: ${p2} €`);
    if (p3 > 0) lines.push(`3r pagament: ${p3} €`);
    if (cash > 0) lines.push(`+${cash} € en efectiu (estalvi IVA)`);
    lines.push(`Total: ${Math.round(st.net)} €`);
    return lines.join(' · ');
  }

  [pricePackInput, addonsTextarea, cashInput, sched0, sched1, sched2].forEach((el) => {
    el?.addEventListener('input', recalcPayment);
  });
  // ↻ buttons: each one fills its sibling input with the diff.
  document.querySelectorAll<HTMLButtonElement>('.pay-fill').forEach((btn) => {
    btn.addEventListener('click', () => {
      const slot = btn.dataset.fillSlot as '0' | '1' | '2' | 'cash' | undefined;
      if (!slot) return;
      const target = document.querySelector<HTMLInputElement>(`.pay-input[data-pay-slot="${slot}"]`);
      if (!target) return;
      target.value = String(solveSlot(slot));
      recalcPayment();
    });
  });
  insertBtn?.addEventListener('click', () => {
    const target = document.getElementById('paymentTermsField') as HTMLInputElement | null;
    if (target) target.value = generatePaymentText();
  });
  recalcPayment();
</script>
