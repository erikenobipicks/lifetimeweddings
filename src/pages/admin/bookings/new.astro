---
// Admin: form to create a new booking proposal.
// All fields render in a single tall page (this is internal tooling — UX
// optimisation goes to the /reserva pages, not here). On submit posts to
// /api/admin/bookings/create which redirects either to the new detail page
// or back here with ?error=... preserving values.
import AdminLayout from '~/layouts/AdminLayout.astro';
import PackPaymentTools from '~/components/admin/PackPaymentTools.astro';
import { publicVideos, fullVideos } from '~/data/videos';
import { PACKS, EXTRAS } from '~/data/packs';
import { eurosFromPriceString, expandedIncludes } from '~/lib/admin/packCatalog';
import { getQuoteById, getLeadByQuoteId, listQuoteResponses } from '~/lib/quotes';

const params = Astro.url.searchParams;
const error = params.get('error');
// Preserved values from a failed submit: keys prefixed v_<fieldname>.
// Falls back to the ?quote= prefill (built below) so a failed resubmit
// never loses what the operator already corrected.
function v(name: string): string {
  return params.get(`v_${name}`) ?? prefill[name] ?? '';
}

// Support ?quote=<id> deep-link from the quote detail page (/admin/[id])
// so the booking form comes pre-filled: couple data from the quote, wedding
// details from the linked lead, and the pack/extras from the couple's own
// configurator response when they submitted one (latest response wins over
// the quote's pack list — it's what they actually picked).
const quoteIdParam = Number(params.get('quote'));
const sourceQuote =
  Number.isFinite(quoteIdParam) && quoteIdParam > 0 ? await getQuoteById(quoteIdParam) : null;
const sourceLead = sourceQuote ? await getLeadByQuoteId(sourceQuote.id) : null;
const sourceResponses = sourceQuote ? await listQuoteResponses(sourceQuote.id) : [];

const prefill: Record<string, string> = {};
if (sourceQuote) {
  // Quotes store the couple as a single string ("Laura i Marc") — split on
  // the usual connectors; if it doesn't split, everything lands on Nom 1
  // and the operator fills Nom 2 (it's a required field anyway).
  const [n1, n2] = sourceQuote.coupleName.split(/\s+(?:i|y|e|and|&|\+)\s+/i);
  prefill.coupleName1 = (n1 ?? '').trim();
  prefill.coupleName2 = (n2 ?? '').trim();
  if (sourceQuote.coupleEmail) prefill.coupleEmailPrimary = sourceQuote.coupleEmail;
  prefill.preferredLanguage = sourceQuote.preferredLanguage;
  if (sourceQuote.flagshipVideoId) prefill.flagshipVideoId = sourceQuote.flagshipVideoId;
  if (sourceLead?.phone) prefill.couplePhonePrimary = sourceLead.phone;
  if (sourceLead?.weddingDate && /^\d{4}-\d{2}-\d{2}$/.test(sourceLead.weddingDate)) {
    prefill.weddingDate = sourceLead.weddingDate;
  }
  if (sourceLead?.venueName) prefill.venueName = sourceLead.venueName;

  const noteLines = [`Creat des del pressupost #${sourceQuote.id} · /p/${sourceQuote.token}`];
  if (sourceQuote.adminDiscountCents > 0) {
    const eur = (sourceQuote.adminDiscountCents / 100).toFixed(0);
    noteLines.push(
      `Descompte aplicat al pressupost: ${eur} €${sourceQuote.adminDiscountReason ? ` (${sourceQuote.adminDiscountReason})` : ''}`,
    );
  }
  if (sourceQuote.notes) noteLines.push(sourceQuote.notes);
  prefill.internalNotes = noteLines.join('\n');

  const latestResponse = [...sourceResponses].sort((a, b) =>
    b.createdAt.localeCompare(a.createdAt),
  )[0];
  const chosenPackIds = latestResponse?.packIds?.length
    ? latestResponse.packIds
    : sourceQuote.packIds;
  const lang = sourceQuote.preferredLanguage;
  // Only auto-fill the pack when the choice is unambiguous; with several
  // packs on the table the operator decides which one becomes the proposal.
  if (chosenPackIds.length === 1) {
    const p = PACKS.find((x) => x.id === chosenPackIds[0]);
    if (p) {
      const priceEuros = eurosFromPriceString(p.price);
      prefill.packName = p.name[lang];
      prefill.packIncludes = expandedIncludes(p)[lang].join('\n');
      prefill.packPriceEuros = String(priceEuros);
      prefill.depositEuros = String(Math.round(priceEuros * 0.3));
    }
  }
  if (latestResponse?.extraIds?.length) {
    prefill.packAddons = latestResponse.extraIds
      .map((xid) => EXTRAS.find((x) => x.id === xid))
      .filter((x): x is (typeof EXTRAS)[number] => Boolean(x))
      .map((x) => `${x.name[lang]} | ${eurosFromPriceString(x.price)}`)
      .join('\n');
  }
}
---

<AdminLayout title="Nova reserva">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <h1 class="font-display text-2xl sm:text-3xl font-bold">Nova reserva</h1>
    <a href="/admin/bookings" class="text-xs font-bold tracking-widest uppercase text-ink/70 hover:text-gold whitespace-nowrap">← Tornar al llistat</a>
  </div>

  {error && (
    <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-800 text-sm">
      <strong class="font-bold">Error:</strong> {error}
    </div>
  )}

  {sourceQuote && (
    <div class="mb-6 px-4 py-3 bg-cream border border-gold/40 text-sm">
      Formulari precarregat des del pressupost
      <a href={`/admin/${sourceQuote.id}`} class="text-gold underline font-bold">#{sourceQuote.id} · {sourceQuote.coupleName}</a>.
      {sourceResponses.length > 0
        ? ' El pack i els extres venen de la configuració que la parella va enviar des de /p.'
        : ' La parella no ha enviat cap configuració — revisa el pack manualment.'}
      Comprova noms, data, venue i preus abans de crear.
    </div>
  )}

  <form method="POST" action="/api/admin/bookings/create" class="space-y-10 bg-white border border-black/10 p-6 md:p-8">

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Parella</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Nom 1 *</span>
          <input name="coupleName1" required value={v('coupleName1')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Nom 2 *</span>
          <input name="coupleName2" required value={v('coupleName2')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Email principal *</span>
          <input type="email" name="coupleEmailPrimary" required value={v('coupleEmailPrimary')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
          <span class="block text-[10px] text-ink/45 mt-1">Cal per enviar el link de /reserva, la confirmació i els formularis de seguiment.</span>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Telèfon</span>
          <input name="couplePhonePrimary" value={v('couplePhonePrimary')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Idioma de la pàgina *</span>
          <select id="preferredLanguageField" name="preferredLanguage" required class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            {[['ca','Català'],['es','Castellano'],['en','English']].map(([code,label]) => (
              <option value={code} selected={v('preferredLanguage') === code || (!v('preferredLanguage') && code === 'ca')}>{label}</option>
            ))}
          </select>
        </label>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Procedència</span>
          <input name="source" value={v('source')} placeholder="Instagram, recomanació de…, orgànic" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Tipus de servei</span>
          <select name="serviceType" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="">— Auto (del pack) —</option>
            {[['photo','Només foto'],['video','Només vídeo'],['combo','Foto + vídeo']].map(([code,label]) => (
              <option value={code} selected={v('serviceType') === code}>{label}</option>
            ))}
          </select>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Propietat</span>
          <select name="kind" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            {[['own','LifeTime Weddings'],['collab','LifeTime + col·laborador'],['external','Per a un altre estudi (sense mailing)']].map(([code,label]) => (
              <option value={code} selected={v('kind') === code || (!v('kind') && code === 'own')}>{label}</option>
            ))}
          </select>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Nom (col·laborador / estudi)</span>
          <input name="collaboratorName" value={v('collaboratorName')} placeholder="només si col·laboració o per a un altre estudi" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Boda</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Data *</span>
          <input type="date" name="weddingDate" required value={v('weddingDate')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Venue *</span>
          <input name="venueName" required value={v('venueName')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Ciutat</span>
          <input name="venueCity" value={v('venueCity')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Adreça</span>
          <input name="venueAddress" value={v('venueAddress')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Pack</legend>
      <PackPaymentTools />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Nom del pack *</span>
          <input id="packNameField" name="packName" required value={v('packName')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Descripció</span>
          <textarea name="packDescription" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('packDescription')}</textarea>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Què inclou</span>
          <span class="block text-[11px] text-ink/70 mb-1">una línia per ítem</span>
          <textarea id="packIncludesField" name="packIncludes" rows="6" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('packIncludes')}</textarea>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Què no inclou</span>
          <span class="block text-[11px] text-ink/70 mb-1">una línia per ítem</span>
          <textarea name="packExcludes" rows="6" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('packExcludes')}</textarea>
        </label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Add-ons</span>
          <span class="block text-[11px] text-ink/70 mb-1">una línia per ítem · format <code class="bg-cream px-1">Nom | preu_en_euros</code> · ex: <code class="bg-cream px-1">Àlbum 30x30 | 390</code></span>
          <textarea id="packAddonsField" name="packAddons" rows="4" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{v('packAddons')}</textarea>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Inversió total (€) *</span>
          <input id="packPriceField" name="packPriceEuros" required inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 1500, 1.500, 1500,00 o 1.500,00" value={v('packPriceEuros')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Dipòsit (€) *</span>
          <input id="depositField" name="depositEuros" required inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 500, 500,00 o 1.500,00" value={v('depositEuros')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Termes de pagament</span>
          <input id="paymentTermsField" name="paymentTerms" value={v('paymentTerms')} placeholder="50% en signar, 50% un mes abans" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>

        <div class="block md:col-span-2 border border-gold/40 bg-gold/5 p-4">
          <p class="text-xs font-bold tracking-widest uppercase text-ink/70 mb-3">Descompte (opcional)</p>
          <div class="flex flex-wrap items-end gap-3">
            <div>
              <p class="text-[11px] font-bold tracking-wide uppercase text-ink/70 mb-1">Tipus</p>
              <div class="flex gap-3 text-sm">
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="discountType" value="percent" id="discountTypePct" class="accent-gold" checked={v('discountType') === 'percent'} />
                  <span>%</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="discountType" value="amount" id="discountTypeAmt" class="accent-gold" checked={v('discountType') === 'amount' || !v('discountType')} />
                  <span>€</span>
                </label>
              </div>
            </div>
            <label class="block">
              <span class="text-[11px] font-bold tracking-wide uppercase text-ink/70">Valor</span>
              <input id="discountValueField" name="discountValue" inputmode="decimal" placeholder="0" value={v('discountValue')} class="mt-1 w-28 px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
            </label>
            <p id="discountPreview" class="text-sm text-gold font-semibold self-end pb-2"></p>
          </div>
        </div>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Personalització</legend>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Intro personalitzada</span>
        <span class="block text-[11px] text-ink/70 mb-1">opcional, sobre l'intro standard del hero</span>
        <textarea name="customIntro" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('customIntro')}</textarea>
      </label>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Notes internes</span>
        <span class="block text-[11px] text-ink/70 mb-1">només per a tu — referrer, acords especials, context. <strong>Mai es mostra a la parella</strong>.</span>
        <textarea name="internalNotes" rows="3" placeholder="ex: ve de part de Maria & Joan (boda 2024) · descompte 10%" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('internalNotes')}</textarea>
      </label>
      <div class="border-t border-black/10 pt-4">
        <p class="text-xs font-bold tracking-widest uppercase text-ink/70 mb-3">Testimoni de referència (opcional)</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="block md:col-span-2">
            <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Quote</span>
            <textarea name="testimonialQuote" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('testimonialQuote')}</textarea>
          </label>
          <label class="block">
            <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Autor</span>
            <input name="testimonialAuthor" value={v('testimonialAuthor')} placeholder="ex: Cristina i Daniel" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Context</span>
            <input name="testimonialContext" value={v('testimonialContext')} placeholder="ex: Mas la Boella, Tarragona" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
          </label>
        </div>
      </div>
      <div class="border-t border-black/10 pt-4">
        <label class="block max-w-md">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Vídeo destacat</span>
          <span class="block text-[11px] text-ink/70 mb-1">opcional · si es deixa buit, s'usa el vídeo per defecte (Elena i Jordi)</span>
          <select name="flagshipVideoId" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="">— Per defecte (Elena i Jordi) —</option>
            <optgroup label="Tràilers">
              {publicVideos.map((vid) => (
                <option value={vid.youtubeId} selected={v('flagshipVideoId') === vid.youtubeId}>
                  {vid.coupleName} · {vid.venue}
                </option>
              ))}
            </optgroup>
            {fullVideos.length > 0 && (
              <optgroup label="Bodes senceres (ocultes a YouTube)">
                {fullVideos.map((vid) => (
                  <option value={vid.youtubeId} selected={v('flagshipVideoId') === vid.youtubeId}>
                    {vid.coupleName} · {vid.venue}{vid.adminNote ? ` · ${vid.adminNote}` : ''}
                  </option>
                ))}
              </optgroup>
            )}
          </select>
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-1">Caramel / Incentiu</legend>
      <p class="text-[11px] text-ink/70 -mt-2 mb-3">opcional · apareix a la proposta per motivar la parella a confirmar. Si queda buit, no es mostra res.</p>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Missatge del caramel</span>
        <span class="block text-[11px] text-ink/70 mb-1">Ex: "Us regalareu una sessió preboda a la llum daurada del delta de l'Ebre, sense cost addicional."</span>
        <textarea name="incentiveBody" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{v('incentiveBody')}</textarea>
      </label>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Preu original (€) — per tatxar</span>
          <span class="block text-[11px] text-ink/70 mb-1">opcional · si és més gran que la inversió, es mostra tatxat</span>
          <input name="incentiveOriginalPriceEuros" inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 3500 o 3.500,00" value={v('incentiveOriginalPriceEuros')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Data límit de l'oferta</span>
          <span class="block text-[11px] text-ink/70 mb-1">opcional · "vàlid si reserveu abans del…"</span>
          <input type="date" name="incentiveDeadline" value={v('incentiveDeadline')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
      </div>
    </fieldset>

    <fieldset>
      <legend class="font-display text-xl font-bold mb-3">Vigència</legend>
      <label class="block max-w-sm">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Vàlid fins (opcional)</span>
        <input type="date" name="expiresAt" value={v('expiresAt')} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
      </label>
    </fieldset>

    <div class="flex items-center gap-4 pt-4 border-t border-black/10">
      <button type="submit" class="bg-ink text-white px-6 py-3 text-xs font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors">
        Crear (estat: draft)
      </button>
      <a href="/admin/bookings" class="text-xs font-bold tracking-widest uppercase text-ink/70 hover:text-gold">Cancel·lar</a>
    </div>
  </form>

</AdminLayout>

<script>
  // The pack picker / extras / payment calculator live in the shared
  // <PackPaymentTools> component. This page only keeps the discount live
  // preview (it reads the same #packPriceField the component writes to).
  // Discount math comes from ~/lib/payments/money (single source of truth).
  import { parseEurosLoose, computeDiscountEuros, formatEurosAmount } from '~/lib/payments/money';

  const discountValueInput = document.getElementById('discountValueField') as HTMLInputElement | null;
  const discountPreviewEl = document.getElementById('discountPreview');
  const priceField = document.getElementById('packPriceField') as HTMLInputElement | null;
  function updateDiscountPreview() {
    const typeEl = document.querySelector<HTMLInputElement>('input[name="discountType"]:checked');
    const packEuros = parseEurosLoose(priceField?.value);
    const discount = computeDiscountEuros(typeEl?.value ?? 'amount', discountValueInput?.value, packEuros);
    if (discount <= 0 || packEuros <= 0) {
      if (discountPreviewEl) discountPreviewEl.textContent = '';
      return;
    }
    if (discountPreviewEl) {
      discountPreviewEl.textContent = `−${formatEurosAmount(discount)} · efectiu: ${formatEurosAmount(packEuros - discount)}`;
    }
  }
  discountValueInput?.addEventListener('input', updateDiscountPreview);
  document.querySelectorAll<HTMLInputElement>('input[name="discountType"]').forEach((r) => r.addEventListener('change', updateDiscountPreview));
  priceField?.addEventListener('input', updateDiscountPreview);
  updateDiscountPreview();
</script>
