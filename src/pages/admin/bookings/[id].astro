---
// Admin: detail and edit view for a single booking. The page is split:
//   - Top sidebar: status, public URL with copy button, status transitions,
//     archive button, summary metadata.
//   - Main: full edit form posting to /api/admin/bookings/[id]/update with
//     _action=update.
//   - Bottom: form_response display if the couple already submitted.
import AdminLayout from '~/layouts/AdminLayout.astro';
import { getBookingById, getFormResponseForBooking } from '~/lib/bookings/repository';
import type { BookingStatus } from '~/lib/bookings/types';
import { publicVideos, fullVideos } from '~/data/videos';
import { getBankTransferDetails, isStripeTestMode } from '~/lib/payments/config';
import { listSchedulesForBooking, listSequences } from '~/lib/bookings/sequences';
import { googleCalendarAddUrl } from '~/lib/bookings/gcal';
import { filterChecklistForPack } from '~/data/bookingChecklist';

const id = Astro.params.id!;
const booking = await getBookingById(id);
if (!booking) return new Response('Not found', { status: 404 });

const formResponse = await getFormResponseForBooking(booking.id);

const params = Astro.url.searchParams;
const ok = params.get('ok');
const err = params.get('error');

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;
const publicUrl = `${siteUrl}/reserva/${booking.slug}`;
const contratoUrl = `${siteUrl}/contrato/${booking.slug}`;

// Workflow checklist: catalogue filtered to items relevant to what's
// been contracted (photo-only packs hide video/SDE items, etc.). The
// "fets" counter in the section header includes deposit + contract for
// a single Done/Total number across the whole post-booking flow.
const visibleChecklist = filterChecklistForPack(booking.packName);
const tickedCount =
  (booking.depositPaidAt ? 1 : 0) +
  (booking.contractAcceptedAt ? 1 : 0) +
  visibleChecklist.filter((i) => booking.checklistState[i.key]).length;

// Email-sequence queue for this booking. Each row maps to a sequence
// template via sequenceId; we join them in-memory for the table.
const schedules = await listSchedulesForBooking(booking.id);
const allSequences = await listSequences(true);
const sequencesById = new Map(allSequences.map((s) => [s.id, s] as const));

// Pre-filled Google Calendar "Add event" URL for this booking. Opens
// the operator's calendar with title/location/details/dates ready —
// just hits Save. Uses ceremony times from the form_response when known.
const gcalUrl = googleCalendarAddUrl({
  booking,
  formResponse,
  adminUrl: `${siteUrl}/admin/bookings/${booking.id}`,
});

const STATUS_LABEL: Record<BookingStatus, string> = {
  draft: 'Draft',
  sent: 'Enviat',
  viewed: 'Vist',
  form_submitted: 'Reservat',
  archived: 'Arxivat',
};
const STATUS_BADGE: Record<BookingStatus, string> = {
  draft: 'bg-gray-100 text-gray-700',
  sent: 'bg-blue-100 text-blue-700',
  viewed: 'bg-amber-100 text-amber-800',
  form_submitted: 'bg-emerald-100 text-emerald-800',
  archived: 'bg-gray-200 text-gray-500',
};

const eurosFromCents = (c: number): string => (c / 100).toFixed(0);
const yyyymmdd = (d: Date | null): string => (d ? d.toISOString().slice(0, 10) : '');
const fmtDateTime = (d: Date | null): string => {
  if (!d) return '—';
  return d.toLocaleString('ca-ES', { timeZone: 'Europe/Madrid', dateStyle: 'short', timeStyle: 'short' });
};

const includesText = booking.packIncludes.join('\n');
const excludesText = booking.packExcludes.join('\n');
const addonsText = booking.packAddons
  .map((a) => `${a.name} | ${eurosFromCents(a.price_cents)}`)
  .join('\n');

const couple = `${booking.coupleName1} & ${booking.coupleName2}`;
const t = booking.referenceTestimonial;

// Payment-config warnings: surface in admin so we never accidentally ship
// a test Stripe key or the placeholder IBAN to a real couple.
const stripeTest = isStripeTestMode();
const transfer = getBankTransferDetails();
const ibanPlaceholder = transfer.isPlaceholder;
---

<AdminLayout title={`Reserva · ${couple}`}>
  {(stripeTest || ibanPlaceholder) && (
    <div class="mb-6 space-y-2">
      {stripeTest && (
        <div class="px-4 py-3 bg-amber-50 border border-amber-300 text-amber-900 text-sm">
          <strong class="font-bold">⚠ Stripe en mode TEST.</strong> Els pagaments amb targeta no es cobraran realment. Posa la clau <code>sk_live_…</code> a Railway abans de cobrar de veritat.
        </div>
      )}
      {ibanPlaceholder && (
        <div class="px-4 py-3 bg-amber-50 border border-amber-300 text-amber-900 text-sm">
          <strong class="font-bold">⚠ IBAN no configurat.</strong> Es mostra a la parella un IBAN fals (<code>ES00 …</code>). Posa <code>BANK_TRANSFER_IBAN</code> a Railway abans d'enviar la URL de la reserva.
        </div>
      )}
    </div>
  )}
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-6">
    <div class="min-w-0">
      <a href="/admin/bookings" class="text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold">← Llistat</a>
      <h1 class="font-display text-2xl sm:text-3xl font-bold mt-1 break-words">{couple}</h1>
    </div>
    <span class:list={['inline-block self-start sm:self-auto text-xs font-bold tracking-widest uppercase px-3 py-1.5 whitespace-nowrap', STATUS_BADGE[booking.status]]}>
      {STATUS_LABEL[booking.status]}
    </span>
  </div>

  {ok && (
    <div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm">
      {ok === 'created' && 'Reserva creada correctament.'}
      {ok === 'updated' && 'Canvis desats.'}
      {ok?.startsWith('status:') && `Estat actualitzat a ${ok.split(':')[1]}.`}
      {ok === 'deposit:paid' && 'Dipòsit marcat com a rebut. La parella ja pot omplir /contrato.'}
      {ok === 'deposit:unpaid' && 'Marca de dipòsit retirada.'}
      {ok === 'offline_confirmed' && 'Booking confirmat offline. Ja podeu enviar la URL /contrato a la parella (la veieu al bloc verd més avall).'}
      {ok === 'offline_silent' && 'Boda històrica registrada (mode silenciós). Dipòsit marcat com a pagat. No s\'ha emès factura ni s\'ha enviat email a la parella.'}
      {ok === 'form:sent' && 'Formulari enviat a la parella. (Mira la cola més avall per veure l\'estat.)'}
      {ok === 'schedule:cancelled' && 'Email programat cancel·lat.'}
      {ok === 'schedule:sent' && 'Email forçat. Mira la cola per veure l\'estat.'}
      {ok === 'schedule:reactivated' && 'Email reactivat.'}
    </div>
  )}
  {err && (
    <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 text-sm">
      <strong>Error:</strong> {err}
    </div>
  )}

  <!-- Sidebar: URL + accions ràpides -->
  <div class="bg-white border border-black/10 p-5 mb-6">
    <!-- Row 1: URL (full width) + copy/open -->
    <div class="flex items-start gap-3 mb-4">
      <div class="flex-1 min-w-0">
        <p class="text-[11px] font-bold tracking-widest uppercase text-ink/50 mb-1">URL pública</p>
        <a
          href={publicUrl}
          target="_blank"
          rel="noopener"
          class="text-sm text-ink/70 underline decoration-dotted underline-offset-2 break-all hover:text-gold"
        >{publicUrl}</a>
      </div>
      <div class="flex gap-2 flex-shrink-0 mt-5">
        <button
          type="button"
          data-copy={publicUrl}
          class="bg-gold text-ink text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-ink hover:text-white transition-colors whitespace-nowrap"
        >Copiar</button>
        <a
          href={publicUrl}
          target="_blank"
          rel="noopener"
          class="border border-black/15 text-xs font-bold tracking-widest uppercase px-4 py-2 hover:border-gold hover:text-gold transition-colors whitespace-nowrap"
        >Obrir →</a>
      </div>
    </div>

    <!-- Row 2: status actions -->
    <div class="flex flex-wrap gap-2">
      {booking.status === 'draft' && (
        <>
          <!-- Primary: mark sent AND send email -->
          <form method="POST" action={`/api/admin/bookings/${booking.id}/update`} class="inline">
            <input type="hidden" name="_action" value="status" />
            <input type="hidden" name="status" value="sent" />
            <input type="hidden" name="send_email" value="1" />
            <button type="submit" class="bg-blue-600 text-white text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-blue-700 transition-colors whitespace-nowrap">
              Marcar com a enviat + enviar email
            </button>
          </form>
          <!-- Secondary: mark sent without email -->
          <form method="POST" action={`/api/admin/bookings/${booking.id}/update`} class="inline">
            <input type="hidden" name="_action" value="status" />
            <input type="hidden" name="status" value="sent" />
            <button type="submit" class="border border-blue-400 text-blue-600 text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-blue-50 transition-colors whitespace-nowrap">
              Marcar com a enviat (sense email)
            </button>
          </form>
          <a
            href={`/admin/bookings/${booking.id}/confirm-offline`}
            class="border border-emerald-300 text-emerald-700 text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-emerald-50 transition-colors whitespace-nowrap"
            title="Per a bodes ja contractades fora del flux web: salta /reserva i obre /contrato directament"
          >
            Confirmar offline →
          </a>
        </>
      )}

      {booking.status !== 'archived' && (
        <form method="POST" action={`/api/admin/bookings/${booking.id}/update`} class="inline" onsubmit="return confirm('Arxivar aquesta reserva? La pàgina pública deixarà de servir-se però es pot recuperar.')">
          <input type="hidden" name="_action" value="status" />
          <input type="hidden" name="status" value="archived" />
          <button type="submit" class="border border-red-300 text-red-700 text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-red-50 transition-colors whitespace-nowrap">
            Arxivar
          </button>
        </form>
      )}
      <a
        href={gcalUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 border border-blue-300 text-blue-700 text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-blue-50 transition-colors whitespace-nowrap"
        title="Afegir aquesta boda al teu Google Calendar amb totes les dades pre-omplertes"
      >
        📅 Google Calendar
      </a>
      <form method="POST" action={`/api/admin/bookings/${booking.id}/update`} class="inline" onsubmit="return confirm('⚠ ELIMINAR aquesta reserva DEFINITIVAMENT?\n\nNo es podrà recuperar. També s\'esborraran les dades de la parella i el contracte.\n\nFes-ho servir només per netejar proves.')">
        <input type="hidden" name="_action" value="delete" />
        <button type="submit" class="border-2 border-red-600 text-red-600 text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-red-600 hover:text-white transition-colors whitespace-nowrap">
          Eliminar definitivament
        </button>
      </form>
    </div>
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-5 pt-5 border-t border-black/10 text-xs">
      <div><dt class="text-ink/50 mb-1">Creat</dt><dd>{fmtDateTime(booking.createdAt)}</dd></div>
      <div><dt class="text-ink/50 mb-1">Actualitzat</dt><dd>{fmtDateTime(booking.updatedAt)}</dd></div>
      <div><dt class="text-ink/50 mb-1">Primera vista</dt><dd>{fmtDateTime(booking.firstViewedAt)}</dd></div>
      <div><dt class="text-ink/50 mb-1">Form enviat</dt><dd>{fmtDateTime(booking.formSubmittedAt)}</dd></div>
    </dl>
  </div>

  <!-- Sidebar: gestió del flux /contrato (només visible un cop la parella
       ha enviat /reserva; abans no té sentit) -->
  {booking.status === 'form_submitted' && (
    <div class="bg-white border border-black/10 p-5 mb-6">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mb-4">
        <div>
          <p class="text-[11px] font-bold tracking-widest uppercase text-ink/50 mb-1">Flux post-dipòsit</p>
          <h3 class="font-display text-lg font-bold">Contracte (/contrato)</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          <button
            type="button"
            data-resend-confirmation
            data-booking-id={booking.id}
            class="border border-ink/20 text-ink text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-cream transition-colors"
            title="Tornar a enviar l'email de confirmació amb el CTA de tarjeta (útil si la configuració de Stripe ha canviat des de l'original)"
          >
            📧 Reenviar confirmació
          </button>
          <button
            type="button"
            data-push-to-sheet
            data-booking-id={booking.id}
            class="border border-ink/20 text-ink text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-cream transition-colors"
            title="Pujar (o re-pujar) aquesta reserva al Google Sheet de bodes"
          >
            📊 Pujar al Sheet
          </button>
          <button
            type="button"
            data-resend-telegram
            data-booking-id={booking.id}
            class="border border-ink/20 text-ink text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-cream transition-colors"
            title="Reenviar el missatge de Telegram amb el nom suggerit del grup WhatsApp i els enllaços wa.me"
          >
            💬 Reenviar Telegram
          </button>
          {booking.depositPaidAt ? (
            <form method="POST" action={`/api/admin/bookings/${booking.id}/update`} class="inline" onsubmit="return confirm('Desmarcar el dipòsit? La pàgina /contrato deixarà de ser accessible per a la parella i les dades ja enviades es perdran.')">
              <input type="hidden" name="_action" value="deposit_unpaid" />
              <button type="submit" class="border border-red-300 text-red-700 text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-red-50 transition-colors">
                Desmarcar dipòsit
              </button>
            </form>
          ) : (
            <form method="POST" action={`/api/admin/bookings/${booking.id}/update`} class="inline">
              <input type="hidden" name="_action" value="deposit_paid" />
              <button type="submit" class="bg-emerald-600 text-white text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-emerald-700 transition-colors">
                Marcar dipòsit rebut
              </button>
            </form>
          )}
        </div>
      </div>

      <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="text-[11px] font-bold tracking-widest uppercase text-ink/50 mb-1">Dipòsit</dt>
          <dd>
            {booking.depositPaidAt
              ? <span class="text-emerald-700 font-semibold">✓ Rebut · {fmtDateTime(booking.depositPaidAt)}</span>
              : <span class="text-ink/50">Pendent</span>}
          </dd>
        </div>
        <div>
          <dt class="text-[11px] font-bold tracking-widest uppercase text-ink/50 mb-1">Contracte enviat per la parella</dt>
          <dd>
            {booking.contractReadyAt
              ? <span class="text-emerald-700 font-semibold">✓ {fmtDateTime(booking.contractReadyAt)}</span>
              : booking.depositPaidAt
                ? <span class="text-ink/50">Esperant que la parella ompli /contrato</span>
                : <span class="text-ink/30">—</span>}
          </dd>
        </div>
      </dl>

      {booking.depositPaidAt && (
        <div class="mt-4 pt-4 border-t border-black/10">
          <div class="flex flex-col md:flex-row md:items-center gap-3">
            <div class="flex-1 min-w-0">
              <p class="text-[11px] font-bold tracking-widest uppercase text-ink/50 mb-1">URL /contrato per a la parella</p>
              <code class="text-sm break-all text-ink/80">{contratoUrl}</code>
            </div>
            <div class="flex flex-wrap gap-2">
              <button
                type="button"
                data-copy={contratoUrl}
                class="bg-gold text-ink text-xs font-bold tracking-widest uppercase px-4 py-2 hover:bg-ink hover:text-white transition-colors"
              >Copiar</button>
              <a
                href={contratoUrl}
                target="_blank"
                rel="noopener"
                class="border border-black/15 text-xs font-bold tracking-widest uppercase px-4 py-2 hover:border-gold hover:text-gold transition-colors"
              >Obrir →</a>
            </div>
          </div>
        </div>
      )}
    </div>
  )}

  {/* Workflow checklist — shown once the booking has form-submitted (we
      have a couple to track), filtered to the items relevant to what's
      been contracted (photo / video / combo). The deposit + contract
      checks are sourced from the booking columns (read-only) for a
      single unified view of the post-booking flow. */}
  {booking.status === 'form_submitted' && (
    <section class="bg-white border border-black/10 p-5 md:p-6 mb-6">
      <div class="flex items-center justify-between gap-3 mb-4">
        <h2 class="font-display text-xl font-bold">Seguiment de la boda</h2>
        <span class="text-[11px] font-bold tracking-widest uppercase text-ink/50">
          {tickedCount} / {visibleChecklist.length + 2} fets
        </span>
      </div>
      <ul class="space-y-2">
        <li class="flex items-start gap-3 px-3 py-2 bg-cream/50">
          <span class={`text-base leading-none mt-0.5 ${booking.depositPaidAt ? 'text-emerald-600' : 'text-ink/30'}`}>
            {booking.depositPaidAt ? '✓' : '○'}
          </span>
          <div class="flex-1">
            <p class="text-sm"><strong>Dipòsit rebut</strong></p>
            {booking.depositPaidAt && (
              <p class="text-[11px] text-ink/55 mt-0.5">{fmtDateTime(booking.depositPaidAt)}</p>
            )}
          </div>
        </li>
        <li class="flex items-start gap-3 px-3 py-2 bg-cream/50">
          <span class={`text-base leading-none mt-0.5 ${booking.contractAcceptedAt ? 'text-emerald-600' : 'text-ink/30'}`}>
            {booking.contractAcceptedAt ? '✓' : '○'}
          </span>
          <div class="flex-1">
            <p class="text-sm"><strong>Contracte signat per la parella</strong></p>
            {booking.contractAcceptedAt && (
              <p class="text-[11px] text-ink/55 mt-0.5">{fmtDateTime(booking.contractAcceptedAt)}</p>
            )}
          </div>
        </li>
        {visibleChecklist.map((item) => {
          const ts = booking.checklistState[item.key];
          return (
            <li class="flex items-start gap-3 px-3 py-2 hover:bg-cream/30">
              <button
                type="button"
                data-checklist-toggle
                data-booking-id={booking.id}
                data-key={item.key}
                aria-pressed={ts ? 'true' : 'false'}
                class={`shrink-0 mt-0.5 w-5 h-5 border-2 flex items-center justify-center transition-colors ${ts ? 'bg-emerald-600 border-emerald-600 text-white' : 'border-ink/30 hover:border-gold'}`}
              >
                <span class="text-xs font-bold leading-none">{ts ? '✓' : ''}</span>
              </button>
              <div class="flex-1">
                <p class="text-sm"><strong>{item.label}</strong></p>
                {ts && (
                  <p class="text-[11px] text-ink/55 mt-0.5" data-checklist-ts={item.key}>
                    {fmtDateTime(new Date(ts))}
                  </p>
                )}
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {formResponse && (
    <section class="bg-emerald-50 border border-emerald-200 p-5 md:p-6 mb-6">
      <h2 class="font-display text-xl font-bold mb-4">Dades enviades per la parella</h2>
      <p class="text-xs text-ink/60 mb-5">Enviades el {fmtDateTime(formResponse.submittedAt)} · IP: {formResponse.ipAddress ?? '—'}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
        <div>
          <h3 class="font-bold mb-2">Contraent 1</h3>
          <dl class="space-y-1">
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Nom</dt><dd>{formResponse.c1FullName}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">DNI</dt><dd>{formResponse.c1Dni}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Naixement</dt><dd>{yyyymmdd(formResponse.c1BirthDate) || '—'}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Adreça</dt><dd>{formResponse.c1Address}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Email</dt><dd>{formResponse.c1Email}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Tel</dt><dd>{formResponse.c1Phone}</dd></div>
          </dl>
        </div>
        <div>
          <h3 class="font-bold mb-2">Contraent 2</h3>
          <dl class="space-y-1">
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Nom</dt><dd>{formResponse.c2FullName}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">DNI</dt><dd>{formResponse.c2Dni}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Naixement</dt><dd>{yyyymmdd(formResponse.c2BirthDate) || '—'}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Adreça</dt><dd>{formResponse.c2Address}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Email</dt><dd>{formResponse.c2Email}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-24 flex-shrink-0">Tel</dt><dd>{formResponse.c2Phone}</dd></div>
          </dl>
        </div>
        <div class="md:col-span-2 border-t border-emerald-300/60 pt-4">
          <h3 class="font-bold mb-2">El dia</h3>
          <dl class="space-y-1">
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Data confirmada</dt><dd>{formResponse.weddingDateConfirmed ? 'Sí' : `No (alt: ${yyyymmdd(formResponse.weddingDateAlt)})`}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Venue confirmat</dt><dd>{formResponse.venueConfirmed ? 'Sí' : `No (alt: ${formResponse.venueAltName ?? '—'})`}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Hora cerimònia</dt><dd>{formResponse.ceremonyTime ?? '—'}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Fi del servei</dt><dd>{formResponse.serviceEndTime ?? '—'}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Convidats estim.</dt><dd>{formResponse.guestCountEstimate ?? '—'}</dd></div>
          </dl>
        </div>
        <div class="md:col-span-2 border-t border-emerald-300/60 pt-4">
          <h3 class="font-bold mb-2">Preferències i context</h3>
          <dl class="space-y-1">
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Comunicació</dt><dd>{formResponse.preferredCommunication ?? '—'}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Idioma</dt><dd>{formResponse.preferredLanguage ?? '—'}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Pagament</dt><dd>{formResponse.preferredPaymentMethod ?? '—'}</dd></div>
            <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Com ens van conèixer</dt><dd>{formResponse.howDidYouFindUs ?? '—'}</dd></div>
            {formResponse.importantNotes && (
              <div class="flex gap-2 mt-3"><dt class="text-ink/50 w-40 flex-shrink-0">Notes importants</dt><dd class="whitespace-pre-line">{formResponse.importantNotes}</dd></div>
            )}
          </dl>
        </div>

        {formResponse.gdprAcceptedAt && (
          <div class="md:col-span-2 border-t border-emerald-300/60 pt-4">
            <h3 class="font-bold mb-2">Dades del contracte (/contrato)</h3>
            <dl class="space-y-1">
              <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Cerimònia</dt><dd>{formResponse.ceremonyLocationText ?? '—'}</dd></div>
              <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Banquet</dt><dd>{formResponse.receptionLocationText ?? '—'}</dd></div>
              <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Tipus cerimònia</dt><dd>
                {formResponse.ceremonyType === 'civil' && 'Civil'}
                {formResponse.ceremonyType === 'religious' && 'Religiosa'}
                {formResponse.ceremonyType === 'other' && `Altres: ${formResponse.ceremonyTypeOther ?? '—'}`}
              </dd></div>
              <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">First Look</dt><dd>
                {formResponse.firstLook === 'yes' && 'Sí'}
                {formResponse.firstLook === 'no' && 'No'}
                {formResponse.firstLook === 'not_sure' && 'Encara no ho tenen clar'}
              </dd></div>
              <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Idioma entre la parella</dt><dd>{formResponse.languageBetween ?? '—'}</dd></div>
              <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">Consentiment publicació</dt><dd>
                {(formResponse.publicationConsent ?? []).length === 0
                  ? '— cap canal autoritzat —'
                  : (formResponse.publicationConsent ?? []).join(', ')}
              </dd></div>
              <div class="flex gap-2"><dt class="text-ink/50 w-40 flex-shrink-0">RGPD acceptat</dt><dd>{fmtDateTime(formResponse.gdprAcceptedAt)}</dd></div>
            </dl>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Edit form -->
  <form method="POST" action={`/api/admin/bookings/${booking.id}/update`} class="space-y-10 bg-white border border-black/10 p-6 md:p-8">
    <input type="hidden" name="_action" value="update" />

    {booking.status !== 'draft' && (
      <p class="px-4 py-3 bg-amber-50 border border-amber-200 text-amber-900 text-sm">
        ⚠️ Aquesta reserva ja està en estat <strong>{STATUS_LABEL[booking.status]}</strong>. Els canvis aquí afecten la pàgina pública immediatament.
      </p>
    )}

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Parella</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Nom 1</span><input name="coupleName1" value={booking.coupleName1} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Nom 2</span><input name="coupleName2" value={booking.coupleName2} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Email principal</span><input type="email" name="coupleEmailPrimary" value={booking.coupleEmailPrimary} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Telèfon</span><input name="couplePhonePrimary" value={booking.couplePhonePrimary ?? ''} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Idioma de la pàgina</span>
          <select name="preferredLanguage" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            {[['ca','Català'],['es','Castellano'],['en','English']].map(([code,label]) => (
              <option value={code} selected={booking.preferredLanguage === code}>{label}</option>
            ))}
          </select>
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Boda</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Data</span><input type="date" name="weddingDate" value={yyyymmdd(booking.weddingDate)} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Venue</span><input name="venueName" value={booking.venueName} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Ciutat</span><input name="venueCity" value={booking.venueCity ?? ''} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Adreça</span><input name="venueAddress" value={booking.venueAddress ?? ''} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Pack</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block md:col-span-2"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Nom del pack</span><input name="packName" value={booking.packName} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Descripció</span>
          <textarea name="packDescription" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{booking.packDescription ?? ''}</textarea>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Què inclou</span>
          <span class="block text-[11px] text-ink/50 mb-1">una línia per ítem</span>
          <textarea name="packIncludes" rows="6" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{includesText}</textarea>
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Què no inclou</span>
          <span class="block text-[11px] text-ink/50 mb-1">una línia per ítem</span>
          <textarea name="packExcludes" rows="6" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{excludesText}</textarea>
        </label>
        <label class="block md:col-span-2">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Add-ons</span>
          <span class="block text-[11px] text-ink/50 mb-1">una línia per ítem · format <code class="bg-cream px-1">Nom | preu_en_euros</code></span>
          <textarea name="packAddons" rows="4" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white font-mono text-sm focus:border-gold focus:outline-none">{addonsText}</textarea>
        </label>
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Inversió total (€)</span><input name="packPriceEuros" inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 1500, 1.500, 1500,00 o 1.500,00" value={eurosFromCents(booking.packPriceCents)} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Dipòsit (€)</span><input name="depositEuros" inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 500, 500,00 o 1.500,00" value={eurosFromCents(booking.depositCents)} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        <label class="block md:col-span-2"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Termes de pagament</span><input name="paymentTerms" value={booking.paymentTerms ?? ''} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>

        <div class="md:col-span-2 border border-gold/40 bg-gold/5 p-4">
          <p class="text-xs font-bold tracking-widest uppercase text-ink/70 mb-3">Descompte (opcional)</p>
          {booking.discountCents > 0 && (
            <p class="text-[11px] text-gold font-semibold mb-2">
              Descompte actiu: −{eurosFromCents(booking.discountCents)} € · Inversió efectiva: {eurosFromCents(booking.packPriceCents - booking.discountCents)} €
            </p>
          )}
          <div class="flex flex-wrap items-end gap-3">
            <div>
              <p class="text-[11px] font-bold tracking-wide uppercase text-ink/60 mb-1">Tipus</p>
              <div class="flex gap-3 text-sm">
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="discountType" value="percent" id="discountTypePct" class="accent-gold" />
                  <span>%</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="discountType" value="amount" id="discountTypeAmt" class="accent-gold" checked />
                  <span>€</span>
                </label>
              </div>
            </div>
            <label class="block">
              <span class="text-[11px] font-bold tracking-wide uppercase text-ink/60">Valor (0 = sense descompte)</span>
              <input id="discountValueField" name="discountValue" inputmode="decimal" placeholder="0" value={booking.discountCents > 0 ? eurosFromCents(booking.discountCents) : ''} class="mt-1 w-28 px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
            </label>
            <p id="discountPreview" class="text-sm text-gold font-semibold self-end pb-2"></p>
          </div>
        </div>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-3">Personalització</legend>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Intro personalitzada</span>
        <textarea name="customIntro" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{booking.customIntro ?? ''}</textarea>
      </label>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Notes internes</span>
        <span class="block text-[11px] text-ink/50 mb-1">només per a tu — referrer, acords especials. <strong>Mai es mostra a la parella</strong>.</span>
        <textarea name="internalNotes" rows="3" placeholder="ex: ve de part de Maria & Joan (boda 2024) · descompte 10%" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{booking.internalNotes ?? ''}</textarea>
      </label>
      <div class="border-t border-black/10 pt-4">
        <p class="text-xs font-bold tracking-widest uppercase text-ink/60 mb-3">Testimoni de referència</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="block md:col-span-2"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Quote</span><textarea name="testimonialQuote" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{t?.quote ?? ''}</textarea></label>
          <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Autor</span><input name="testimonialAuthor" value={t?.author ?? ''} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
          <label class="block"><span class="text-xs font-bold tracking-widest uppercase text-ink/60">Context</span><input name="testimonialContext" value={t?.context ?? ''} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" /></label>
        </div>
      </div>
      <div class="border-t border-black/10 pt-4">
        <label class="block max-w-md">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Vídeo destacat</span>
          <span class="block text-[11px] text-ink/50 mb-1">opcional · si es deixa buit, s'usa el vídeo per defecte (Elena i Jordi)</span>
          <select name="flagshipVideoId" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
            <option value="" selected={!booking.flagshipVideoId}>— Per defecte (Elena i Jordi) —</option>
            <optgroup label="Tràilers">
              {publicVideos.map((vid) => (
                <option value={vid.youtubeId} selected={booking.flagshipVideoId === vid.youtubeId}>
                  {vid.coupleName} · {vid.venue}
                </option>
              ))}
            </optgroup>
            {fullVideos.length > 0 && (
              <optgroup label="Bodes senceres (ocultes a YouTube)">
                {fullVideos.map((vid) => (
                  <option value={vid.youtubeId} selected={booking.flagshipVideoId === vid.youtubeId}>
                    {vid.coupleName} · {vid.venue}{vid.adminNote ? ` · ${vid.adminNote}` : ''}
                  </option>
                ))}
              </optgroup>
            )}
          </select>
        </label>
      </div>
    </fieldset>

    <fieldset class="space-y-4">
      <legend class="font-display text-xl font-bold mb-1">Caramel / Incentiu</legend>
      <p class="text-[11px] text-ink/50 -mt-2 mb-3">opcional · apareix a la proposta per motivar la parella a confirmar. Si queda buit, no es mostra res.</p>
      <label class="block">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Missatge del caramel</span>
        <textarea name="incentiveBody" rows="3" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">{booking.incentiveBody ?? ''}</textarea>
      </label>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Preu original (€) — per tatxar</span>
          <span class="block text-[11px] text-ink/50 mb-1">opcional · si és més gran que la inversió, es mostra tatxat</span>
          <input name="incentiveOriginalPriceEuros" inputmode="decimal" pattern="\\d{1,3}(?:\\.\\d{3})+(?:,\\d{1,2})?|\\d+(?:[.,]\\d{1,2})?" title="Ex: 3500 o 3.500,00" value={booking.incentiveOriginalPriceCents != null ? eurosFromCents(booking.incentiveOriginalPriceCents) : ''} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Data límit de l'oferta</span>
          <span class="block text-[11px] text-ink/50 mb-1">opcional · "vàlid si reserveu abans del…"</span>
          <input type="date" name="incentiveDeadline" value={yyyymmdd(booking.incentiveDeadline)} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
        </label>
      </div>
    </fieldset>

    <fieldset>
      <legend class="font-display text-xl font-bold mb-3">Vigència</legend>
      <label class="block max-w-sm">
        <span class="text-xs font-bold tracking-widest uppercase text-ink/60">Vàlid fins</span>
        <input type="date" name="expiresAt" value={yyyymmdd(booking.expiresAt)} class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none" />
      </label>
    </fieldset>

    <div class="flex items-center gap-4 pt-4 border-t border-black/10">
      <button type="submit" class="bg-ink text-white px-6 py-3 text-xs font-bold tracking-widest uppercase hover:bg-gold transition-colors">
        Desar canvis
      </button>
      <a href="/admin/bookings" class="text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold">Cancel·lar</a>
    </div>
  </form>

  <!-- ── Communicacions ─────────────────────────────────────────────── -->
  <!-- Email-sequence queue for this booking. Lets Eric see what's been
       sent / is pending, force-send something now, or cancel an upcoming
       row. Triggered automatically when the deposit is marked paid. -->
  <section class="mt-10 bg-white border border-black/10 p-5 md:p-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
      <div>
        <h2 class="font-display text-xl md:text-2xl font-bold">Comunicacions</h2>
        <p class="text-sm text-ink/65 mt-1">Cola d'emails programats per a aquesta parella. Es genera quan marques el dipòsit com a pagat.</p>
      </div>
      <a href="/admin/sequences" class="text-xs font-bold tracking-widest uppercase text-ink/60 hover:text-gold whitespace-nowrap">Plantilles →</a>
    </div>

    <!-- Manual send: pick any sequence with a form and fire it NOW.
         Useful when a couple needs a questionnaire ahead of (or after)
         its scheduled date. Only sequences with form_kind appear so we
         don't accidentally re-send the deposit-paid invite. -->
    {allSequences.filter((s) => s.formKind && s.enabled).length > 0 && (
      <form
        method="POST"
        action={`/api/admin/bookings/${booking.id}/send-form`}
        class="mb-6 p-4 bg-cream/60 border border-gold/30 flex flex-col sm:flex-row sm:items-end gap-3"
      >
        <div class="flex-1">
          <label class="block">
            <span class="text-[0.7rem] font-bold tracking-widest uppercase text-ink/65">Enviar formulari ara</span>
            <span class="block text-xs text-ink/55 mt-0.5">Tria una plantilla amb formulari i l'enviem a la parella ara mateix, independentment de la data programada.</span>
            <select name="sequenceId" required class="mt-2 w-full px-3 py-2 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none">
              <option value="">— Trià una plantilla —</option>
              {allSequences.filter((s) => s.formKind && s.enabled).map((s) => (
                <option value={s.id}>{s.slug} · {s.formKind}</option>
              ))}
            </select>
          </label>
        </div>
        <button type="submit" class="bg-ink text-white text-xs font-bold tracking-widest uppercase px-5 py-2.5 hover:bg-gold transition-colors whitespace-nowrap">
          Enviar ara
        </button>
      </form>
    )}

    {schedules.length === 0 ? (
      <p class="text-sm text-ink/55 italic py-3">Cap email programat. Es generaran automàticament quan marquis el dipòsit com a pagat (i hi hagi plantilles actives a <a href="/admin/sequences" class="text-gold underline">/admin/sequences</a>).</p>
    ) : (
      <div class="overflow-x-auto -mx-5 md:mx-0">
        <table class="w-full text-sm">
          <thead class="text-[0.7rem] uppercase tracking-widest text-ink/55">
            <tr>
              <th class="text-left px-3 py-2">Plantilla</th>
              <th class="text-left px-3 py-2">Programat per</th>
              <th class="text-left px-3 py-2">Estat</th>
              <th class="px-3 py-2"></th>
            </tr>
          </thead>
          <tbody>
            {schedules.map((sch) => {
              const seq = sequencesById.get(sch.sequenceId);
              const isSent = sch.sentAt instanceof Date;
              const isCancelled = sch.cancelledAt instanceof Date;
              const isPending = !isSent && !isCancelled;
              return (
                <tr class="border-t border-black/5">
                  <td class="px-3 py-2 font-mono text-xs">{seq?.slug ?? `#${sch.sequenceId}`}</td>
                  <td class="px-3 py-2 whitespace-nowrap">{sch.scheduledFor}</td>
                  <td class="px-3 py-2 text-xs">
                    {isSent && <span class="bg-emerald-100 text-emerald-700 px-2 py-0.5 font-bold uppercase tracking-widest">Enviat</span>}
                    {isCancelled && <span class="bg-ink/10 text-ink/55 px-2 py-0.5 font-bold uppercase tracking-widest">Cancel·lat</span>}
                    {isPending && (sch.lastError
                      ? <span class="bg-amber-100 text-amber-800 px-2 py-0.5 font-bold uppercase tracking-widest" title={sch.lastError}>Reintent</span>
                      : <span class="bg-blue-100 text-blue-700 px-2 py-0.5 font-bold uppercase tracking-widest">Pendent</span>)}
                  </td>
                  <td class="px-3 py-2 text-right whitespace-nowrap">
                    {isPending && (
                      <>
                        <form method="POST" action={`/api/admin/schedules/${sch.id}/fast-forward`} class="inline">
                          <button type="submit" class="text-xs text-gold hover:underline mr-3">Enviar ja</button>
                        </form>
                        <form method="POST" action={`/api/admin/schedules/${sch.id}/cancel`} class="inline" onsubmit="return confirm('Cancel·lar aquest email programat?')">
                          <button type="submit" class="text-xs text-red-600 hover:underline">Cancel·lar</button>
                        </form>
                      </>
                    )}
                    {isCancelled && (
                      <form method="POST" action={`/api/admin/schedules/${sch.id}/reactivate`} class="inline">
                        <button type="submit" class="text-xs text-emerald-700 hover:underline">Reactivar</button>
                      </form>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </section>
</AdminLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy!;
      try {
        await navigator.clipboard.writeText(text);
        const old = btn.textContent;
        btn.textContent = '✓ Copiat';
        setTimeout(() => (btn.textContent = old), 1500);
      } catch {
        prompt('Copia:', text);
      }
    });
  });

  // Manual re-push of the booking row to Eric's master Google Sheet —
  // mirrors what /api/reserva/submit fires automatically. Useful when the
  // webhook wasn't wired yet at original-submission time.
  document.querySelectorAll<HTMLButtonElement>('[data-push-to-sheet]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.bookingId;
      if (!id) return;
      if (!confirm('Pujar aquesta reserva al Google Sheet? S\'afegirà una fila nova (no detecta duplicats — comprova el Sheet abans si dubtes).')) return;
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Pujant…';
      try {
        const res = await fetch(`/api/admin/bookings/${id}/push-to-sheet`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          const reason =
            body.error === 'not_configured' ? 'El webhook del Sheet no està configurat (BOOKINGS_SHEET_WEBHOOK_URL / _TOKEN).'
            : body.error === 'push_failed' ? `Push fallat: ${body.detail ?? 'desconegut'}.`
            : `Error ${res.status}.`;
          alert(reason);
          btn.textContent = original;
          btn.disabled = false;
          return;
        }
        btn.textContent = '✓ Pujat';
        setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 3000);
      } catch (err) {
        console.error(err);
        alert('Error de xarxa. Torna-ho a provar.');
        btn.textContent = original;
        btn.disabled = false;
      }
    });
  });

  // Re-fire the booking Telegram alert. Same payload as /api/reserva/
  // submit dispatches automatically — useful for legacy bookings that
  // pre-date the WhatsApp group block, or when the original message
  // scrolled away in a busy chat.
  document.querySelectorAll<HTMLButtonElement>('[data-resend-telegram]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.bookingId;
      if (!id) return;
      if (!confirm('Reenviar el missatge de Telegram amb el suggerit del grup WhatsApp?')) return;
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Enviant…';
      try {
        const res = await fetch(`/api/admin/bookings/${id}/resend-telegram`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          const reason =
            body.error === 'no_form_response' ? 'La parella encara no ha enviat les dades de /reserva.'
            : body.error === 'send_failed' ? "L'enviament ha fallat — mira els logs."
            : `Error ${res.status}.`;
          alert(reason);
          btn.textContent = original;
          btn.disabled = false;
          return;
        }
        btn.textContent = '✓ Enviat';
        setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 3000);
      } catch (err) {
        console.error(err);
        alert('Error de xarxa. Torna-ho a provar.');
        btn.textContent = original;
        btn.disabled = false;
      }
    });
  });

  // Resend the post-/reserva confirmation email. The email body rebuilds
  // from the current env state, so toggling Stripe in Railway and re-sending
  // is enough to recover a couple who was sent the original email before
  // the card CTA was live.
  document.querySelectorAll<HTMLButtonElement>('[data-resend-confirmation]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.bookingId;
      if (!id) return;
      if (!confirm("Reenviar l'email de confirmació a la parella? Es generarà amb la configuració actual (Stripe / IBAN tal com estan ara mateix).")) return;
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Enviant…';
      try {
        const res = await fetch(`/api/admin/bookings/${id}/resend-confirmation`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          const reason =
            body.error === 'no_form_response' ? 'La parella encara no ha enviat les dades de /reserva.'
            : body.error === 'wrong_status' ? `Estat del booking incompatible (${body.status}).`
            : body.error === 'send_failed' ? "L'enviament ha fallat — mira els logs."
            : `Error ${res.status}.`;
          alert(reason);
          btn.textContent = original;
          btn.disabled = false;
          return;
        }
        btn.textContent = '✓ Enviat';
        setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 3000);
      } catch (err) {
        console.error(err);
        alert('Error de xarxa. Torna-ho a provar.');
        btn.textContent = original;
        btn.disabled = false;
      }
    });
  });

  // Checklist: toggle a single item via POST and update the box without
  // a page reload. We optimistically flip the UI immediately and revert
  // if the server rejects.
  document.querySelectorAll<HTMLButtonElement>('[data-checklist-toggle]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const bookingId = btn.dataset.bookingId;
      const key = btn.dataset.key;
      if (!bookingId || !key) return;
      const wasChecked = btn.getAttribute('aria-pressed') === 'true';
      const next = !wasChecked;

      // Optimistic flip — box + checkmark.
      flipBox(btn, next);
      const tsEl = document.querySelector(`[data-checklist-ts="${key}"]`);

      try {
        const res = await fetch(`/api/admin/bookings/${bookingId}/checklist`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key, checked: next }),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.error ?? `HTTP ${res.status}`);

        // Server-confirmed timestamp for the ticked state (so the date
        // line stays exact even if device clock differs).
        const ts = body.state?.[key];
        if (next && ts && tsEl) {
          tsEl.textContent = new Date(ts).toLocaleString('ca-ES', {
            timeZone: 'Europe/Madrid', dateStyle: 'short', timeStyle: 'short',
          });
        } else if (!next && tsEl) {
          tsEl.textContent = '';
        }
      } catch (err) {
        console.error('[checklist] toggle failed', err);
        // Revert UI.
        flipBox(btn, wasChecked);
        alert("No s'ha pogut desar el canvi. Torna-ho a provar.");
      }
    });

    function flipBox(button: HTMLButtonElement, checked: boolean) {
      button.setAttribute('aria-pressed', checked ? 'true' : 'false');
      const span = button.querySelector('span');
      if (span) span.textContent = checked ? '✓' : '';
      if (checked) {
        button.classList.add('bg-emerald-600', 'border-emerald-600', 'text-white');
        button.classList.remove('border-ink/30', 'hover:border-gold');
      } else {
        button.classList.remove('bg-emerald-600', 'border-emerald-600', 'text-white');
        button.classList.add('border-ink/30', 'hover:border-gold');
      }
    }
  });

  // ── Discount live preview ────────────────────────────────────────────────
  const discountValueInput = document.getElementById('discountValueField') as HTMLInputElement | null;
  const discountPreviewEl = document.getElementById('discountPreview');
  const packPriceInput = document.querySelector<HTMLInputElement>('input[name="packPriceEuros"]');
  function updateDiscountPreview() {
    const typeEl = document.querySelector<HTMLInputElement>('input[name="discountType"]:checked');
    const type = typeEl?.value ?? 'amount';
    const val = parseFloat((discountValueInput?.value ?? '').replace(',', '.'));
    const packCents = Math.round(parseFloat((packPriceInput?.value ?? '0').replace(',', '.')) * 100);
    if (!Number.isFinite(val) || val <= 0 || packCents <= 0) {
      if (discountPreviewEl) discountPreviewEl.textContent = '';
      return;
    }
    const discountCents = type === 'percent'
      ? Math.round(packCents * Math.min(val, 100) / 100)
      : Math.round(val * 100);
    const effectiveCents = packCents - discountCents;
    if (discountPreviewEl) {
      discountPreviewEl.textContent = `−${(discountCents / 100).toFixed(0)} € · efectiu: ${(effectiveCents / 100).toFixed(0)} €`;
    }
  }
  discountValueInput?.addEventListener('input', updateDiscountPreview);
  document.querySelectorAll<HTMLInputElement>('input[name="discountType"]').forEach((r) => r.addEventListener('change', updateDiscountPreview));
  packPriceInput?.addEventListener('input', updateDiscountPreview);
  updateDiscountPreview();
</script>
