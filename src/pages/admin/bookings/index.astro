---
// Admin listing of bookings.
// Filters: ?status=<status>, ?archived=1 to include archived.
// Search: client-side filter on couple/venue text.
import AdminLayout from '~/layouts/AdminLayout.astro';
import { listBookings } from '~/lib/bookings/repository';
import type { Booking, BookingStatus } from '~/lib/bookings/types';
import { inferServiceType } from '~/lib/contracts/generate';

const SERVICE_LABEL: Record<string, string> = {
  photo: 'Foto',
  video: 'Vídeo',
  combo: 'Foto+vídeo',
};
function serviceLabelFor(b: Booking): string {
  const t = b.serviceType ?? inferServiceType(b.packName, b.packIncludes);
  return SERVICE_LABEL[t] ?? t;
}
/** Ownership chip text + classes. null → own (LifeTime), no chip needed. */
function ownership(b: Booking): { label: string; classes: string } | null {
  if (b.kind === 'external') {
    return {
      label: b.collaboratorName ? `Per a ${b.collaboratorName}` : 'Per a un altre estudi',
      classes: 'bg-purple-100 text-purple-800',
    };
  }
  if (b.kind === 'collab') {
    return {
      label: b.collaboratorName ? `LW + ${b.collaboratorName}` : 'LW + col·laborador',
      classes: 'bg-sky-100 text-sky-800',
    };
  }
  return null;
}

const statusFilter = (Astro.url.searchParams.get('status') ?? '') as BookingStatus | '';
const yearFilterRaw = Astro.url.searchParams.get('year') ?? '';
const yearFilter = /^\d{4}$/.test(yearFilterRaw) ? Number(yearFilterRaw) : null;
const includeArchived = Astro.url.searchParams.get('archived') === '1';
const ok = Astro.url.searchParams.get('ok');

type SortKey = 'date_asc' | 'date_desc' | 'recent';
const sortRaw = Astro.url.searchParams.get('sort') ?? '';
const sortKey: SortKey =
  sortRaw === 'date_desc' || sortRaw === 'recent' ? sortRaw : 'date_asc';

const all = await listBookings({ includeArchived });

// Years dropdown — derived from the live data so it stays current without
// hand-maintained lists; we also throw next year into the mix so a quote
// for a wedding way in the future doesn't disappear from the picker.
const allYears = new Set<number>(all.map((b) => b.weddingDate.getFullYear()));
allYears.add(new Date().getFullYear());
allYears.add(new Date().getFullYear() + 1);
const yearOptions = [...allYears].sort((a, b) => a - b);

const filtered = all
  .filter((b) => (statusFilter ? b.status === statusFilter : true))
  .filter((b) => (yearFilter ? b.weddingDate.getFullYear() === yearFilter : true));

// Sort according to the chosen key. Default 'date_asc' = chronological, the
// closest-coming wedding first (best for planning). Ties fall back to
// updatedAt desc so the most recently-touched record wins.
const bookings = [...filtered].sort((a, b) => {
  if (sortKey === 'recent') return b.updatedAt.getTime() - a.updatedAt.getTime();
  const d = a.weddingDate.getTime() - b.weddingDate.getTime();
  const dir = sortKey === 'date_desc' ? -d : d;
  if (dir !== 0) return dir;
  return b.updatedAt.getTime() - a.updatedAt.getTime();
});

// Aggregate total quoted for the current view (post-filter). Stored as cents
// so the formatter shows the same number we keep in the DB.
const totalQuotedCents = bookings.reduce((acc, b) => acc + b.packPriceCents, 0);
function formatEuros(cents: number): string {
  const euros = cents / 100;
  return new Intl.NumberFormat('ca-ES', {
    style: 'currency',
    currency: 'EUR',
    maximumFractionDigits: euros % 1 === 0 ? 0 : 2,
  }).format(euros);
}

const STATUS_BADGE: Record<BookingStatus, { label: string; classes: string }> = {
  draft:           { label: 'Draft',     classes: 'bg-gray-100 text-gray-700' },
  sent:            { label: 'Enviat',    classes: 'bg-blue-100 text-blue-700' },
  viewed:          { label: 'Vist',      classes: 'bg-amber-100 text-amber-800' },
  form_submitted:  { label: 'Reservat',  classes: 'bg-emerald-100 text-emerald-800' },
  archived:        { label: 'Arxivat',   classes: 'bg-gray-200 text-gray-500' },
};

/** Compact one-line wedding date with weekday, e.g. "ds. 14 març 2026".
 *  Weekday matters for wedding planning, and keeping it on one line stops the
 *  column from wrapping into a tall 4-line cell. */
function fmtWedding(d: Date | null): { weekday: string; date: string } {
  if (!d) return { weekday: '', date: '—' };
  const opts = { timeZone: 'Europe/Madrid' } as const;
  const weekday = d.toLocaleDateString('ca-ES', { ...opts, weekday: 'short' }).replace('.', '');
  const date = d.toLocaleDateString('ca-ES', { ...opts, day: 'numeric', month: 'short', year: 'numeric' });
  return { weekday, date };
}
function fmtRelative(d: Date | null): string {
  if (!d) return '—';
  const diff = Date.now() - d.getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'ara mateix';
  if (mins < 60) return `fa ${mins} min`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `fa ${hours}h`;
  const days = Math.floor(hours / 24);
  if (days < 7) return `fa ${days}d`;
  return d.toLocaleDateString('ca-ES', { timeZone: 'Europe/Madrid', day: 'numeric', month: 'short' });
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;

const STATUS_TABS: { key: '' | BookingStatus; label: string }[] = [
  { key: '',               label: 'Tot' },
  { key: 'draft',          label: 'Draft' },
  { key: 'sent',           label: 'Enviats' },
  { key: 'viewed',         label: 'Vistos' },
  { key: 'form_submitted', label: 'Reservats' },
];
---

<AdminLayout title="Reserves">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
    <h1 class="font-display text-2xl sm:text-3xl font-bold">Reserves</h1>
    <div class="flex items-center gap-2 self-start sm:self-auto">
      <a
        href="/admin/bookings/import"
        class="border border-ink/20 text-ink px-5 py-2.5 text-xs font-bold tracking-widest uppercase hover:bg-cream transition-colors whitespace-nowrap"
      >
        Importar CSV
      </a>
      <a
        href="/admin/bookings/new"
        class="bg-ink text-white px-5 py-2.5 text-xs font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors whitespace-nowrap"
      >
        + Nova reserva
      </a>
    </div>
  </div>

  {ok === 'created' && (
    <div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm">
      Reserva creada. Copia l'enllaç des de la fila per enviar-la.
    </div>
  )}

  <div class="flex flex-wrap items-center gap-2 mb-4">
    {STATUS_TABS.map((tab) => {
      // Preserve the year filter while switching status tabs.
      const params = new URLSearchParams();
      if (tab.key) params.set('status', tab.key);
      if (yearFilter) params.set('year', String(yearFilter));
      if (includeArchived) params.set('archived', '1');
      if (sortKey !== 'date_asc') params.set('sort', sortKey);
      const qs = params.toString();
      const isActive = (tab.key === '' && !statusFilter) || tab.key === statusFilter;
      return (
        <a
          href={qs ? `/admin/bookings?${qs}` : '/admin/bookings'}
          class:list={[
            'text-xs font-bold tracking-widest uppercase px-3 py-1.5 border transition-colors',
            isActive ? 'bg-ink text-white border-ink' : 'border-black/15 text-ink/70 hover:text-gold hover:border-gold',
          ]}
        >
          {tab.label}
        </a>
      );
    })}
    <span class="hidden md:block flex-1"></span>
    <form method="GET" class="contents">
      {statusFilter && <input type="hidden" name="status" value={statusFilter} />}
      {includeArchived && <input type="hidden" name="archived" value="1" />}
      <label class="flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-ink/70">
        Ordenar
        <select
          name="sort"
          onchange="this.form.submit()"
          class="px-2 py-1.5 border border-black/15 bg-white text-xs focus:border-gold focus:outline-none"
        >
          <option value="date_asc" selected={sortKey === 'date_asc'}>Data ↑ (properes)</option>
          <option value="date_desc" selected={sortKey === 'date_desc'}>Data ↓ (llunyanes)</option>
          <option value="recent" selected={sortKey === 'recent'}>Actualització</option>
        </select>
      </label>
      <label class="flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-ink/70">
        Any
        <select
          name="year"
          onchange="this.form.submit()"
          class="px-2 py-1.5 border border-black/15 bg-white text-xs focus:border-gold focus:outline-none"
        >
          <option value="">— Tots —</option>
          {yearOptions.map((y) => (
            <option value={y} selected={yearFilter === y}>{y}</option>
          ))}
        </select>
      </label>
    </form>
    <input
      type="text"
      id="search-input"
      placeholder="Cercar per nom o venue..."
      class="w-full md:w-64 px-3 py-2 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none"
    />
    {(() => {
      const params = new URLSearchParams();
      if (statusFilter) params.set('status', statusFilter);
      if (yearFilter) params.set('year', String(yearFilter));
      if (sortKey !== 'date_asc') params.set('sort', sortKey);
      if (!includeArchived) params.set('archived', '1');
      const qs = params.toString();
      return (
        <a
          href={qs ? `/admin/bookings?${qs}` : '/admin/bookings'}
          class="text-xs font-bold tracking-widest uppercase text-ink/70 hover:text-gold transition-colors whitespace-nowrap"
        >
          {includeArchived ? '✕ Ocultar arxivats' : '📦 Mostrar arxivats'}
        </a>
      );
    })()}
  </div>

  {bookings.length > 0 && (
    <div class="mb-4 px-4 py-3 bg-cream border border-black/10 flex flex-wrap items-baseline gap-x-6 gap-y-1 text-sm">
      <span><strong>{bookings.length}</strong> {bookings.length === 1 ? 'reserva' : 'reserves'}{yearFilter ? ` · ${yearFilter}` : ''}</span>
      <span><strong>Total pressupostat:</strong> <span class="text-gold font-bold">{formatEuros(totalQuotedCents)}</span></span>
    </div>
  )}

  {bookings.length === 0 ? (
    <p class="text-ink/70 text-center py-16">
      Cap reserva en aquesta vista.
      <a href="/admin/bookings/new" class="text-gold underline">Crea'n una</a>.
    </p>
  ) : (
    <>
    {/* Mobile: stack as cards. Each card is a tappable surface (whole
        thing links to the detail). Stays under md:hidden so iPad+ keeps
        the table where the extra columns earn their space. */}
    <ul class="md:hidden space-y-3" id="bookings-cards">
      {bookings.map((b) => {
        const badge = STATUS_BADGE[b.status];
        const couple = `${b.coupleName1} & ${b.coupleName2}`;
        return (
          <li
            class="bg-white border border-black/10"
            data-search={`${couple} ${b.venueName} ${b.coupleEmailPrimary}`.toLowerCase()}
          >
            <a href={`/admin/bookings/${b.id}`} class="block p-4 hover:bg-cream/50">
              <div class="flex items-start justify-between gap-3 mb-2">
                <div class="min-w-0 flex-1">
                  <p class="font-bold leading-tight">{couple}</p>
                  <p class="text-[0.7rem] text-ink/70 truncate">{b.coupleEmailPrimary}</p>
                  <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    <span class="text-[0.6rem] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded-sm bg-cream border border-gold/30 text-ink/70">{serviceLabelFor(b)}</span>
                    {ownership(b) && (
                      <span class:list={['text-[0.6rem] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded-sm', ownership(b)!.classes]}>{ownership(b)!.label}</span>
                    )}
                  </div>
                </div>
                <span class:list={['shrink-0 text-[0.6rem] font-bold tracking-widest uppercase px-2 py-1 rounded-sm', badge.classes]}>
                  {badge.label}
                </span>
              </div>
              <p class="text-sm mb-1">
                <strong>{fmtWedding(b.weddingDate).date}</strong>
                {fmtWedding(b.weddingDate).weekday && <span class="text-ink/60"> · {fmtWedding(b.weddingDate).weekday}</span>}
              </p>
              <p class="text-xs text-ink/70">{b.venueName}{b.venueCity && ` · ${b.venueCity}`}</p>
              <div class="mt-3 pt-3 border-t border-black/5 flex items-center justify-between text-xs">
                <span class="text-gold font-bold">{formatEuros(b.packPriceCents)}</span>
                <span class="text-ink/70">{fmtRelative(b.updatedAt)}</span>
              </div>
            </a>
            <button
              type="button"
              data-copy={`${siteUrl}/reserva/${b.slug}`}
              class="block w-full text-center text-gold text-[0.7rem] font-bold tracking-widest uppercase px-4 py-3 border-t border-black/5 hover:bg-cream"
            >
              Copiar enllaç
            </button>
          </li>
        );
      })}
    </ul>

    <div class="hidden md:block overflow-x-auto bg-white border border-black/10">
      <table class="w-full text-sm" id="bookings-table">
        <thead class="bg-cream text-[0.7rem] font-bold tracking-widest uppercase">
          <tr>
            <th class="text-left px-4 py-3">Estat</th>
            <th class="text-left px-4 py-3">Parella</th>
            <th class="text-left px-4 py-3">Data boda</th>
            <th class="text-left px-4 py-3">Venue</th>
            <th class="text-right px-4 py-3">Pressupostat</th>
            <th class="text-left px-4 py-3">Actualitzat</th>
            <th class="text-right px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {bookings.map((b) => {
            const badge = STATUS_BADGE[b.status];
            const couple = `${b.coupleName1} & ${b.coupleName2}`;
            return (
              <tr
                class="border-t border-black/5 hover:bg-cream/50"
                data-search={`${couple} ${b.venueName} ${b.coupleEmailPrimary}`.toLowerCase()}
              >
                <td class="px-4 py-3">
                  <span class:list={['inline-block text-[0.65rem] font-bold tracking-widest uppercase px-2 py-1 rounded-sm', badge.classes]}>
                    {badge.label}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <a href={`/admin/bookings/${b.id}`} class="font-bold hover:text-gold">{couple}</a>
                  <div class="text-xs text-ink/70">{b.coupleEmailPrimary} · {b.preferredLanguage.toUpperCase()}</div>
                  <div class="flex flex-wrap items-center gap-1.5 mt-1">
                    <span class="text-[0.6rem] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded-sm bg-cream border border-gold/30 text-ink/70">{serviceLabelFor(b)}</span>
                    {ownership(b) && (
                      <span class:list={['text-[0.6rem] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded-sm', ownership(b)!.classes]}>{ownership(b)!.label}</span>
                    )}
                    {b.source && <span class="text-[0.6rem] text-ink/50">· {b.source}</span>}
                  </div>
                </td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <div class="font-semibold text-ink">{fmtWedding(b.weddingDate).date}</div>
                  {fmtWedding(b.weddingDate).weekday && (
                    <div class="text-[0.7rem] uppercase tracking-wider text-ink/60">{fmtWedding(b.weddingDate).weekday}</div>
                  )}
                </td>
                <td class="px-4 py-3 text-ink/70">
                  {b.venueName}
                  {b.venueCity && <span class="text-ink/70"> · {b.venueCity}</span>}
                </td>
                <td class="px-4 py-3 text-right font-bold text-gold whitespace-nowrap">{formatEuros(b.packPriceCents)}</td>
                <td class="px-4 py-3 text-ink/70">{fmtRelative(b.updatedAt)}</td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <button
                    type="button"
                    data-copy={`${siteUrl}/reserva/${b.slug}`}
                    class="text-gold text-xs font-bold tracking-widest uppercase hover:underline mr-3"
                    title="Copiar enllaç"
                  >Copiar</button>
                  <a href={`/admin/bookings/${b.id}`} class="text-ink/70 text-xs font-bold tracking-widest uppercase hover:text-gold">
                    Veure →
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    </>
  )}
</AdminLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy!;
      try {
        await navigator.clipboard.writeText(text);
        const old = btn.textContent;
        btn.textContent = '✓ Copiat';
        setTimeout(() => (btn.textContent = old), 1500);
      } catch {
        prompt('Copia aquest enllaç:', text);
      }
    });
  });

  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const rows = document.querySelectorAll<HTMLElement>('#bookings-table tbody tr, #bookings-cards li');
  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    rows.forEach((row) => {
      const hay = row.dataset.search ?? '';
      row.style.display = !q || hay.includes(q) ? '' : 'none';
    });
  });
</script>
