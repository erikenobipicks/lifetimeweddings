---
// Public form gate. Resolves a one-shot token to an email_schedule row
// and renders the form attached to its sequence. Once submitted, the
// data lands in `form_submissions` and the page shows a thank-you.
//
// Today we recognise these form_kinds: wedding_details (fully built),
// timeline, guest_list, music (placeholders until each is designed).

export const prerender = false;

import BaseLayout from '~/layouts/BaseLayout.astro';
import { getScheduleByToken } from '~/lib/bookings/sequences';
import { getBookingById } from '~/lib/bookings/repository';
import { db, initSchema } from '~/lib/db';

const token = Astro.params.token!;
const schedule = await getScheduleByToken(token);
const booking = schedule ? await getBookingById(schedule.bookingId) : null;

// What kind of form does this token map to? We look up the sequence row
// inline (sequences.formKind tells us). Avoids loading every sequence in
// memory just to read one column.
let formKind: string | null = null;
let alreadySubmitted = false;
if (schedule) {
  await initSchema();
  const res = await db.execute({
    sql: 'SELECT form_kind FROM email_sequences WHERE id = ?',
    args: [schedule.sequenceId],
  });
  formKind = res.rows[0]?.form_kind ? String(res.rows[0].form_kind) : null;
  if (formKind) {
    const prev = await db.execute({
      sql: 'SELECT id FROM form_submissions WHERE schedule_id = ? LIMIT 1',
      args: [schedule.id],
    });
    alreadySubmitted = prev.rows.length > 0;
  }
}

type L = 'ca' | 'es' | 'en';
const lang: L = (booking?.preferredLanguage as L) ?? 'ca';

const formTitles: Record<string, Record<L, string>> = {
  wedding_details: { ca: 'Informació de la boda', es: 'Información de la boda', en: 'Wedding details' },
  inspiration: { ca: 'Inspiració i música', es: 'Inspiración y música', en: 'Inspiration & music' },
  timeline: { ca: 'Timeline del dia', es: 'Timeline del día', en: 'Wedding-day timeline' },
  guest_list: { ca: 'Llista de convidats', es: 'Lista de invitados', en: 'Guest list' },
  music: { ca: 'Música', es: 'Música', en: 'Music' },
  basic_info: { ca: 'Dades de la boda', es: 'Datos de la boda', en: 'Wedding details' },
};
const title = formKind ? (formTitles[formKind]?.[lang] ?? 'Formulari') : 'Formulari';
const invalid = !schedule || !booking || !formKind;
if (invalid) Astro.response.status = 404;

const isWeddingDetails = formKind === 'wedding_details';
const isInspiration = formKind === 'inspiration';
const isBasicInfo = formKind === 'basic_info';
const name1 = booking?.coupleName1 ?? '';
const name2 = booking?.coupleName2 ?? '';
const venueName = booking?.venueName ?? '';

