// Operator-proposed wedding-day timeline, shown read-only at the top of the
// wedding_details form so the couple can see the plan while adding details.
const tl = booking?.dayTimeline ?? null;
const hasTimeline = !!tl && Object.keys(tl).some((k) => k !== 'prepSameVenue' && (tl as any)[k]);
function fmtMaps(address?: string, url?: string): string | null {
  if (url && url.trim()) return url.trim();
  if (address && address.trim()) return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address.trim())}`;
  return null;
}

