---

<BaseLayout
  lang={lang}
  title={`${title} · Lifetime`}
  description={title}
  noindex={true}
  chromeless={true}
>
  <header class="px-6 md:px-12 py-5 border-b border-ink/10 bg-white">
    <a href="/" class="inline-flex items-center gap-2">
      <img src="/logos/logo-circle-color.png" alt="Lifetime Weddings" width="36" height="36" class="h-9 w-9" />
      <span class="font-display text-base font-bold tracking-wide">Lifetime</span>
    </a>
  </header>

  <section class="px-6 md:px-12 py-16 md:py-24 bg-cream text-ink">
    <div class="max-w-2xl mx-auto">
      {invalid ? (
        <>
          <h1 class="font-display text-3xl md:text-4xl font-bold mb-3">No trobat</h1>
          <p class="text-ink/75 leading-relaxed">Aquest enllaç ja no és vàlid. Si creus que és un error, escriu-nos.</p>
        </>
      ) : alreadySubmitted ? (
        <>
          <h1 class="font-display text-3xl md:text-4xl font-bold mb-3">{isWeddingDetails ? TX.thanksH : 'Gràcies!'}</h1>
          <p class="text-ink/75 leading-relaxed">{isWeddingDetails ? TX.thanksP : 'Ja hem rebut les vostres respostes. Si voleu modificar alguna cosa, escriviu-nos.'}</p>
        </>
      ) : isWeddingDetails ? (
        <>
          <h1 class="font-display text-3xl md:text-4xl font-bold mb-3">{title}</h1>
          <p class="text-ink/75 leading-relaxed mb-10">{TX.intro}</p>

          <form id="wd-form" data-token={token} class="space-y-12">
            {[{ n: 1, name: name1 }, { n: 2, name: name2 }].map(({ n, name }) => (
              <fieldset class="space-y-5">
                <legend class="font-display text-xl font-bold mb-2">{TX.prepFor} {name}</legend>

                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.address}</span>
                  <input name={`prep${n}_address`} type="text" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                </label>

                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.maps} <span class="font-normal text-ink/45">· {TX.optional}</span></span>
                  <span class="block text-xs text-ink/55 mb-1">{TX.mapsHint}</span>
                  <input name={`prep${n}_maps`} type="url" inputmode="url" placeholder="https://maps.app.goo.gl/…" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                </label>

                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.parents}</span>
                  <span class="block text-xs text-ink/55 mb-1">{TX.parentsHint}</span>
                  <select name={`prep${n}_parents`} class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none">
                    <option value="">{TX.choose}</option>
                    <option value="junts">{TX.pJunts}</option>
                    <option value="separats">{TX.pSeparats}</option>
                    <option value="ho_comento">{TX.pHoComento}</option>
                  </select>
                </label>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                  <label class="block">
                    <span class="text-sm font-bold text-ink/80">{TX.father}</span>
                    <input name={`prep${n}_father`} type="text" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                  </label>
                  <label class="block">
                    <span class="text-sm font-bold text-ink/80">{TX.mother}</span>
                    <input name={`prep${n}_mother`} type="text" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                  </label>
                  <label class="block">
                    <span class="text-sm font-bold text-ink/80">{TX.siblings}</span>
                    <input name={`prep${n}_siblings`} type="text" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                  </label>
                </div>
              </fieldset>
            ))}

            <!-- Cerimònia -->
            <fieldset class="space-y-5">
              <legend class="font-display text-xl font-bold mb-2">{TX.secCeremony}</legend>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.ceremonyPlace}</span>
                  <span class="block text-xs text-ink/55 mb-1">{TX.ceremonyPlaceHint}</span>
                  <input name="ceremony_place" type="text" value={venueName} class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                </label>
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.ceremonyTime}</span>
                  <input name="ceremony_time" type="time" class="mt-1 sm:mt-[22px] w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                </label>
              </div>

              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.ceremonyType}</span>
                <select name="ceremony_type" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none">
                  <option value="">{TX.choose}</option>
                  <option value="religiosa">{TX.tReligiosa}</option>
                  <option value="civil">{TX.tCivil}</option>
                  <option value="simbolica">{TX.tSimbolica}</option>
                </select>
              </label>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.officiantName}</span>
                  <span class="block text-xs text-ink/55 mb-1">{TX.officiantNameHint}</span>
                  <input name="ceremony_officiant_name" type="text" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                </label>
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.officiantRelation}</span>
                  <select name="ceremony_officiant_relation" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none">
                    <option value="">{TX.choose}</option>
                    <option value="amics_familia">{TX.rAmics}</option>
                    <option value="contractat">{TX.rContractat}</option>
                    <option value="altres">{TX.rAltres}</option>
                  </select>
                </label>
              </div>
            </fieldset>

            <!-- Música i proveïdors -->
            <fieldset class="space-y-5">
              <legend class="font-display text-xl font-bold mb-2">{TX.secMusic}</legend>

              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.liveMusic}</span>
                <select id="live_music" name="live_music" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none">
                  <option value="">{TX.choose}</option>
                  <option value="si">{TX.lmSi}</option>
                  <option value="no">{TX.lmNo}</option>
                  <option value="no_ho_sabem">{TX.lmNoSabem}</option>
                </select>
              </label>

              <div id="lm-details-wrap" data-cond hidden>
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.liveMusicDetails}</span>
                  <textarea name="live_music_details" rows="2" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none"></textarea>
                </label>
              </div>

              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.otherProviders}</span>
                <span class="block text-xs text-ink/55 mb-1">{TX.otherProvidersHint}</span>
                <textarea name="other_providers" rows="3" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none"></textarea>
              </label>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.dayContactName}</span>
                  <span class="block text-xs text-ink/55 mb-1">{TX.dayContactNameHint}</span>
                  <input name="day_contact_name" type="text" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                </label>
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.dayContactPhone}</span>
                  <input name="day_contact_phone" type="tel" class="mt-1 sm:mt-[26px] w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                </label>
              </div>
            </fieldset>

            <!-- Persones i moments -->
            <fieldset class="space-y-5">
              <legend class="font-display text-xl font-bold mb-2">{TX.secPeople}</legend>

              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.keyPeople}</span>
                <span class="block text-xs text-ink/55 mb-1">{TX.keyPeopleHint}</span>
                <textarea name="key_people" rows="3" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none"></textarea>
              </label>

              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.surprises}</span>
                <span class="block text-xs text-ink/55 mb-1">{TX.surprisesHint}</span>
                <textarea name="surprises" rows="2" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none"></textarea>
              </label>

              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.specialMoments}</span>
                <span class="block text-xs text-ink/55 mb-1">{TX.specialMomentsHint}</span>
                <textarea name="special_moments" rows="2" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none"></textarea>
              </label>

              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.sensitiveInfo} <span class="font-normal text-ink/45">· {TX.optional}</span></span>
                <span class="block text-xs text-ink/55 mb-1">{TX.sensitiveInfoHint}</span>
                <textarea name="sensitive_info" rows="2" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none"></textarea>
              </label>
            </fieldset>

            <!-- Instagram -->
            <fieldset class="space-y-5">
              <legend class="font-display text-xl font-bold mb-2">{TX.secInsta}</legend>

              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.instaConsent}</span>
                <select id="insta_consent" name="insta_consent" class="mt-1 w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none">
                  <option value="">{TX.choose}</option>
                  <option value="si">{TX.cSi}</option>
                  <option value="no">{TX.cNo}</option>
                </select>
              </label>

              <div id="insta-fields-wrap" data-cond hidden class="space-y-5">
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.instaCouple}</span>
                  <span class="block text-xs text-ink/55 mb-1">{TX.instaCoupleHint}</span>
                  <input name="insta_couple" type="text" placeholder="@…" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
                </label>
                <label class="block">
                  <span class="text-sm font-bold text-ink/80">{TX.instaProviders}</span>
                  <span class="block text-xs text-ink/55 mb-1">{TX.instaProvidersHint}</span>
                  <textarea name="insta_providers" rows="4" placeholder="Flors: @floristeria&#10;Catering: @catering&#10;DJ: @dj" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none font-mono text-sm"></textarea>
                </label>
              </div>
            </fieldset>

            <!-- Altres -->
            <fieldset>
              <label class="block">
                <span class="text-sm font-bold text-ink/80">{TX.anythingElse} <span class="font-normal text-ink/45">· {TX.optional}</span></span>
                <span class="block text-xs text-ink/55 mb-1">{TX.anythingElseHint}</span>
                <textarea name="anything_else" rows="3" class="w-full px-3 py-2 border border-ink/15 bg-white focus:border-gold focus:outline-none"></textarea>
              </label>
            </fieldset>

            <p id="wd-error" class="hidden text-sm text-red-600">{TX.errorMsg}</p>

            <button
              type="submit"
              id="wd-submit"
              class="bg-ink text-white text-sm font-bold tracking-widest uppercase px-8 py-3 hover:bg-gold transition-colors"
              data-sending={TX.sending}
            >{TX.submit}</button>
          </form>

          <div id="wd-thanks" class="hidden">
            <h2 class="font-display text-3xl md:text-4xl font-bold mb-3">{TX.thanksH}</h2>
            <p class="text-ink/75 leading-relaxed">{TX.thanksP}</p>
          </div>
        </>
      ) : (
        <>
          <h1 class="font-display text-3xl md:text-4xl font-bold mb-3">{title}</h1>
          <p class="text-ink/75 leading-relaxed mb-8">Aquest formulari està en preparació. T'avisarem quan estigui llest!</p>
          <p class="text-sm text-ink/55">Token: <code class="font-mono">{token}</code> · Form kind: <code class="font-mono">{formKind}</code></p>
        </>
      )}
    </div>
  </section>

  <footer class="px-6 md:px-12 py-8 bg-ink text-white/70 text-center text-xs">
    <p>© {new Date().getFullYear()} Lifetime Weddings</p>
  </footer>
</BaseLayout>

<script>
  const form = document.getElementById('wd-form') as HTMLFormElement | null;
  if (form) {
    const submitBtn = document.getElementById('wd-submit') as HTMLButtonElement;
    const errorEl = document.getElementById('wd-error') as HTMLElement;
    const thanksEl = document.getElementById('wd-thanks') as HTMLElement;
    const token = form.dataset.token!;
    const defaultLabel = submitBtn.textContent;

    // Conditional reveals: show a wrapped block when its driver select has
    // the matching value. Hidden blocks are skipped on submit so stale
    // values never get stored.
    function bindReveal(selectId: string, wrapId: string, showValues: string[]) {
      const sel = document.getElementById(selectId) as HTMLSelectElement | null;
      const wrap = document.getElementById(wrapId) as HTMLElement | null;
      if (!sel || !wrap) return;
      const sync = () => {
        if (showValues.includes(sel.value)) wrap.removeAttribute('hidden');
        else wrap.setAttribute('hidden', '');
      };
      sel.addEventListener('change', sync);
      sync();
    }
    bindReveal('live_music', 'lm-details-wrap', ['si']);
    bindReveal('insta_consent', 'insta-fields-wrap', ['si']);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = submitBtn.dataset.sending ?? 'Sending…';

      // Collect non-empty fields, skipping any inside a hidden conditional
      // block so we don't persist values the couple can't see.
      const data: Record<string, string> = {};
      const fields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('input[name], textarea[name], select[name]');
      fields.forEach((el) => {
        if (el.closest('[data-cond][hidden]')) return;
        const val = el.value.trim();
        if (val) data[el.name] = val;
      });

      try {
        const res = await fetch('/api/formulari/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, data }),
        });
        if (!res.ok) throw new Error(`status ${res.status}`);
        form.classList.add('hidden');
        thanksEl.classList.remove('hidden');
        thanksEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch (err) {
        console.error('[wd-form] submit failed', err);
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = defaultLabel;
      }
    });
  }
</script>
