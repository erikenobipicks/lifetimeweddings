---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomePage from '~/components/HomePage.astro';
import { localBusinessJsonLd, personJsonLd } from '~/lib/seo';
import { TEAM } from '~/data/team';

const lang = 'ca' as const;

const jsonLd = [
  localBusinessJsonLd(lang),
  ...TEAM.map((m) => personJsonLd({
    name: m.name,
    role: m.role[lang],
    url: m.instagram,
    sameAs: [m.instagram],
  })),
];
---

<BaseLayout
  lang={lang}
  title="Fotògrafs de bodes a Tarragona, Reus i Lleida | Lifetime Weddings"
  description="Dos germans, segona generació de fotògrafs. Fotografia i vídeo documental de bodes a Catalunya. Reportatge natural, sense posats. Consulta disponibilitat."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <HomePage lang={lang} />
</BaseLayout>
