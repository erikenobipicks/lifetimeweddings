---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomePage from '~/components/HomePage.astro';
import { homeJsonLd } from '~/lib/seo';

const lang = 'ca' as const;
const jsonLd = await homeJsonLd(lang);
---

<BaseLayout
  lang={lang}
  title="Fotògrafs de bodes a Tarragona, Reus i Lleida | Lifetime Weddings"
  description="Dos germans, segona generació de fotògrafs. Fotografia i vídeo documental de bodes a Catalunya. Reportatge natural, sense posats. Consulta disponibilitat."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <HomePage lang={lang} />
</BaseLayout>
