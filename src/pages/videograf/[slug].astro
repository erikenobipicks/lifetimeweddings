---
// Private, chromeless video-only landing for a specific collaboration link
// created in /admin/videograf. Same page as /videograf, but its config
// (language, quote on/off, featured videos, referring photographer) comes from
// the video_links row identified by <slug>. When a photographer is set, every
// contact CTA routes to them (see VideografLanding).
import BaseLayout from '~/layouts/BaseLayout.astro';
import CookieBanner from '~/components/CookieBanner.astro';
import VideografLanding from '~/components/VideografLanding.astro';
import { getVideoLinkBySlug, photographerContactHref } from '~/lib/videoLinks';
import { videos, publicVideos, fullVideos, type Video } from '~/data/videos';

const { slug } = Astro.params;
const link = slug ? await getVideoLinkBySlug(slug) : null;
if (!link || link.archived) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const lang = link.lang;

// Resolve featured videos from the catalog (never trust a stored id blindly).
function pick(id: string | null, pool: Video[]): Video | null {
  if (id) {
    const found = videos.find((v) => v.youtubeId === id);
    if (found) return found;
  }
  return pool[0] ?? null;
}
const trailer = pick(link.trailerId, publicVideos);
const full = pick(link.fullId, fullVideos);

// Referring photographer (Opció 1: all CTAs route to them). Only active when we
// have both a name and a usable contact.
const contactHref = photographerContactHref(link);
const photographer =
  link.photographerName && contactHref
    ? {
        name: link.photographerName,
        contactHref,
        // email opens the mail client in place; whatsapp/web open a new tab.
        newTab: link.photographerContactType !== 'email',
      }
    : null;

const META: Record<typeof lang, { title: string; description: string }> = {
  ca: {
    title: 'Vídeo de boda · Eric Blasco',
    description: 'Vídeo de boda documental per l’Eric Blasco. Tràiler, pel·lícula sencera i qui hi ha darrere la càmera.',
  },
  es: {
    title: 'Vídeo de boda · Eric Blasco',
    description: 'Vídeo de boda documental por Eric Blasco. Tráiler, película completa y quién está detrás de la cámara.',
  },
  en: {
    title: 'Wedding video · Eric Blasco',
    description: 'Documentary wedding video by Eric Blasco. Trailer, full film and who’s behind the camera.',
  },
};
const meta = META[lang];
---

<BaseLayout
  lang={lang}
  title={meta.title}
  description={meta.description}
  canonicalPath={`/videograf/${link.slug}`}
  noindex
  chromeless
>
  {trailer && (
    <VideografLanding
      lang={lang}
      showQuote={link.showQuote}
      trailer={trailer}
      full={full}
      photographer={photographer}
    />
  )}
  <CookieBanner lang={lang} />
</BaseLayout>
