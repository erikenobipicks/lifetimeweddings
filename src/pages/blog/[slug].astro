---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import { BLOG_POSTS, BLOG_CATEGORIES } from '~/data/blog';
import { TEAM } from '~/data/team';
import { getEntry, render } from 'astro:content';

export function getStaticPaths() {
  return BLOG_POSTS.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const lang = 'ca' as const;

const author = post.author ? TEAM.find((m) => m.id === post.author) : null;
const category = BLOG_CATEGORIES[post.category];
const fmt = (iso: string | null) =>
  iso ? new Date(iso).toLocaleDateString('ca-ES', { year: 'numeric', month: 'long', day: 'numeric' }) : null;

// Look up the Markdown body: prefer a per-language variant (`<slug>.ca.md`)
// if one exists, otherwise fall back to the canonical `<slug>` entry.
// Posts without any .md file fall back to the "in preparation" placeholder.
const entry = (await getEntry('blog', `${post.slug}.ca`)) ?? (await getEntry('blog', post.slug));
const Content = entry ? (await render(entry)).Content : null;
const description = entry?.data.description ?? post.title;
---

<BaseLayout
  lang={lang}
  title={`${post.title} | Lifetime Weddings`}
  description={description}
  canonicalPath={`/blog/${post.slug}`}
  ogImage={post.cover}
>
  {post.cover && (
    <section class="relative h-[50vh] min-h-[360px] overflow-hidden">
      <img src={post.cover} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-black/45"></div>
      <div class="relative h-full flex flex-col items-center justify-center text-center text-white px-6 pt-20">
        <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{category.ca}</p>
        <h1 class="font-display text-3xl md:text-5xl font-bold max-w-4xl">{post.title}</h1>
        <p class="mt-3 text-sm opacity-90">
          {author && <span>{author.name}</span>}
          {author && post.publishedAt && <span class="mx-2 opacity-50">·</span>}
          {post.publishedAt && <span>{fmt(post.publishedAt)}</span>}
          {post.readingTime && <span class="mx-2 opacity-50">·</span>}
          {post.readingTime && <span>{post.readingTime} min</span>}
        </p>
      </div>
    </section>
  )}

  <Section>
    <article class="max-w-2xl mx-auto prose prose-neutral prose-img:rounded-lg prose-img:my-8 prose-headings:font-display">
      {Content ? (
        <Content />
      ) : (
        <>
          <p class="text-ink/75 leading-relaxed">
            Contingut en preparació. Mentrestant, si voleu llegir aquest article podeu consultar la <a href={`https://www.lifetime.photo/post/${post.legacySlug}`} target="_blank" rel="noopener" class="text-gold underline">versió actual a lifetime.photo</a>.
          </p>
        </>
      )}
      <p class="mt-8"><a href="/blog" class="text-gold underline text-sm">← Tornar al blog</a></p>
    </article>
  </Section>
</BaseLayout>
