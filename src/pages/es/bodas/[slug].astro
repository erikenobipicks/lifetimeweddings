---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import WeddingGalleryChunk from '~/components/WeddingGalleryChunk.astro';
import { WEDDINGS, weddingCover, weddingGallery, type Wedding } from '~/data/weddings';
import { useTranslations } from '~/i18n/ui';
import { SITE, WHATSAPP_BASE } from '~/data/site';
import { breadcrumbJsonLd, imageGalleryJsonLd } from '~/lib/seo';
import { getGbpRating } from '~/lib/gbp-rating';

export function getStaticPaths() {
  return WEDDINGS.map((w) => ({ params: { slug: w.slug }, props: { wedding: w } }));
}

const { wedding } = Astro.props;
const lang = 'es' as const;
const t = useTranslations(lang);
const cover = weddingCover(wedding);
const gallery = weddingGallery(wedding);
const coverLarge = gallery[0]?.variants.lg ?? cover;
const totalPhotos = gallery.length;
const hasVenue = wedding.venue && wedding.venue !== '—';
const hasLocation = wedding.location && wedding.location !== '—';

const rating = await getGbpRating();

function galleryAlt(i: number): string {
  const nn = String(i).padStart(2, '0');
  const count = String(totalPhotos).padStart(2, '0');
  if (hasVenue && hasLocation) {
    return `Boda de ${wedding.couple} en ${wedding.venue} · ${wedding.location} · Foto ${nn} de ${count}`;
  }
  if (hasVenue) {
    return `Boda de ${wedding.couple} en ${wedding.venue} · Foto ${nn} de ${count}`;
  }
  return `Boda de ${wedding.couple} · Lifetime Weddings · Foto ${nn} de ${count}`;
}

function chunkGallery<T>(arr: T[], n: number): T[][] {
  if (arr.length === 0) return [];
  const size = Math.ceil(arr.length / n);
  const out: T[][] = [];
  for (let i = 0; i < arr.length; i += size) {
    out.push(arr.slice(i, i + size));
  }
  return out;
}
const chunks = chunkGallery(gallery, 3);
const chunkStart = (idx: number): number =>
  chunks.slice(0, idx).reduce((sum, c) => sum + c.length, 0);

const relatedAll: Wedding[] = WEDDINGS.filter(
  (w) => w.slug !== wedding.slug && weddingGallery(w).length > 0,
);
const relatedScored = relatedAll
  .map((w) => {
    const sameVenue = hasVenue && w.venue === wedding.venue ? 10 : 0;
    const sameLocation = hasLocation && w.location === wedding.location ? 5 : 0;
    const photos = weddingGallery(w).length / 1000;
    return { w, score: sameVenue + sameLocation + photos };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((x) => x.w);

const waMessage = encodeURIComponent(
  `¡Hola! Hemos visto la boda de ${wedding.couple} en vuestra web. Nos casamos y queremos saber si tenéis disponibilidad.`,
);
const waLink = `${WHATSAPP_BASE}&text=${waMessage}`;

const seoTitle = hasVenue && hasLocation
  ? `Boda de ${wedding.couple} en ${wedding.venue}, ${wedding.location} · Fotógrafo documental | Lifetime Weddings`
  : hasVenue
    ? `Boda de ${wedding.couple} en ${wedding.venue} · Fotógrafo documental | Lifetime Weddings`
    : `Boda de ${wedding.couple} · Fotógrafo documental de bodas | Lifetime Weddings`;
const seoDescription = hasVenue && hasLocation
  ? `Galería documental de la boda de ${wedding.couple} en ${wedding.venue} (${wedding.location}). Foto + vídeo en pareja, sin posados. Mira ${totalPhotos} fotografías del día.`
  : hasVenue
    ? `Galería documental de la boda de ${wedding.couple} en ${wedding.venue}. Foto + vídeo en pareja, sin posados.`
    : `Galería documental de la boda de ${wedding.couple}. Foto + vídeo en pareja, sin posados.`;

const pageUrl = `${SITE.url}/es/bodas/${wedding.slug}`;
const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/es` },
    { name: t('schema.breadcrumb.bodas'), url: `${SITE.url}/es/#portfolio` },
    { name: wedding.couple, url: pageUrl },
  ]),
  ...(gallery.length > 0
    ? [
        imageGalleryJsonLd({
          pageUrl,
          name: hasVenue ? `Boda de ${wedding.couple} en ${wedding.venue}` : `Boda de ${wedding.couple}`,
          description: seoDescription,
          contentLocation: hasVenue
            ? { name: wedding.venue, addressLocality: hasLocation ? wedding.location : undefined }
            : undefined,
          photos: gallery.map((img, i) => ({
            contentUrl: img.variants.lg,
            thumbnailUrl: img.variants.sm,
            width: img.width,
            height: img.height,
            caption: galleryAlt(i + 1),
          })),
        }),
      ]
    : []),
];

const h1 = hasVenue ? `Boda de ${wedding.couple} en ${wedding.venue}` : `Boda de ${wedding.couple}`;
---

<BaseLayout
  lang={lang}
  title={seoTitle}
  description={seoDescription}
  canonicalPath={`/bodas/${wedding.slug}`}
  jsonLd={jsonLd}
  ogImage={cover ?? '/og-default.jpg'}
  ogType="article"
>
  {cover && (
    <section class="relative h-[60vh] min-h-[420px] overflow-hidden">
      <picture>
        <source type="image/webp" srcset={coverLarge.replace(/\.jpe?g$/, '.webp')} />
        <img
          src={coverLarge}
          alt={`${h1}${hasLocation ? ' · ' + wedding.location : ''} · Reportaje documental por Lifetime Weddings`}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1920"
          height="1280"
        />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/70"></div>
      <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
        <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">Bodas · Reportaje documental</p>
        <h1 class="font-display text-3xl md:text-5xl font-bold leading-tight max-w-4xl">{h1}</h1>
        <p class="mt-3 opacity-90">
          {wedding.venue !== '—' ? wedding.venue : ''}
          {wedding.venue !== '—' && wedding.location !== '—' ? ' · ' : ''}
          {wedding.location !== '—' ? wedding.location : ''}
        </p>
      </div>
    </section>
  )}

  <section class="bg-ink text-white py-6 px-6 border-y border-gold/20">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row gap-4 sm:gap-10 items-center justify-center text-center text-sm">
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">+150</span>
        <span class="opacity-85">bodas documentadas</span>
      </div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">{rating.ratingValue.toFixed(1)}★</span>
        <span class="opacity-85">Google · {rating.reviewCount} reseñas</span>
      </div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">2</span>
        <span class="opacity-85">hermanos · foto + vídeo en un solo equipo</span>
      </div>
    </div>
  </section>

  {gallery.length === 0 ? (
    <Section>
      <div class="max-w-2xl mx-auto text-center text-ink/75 leading-relaxed">
        <p>Galería en preparación.</p>
      </div>
    </Section>
  ) : (
    <>
      <Section>
        <div class="max-w-2xl mx-auto px-2 text-center">
          <p class="text-ink/85 leading-relaxed text-base md:text-lg">
            {hasVenue && hasLocation
              ? <>Un reportaje documental de la boda de <span class="font-semibold">{wedding.couple}</span> en <span class="font-semibold">{wedding.venue}</span>, {wedding.location}. {totalPhotos} fotografías del día — sin posados, captando la emoción real entre ceremonia, cóctel y fiesta.</>
              : hasVenue
                ? <>Un reportaje documental de la boda de <span class="font-semibold">{wedding.couple}</span> en <span class="font-semibold">{wedding.venue}</span>. {totalPhotos} fotografías del día — sin posados, captando la emoción real entre ceremonia, cóctel y fiesta.</>
                : <>Un reportaje documental de la boda de <span class="font-semibold">{wedding.couple}</span>. {totalPhotos} fotografías del día — sin posados, captando la emoción real entre ceremonia, cóctel y fiesta.</>}
          </p>
        </div>
      </Section>

      <Section>
        <WeddingGalleryChunk photos={chunks[0]} startIndex={0} pageUrl={pageUrl} galleryAlt={galleryAlt} photoLabel={(i) => `Foto ${i}`} pinterestLabel="Guardar en Pinterest" />
      </Section>

      {chunks.length > 1 && (
        <section class="bg-cream py-12 md:py-16 px-6 border-y border-ink/10">
          <div class="max-w-2xl mx-auto text-center">
            <p class="text-ink/85 leading-relaxed text-base md:text-lg mb-5">
              ¿Quieres una boda documentada así{hasLocation ? ` en ${wedding.location}` : ''}? Aceptamos un máximo de 20 bodas al año — mira si tenemos tu fecha libre.
            </p>
            <a href={waLink} target="_blank" rel="noopener" class="inline-block bg-ink text-white border-2 border-ink px-7 py-3 text-sm font-bold tracking-[0.14em] uppercase hover:bg-gold hover:border-gold transition-colors">
              WhatsApp directo
            </a>
          </div>
        </section>
      )}

      {chunks[1] && (
        <Section>
          <WeddingGalleryChunk photos={chunks[1]} startIndex={chunkStart(1)} pageUrl={pageUrl} galleryAlt={galleryAlt} photoLabel={(i) => `Foto ${i}`} pinterestLabel="Guardar en Pinterest" />
        </Section>
      )}
      {chunks[2] && (
        <Section>
          <WeddingGalleryChunk photos={chunks[2]} startIndex={chunkStart(2)} pageUrl={pageUrl} galleryAlt={galleryAlt} photoLabel={(i) => `Foto ${i}`} pinterestLabel="Guardar en Pinterest" />
        </Section>
      )}

      <Section bg="cream">
        <div class="max-w-2xl mx-auto px-2 text-center">
          <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">
            {hasLocation ? `¿Quieres una boda así en ${wedding.location}?` : '¿Quieres una boda así?'}
          </h2>
          <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">
            Vamos en pareja — foto + vídeo en un solo equipo. Aceptamos un máximo de 20 bodas al año.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={waLink} target="_blank" rel="noopener" class="inline-block bg-gold text-ink border-2 border-gold px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors">
              WhatsApp directo
            </a>
            <a href="/es/quiz" class="inline-block border-2 border-ink text-ink px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors">
              Quiz de 1 minuto
            </a>
          </div>
        </div>
      </Section>

      {relatedScored.length > 0 && (
        <Section>
          <div class="max-w-6xl mx-auto px-2">
            <h2 class="font-display text-2xl md:text-3xl font-bold text-center mb-10">Otras bodas que te gustarán</h2>
            <div class="grid md:grid-cols-3 gap-6 md:gap-8">
              {relatedScored.map((w) => {
                const wG = weddingGallery(w);
                const wThumb = wG[0]?.variants.md ?? weddingCover(w) ?? '/og-default.jpg';
                const wThumbWebp = wThumb.replace(/\.jpe?g$/, '.webp');
                return (
                  <a href={`/es/bodas/${w.slug}`} class="block group">
                    <div class="relative overflow-hidden aspect-[4/5]">
                      <picture>
                        <source type="image/webp" srcset={wThumbWebp} />
                        <img src={wThumb} alt={`Boda de ${w.couple}${w.venue !== '—' ? ' en ' + w.venue : ''}`} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" width="800" height="1000" />
                      </picture>
                      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
                      <div class="absolute bottom-4 left-4 right-4 text-white">
                        <p class="font-display italic text-xl leading-tight" style="font-weight: 400; letter-spacing: -0.01em;">{w.couple}</p>
                        {w.venue !== '—' && <p class="text-xs uppercase tracking-[0.12em] text-white/80 mt-1">{w.venue}</p>}
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </Section>
      )}
    </>
  )}
</BaseLayout>
