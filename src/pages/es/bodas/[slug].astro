---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import { WEDDINGS, weddingCover, weddingGallery } from '~/data/weddings';
import { useTranslations } from '~/i18n/ui';
import { SITE } from '~/data/site';
import { breadcrumbJsonLd, imageGalleryJsonLd } from '~/lib/seo';

export function getStaticPaths() {
  return WEDDINGS.map((w) => ({ params: { slug: w.slug }, props: { wedding: w } }));
}

const { wedding } = Astro.props;
const lang = 'es' as const;
const t = useTranslations(lang);
const cover = weddingCover(wedding);
const gallery = weddingGallery(wedding);
const coverLarge = gallery[0]?.variants.lg ?? cover;
const totalPhotos = gallery.length;
const hasVenue = wedding.venue && wedding.venue !== '—';
const hasLocation = wedding.location && wedding.location !== '—';

/** Alt text for gallery image i (1-indexed position). Never empty. */
function galleryAlt(i: number): string {
  const nn = String(i).padStart(2, '0');
  const count = String(totalPhotos).padStart(2, '0');
  if (hasVenue && hasLocation) {
    return `Boda de ${wedding.couple} en ${wedding.venue} · ${wedding.location} · Foto ${nn} de ${count}`;
  }
  if (hasVenue) {
    return `Boda de ${wedding.couple} en ${wedding.venue} · Foto ${nn} de ${count}`;
  }
  return `Boda de ${wedding.couple} · Lifetime Weddings · Foto ${nn} de ${count}`;
}

const pageUrl = `${SITE.url}/es/bodas/${wedding.slug}`;
const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/es` },
    { name: t('schema.breadcrumb.bodas'), url: `${SITE.url}/es/#portfolio` },
    { name: wedding.couple, url: pageUrl },
  ]),
  ...(gallery.length > 0
    ? [
        imageGalleryJsonLd({
          pageUrl,
          name: hasVenue
            ? `Boda de ${wedding.couple} en ${wedding.venue}`
            : `Boda de ${wedding.couple}`,
          description: hasVenue && hasLocation
            ? `Galería de la boda de ${wedding.couple} en ${wedding.venue} (${wedding.location}).`
            : `Galería de la boda de ${wedding.couple}.`,
          contentLocation: hasVenue
            ? { name: wedding.venue, addressLocality: hasLocation ? wedding.location : undefined }
            : undefined,
          photos: gallery.map((img, i) => ({
            contentUrl: img.variants.lg,
            thumbnailUrl: img.variants.sm,
            width: img.width,
            height: img.height,
            caption: galleryAlt(i + 1),
          })),
        }),
      ]
    : []),
];
---

<BaseLayout
  lang={lang}
  title={wedding.venue && wedding.venue !== '—'
    ? `${wedding.couple} · ${wedding.venue} · Lifetime Weddings`
    : `${wedding.couple} · Lifetime Weddings`}
  description={wedding.venue && wedding.venue !== '—'
    ? `Galería de la boda de ${wedding.couple} en ${wedding.venue} (${wedding.location}).`
    : `Galería de la boda de ${wedding.couple}.`}
  canonicalPath={`/bodas/${wedding.slug}`}
  jsonLd={jsonLd}
  ogImage={cover ?? '/og-default.jpg'}
  ogType="article"
>
  {cover && (
    <section class="relative h-[60vh] min-h-[420px] overflow-hidden">
      <img
        src={coverLarge}
        alt={wedding.venue && wedding.venue !== '—' ? `${wedding.couple} · ${wedding.venue}` : wedding.couple}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1280"
      />
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
        <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">Bodas</p>
        <h1 class="font-display text-4xl md:text-5xl font-bold">{wedding.couple}</h1>
        <p class="mt-3 opacity-90">{wedding.venue !== '—' ? wedding.venue : ''} {wedding.venue !== '—' && wedding.location !== '—' ? '·' : ''} {wedding.location !== '—' ? wedding.location : ''}</p>
      </div>
    </section>
  )}

  {gallery.length > 0 ? (
    <Section>
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-3">
          {gallery.map((img, i) => {
            const span = img.orientation === 'landscape' ? 'md:col-span-2' : '';
            const description = galleryAlt(i + 1);
            const pinterestUrl = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(pageUrl)}&media=${encodeURIComponent(new URL(img.variants.lg, SITE.url).toString())}&description=${encodeURIComponent(description)}`;
            return (
              <div class:list={['relative overflow-hidden group', span]}>
                <a
                  href={img.variants.lg}
                  target="_blank"
                  rel="noopener"
                  class="block"
                  aria-label={`Foto ${i + 1}`}
                >
                  <img
                    src={img.variants.md}
                    srcset={`${img.variants.sm} 640w, ${img.variants.md} 1200w, ${img.variants.lg} 1920w`}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                    alt={description}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading={i < 2 ? 'eager' : 'lazy'}
                    fetchpriority={i === 0 ? 'high' : 'auto'}
                    decoding="async"
                    width={img.width}
                    height={img.height}
                  />
                </a>
                <a
                  href={pinterestUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Guardar en Pinterest"
                  data-pin-do="none"
                  class="absolute top-3 right-3 w-9 h-9 rounded-full bg-white/90 hover:bg-white text-[#E60023] flex items-center justify-center opacity-70 md:opacity-0 md:group-hover:opacity-100 transition-opacity shadow-md"
                >
                  <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
                    <path d="M12 0a12 12 0 0 0-4.37 23.17c-.1-.93-.2-2.36.04-3.38.22-.92 1.4-5.85 1.4-5.85s-.36-.72-.36-1.78c0-1.66.96-2.9 2.16-2.9 1.02 0 1.51.77 1.51 1.69 0 1.03-.66 2.57-1 4-.28 1.2.6 2.17 1.78 2.17 2.13 0 3.77-2.25 3.77-5.5 0-2.88-2.07-4.89-5.02-4.89-3.42 0-5.43 2.57-5.43 5.22 0 1.03.4 2.14.9 2.74.1.12.11.22.08.34l-.34 1.36c-.05.22-.17.27-.4.16-1.5-.7-2.42-2.88-2.42-4.64 0-3.78 2.74-7.25 7.91-7.25 4.15 0 7.38 2.96 7.38 6.92 0 4.13-2.6 7.46-6.21 7.46-1.21 0-2.36-.63-2.75-1.38l-.75 2.86c-.27 1.04-1 2.34-1.49 3.13A12 12 0 1 0 12 0z" />
                  </svg>
                </a>
              </div>
            );
          })}
        </div>
      </div>
    </Section>
  ) : (
    <Section>
      <div class="max-w-2xl mx-auto text-center text-ink/75 leading-relaxed">
        <p>Galería en preparación.</p>
      </div>
    </Section>
  )}
</BaseLayout>
