---
import BaseLayout from '~/layouts/BaseLayout.astro';
import LandingPage from '~/components/LandingPage.astro';
import { landingBySlug } from '~/data/landings';

const slug = Astro.params.slug;
const landing = slug ? landingBySlug(slug) : undefined;

if (!landing) return Astro.redirect('/es/contacto', 302);

const lang = 'es' as const;
const c = landing.copy[lang];
---

<BaseLayout
  lang={lang}
  title={c.metaTitle}
  description={c.metaDesc}
  canonicalPath={`/ofertes/${landing.slug}`}
  noindex
>
  <LandingPage lang={lang} landing={landing} />
</BaseLayout>
