---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import { BLOG_POSTS, BLOG_CATEGORIES, type BlogCategory } from '~/data/blog';
import { useTranslations } from '~/i18n/ui';
import { SITE } from '~/data/site';
import { breadcrumbJsonLd } from '~/lib/seo';

export function getStaticPaths() {
  return Object.entries(BLOG_CATEGORIES).map(([key, value]) => ({
    params: { slug: value.slug },
    props: { category: key as BlogCategory },
  }));
}

const { category } = Astro.props;
const lang = 'es' as const;
const t = useTranslations(lang);
const meta = BLOG_CATEGORIES[category];

const posts = BLOG_POSTS
  .filter((p) => p.category === category)
  .sort((a, b) => (a.updatedAt < b.updatedAt ? 1 : -1));

const fmtDate = (iso: string | null): string =>
  iso ? new Date(iso).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' }) : '';

const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/es` },
    { name: t('schema.breadcrumb.blog'), url: `${SITE.url}/es/blog` },
    { name: meta.es, url: `${SITE.url}/es/blog/categoria/${meta.slug}` },
  ]),
];
---

<BaseLayout
  lang={lang}
  title={`${meta.es} | Blog | Lifetime Weddings`}
  description={`Artículos del blog de Lifetime Weddings sobre ${meta.es.toLowerCase()}.`}
  canonicalPath={`/blog/categoria/${meta.slug}`}
  jsonLd={jsonLd}
>
  <Section bg="cream" class="pt-32">
    <div class="max-w-6xl mx-auto">
      <nav aria-label="Breadcrumb" class="text-xs text-ink/70 mb-6 text-center">
        <a href="/es/blog" class="hover:text-gold">Blog</a>
        <span class="mx-2 opacity-50">·</span>
        <span>{meta.es}</span>
      </nav>

      <div class="text-center mb-12">
        <h1 class="font-display text-4xl md:text-5xl font-bold mb-3">{meta.es}</h1>
        <p class="text-ink/75">{posts.length} {posts.length === 1 ? 'artículo' : 'artículos'}</p>
      </div>

      <nav aria-label="Categorías" class="flex flex-wrap justify-center gap-3 mb-12 text-xs font-bold tracking-widest uppercase">
        <a href="/es/blog" class="px-4 py-2 border border-ink/20 hover:bg-ink hover:text-white transition-colors">Todas</a>
        {Object.entries(BLOG_CATEGORIES).map(([key, c]) => (
          <a
            href={`/es/blog/categoria/${c.slug}`}
            class={`px-4 py-2 transition-colors ${key === category ? 'bg-ink text-white' : 'border border-ink/20 hover:bg-ink hover:text-white'}`}
          >
            {c.es}
          </a>
        ))}
      </nav>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((p) => (
          <article class="bg-white border border-line group">
            <a href={`/es/blog/${p.slug}`} class="block">
              {p.cover ? (
                <img
                  src={p.cover}
                  alt={p.title}
                  class="w-full aspect-[4/3] object-cover group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                  decoding="async"
                  width="1200"
                  height="900"
                />
              ) : (
                <div class="w-full aspect-[4/3] bg-cream flex items-center justify-center text-ink/30 text-sm">Próximamente</div>
              )}
              <div class="p-6">
                <p class="text-[0.7rem] font-bold tracking-[0.18em] uppercase text-gold-deep mb-2">
                  {BLOG_CATEGORIES[p.category].es}
                  {p.readingTime ? <span class="text-ink/70"> · {p.readingTime} min</span> : null}
                </p>
                <h2 class="font-display text-xl font-bold leading-tight mb-3 group-hover:text-gold transition-colors">
                  {p.title}
                </h2>
                {p.publishedAt && (
                  <p class="text-xs text-ink/70">{fmtDate(p.publishedAt)}</p>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </Section>
</BaseLayout>
