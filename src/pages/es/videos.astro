---
import BaseLayout from '~/layouts/BaseLayout.astro';
import VideosPage from '~/components/VideosPage.astro';
import { videos, videoThumb, videoEmbed, videoWatch } from '~/data/videos';
import { useTranslations } from '~/i18n/ui';
import { SITE } from '~/data/site';
import { breadcrumbJsonLd, ID } from '~/lib/seo';

const lang = 'es' as const;
const t = useTranslations(lang);

const videoBlocks = videos.map((v) => ({
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: `Tráiler de boda · ${v.coupleName}`,
  description: `Tráiler de boda de ${v.coupleName} en ${v.venue}.`,
  thumbnailUrl: [videoThumb(v.youtubeId)],
  uploadDate: v.date,
  contentUrl: videoWatch(v.youtubeId),
  embedUrl: videoEmbed(v.youtubeId),
  publisher: { '@id': ID.business },
}));

const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/es` },
    { name: t('schema.breadcrumb.videos'), url: `${SITE.url}/es/videos` },
  ]),
  ...videoBlocks,
];
---

<BaseLayout
  lang={lang}
  title="Vídeos de boda · Tráilers reales | Lifetime Weddings"
  description="Tráilers de bodas filmadas por Lifetime Weddings en Tarragona, Reus y por toda Cataluña. Estilo documental, sin poses forzadas."
  canonicalPath="/videos"
  jsonLd={jsonLd}
>
  <VideosPage lang={lang} />
</BaseLayout>
