---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import BookingRequestForm from '~/components/sections/BookingRequestForm.astro';
import { SITE } from '~/data/site';
import { useTranslations } from '~/i18n/ui';
import { breadcrumbJsonLd } from '~/lib/seo';

const lang = 'es' as const;
const t = useTranslations(lang);

const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/es` },
    { name: 'Solicitar reserva', url: `${SITE.url}/es/sol-licitar-reserva` },
  ]),
];
---

<BaseLayout
  lang={lang}
  title="Solicitar reserva | Lifetime Weddings"
  description="Solicita nuestra cobertura de foto y vídeo para tu boda. Respuesta con propuesta personalizada en menos de 24h."
  canonicalPath="/sol-licitar-reserva"
  jsonLd={jsonLd}
  noindex
>
  <Section bg="cream" class="pt-28 pb-16">
    <BookingRequestForm lang={lang} />
  </Section>
</BaseLayout>
