---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomePage from '~/components/HomePage.astro';
import { localBusinessJsonLd, personJsonLd } from '~/lib/seo';
import { TEAM } from '~/data/team';

const lang = 'es' as const;

const jsonLd = [
  localBusinessJsonLd(lang),
  ...TEAM.map((m) => personJsonLd({
    name: m.name,
    role: m.role[lang],
    url: m.instagram,
    sameAs: [m.instagram],
  })),
];
---

<BaseLayout
  lang={lang}
  title="Fotógrafos de bodas en Tarragona, Reus y Lleida | Lifetime Weddings"
  description="Dos hermanos, segunda generación de fotógrafos. Fotografía y vídeo documental de bodas en Cataluña. Reportaje natural, sin poses. Consulta disponibilidad."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <HomePage lang={lang} />
</BaseLayout>
