---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomePage from '~/components/HomePage.astro';
import { homeJsonLd } from '~/lib/seo';

const lang = 'es' as const;
const jsonLd = homeJsonLd(lang);
---

<BaseLayout
  lang={lang}
  title="Fotógrafos de bodas en Tarragona, Reus y Lleida | Lifetime Weddings"
  description="Dos hermanos, segunda generación de fotógrafos. Fotografía y vídeo documental de bodas en Cataluña. Reportaje natural, sin poses. Consulta disponibilidad."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <HomePage lang={lang} />
</BaseLayout>
