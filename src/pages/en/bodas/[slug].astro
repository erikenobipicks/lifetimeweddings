---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import WeddingGalleryChunk from '~/components/WeddingGalleryChunk.astro';
import { WEDDINGS, weddingCover, weddingGallery } from '~/data/weddings';
import { useTranslations } from '~/i18n/ui';
import { SITE, WHATSAPP_BASE } from '~/data/site';
import { breadcrumbJsonLd, imageGalleryJsonLd } from '~/lib/seo';

export function getStaticPaths() {
  return WEDDINGS.map((w) => ({ params: { slug: w.slug }, props: { wedding: w } }));
}

const { wedding } = Astro.props;
const lang = 'en' as const;
const t = useTranslations(lang);
const cover = weddingCover(wedding);
const gallery = weddingGallery(wedding);
const coverLarge = gallery[0]?.variants.lg ?? cover;
const totalPhotos = gallery.length;
const hasVenue = wedding.venue && wedding.venue !== '—';
const hasLocation = wedding.location && wedding.location !== '—';

/** Alt text for gallery image i (1-indexed position). Never empty. */
function galleryAlt(i: number): string {
  const nn = String(i).padStart(2, '0');
  const count = String(totalPhotos).padStart(2, '0');
  if (hasVenue && hasLocation) {
    return `${wedding.couple}'s wedding at ${wedding.venue} · ${wedding.location} · Photo ${nn} of ${count}`;
  }
  if (hasVenue) {
    return `${wedding.couple}'s wedding at ${wedding.venue} · Photo ${nn} of ${count}`;
  }
  return `${wedding.couple}'s wedding · Lifetime Weddings · Photo ${nn} of ${count}`;
}

function chunkGallery<T>(arr: T[], n: number): T[][] {
  if (arr.length === 0) return [];
  const size = Math.ceil(arr.length / n);
  const out: T[][] = [];
  for (let i = 0; i < arr.length; i += size) {
    out.push(arr.slice(i, i + size));
  }
  return out;
}
const chunks = chunkGallery(gallery, 3);
const chunkStart = (idx: number): number =>
  chunks.slice(0, idx).reduce((sum, c) => sum + c.length, 0);

const waMessage = encodeURIComponent(
  `Hi! We saw ${wedding.couple}'s wedding on your site. We're getting married and would love to know if you're available.`,
);
const waLink = `${WHATSAPP_BASE}&text=${waMessage}`;

const pageUrl = `${SITE.url}/en/bodas/${wedding.slug}`;
const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}/en` },
    { name: t('schema.breadcrumb.bodas'), url: `${SITE.url}/en/#portfolio` },
    { name: wedding.couple, url: pageUrl },
  ]),
  ...(gallery.length > 0
    ? [
        imageGalleryJsonLd({
          pageUrl,
          name: hasVenue
            ? `${wedding.couple}'s wedding at ${wedding.venue}`
            : `${wedding.couple}'s wedding`,
          description: hasVenue && hasLocation
            ? `Gallery of ${wedding.couple}'s wedding at ${wedding.venue} (${wedding.location}).`
            : `Gallery of ${wedding.couple}'s wedding.`,
          contentLocation: hasVenue
            ? { name: wedding.venue, addressLocality: hasLocation ? wedding.location : undefined }
            : undefined,
          photos: gallery.map((img, i) => ({
            contentUrl: img.variants.lg,
            thumbnailUrl: img.variants.sm,
            width: img.width,
            height: img.height,
            caption: galleryAlt(i + 1),
          })),
        }),
      ]
    : []),
];
---

<BaseLayout
  lang={lang}
  title={wedding.venue && wedding.venue !== '—'
    ? `${wedding.couple} · ${wedding.venue} · Lifetime Weddings`
    : `${wedding.couple} · Lifetime Weddings`}
  description={wedding.venue && wedding.venue !== '—'
    ? `Gallery of ${wedding.couple}'s wedding at ${wedding.venue} (${wedding.location}).`
    : `Gallery of ${wedding.couple}'s wedding.`}
  canonicalPath={`/bodas/${wedding.slug}`}
  jsonLd={jsonLd}
  ogImage={cover ?? '/og-default.jpg'}
  ogType="article"
>
  {cover && (
    <section class="relative h-[60vh] min-h-[420px] overflow-hidden">
      <picture>
        <source type="image/webp" srcset={coverLarge.replace(/\.jpe?g$/, '.webp')} />
        <img
          src={coverLarge}
          alt={wedding.venue && wedding.venue !== '—' ? `${wedding.couple} · ${wedding.venue}` : wedding.couple}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1920"
          height="1280"
        />
      </picture>
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
        <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">Weddings</p>
        <h1 class="font-display text-4xl md:text-5xl font-bold">{wedding.couple}</h1>
        <p class="mt-3 opacity-90">{wedding.venue !== '—' ? wedding.venue : ''} {wedding.venue !== '—' && wedding.location !== '—' ? '·' : ''} {wedding.location !== '—' ? wedding.location : ''}</p>
      </div>
    </section>
  )}

  {gallery.length === 0 ? (
    <Section>
      <div class="max-w-2xl mx-auto text-center text-ink/75 leading-relaxed">
        <p>Gallery in preparation.</p>
      </div>
    </Section>
  ) : (
    <>
      <Section>
        <div class="max-w-2xl mx-auto px-2 text-center">
          <p class="text-ink/85 leading-relaxed text-base md:text-lg">
            {hasVenue && hasLocation
              ? <>A day documented at <span class="font-semibold">{wedding.venue}</span>, {wedding.location}. {totalPhotos} photographs from <span class="font-semibold">{wedding.couple}</span>'s wedding — no posing, capturing the day as it happened.</>
              : hasVenue
                ? <>A day documented at <span class="font-semibold">{wedding.venue}</span>. {totalPhotos} photographs from <span class="font-semibold">{wedding.couple}</span>'s wedding — no posing, capturing the day as it happened.</>
                : <>{totalPhotos} photographs from <span class="font-semibold">{wedding.couple}</span>'s wedding — no posing, capturing the day as it happened.</>}
          </p>
        </div>
      </Section>

      <Section>
        <WeddingGalleryChunk
          photos={chunks[0]}
          startIndex={0}
          pageUrl={pageUrl}
          galleryAlt={galleryAlt}
          photoLabel={(i) => `Photo ${i}`}
          pinterestLabel="Save to Pinterest"
        />
      </Section>

      {chunks.length > 1 && (
        <section class="bg-cream py-12 md:py-16 px-6 border-y border-ink/10">
          <div class="max-w-2xl mx-auto text-center">
            <p class="text-ink/85 leading-relaxed text-base md:text-lg mb-5">
              Want a wedding documented like this? We accept a max of 20 weddings per year — check if your date is still open.
            </p>
            <a
              href={waLink}
              target="_blank"
              rel="noopener"
              class="inline-block bg-ink text-white border-2 border-ink px-7 py-3 text-sm font-bold tracking-[0.14em] uppercase hover:bg-gold hover:border-gold transition-colors"
            >
              WhatsApp us
            </a>
          </div>
        </section>
      )}

      {chunks[1] && (
        <Section>
          <WeddingGalleryChunk
            photos={chunks[1]}
            startIndex={chunkStart(1)}
            pageUrl={pageUrl}
            galleryAlt={galleryAlt}
            photoLabel={(i) => `Photo ${i}`}
            pinterestLabel="Save to Pinterest"
          />
        </Section>
      )}

      {chunks[2] && (
        <Section>
          <WeddingGalleryChunk
            photos={chunks[2]}
            startIndex={chunkStart(2)}
            pageUrl={pageUrl}
            galleryAlt={galleryAlt}
            photoLabel={(i) => `Photo ${i}`}
            pinterestLabel="Save to Pinterest"
          />
        </Section>
      )}

      <Section bg="cream">
        <div class="max-w-2xl mx-auto px-2 text-center">
          <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">
            Want a wedding like this?
          </h2>
          <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">
            We work as a team of two — photo + video, one crew. Max 20 weddings per year.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href={waLink}
              target="_blank"
              rel="noopener"
              class="inline-block bg-gold text-ink border-2 border-gold px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors"
            >
              WhatsApp us
            </a>
            <a
              href="/en/quiz"
              class="inline-block border-2 border-ink text-ink px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors"
            >
              1-minute quiz
            </a>
          </div>
        </div>
      </Section>
    </>
  )}
</BaseLayout>
