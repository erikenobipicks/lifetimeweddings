---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ContactForm from '~/components/sections/ContactForm.astro';
import Section from '~/components/Section.astro';
import { SITE } from '~/data/site';
import { useTranslations } from '~/i18n/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<BaseLayout
  lang={lang}
  title="Contact | Lifetime Weddings"
  description="Let’s talk about your wedding. Drop us a line and we’ll get back to you very soon with all the info."
  canonicalPath="/contacto"
>
  <Section bg="cream" class="pt-32">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Let’s talk…</h1>
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-4">Wedding photo &amp; video</p>
      <p class="text-ink/75 leading-relaxed max-w-xl mx-auto">
        Looking for a professional wedding photographer and videographer? Leave us your details and we’ll get in touch very soon.
      </p>
    </div>
  </Section>

  <ContactForm lang={lang} compact />

  <Section>
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">{t('contact.where.title')}</h2>
      <p class="text-ink/75 leading-relaxed mb-6">{t('contact.where.desc')}</p>
      <address class="not-italic space-y-1 text-ink/80">
        <p><strong>{SITE.address.street}</strong> · {SITE.address.city} ({SITE.address.region})</p>
        <p>
          <a href={`mailto:${SITE.email}`} class="text-gold hover:underline">{SITE.email}</a>
          <span class="mx-2 opacity-50">·</span>
          <a href={`tel:${SITE.phone}`} class="text-gold hover:underline">{SITE.phoneDisplay}</a>
        </p>
      </address>
    </div>
  </Section>
</BaseLayout>
