---
import BaseLayout from '~/layouts/BaseLayout.astro';
import VideosPage from '~/components/VideosPage.astro';
import { videos, videoThumb, videoEmbed, videoWatch } from '~/data/videos';

const lang = 'en' as const;

const jsonLd = videos.map((v) => ({
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: `Wedding trailer · ${v.coupleName}`,
  description: `Wedding trailer of ${v.coupleName} at ${v.venue}.`,
  thumbnailUrl: [videoThumb(v.youtubeId)],
  uploadDate: v.date,
  contentUrl: videoWatch(v.youtubeId),
  embedUrl: videoEmbed(v.youtubeId),
  publisher: {
    '@type': 'Organization',
    name: 'Lifetime Weddings',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.lifetime.photo/logos/logo-circle-color.png',
    },
  },
}));
---

<BaseLayout
  lang={lang}
  title="Wedding videos · Real trailers | Lifetime Weddings"
  description="Wedding trailers filmed by Lifetime Weddings in Tarragona, Reus and across Catalonia. Documentary style, no forced poses."
  canonicalPath="/videos"
  jsonLd={jsonLd}
>
  <VideosPage lang={lang} />
</BaseLayout>
