---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomePage from '~/components/HomePage.astro';
import { localBusinessJsonLd, personJsonLd } from '~/lib/seo';
import { TEAM } from '~/data/team';

const lang = 'en' as const;

const jsonLd = [
  localBusinessJsonLd(lang),
  ...TEAM.map((m) => personJsonLd({
    name: m.name,
    role: m.role[lang],
    url: m.instagram,
    sameAs: [m.instagram],
  })),
];
---

<BaseLayout
  lang={lang}
  title="Wedding photographers in Tarragona, Reus & Lleida | Lifetime Weddings"
  description="Two brothers, second-generation photographers. Documentary wedding photo and film across Catalonia. Natural, never posed. Check availability."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <HomePage lang={lang} />
</BaseLayout>
