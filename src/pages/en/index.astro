---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HomePage from '~/components/HomePage.astro';
import { homeJsonLd } from '~/lib/seo';

const lang = 'en' as const;
const jsonLd = await homeJsonLd(lang);
---

<BaseLayout
  lang={lang}
  title="Wedding photographers in Tarragona, Reus & Lleida | Lifetime Weddings"
  description="Two brothers, second-generation photographers. Documentary wedding photo and film across Catalonia. Natural, never posed. Check availability."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <HomePage lang={lang} />
</BaseLayout>
