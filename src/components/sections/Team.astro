---
import Section from '../Section.astro';
import { useTranslations, type Lang } from '~/i18n/ui';
import { TEAM } from '~/data/team';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Section id="team">
  <div class="max-w-6xl mx-auto">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('team.label')}</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold leading-tight mb-6">
        {t('team.title')} <em class="italic text-gold font-normal">{t('team.title.em')}</em>
      </h2>
      <p class="text-ink/70 leading-relaxed">{t('team.intro')}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 md:gap-16 max-w-5xl mx-auto">
      {TEAM.map((m) => (
        <article class="text-center">
          <img
            src={m.photo}
            alt={`${m.name} — ${m.role[lang]}`}
            class="w-44 h-44 md:w-52 md:h-52 rounded-full object-cover mx-auto mb-6 ring-4 ring-cream"
            loading="lazy"
            decoding="async"
            width="208"
            height="208"
          />
          <h3 class="font-display text-2xl font-bold mb-1">{m.name}</h3>
          <p class="text-xs font-bold tracking-[0.18em] uppercase text-gold mb-4">{m.role[lang]}</p>
          <a
            href={m.instagram}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 text-xs font-bold tracking-[0.12em] uppercase text-ink hover:text-gold transition-colors mb-5"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Instagram
          </a>
          <div class="text-left max-w-md mx-auto space-y-4 text-ink/75 leading-relaxed text-[0.95rem]">
            {m.bio[lang].map((p) => <p>{p}</p>)}
            <p class="font-medium text-ink">{m.cta[lang]}</p>
          </div>
        </article>
      ))}
    </div>

    <p class="text-center text-ink/75 mt-14 max-w-2xl mx-auto">{t('team.cta')}</p>
  </div>
</Section>
