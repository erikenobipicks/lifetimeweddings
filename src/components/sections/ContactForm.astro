---
import Section from '../Section.astro';
import { useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  /** Render compact (without label+title block), for when used inside /contacto page */
  compact?: boolean;
}
const { lang, compact = false } = Astro.props;
const t = useTranslations(lang);

// Turnstile sitekey. If not configured, the widget is skipped entirely and
// the server also skips verification — forms keep working in dev/staging.
const turnstileSitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '';
---

<Section id="contact" bg="cream">
  <div class="max-w-xl mx-auto text-center">
    {!compact && (
      <>
        <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('contact.label')}</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-5">{t('contact.title')}</h2>
        <p class="text-ink/75 leading-relaxed mb-10">{t('contact.subtitle')}</p>
      </>
    )}

    <form
      class="grid gap-5 text-left"
      data-contact-form
      action="/api/contact"
      method="POST"
      novalidate
    >
      <input type="hidden" name="_language" value={lang} />
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

      <div>
        <label for="name" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{t('contact.field.name')} *</label>
        <input id="name" name="name" type="text" required autocomplete="name"
               class="w-full px-4 py-3 border border-black/15 bg-white focus:border-gold focus:outline-none transition-colors" />
      </div>

      <div>
        <label for="email" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{t('contact.field.email')} *</label>
        <input id="email" name="email" type="email" required autocomplete="email"
               class="w-full px-4 py-3 border border-black/15 bg-white focus:border-gold focus:outline-none transition-colors" />
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label for="wedding_date" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{t('contact.field.date')}</label>
          <input id="wedding_date" name="wedding_date" type="text" placeholder={t('contact.date.placeholder')}
                 class="w-full px-4 py-3 border border-black/15 bg-white focus:border-gold focus:outline-none transition-colors" />
        </div>
        <div>
          <label for="venue" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{t('contact.field.venue')}</label>
          <input id="venue" name="venue" type="text"
                 class="w-full px-4 py-3 border border-black/15 bg-white focus:border-gold focus:outline-none transition-colors" />
        </div>
      </div>

      <div>
        <label for="message" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{t('contact.field.message')}</label>
        <textarea id="message" name="message" rows="4" placeholder={t('contact.placeholder.message')}
                  class="w-full px-4 py-3 border border-black/15 bg-white focus:border-gold focus:outline-none transition-colors resize-y"></textarea>
      </div>

      <label class="flex items-start gap-2 text-sm text-ink/75">
        <input type="checkbox" name="consent" required class="mt-1 accent-gold" />
        <span>{t('contact.field.consent')}</span>
      </label>

      {turnstileSitekey && (
        <div class="cf-turnstile flex justify-center" data-sitekey={turnstileSitekey} data-theme="light" data-size="flexible"></div>
      )}

      <div class="flex flex-col items-center gap-3">
        <button
          type="submit"
          class="border-2 border-ink bg-ink text-white px-14 py-4 text-xs font-bold tracking-[0.18em] uppercase hover:bg-gold hover:border-gold transition-colors"
        >
          {t('contact.submit')}
        </button>
        <p class="text-xs text-ink/60">{t('contact.microcopy')}</p>
      </div>

      <p class="hidden text-center font-display italic text-gold" data-contact-success>{t('contact.success')}</p>
      <p class="hidden text-center text-red-600" data-contact-error>{t('contact.error')}</p>
    </form>
  </div>
</Section>

{turnstileSitekey && (
  <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
)}

<script>
  // Intercept the submit and POST via fetch so we can swap the success/error
  // message inline instead of navigating away on failure.
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  const ok = document.querySelector<HTMLElement>('[data-contact-success]');
  const err = document.querySelector<HTMLElement>('[data-contact-error]');
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    ok?.classList.add('hidden');
    err?.classList.add('hidden');
    if (submitBtn) submitBtn.disabled = true;

    try {
      // Send as JSON, not multipart. Astro 5's security.checkOrigin rejects
      // multipart/form-data POSTs with 403 "Cross-site POST form submissions
      // are forbidden" when a proxy (Cloudflare/Railway) strips or rewrites
      // the Origin header — which is what was happening in production.
      const payload: Record<string, string> = {};
      for (const [k, v] of new FormData(form).entries()) payload[k] = String(v);

      // Cloudflare Turnstile injects its token into a hidden input named
      // `cf-turnstile-response`. Move it into the `captchaToken` field the
      // server expects. Absent when the widget isn't configured.
      const tkInput = form.querySelector<HTMLInputElement>('input[name="cf-turnstile-response"]');
      if (tkInput?.value) payload.captchaToken = tkInput.value;
      delete payload['cf-turnstile-response'];

      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const detail = await res.text().catch(() => '');
        throw new Error('HTTP ' + res.status + (detail ? ' ' + detail : ''));
      }
      ok?.classList.remove('hidden');
      form.reset();
    } catch (error) {
      console.error('[contact] submit failed', error);
      err?.classList.remove('hidden');
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
