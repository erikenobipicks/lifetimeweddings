---
import Section from '../Section.astro';
import { useTranslations, localePath, type Lang } from '~/i18n/ui';
import { WEDDINGS, weddingCover } from '~/data/weddings';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const featured = WEDDINGS.filter((w) => weddingCover(w)).slice(0, 6);

function altFor(w: typeof featured[number]): string {
  const venueOk = w.venue && w.venue !== '—';
  return venueOk ? `Boda de ${w.couple} a ${w.venue}` : `Boda de ${w.couple}`;
}
---

<Section id="portfolio" bg="ink">
  <div class="max-w-6xl mx-auto text-center">
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('portfolio.label')}</p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-8 md:mb-10 text-white">{t('portfolio.title')}</h2>

    <p class="max-w-2xl mx-auto text-white/70 leading-relaxed text-[0.95rem] md:text-base">
      {t('portfolio.intro')}
    </p>

    {featured.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mt-12 md:mt-14">
        {featured.map((w) => (
          <a
            href={localePath(lang, `/bodas/${w.slug}`)}
            class="group relative block overflow-hidden aspect-[4/5] focus:outline-none focus:ring-2 focus:ring-gold"
            aria-label={altFor(w)}
          >
            <img
              src={weddingCover(w) ?? ''}
              alt={altFor(w)}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4 text-left">
              <p class="font-display italic text-xl text-white" style="font-weight: 400; letter-spacing: -0.01em;">{w.couple}</p>
              {w.venue && w.venue !== '—' && (
                <p class="text-xs uppercase tracking-[0.12em] text-white/70 mt-0.5">{w.venue}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Section>
