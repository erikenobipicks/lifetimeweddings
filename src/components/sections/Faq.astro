---
// Accessible FAQ accordion (native <details>/<summary>) with FAQPage JSON-LD.
// Keys are ui.ts faq.q1..q10 / faq.a1..a10 — if we ever add more, extend here.

import Section from '../Section.astro';
import { useTranslations, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const items = Array.from({ length: 10 }, (_, i) => ({
  q: t(`faq.q${i + 1}` as any),
  a: t(`faq.a${i + 1}` as any),
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a },
  })),
};
---

<Section id="faq" bg="cream">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10 md:mb-14">
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('faq.label')}</p>
      <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold leading-tight">{t('faq.title')}</h2>
    </div>

    <div class="divide-y divide-black/10 border-y border-black/10">
      {items.map((it) => (
        <details class="group">
          <summary class="flex items-start justify-between gap-4 py-5 md:py-6 cursor-pointer list-none select-none">
            <span class="font-display text-lg md:text-xl leading-snug pr-2">{it.q}</span>
            <span
              aria-hidden="true"
              class="shrink-0 w-6 h-6 mt-1 flex items-center justify-center text-gold transition-transform duration-200 group-open:rotate-45"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
            </span>
          </summary>
          <p class="pb-5 md:pb-6 pr-10 text-ink/75 leading-relaxed text-[0.95rem]">{it.a}</p>
        </details>
      ))}
    </div>
  </div>
</Section>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<style>
  /* Remove default disclosure triangle */
  summary::-webkit-details-marker { display: none; }
  summary { -webkit-tap-highlight-color: transparent; }
</style>
