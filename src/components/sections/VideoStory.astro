---
import Section from '../Section.astro';
import { useTranslations, localePath, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Per-locale alt for the engagement-session photo. Used for a11y + SEO.
const imageAlt =
  lang === 'es'
    ? 'Sesión pre-boda en Brooklyn, Nueva York'
    : lang === 'en'
      ? 'Engagement session in Brooklyn, New York'
      : 'Sessió pre-boda a Brooklyn, Nova York';
---

<Section id="video-story">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-10 md:gap-16 items-center">
    <div class="relative overflow-hidden group">
      <img
        src="/photos/generic/006-lg.jpg"
        alt={imageAlt}
        class="w-full h-80 md:h-[460px] object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
        width="1200"
        height="800"
      />
      {/* The play badge is purely decorative — we don't host a video here.
          Rendering it as a non-interactive overlay (no <button>, aria-hidden)
          keeps it out of the keyboard tab order and prevents screen readers
          from announcing a button that does nothing. The whole photo links
          to /quiz through the CTA on the right side of the layout. */}
      <span aria-hidden="true" class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <span class="w-20 h-20 bg-white/90 rounded-full flex items-center justify-center group-hover:bg-white transition-colors">
          <svg viewBox="0 0 24 24" class="w-8 h-8 fill-ink ml-1" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
        </span>
      </span>
    </div>

    <div>
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('video.label')}</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold leading-tight mb-6">{t('video.title')}</h2>
      <p class="text-ink/75 leading-relaxed mb-4">{t('video.p1')}</p>
      <p class="text-ink/75 leading-relaxed mb-8">{t('video.p2')}</p>
      <a
        href={localePath(lang, '/quiz')}
        class="inline-block border-2 border-ink bg-ink text-white px-8 py-3.5 text-xs font-bold tracking-[0.18em] uppercase hover:bg-gold hover:border-gold transition-colors"
      >
        {t('video.cta')}
      </a>
    </div>
  </div>
</Section>
