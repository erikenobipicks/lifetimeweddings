---
import Section from '../Section.astro';
import { useTranslations, localePath, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Locale-aware alt text for the three couple photos. Keeps the "names i
// venue" wording stable in CA, swaps the connector "i" → "y" / "and" for
// the other locales, and rewrites the sentence frame in EN. Used for a11y
// (screen readers) and SEO image context.
function altFor(names: string, venue: string): string {
  if (lang === 'es') return `Boda de ${names.replace(/ i /g, ' y ')} en ${venue}`;
  if (lang === 'en') return `${names.replace(/ i /g, ' and ')}'s wedding at ${venue}`;
  return `Boda de ${names} a ${venue}`;
}

const logoAlt =
  lang === 'es'
    ? 'Lifetime Weddings — sello circular'
    : lang === 'en'
      ? 'Lifetime Weddings — circular seal'
      : 'Lifetime Weddings — segell circular';
---

<Section id="about" bg="cream">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 md:gap-16 items-center">
    <div class="grid grid-cols-2 gap-3">
      <img
        src="/photos/josep-eli/005-md.jpg"
        srcset="/photos/josep-eli/005-sm.jpg 640w, /photos/josep-eli/005-md.jpg 1200w"
        sizes="(max-width: 768px) 100vw, 50vw"
        alt={altFor('Elisabet i Josep', "L'Orangerie Clos Barenys")}
        class="col-span-2 h-64 md:h-80 w-full object-cover object-top"
        loading="lazy"
        decoding="async"
        width="1200"
        height="800"
      />
      <img
        src="/photos/cristina-daniel/001-md.jpg"
        srcset="/photos/cristina-daniel/001-sm.jpg 640w, /photos/cristina-daniel/001-md.jpg 1200w"
        sizes="(max-width: 768px) 50vw, 25vw"
        alt={altFor('Cristina i Daniel', 'Mas La Boella')}
        class="h-48 md:h-56 w-full object-cover"
        loading="lazy"
        decoding="async"
        width="600"
        height="600"
      />
      <img
        src="/photos/elena-jordi/001-md.jpg"
        srcset="/photos/elena-jordi/001-sm.jpg 640w, /photos/elena-jordi/001-md.jpg 1200w"
        sizes="(max-width: 768px) 50vw, 25vw"
        alt={altFor('Elena i Jordi', 'Masia San Antonio')}
        class="h-48 md:h-56 w-full object-cover"
        loading="lazy"
        decoding="async"
        width="600"
        height="600"
      />
    </div>

    <div>
      <img
        src="/logos/logo-circle-color.png"
        alt={logoAlt}
        width="96"
        height="96"
        class="w-20 h-20 md:w-24 md:h-24 object-contain mb-5"
        loading="lazy"
        decoding="async"
      />
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('about.label')}</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold leading-[1.15] mb-7">
        {t('about.title')}
      </h2>
      <p class="text-ink/75 leading-relaxed mb-4">{t('about.p1')}</p>
      <p class="text-ink/75 leading-relaxed mb-4">{t('about.p2')}</p>
      <p class="text-ink/75 leading-relaxed mb-8">{t('about.p3')}</p>
      <a
        href="#portfolio"
        class="inline-block border-2 border-ink bg-ink text-white px-10 py-4 text-xs font-bold tracking-[0.18em] uppercase hover:bg-gold hover:border-gold transition-colors"
      >
        {t('about.cta')}
      </a>
    </div>
  </div>
</Section>
