---
import Section from '../Section.astro';
import { useTranslations, type Lang } from '~/i18n/ui';
import { TESTIMONIALS } from '~/data/testimonials';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Section id="testimonials" bg="cream">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('testi.label')}</p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-12">{t('testi.title')}</h2>

    <div class="relative" data-testi-slider>
      {TESTIMONIALS.map((tes, i) => (
        <article
          data-testi-slide
          data-index={i}
          class={`px-4 md:px-8 ${i === 0 ? '' : 'hidden'}`}
        >
          <img
            src={tes.photo}
            alt={tes.alt}
            class="w-24 h-24 rounded-full object-cover mx-auto mb-6 ring-4 ring-gold"
            loading="lazy"
            decoding="async"
            width="96"
            height="96"
          />
          <blockquote class="font-display italic text-lg md:text-xl leading-relaxed text-ink mb-5">
            “{tes.quote[lang]}”
          </blockquote>
          <p class="text-xs font-bold tracking-[0.2em] uppercase text-gold">— {tes.author}</p>
        </article>
      ))}

      <div class="flex justify-center gap-2 mt-10" role="tablist" aria-label="Testimonios">
        {TESTIMONIALS.map((tes, i) => (
          <button
            type="button"
            data-testi-dot
            data-index={i}
            aria-label={`Ver testimonio de ${tes.author}`}
            class={`w-2.5 h-2.5 rounded-full transition-colors ${i === 0 ? 'bg-gold' : 'bg-black/20 hover:bg-black/40'}`}
          />
        ))}
      </div>
    </div>
  </div>
</Section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('[data-testi-slide]');
  const dots = document.querySelectorAll<HTMLButtonElement>('[data-testi-dot]');
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = Number(dot.dataset.index);
      slides.forEach((s) => s.classList.toggle('hidden', Number(s.dataset.index) !== idx));
      dots.forEach((d, i) => {
        d.classList.toggle('bg-gold', i === idx);
        d.classList.toggle('bg-black/20', i !== idx);
      });
    });
  });
</script>
