---
import Section from '../Section.astro';
import { useTranslations, type Lang } from '~/i18n/ui';
import { TESTIMONIALS } from '~/data/testimonials';
import { SITE } from '~/data/site';
import { getGbpReviews } from '~/lib/gbp-reviews';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Slide list = curated testimonials first (hand-tuned translations),
// then Google reviews fetched from the Places API (Google-translated to
// the current locale). Dedupe by author surface form so a couple that
// appears in both sources only shows once.
const gbpReviews = await getGbpReviews(lang);
const curatedAuthorKeys = new Set(
  TESTIMONIALS.map((tes) => tes.author.toLowerCase().replace(/\s+/g, ' ').trim()),
);
const slides: Array<{ author: string; quote: string }> = [
  ...TESTIMONIALS.map((tes) => ({ author: tes.author, quote: tes.quote[lang] })),
  ...gbpReviews
    .filter((r) => !curatedAuthorKeys.has(r.author.toLowerCase().replace(/\s+/g, ' ').trim()))
    .map((r) => ({ author: r.author, quote: r.text })),
];

const tablistLabel =
  lang === 'es' ? 'Testimonios' : lang === 'en' ? 'Testimonials' : 'Testimonis';
const seeTestimonialOf = (author: string) =>
  lang === 'es'
    ? `Ver testimonio de ${author}`
    : lang === 'en'
      ? `See testimonial from ${author}`
      : `Veure testimoni de ${author}`;
const ratingLabel =
  lang === 'es' ? '5 de 5 estrellas' : lang === 'en' ? '5 out of 5 stars' : '5 de 5 estrelles';
---

<Section id="testimonials" bg="cream">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-3">{t('testi.label')}</p>
    <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold mb-14 md:mb-16">{t('testi.title')}</h2>

    <div class="relative" data-testi-slider>
      <span
        aria-hidden="true"
        class="font-display text-[7rem] md:text-[9rem] leading-none text-gold/30 absolute -top-8 md:-top-12 left-1/2 -translate-x-1/2 pointer-events-none select-none"
      >
        &ldquo;
      </span>

      {slides.map((tes, i) => (
        <article
          data-testi-slide
          data-index={i}
          class={`relative px-4 md:px-12 ${i === 0 ? '' : 'hidden'}`}
        >
          <blockquote class="font-display italic text-lg md:text-2xl lg:text-[1.7rem] leading-[1.5] md:leading-[1.6] text-ink mb-8 md:mb-10">
            {tes.quote}
          </blockquote>
          <p class="text-[0.7rem] md:text-xs font-bold tracking-[0.28em] uppercase text-ink">
            {tes.author}
          </p>
        </article>
      ))}

      <div class="flex justify-center gap-2 mt-10 md:mt-12" role="tablist" aria-label={tablistLabel}>
        {slides.map((tes, i) => (
          <button
            type="button"
            role="tab"
            data-testi-dot
            data-index={i}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-label={seeTestimonialOf(tes.author)}
            class={`w-1.5 h-1.5 rounded-full transition-colors ${i === 0 ? 'bg-gold' : 'bg-black/20 hover:bg-black/40'}`}
          />
        ))}
      </div>
    </div>

    <p class="mt-12 md:mt-16 text-[0.7rem] md:text-xs tracking-[0.18em] uppercase text-ink/70">
      <span role="img" aria-label={ratingLabel}>★★★★★</span>
      <span class="mx-2" aria-hidden="true">·</span>
      <a href="https://www.google.com/search?q=lifetime+weddings+reus" target="_blank" rel="noopener" class="hover:text-gold transition-colors">Google</a>
      <span class="mx-2">·</span>
      <a href={SITE.social.instagram} target="_blank" rel="noopener" class="hover:text-gold transition-colors">Instagram</a>
    </p>
  </div>
</Section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('[data-testi-slide]');
  const dots = document.querySelectorAll<HTMLButtonElement>('[data-testi-dot]');
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = Number(dot.dataset.index);
      slides.forEach((s) => s.classList.toggle('hidden', Number(s.dataset.index) !== idx));
      dots.forEach((d, i) => {
        d.classList.toggle('bg-gold', i === idx);
        d.classList.toggle('bg-black/20', i !== idx);
        d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
    });
  });
</script>
