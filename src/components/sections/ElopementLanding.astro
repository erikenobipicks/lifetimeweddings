---
// Shared template for every elopement locality child page
// (/elopement-<slug>, + /es and /en). Fully data-driven from one
// ElopementPage object (src/data/elopements/*) so each page carries its own
// unique, place-specific copy — concrete spots, permits, best season,
// logistics — not a template with the town name swapped in.
//
// Honesty: localities without a real on-location gallery (hasRealGallery
// false) use real portfolio imagery (PHOTOS['generic']) with neutral, honest
// alt text and link out to genuine real work (the Siurana elopement + nearby
// real weddings) rather than faking a "real elopement here" gallery.

import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import StickyMobileCta from '~/components/StickyMobileCta.astro';
import LeadQualifyForm from '~/components/sections/LeadQualifyForm.astro';
import { SITE, WHATSAPP_BASE } from '~/data/site';
import { useTranslations, type Lang } from '~/i18n/ui';
import { getGbpRating } from '~/lib/gbp-rating';
import {
  breadcrumbJsonLd,
  faqPageJsonLd,
  webPageJsonLd,
  elopementServiceJsonLd,
} from '~/lib/seo';
import { PHOTOS } from '~/data/photos.generated';
import { WEDDINGS, weddingCover } from '~/data/weddings';
import type { ElopementPage } from '~/data/elopements/types';

interface Props {
  page: ElopementPage;
  lang: Lang;
}
const { page, lang } = Astro.props;
const t = useTranslations(lang);
const c = page.copy[lang];
const rating = await getGbpRating();

const langPath = lang === 'ca' ? '' : `/${lang}`;
const canonicalPath = `/elopement-${page.slug}`;
const canonicalUrl = `${SITE.url}${langPath}${canonicalPath}`;

// Real portfolio photos (with real dimensions → no CLS), picked by index so
// no two locality pages open with the same image.
const GEN = PHOTOS['generic']?.images ?? [];
const pics = page.photoIndices.map((i) => GEN[i - 1]).filter(Boolean);
const hero = pics[0];
const bandA = pics[1];
const bandB = pics[2];
const galleryPics = pics.slice(3);

const toWebp = (p: string): string => p.replace(/\.jpe?g$/i, '.webp');

// Cross-links.
const SIBLING_LABEL: Record<string, string> = {
  siurana: 'Siurana',
  barcelona: 'Barcelona',
  tarragona: 'Tarragona',
  'costa-daurada': 'Costa Daurada',
  'delta-ebre': "Delta de l'Ebre",
};
const pillarPath = `${langPath}/elopement-catalunya`;
const pillarLabel =
  lang === 'es' ? 'Elopement en Cataluña' : lang === 'en' ? 'Elopement in Catalonia' : 'Elopement a Catalunya';
const siblings = page.siblingSlugs
  .map((s) => ({ slug: s, label: SIBLING_LABEL[s] ?? s, href: `${langPath}/elopement-${s}` }))
  .filter((s) => SIBLING_LABEL[s.slug]);

// Real work to surface as related posts (genuine galleries — never labelled
// as this locality).
const related = page.relatedWeddingSlugs
  .map((slug) => WEDDINGS.find((w) => w.slug === slug))
  .filter((w): w is NonNullable<typeof w> => Boolean(w))
  .map((w) => ({ slug: w.slug, couple: w.couple, cover: weddingCover(w) }))
  .filter((w) => w.cover);

// Chrome labels not part of the per-locality copy.
const UI: Record<Lang, {
  places: string; permits: string; season: string; logistics: string; special: string;
  realWork: string; realWorkIntro: string; viewGallery: string;
  explore: string; backToGuide: string; ctaPrimary: string; ctaSecondary: string;
}> = {
  ca: {
    places: c.places.title, permits: c.permits.title, season: c.season.title,
    logistics: c.logistics.title, special: c.special.title,
    realWork: 'Feines reals nostres', realWorkIntro: 'Bodes i parelles reals que hem documentat. Aquesta és la nostra mirada — la mateixa que portem a un elopement.',
    viewGallery: 'Veure la galeria', explore: 'Elopements en altres indrets de Catalunya',
    backToGuide: 'Torna a la guia d’elopement a Catalunya', ctaPrimary: 'Parla amb nosaltres', ctaSecondary: 'Escriviu-nos',
  },
  es: {
    places: c.places.title, permits: c.permits.title, season: c.season.title,
    logistics: c.logistics.title, special: c.special.title,
    realWork: 'Trabajo real nuestro', realWorkIntro: 'Bodas y parejas reales que hemos documentado. Esta es nuestra mirada — la misma que llevamos a un elopement.',
    viewGallery: 'Ver la galería', explore: 'Elopements en otros rincones de Cataluña',
    backToGuide: 'Volver a la guía de elopement en Cataluña', ctaPrimary: 'Habla con nosotros', ctaSecondary: 'Escribidnos',
  },
  en: {
    places: c.places.title, permits: c.permits.title, season: c.season.title,
    logistics: c.logistics.title, special: c.special.title,
    realWork: 'Our real work', realWorkIntro: 'Real weddings and couples we have documented. This is how we see — the same eye we bring to an elopement.',
    viewGallery: 'View the gallery', explore: 'Elopements in other corners of Catalonia',
    backToGuide: 'Back to the elopement in Catalonia guide', ctaPrimary: 'Talk to us', ctaSecondary: 'Write to us',
  },
};
const ui = UI[lang];

const waLink = `${WHATSAPP_BASE}&text=${encodeURIComponent(c.whatsAppMessage)}`;

const jsonLd = [
  webPageJsonLd({
    pageUrl: canonicalUrl,
    name: c.meta.title,
    description: c.meta.description,
    lang,
    primaryImage: hero
      ? { url: hero.variants.lg, width: hero.width, height: hero.height, caption: c.hero.heroAlt }
      : undefined,
  }),
  elopementServiceJsonLd({
    areaName: page.region,
    areaServed: page.areaServed,
    canonicalUrl,
  }),
  faqPageJsonLd(c.faqs.map((f) => ({ question: f.q, answer: f.a }))),
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}${langPath}/` },
    { name: pillarLabel, url: `${SITE.url}${pillarPath}` },
    { name: c.breadcrumbCurrent, url: canonicalUrl },
  ]),
];

/** Render a copy snippet that may contain **bold** markers, HTML-escaped first. */
function renderBold(s: string): string {
  const escaped = s.replace(/[<>&]/g, (ch) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[ch] as string));
  return escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}
const galleryAlt = (i: number) =>
  `${pillarLabel} · Lifetime Weddings · ${String(i + 1).padStart(2, '0')}`;
---

<BaseLayout
  lang={lang}
  title={c.meta.title}
  description={c.meta.description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  ogImage={hero ? hero.variants.lg : '/og-default.jpg'}
  ogType="article"
>
  <!-- Hero -->
  <section class="relative h-[76vh] min-h-[520px] overflow-hidden">
    {hero && (
      <picture>
        <source type="image/webp" srcset={toWebp(hero.variants.lg)} />
        <img
          src={hero.variants.lg}
          alt={c.hero.heroAlt}
          class="absolute inset-0 w-full h-full object-cover"
          style="object-position: center 42%"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width={hero.width}
          height={hero.height}
        />
      </picture>
    )}
    <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/30 to-black/75"></div>
    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
      <p class="text-xs font-bold tracking-[0.24em] uppercase text-gold mb-4">{c.hero.eyebrow}</p>
      <h1 class="font-display text-3xl md:text-5xl font-bold max-w-4xl leading-tight">{c.hero.h1}</h1>
      <p class="mt-5 max-w-2xl text-base md:text-lg leading-relaxed opacity-95">{c.hero.sub}</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href={waLink} target="_blank" rel="noopener"
           class="inline-block bg-gold text-ink border-2 border-gold px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors">
          {ui.ctaPrimary}
        </a>
        <a href="#contacte"
           class="inline-block border-2 border-white/80 text-white px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-white/10 transition-colors">
          {c.formTitle}
        </a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="bg-ink text-white py-6 px-6 border-y border-gold/20">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row gap-4 sm:gap-10 items-center justify-center text-center text-sm">
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">{rating.ratingValue.toFixed(1)}★</span>
        <span class="opacity-85">Google · {rating.reviewCount}</span>
      </div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">2</span>
        <span class="opacity-85">{lang === 'es' ? 'hermanos · foto + vídeo' : lang === 'en' ? 'brothers · photo + video' : 'germans · foto + vídeo'}</span>
      </div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2">
        <span class="text-gold font-bold">{lang === 'en' ? '1 week' : '1 setmana'}</span>
        <span class="opacity-85">{lang === 'es' ? 'de entrega' : lang === 'en' ? 'delivery' : 'de lliurament'}</span>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <Section id="intro">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-6">{c.intro.title}</h2>
      {c.intro.paras.map((p) => (
        <p class="text-ink/80 leading-relaxed mb-4 text-base md:text-lg" set:html={renderBold(p)} />
      ))}
    </div>
  </Section>

  <!-- Editorial band A -->
  {bandA && (
    <section class="relative h-[46vh] min-h-[300px] md:h-[64vh] overflow-hidden">
      <picture>
        <source type="image/webp" srcset={toWebp(bandA.variants.lg)} />
        <img src={bandA.variants.lg} alt="" aria-hidden="true"
             class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async"
             width={bandA.width} height={bandA.height} />
      </picture>
    </section>
  )}

  <!-- Places (the unique, place-specific heart of the page) -->
  <Section bg="cream">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.places.title}</h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.places.intro}</p>
      <div class="space-y-7">
        {c.places.items.map((spot) => (
          <div>
            <h3 class="font-display text-lg md:text-xl font-bold text-ink mb-2">{spot.name}</h3>
            <p class="text-ink/80 leading-relaxed" set:html={renderBold(spot.body)} />
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Permits -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.permits.title}</h2>
      {c.permits.paras.map((p) => (
        <p class="text-ink/80 leading-relaxed mb-4 text-base md:text-lg" set:html={renderBold(p)} />
      ))}
    </div>
  </Section>

  <!-- Season + Logistics -->
  <Section bg="cream">
    <div class="max-w-5xl mx-auto px-2 grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.season.title}</h2>
        {c.season.paras.map((p) => (
          <p class="text-ink/80 leading-relaxed mb-4" set:html={renderBold(p)} />
        ))}
      </div>
      <div>
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.logistics.title}</h2>
        {c.logistics.paras.map((p) => (
          <p class="text-ink/80 leading-relaxed mb-4" set:html={renderBold(p)} />
        ))}
      </div>
    </div>
  </Section>

  <!-- Editorial band B -->
  {bandB && (
    <section class="relative h-[46vh] min-h-[300px] md:h-[64vh] overflow-hidden">
      <picture>
        <source type="image/webp" srcset={toWebp(bandB.variants.lg)} />
        <img src={bandB.variants.lg} alt="" aria-hidden="true"
             class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async"
             width={bandB.width} height={bandB.height} />
      </picture>
    </section>
  )}

  <!-- Why special -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.special.title}</h2>
      {c.special.paras.map((p) => (
        <p class="text-ink/80 leading-relaxed mb-4 text-base md:text-lg" set:html={renderBold(p)} />
      ))}
    </div>
  </Section>

  <!-- Gallery (real portfolio, honest framing) -->
  {galleryPics.length > 0 && (
    <Section bg="cream">
      <div class="max-w-6xl mx-auto px-2">
        <div class="max-w-2xl mb-8">
          <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{c.gallery.title}</h2>
          <p class="text-ink/75 leading-relaxed">{c.gallery.intro}</p>
        </div>
        <div class="columns-2 md:columns-3 gap-2 md:gap-3 [&>figure]:mb-2 md:[&>figure]:mb-3">
          {galleryPics.map((g, i) => (
            <figure class="break-inside-avoid overflow-hidden">
              <picture>
                <source type="image/webp" srcset={toWebp(g.variants.md)} />
                <img src={g.variants.md} alt={galleryAlt(i)}
                     class="w-full h-auto object-cover align-top" loading="lazy" decoding="async"
                     width={g.width} height={g.height} />
              </picture>
            </figure>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Related real work (genuine galleries) -->
  {related.length > 0 && (
    <Section>
      <div class="max-w-5xl mx-auto px-2">
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{ui.realWork}</h2>
        <p class="text-ink/75 leading-relaxed mb-8 max-w-2xl">{ui.realWorkIntro}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {related.map((w) => (
            <a href={`${langPath}/bodas/${w.slug}`} class="group block">
              <div class="overflow-hidden aspect-[4/3] mb-3">
                <picture>
                  <source type="image/webp" srcset={toWebp(w.cover!)} />
                  <img src={w.cover!} alt={`${w.couple} · Lifetime Weddings`}
                       class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                       loading="lazy" decoding="async" width="800" height="600" />
                </picture>
              </div>
              <p class="font-display font-bold text-ink group-hover:text-gold-deep transition-colors">{w.couple}</p>
              <p class="text-sm text-ink/60">{ui.viewGallery} →</p>
            </a>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Lead-qualifying form -->
  <LeadQualifyForm lang={lang} locationPrefill={page.locationPrefill} heading={c.formTitle} intro={c.formIntro} />

  <!-- FAQ (mirrors FAQPage schema) -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-8">{c.faqTitle}</h2>
      <div class="divide-y divide-line border-y border-line">
        {c.faqs.map((f) => (
          <details class="group">
            <summary class="flex items-start justify-between gap-4 py-5 md:py-6 cursor-pointer list-none select-none">
              <span class="text-base md:text-lg leading-snug pr-2" style="font-weight: 500;">{f.q}</span>
              <span aria-hidden="true" class="shrink-0 w-6 h-6 mt-1 flex items-center justify-center text-gold-deep transition-transform duration-200 group-open:rotate-45">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
              </span>
            </summary>
            <p class="pb-5 md:pb-6 pr-10 text-ink/75 leading-relaxed text-[0.95rem]" set:html={renderBold(f.a)} />
          </details>
        ))}
      </div>
    </div>
  </Section>

  <!-- Cluster cross-links (bidirectional: pillar + siblings) -->
  <Section bg="cream">
    <div class="max-w-4xl mx-auto px-2 text-center">
      <h2 class="font-display text-xl md:text-2xl font-bold mb-6">{ui.explore}</h2>
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        {siblings.map((s) => (
          <a href={s.href}
             class="inline-block border border-ink/25 px-5 py-2.5 text-sm font-semibold hover:border-gold hover:text-gold-deep transition-colors">
            {s.label}
          </a>
        ))}
      </div>
      <a href={pillarPath} class="inline-block border-b border-gold text-ink font-semibold hover:text-gold transition-colors">
        {ui.backToGuide} →
      </a>
    </div>
  </Section>

  <!-- Final CTA -->
  <Section>
    <div class="max-w-2xl mx-auto px-2 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-5">{c.finalCta.h2}</h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.finalCta.body}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={waLink} target="_blank" rel="noopener"
           class="inline-block bg-gold text-ink border-2 border-gold px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors">
          {ui.ctaPrimary}
        </a>
        <a href="#contacte"
           class="inline-block border-2 border-ink text-ink px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors">
          {ui.ctaSecondary}
        </a>
      </div>
    </div>
  </Section>

  <StickyMobileCta
    lang={lang}
    whatsAppHref={waLink}
    secondaryHref="#contacte"
    primaryLabel={ui.ctaPrimary}
  />
</BaseLayout>
