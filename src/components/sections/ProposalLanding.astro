{/* Click-to-load YouTube — same pattern as src/components/sections/YouTube.astro.
    No iframe is created until the visitor taps a play button, so we never
    pay the bandwidth, layout, or third-party-cookie cost up-front. */}
<script is:inline define:vars={{
  gatedTitle: t('consent.gated.title'),
  gatedBody: t('consent.gated.body'),
  gatedCta: t('consent.gated.cta'),
}}>
  (() => {
    function consentRejected() {
      try {
        const raw = localStorage.getItem('lifetime.cookies.v1');
        if (!raw) return false;
        return JSON.parse(raw)?.choice === 'reject';
      } catch {
        return false;
      }
    }
    function showGatedMessage(wrap) {
      const div = document.createElement('div');
      div.className =
        'absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-ink/90 text-white';
      div.innerHTML =
        '<p class="font-display text-lg font-bold mb-2">' + gatedTitle +
        '</p><p class="text-sm text-white/80 max-w-md mb-4">' + gatedBody +
        '</p><button type="button" data-cookie-reopen class="bg-gold text-ink text-xs font-bold tracking-[0.15em] uppercase px-5 py-2.5 hover:brightness-110 transition">' +
        gatedCta + '</button>';
      wrap.replaceChildren(div);
      const btn = div.querySelector('[data-cookie-reopen]');
      if (btn) {
        btn.addEventListener('click', () => {
          document.dispatchEvent(new CustomEvent('consent:reopen'));
        });
      }
    }
    document.querySelectorAll('[data-yt-embed]').forEach((wrap) => {
      const btn = wrap.querySelector('[data-yt-toggle]');
      const img = wrap.querySelector('img[data-fallback]');
      const id = wrap.getAttribute('data-yt-id');
      if (img) {
        img.addEventListener('error', () => { img.src = img.dataset.fallback; }, { once: true });
      }
      if (!btn || !id) return;
      btn.addEventListener('click', () => {
        if (consentRejected()) { showGatedMessage(wrap); return; }
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.title = btn.getAttribute('aria-label') || 'Video';
        iframe.className = 'absolute inset-0 w-full h-full';
        iframe.setAttribute('frameborder', '0');
        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
        iframe.setAttribute('allowfullscreen', '');
        iframe.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
        wrap.replaceChildren(iframe);
      });
    });
  })();
</script>
