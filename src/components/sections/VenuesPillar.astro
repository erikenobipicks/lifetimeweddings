---
// Venues pillar page /venues (+ /es, /en). Hub that ties together the 6 real
// venue landings (/venues/<slug>, which carry real galleries) and a curated,
// honest list of other top venues in the area — each linking to the relevant
// city photo page instead of faking a gallery we don't have.

import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import StickyMobileCta from '~/components/StickyMobileCta.astro';
import LeadQualifyForm from '~/components/sections/LeadQualifyForm.astro';
import { SITE, WHATSAPP_BASE } from '~/data/site';
import { useTranslations, type Lang } from '~/i18n/ui';
import { getGbpRating } from '~/lib/gbp-rating';
import { breadcrumbJsonLd, faqPageJsonLd, webPageJsonLd } from '~/lib/seo';
import { VENUES } from '~/data/venues';
import { WEDDINGS, weddingCover } from '~/data/weddings';
import { PHOTOS } from '~/data/photos.generated';
import { VENUES_PILLAR } from '~/data/venues-pillar';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const c = VENUES_PILLAR[lang];
const rating = await getGbpRating();

const langPath = lang === 'ca' ? '' : `/${lang}`;
const canonicalPath = '/venues';
const canonicalUrl = `${SITE.url}${langPath}${canonicalPath}`;
const toWebp = (p: string): string => p.replace(/\.jpe?g$/i, '.webp');

const GEN = PHOTOS['generic']?.images ?? [];

// Venues with a real wedding gallery.
const ourVenues = VENUES.filter((v) => v.realWeddingSlug).map((v) => {
  const w = WEDDINGS.find((x) => x.slug === v.realWeddingSlug);
  return { slug: v.slug, name: v.name, region: v.region, couple: v.realWeddingCouple, cover: w ? weddingCover(w) : null };
}).filter((v) => v.cover);

// Venues we cover but don't have a real gallery for yet — placeholder
// portfolio imagery, each linking to its own fiche.
const otherVenues = VENUES.filter((v) => !v.realWeddingSlug && v.portfolioIndices?.length).map((v) => ({
  slug: v.slug,
  name: v.name,
  region: v.region,
  cover: GEN[(v.portfolioIndices as number[])[0] - 1]?.variants.md ?? null,
}));

const hero = ourVenues[0]?.cover ?? '/og-default.jpg';

const waLink = `${WHATSAPP_BASE}&text=${encodeURIComponent(c.whatsAppMessage)}`;

const jsonLd = [
  webPageJsonLd({ pageUrl: canonicalUrl, name: c.meta.title, description: c.meta.description, lang, primaryImage: { url: hero, caption: c.hero.heroAlt } }),
  faqPageJsonLd(c.faqs.map((f) => ({ question: f.q, answer: f.a }))),
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}${langPath}/` },
    { name: c.breadcrumbCurrent, url: canonicalUrl },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: c.breadcrumbCurrent,
    itemListElement: [
      ...[...ourVenues, ...otherVenues].map((v, i) => ({ '@type': 'ListItem', position: i + 1, name: v.name, url: `${SITE.url}${langPath}/venues/${v.slug}` })),
    ],
  },
];
---

<BaseLayout lang={lang} title={c.meta.title} description={c.meta.description} canonicalPath={canonicalPath} jsonLd={jsonLd} ogImage={hero} ogType="article">
  <!-- Hero -->
  <section class="relative h-[64vh] min-h-[460px] overflow-hidden">
    <picture><source type="image/webp" srcset={toWebp(hero)} /><img src={hero} alt={c.hero.heroAlt} class="absolute inset-0 w-full h-full object-cover" style="object-position:center 45%" loading="eager" fetchpriority="high" decoding="async" width="1920" height="1280" /></picture>
    <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/30 to-black/75"></div>
    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
      <p class="text-xs font-bold tracking-[0.24em] uppercase text-gold mb-4">{c.hero.eyebrow}</p>
      <h1 class="font-display text-3xl md:text-5xl font-bold max-w-4xl leading-tight">{c.hero.h1}</h1>
      <p class="mt-5 max-w-2xl text-base md:text-lg leading-relaxed opacity-95">{c.hero.sub}</p>
    </div>
  </section>

  <!-- Intro -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-6">{c.intro.title}</h2>
      {c.intro.paras.map((p) => (<p class="text-ink/80 leading-relaxed mb-4 text-base md:text-lg">{p}</p>))}
    </div>
  </Section>

  <!-- Our venues (real galleries) -->
  <Section bg="cream">
    <div class="max-w-6xl mx-auto px-2">
      <div class="max-w-2xl mb-10"><h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{c.ourVenuesTitle}</h2><p class="text-ink/75 leading-relaxed">{c.ourVenuesIntro}</p></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {ourVenues.map((v) => (
          <a href={`${langPath}/venues/${v.slug}`} class="group block">
            <div class="relative overflow-hidden aspect-[4/5] mb-4">
              <picture><source type="image/webp" srcset={toWebp(v.cover!)} /><img src={v.cover!} alt={`${v.name} · ${v.couple} · Lifetime Weddings`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async" width="800" height="1000" /></picture>
              <span class="absolute top-3 left-3 bg-gold text-ink text-[0.62rem] font-bold tracking-[0.12em] uppercase px-2.5 py-1">{v.region}</span>
            </div>
            <h3 class="font-display text-xl font-bold text-ink group-hover:text-gold-deep transition-colors mb-1">{v.name}</h3>
            <p class="text-sm text-ink/70">{v.couple} · {c.seeVenue} →</p>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <!-- Other top venues (curated, honest) -->
  <Section>
    <div class="max-w-4xl mx-auto px-2">
      <div class="max-w-2xl mb-8"><h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{c.otherTitle}</h2><p class="text-ink/75 leading-relaxed">{c.otherIntro}</p></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {otherVenues.map((v) => (
          <a href={`${langPath}/venues/${v.slug}`} class="group block">
            <div class="relative overflow-hidden aspect-[4/5] mb-4">
              {v.cover && (<picture><source type="image/webp" srcset={toWebp(v.cover)} /><img src={v.cover} alt={`${v.name} · Lifetime Weddings`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async" width="800" height="1000" /></picture>)}
              <span class="absolute top-3 left-3 bg-ink/80 text-white text-[0.62rem] font-bold tracking-[0.12em] uppercase px-2.5 py-1">{v.region}</span>
            </div>
            <h3 class="font-display text-xl font-bold text-ink group-hover:text-gold-deep transition-colors mb-1">{v.name}</h3>
            <p class="text-sm text-ink/70">{c.coverHere} →</p>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <!-- Form -->
  <LeadQualifyForm lang={lang} heading={c.formTitle} intro={c.formIntro} />

  <!-- FAQ -->
  <Section bg="cream">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-8">{c.faqTitle}</h2>
      <div class="divide-y divide-line border-y border-line">
        {c.faqs.map((f) => (
          <details class="group"><summary class="flex items-start justify-between gap-4 py-5 md:py-6 cursor-pointer list-none select-none"><span class="text-base md:text-lg leading-snug pr-2" style="font-weight:500;">{f.q}</span><span aria-hidden="true" class="shrink-0 w-6 h-6 mt-1 flex items-center justify-center text-gold-deep transition-transform duration-200 group-open:rotate-45"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg></span></summary><p class="pb-5 md:pb-6 pr-10 text-ink/75 leading-relaxed text-[0.95rem]">{f.a}</p></details>
        ))}
      </div>
    </div>
  </Section>

  <!-- Final CTA -->
  <Section>
    <div class="max-w-2xl mx-auto px-2 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-5">{c.finalCta.h2}</h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.finalCta.body}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={waLink} target="_blank" rel="noopener" class="inline-block bg-gold text-ink border-2 border-gold px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors">{lang === 'es' ? 'Habla con nosotros' : lang === 'en' ? 'Talk to us' : 'Parla amb nosaltres'}</a>
        <a href="#contacte" class="inline-block border-2 border-ink text-ink px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors">{lang === 'es' ? 'Escribidnos' : lang === 'en' ? 'Write to us' : 'Escriviu-nos'}</a>
      </div>
    </div>
  </Section>

  <StickyMobileCta lang={lang} whatsAppHref={waLink} secondaryHref="#contacte" primaryLabel="WhatsApp" />
</BaseLayout>
