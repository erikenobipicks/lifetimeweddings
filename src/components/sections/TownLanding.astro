---
// Coastal micro-niche town landing (Costa Daurada). A sales funnel with a CTA
// at the hero, a mid-page band, and the close — built around each town's own
// nearby venues and photo spots. Data-driven from one TownPage.
//
// Route: /fotograf-boda-<slug> (+ /es, /en). For Salou & Cambrils this
// supersedes the thinner city page at the same URL.

import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import StickyMobileCta from '~/components/StickyMobileCta.astro';
import LeadQualifyForm from '~/components/sections/LeadQualifyForm.astro';
import { SITE, WHATSAPP_BASE } from '~/data/site';
import { useTranslations, type Lang } from '~/i18n/ui';
import { getGbpRating } from '~/lib/gbp-rating';
import { breadcrumbJsonLd, faqPageJsonLd, webPageJsonLd, cityServiceJsonLd } from '~/lib/seo';
import { PHOTOS } from '~/data/photos.generated';
import { WEDDINGS, weddingCover } from '~/data/weddings';
import { TOWNS } from '~/data/towns';
import type { TownPage } from '~/data/towns/types';

interface Props { town: TownPage; lang: Lang }
const { town, lang } = Astro.props;
const t = useTranslations(lang);
const c = town.copy[lang];
const rating = await getGbpRating();

const langPath = lang === 'ca' ? '' : `/${lang}`;
const canonicalPath = `/fotograf-boda-${town.slug}`;
const canonicalUrl = `${SITE.url}${langPath}${canonicalPath}`;
const toWebp = (p: string): string => p.replace(/\.jpe?g$/i, '.webp');

// Imagery: a real gallery when we have one, else varied portfolio photos.
const GEN = PHOTOS['generic']?.images ?? [];
const pics = town.realPhotoSlug
  ? (PHOTOS[town.realPhotoSlug]?.images ?? [])
  : town.imageIndices.map((i) => GEN[i - 1]).filter(Boolean);
const hero = pics[0];
const bandA = pics[1];
const bandB = pics[2];
const galleryPics = pics.slice(3, 9);

// Cross-links.
const townBySlug = new Map(TOWNS.map((x) => [x.slug, x]));
const siblings = town.siblingSlugs
  .map((s) => townBySlug.get(s))
  .filter((x): x is TownPage => Boolean(x))
  .map((x) => ({ name: x.name, href: `${langPath}/fotograf-boda-${x.slug}` }));
const pillarPath = `${langPath}/fotograf-boda-tarragona-lleida`;
const venuesPath = `${langPath}/venues`;
const videoPath = `${langPath}/videograf-boda-tarragona-lleida`;

const related = town.relatedWeddingSlugs
  .map((slug) => WEDDINGS.find((w) => w.slug === slug))
  .filter((w): w is NonNullable<typeof w> => Boolean(w))
  .map((w) => ({ slug: w.slug, couple: w.couple, cover: weddingCover(w) }))
  .filter((w) => w.cover);

const UI: Record<Lang, { realWork: string; realWorkIntro: string; viewGallery: string; venuesHere: string; other: string; back: string; alsoVideo: string; alsoVenues: string }> = {
  ca: { realWork: 'Feines reals nostres', realWorkIntro: 'Bodes reals que hem documentat a la zona. Aquesta és la nostra mirada.', viewGallery: 'Veure la galeria', venuesHere: 'Veure la fitxa', other: 'Altres pobles de la costa', back: 'Guia de tota la zona', alsoVideo: 'Vídeo de boda', alsoVenues: 'Millors espais' },
  es: { realWork: 'Trabajo real nuestro', realWorkIntro: 'Bodas reales que hemos documentado en la zona. Esta es nuestra mirada.', viewGallery: 'Ver la galería', venuesHere: 'Ver la ficha', other: 'Otros pueblos de la costa', back: 'Guía de toda la zona', alsoVideo: 'Vídeo de boda', alsoVenues: 'Mejores espacios' },
  en: { realWork: 'Our real work', realWorkIntro: 'Real weddings we have documented in the area. This is how we see.', viewGallery: 'View the gallery', venuesHere: 'See the venue', other: 'Other coastal towns', back: 'Guide to the whole area', alsoVideo: 'Wedding video', alsoVenues: 'Best venues' },
};
const ui = UI[lang];
const waLink = `${WHATSAPP_BASE}&text=${encodeURIComponent(c.whatsAppMessage)}`;

const jsonLd = [
  webPageJsonLd({
    pageUrl: canonicalUrl,
    name: c.meta.title,
    description: c.meta.description,
    lang,
    primaryImage: hero ? { url: hero.variants.lg, width: hero.width, height: hero.height, caption: c.hero.heroAlt } : undefined,
  }),
  cityServiceJsonLd({
    name: c.meta.title.split(' | ')[0],
    serviceType: 'Wedding photography',
    areaName: town.name,
    areaServed: town.areaServed,
    canonicalUrl,
  }),
  faqPageJsonLd(c.faqs.map((f) => ({ question: f.q, answer: f.a }))),
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}${langPath}/` },
    { name: lang === 'es' ? 'Fotógrafo de boda en Tarragona y Lleida' : lang === 'en' ? 'Wedding photographer in Tarragona & Lleida' : 'Fotògraf de boda a Tarragona i Lleida', url: `${SITE.url}${pillarPath}` },
    { name: c.breadcrumbCurrent, url: canonicalUrl },
  ]),
];

function renderBold(s: string): string {
  const escaped = s.replace(/[<>&]/g, (ch) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[ch] as string));
  return escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}
const galleryAlt = (i: number) => `${c.breadcrumbCurrent} · Lifetime Weddings · ${String(i + 1).padStart(2, '0')}`;
---

<BaseLayout lang={lang} title={c.meta.title} description={c.meta.description} canonicalPath={canonicalPath} jsonLd={jsonLd} ogImage={hero ? hero.variants.lg : '/og-default.jpg'} ogType="article">
  <!-- Hero + CTA 1 -->
  <section class="relative h-[76vh] min-h-[520px] overflow-hidden">
    {hero && (
      <picture><source type="image/webp" srcset={toWebp(hero.variants.lg)} /><img src={hero.variants.lg} alt={c.hero.heroAlt} class="absolute inset-0 w-full h-full object-cover" style="object-position:center 42%" loading="eager" fetchpriority="high" decoding="async" width={hero.width} height={hero.height} /></picture>
    )}
    <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/30 to-black/75"></div>
    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
      <p class="text-xs font-bold tracking-[0.24em] uppercase text-gold mb-4">{c.hero.eyebrow}</p>
      <h1 class="font-display text-3xl md:text-5xl font-bold max-w-4xl leading-tight">{c.hero.h1}</h1>
      <p class="mt-5 max-w-2xl text-base md:text-lg leading-relaxed opacity-95">{c.hero.sub}</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href="#contacte" class="inline-block bg-gold text-ink border-2 border-gold px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors">{c.hero.cta1}</a>
        <a href={waLink} target="_blank" rel="noopener" class="inline-block border-2 border-white/80 text-white px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-white/10 transition-colors">WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="bg-ink text-white py-6 px-6 border-y border-gold/20">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row gap-4 sm:gap-10 items-center justify-center text-center text-sm">
      <div class="flex items-center gap-2"><span class="text-gold font-bold">{rating.ratingValue.toFixed(1)}★</span><span class="opacity-85">Google · {rating.reviewCount}</span></div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2"><span class="text-gold font-bold">2</span><span class="opacity-85">{lang === 'es' ? 'hermanos · foto + vídeo' : lang === 'en' ? 'brothers · photo + video' : 'germans · foto + vídeo'}</span></div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2"><span class="text-gold font-bold">Reus</span><span class="opacity-85">{lang === 'es' ? 'sin recargo en la zona' : lang === 'en' ? 'no surcharge in the area' : 'sense recàrrec a la zona'}</span></div>
    </div>
  </section>

  <!-- Intro -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-6">{c.intro.title}</h2>
      {c.intro.paras.map((p) => (<p class="text-ink/80 leading-relaxed mb-4 text-base md:text-lg" set:html={renderBold(p)} />))}
    </div>
  </Section>

  <!-- Editorial band -->
  {bandA && (
    <section class="relative h-[46vh] min-h-[300px] md:h-[62vh] overflow-hidden">
      <picture><source type="image/webp" srcset={toWebp(bandA.variants.lg)} /><img src={bandA.variants.lg} alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" width={bandA.width} height={bandA.height} /></picture>
    </section>
  )}

  <!-- Nearby venues (internal links preferred) -->
  <Section bg="cream">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.nearbyVenues.title}</h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.nearbyVenues.intro}</p>
      <div class="space-y-7">
        {c.nearbyVenues.items.map((v) => (
          <div>
            <h3 class="font-display text-lg md:text-xl font-bold text-ink mb-2">{v.name}</h3>
            <p class="text-ink/80 leading-relaxed" set:html={renderBold(v.body)} />
            {v.internalSlug && (
              <p class="mt-2"><a href={`${langPath}/venues/${v.internalSlug}`} class="inline-block border-b border-gold text-ink font-semibold hover:text-gold transition-colors">{ui.venuesHere} →</a></p>
            )}
            {!v.internalSlug && v.externalUrl && (
              <p class="mt-2"><a href={v.externalUrl} target="_blank" rel="nofollow noopener" class="inline-block border-b border-line text-ink/70 font-semibold hover:text-gold transition-colors">{v.name} ↗</a></p>
            )}
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- CTA 2 — mid-funnel band -->
  <section class="relative overflow-hidden bg-ink text-white">
    <div class="max-w-3xl mx-auto px-6 py-16 md:py-20 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">{c.midCta.title}</h2>
      <p class="text-white/80 leading-relaxed mb-7 max-w-2xl mx-auto">{c.midCta.body}</p>
      <a href={waLink} target="_blank" rel="noopener" class="inline-block bg-gold text-ink border-2 border-gold px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-white hover:border-white transition-colors">{c.midCta.label}</a>
    </div>
  </section>

  <!-- Photo spots -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.photoSpots.title}</h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.photoSpots.intro}</p>
      <div class="space-y-7">
        {c.photoSpots.items.map((s) => (
          <div>
            <h3 class="font-display text-lg md:text-xl font-bold text-ink mb-2">{s.name}</h3>
            <p class="text-ink/80 leading-relaxed" set:html={renderBold(s.body)} />
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Editorial band B -->
  {bandB && (
    <section class="relative h-[46vh] min-h-[300px] md:h-[62vh] overflow-hidden">
      <picture><source type="image/webp" srcset={toWebp(bandB.variants.lg)} /><img src={bandB.variants.lg} alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" width={bandB.width} height={bandB.height} /></picture>
    </section>
  )}

  <!-- Value-extra -->
  <Section bg="cream">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.valueExtra.title}</h2>
      {c.valueExtra.paras.map((p) => (<p class="text-ink/80 leading-relaxed mb-4 text-base md:text-lg" set:html={renderBold(p)} />))}
    </div>
  </Section>

  <!-- Gallery -->
  {galleryPics.length > 0 && (
    <Section>
      <div class="max-w-6xl mx-auto px-2">
        <div class="max-w-2xl mb-8"><h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{c.gallery.title}</h2><p class="text-ink/75 leading-relaxed">{c.gallery.intro}</p></div>
        <div class="columns-2 md:columns-3 gap-2 md:gap-3 [&>figure]:mb-2 md:[&>figure]:mb-3">
          {galleryPics.map((g, i) => (
            <figure class="break-inside-avoid overflow-hidden"><picture><source type="image/webp" srcset={toWebp(g.variants.md)} /><img src={g.variants.md} alt={galleryAlt(i)} class="w-full h-auto object-cover align-top" loading="lazy" decoding="async" width={g.width} height={g.height} /></picture></figure>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Related real work -->
  {related.length > 0 && (
    <Section bg="cream">
      <div class="max-w-5xl mx-auto px-2">
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{ui.realWork}</h2>
        <p class="text-ink/75 leading-relaxed mb-8 max-w-2xl">{ui.realWorkIntro}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {related.map((w) => (
            <a href={`${langPath}/bodas/${w.slug}`} class="group block">
              <div class="overflow-hidden aspect-[4/3] mb-3"><picture><source type="image/webp" srcset={toWebp(w.cover!)} /><img src={w.cover!} alt={`${w.couple} · Lifetime Weddings`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async" width="800" height="600" /></picture></div>
              <p class="font-display font-bold text-ink group-hover:text-gold-deep transition-colors">{w.couple}</p>
              <p class="text-sm text-ink/60">{ui.viewGallery} →</p>
            </a>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Qualifying form -->
  <LeadQualifyForm lang={lang} locationPrefill={town.locationPrefill} heading={c.formTitle} intro={c.formIntro} />

  <!-- FAQ -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-8">{c.faqTitle}</h2>
      <div class="divide-y divide-line border-y border-line">
        {c.faqs.map((f) => (
          <details class="group"><summary class="flex items-start justify-between gap-4 py-5 md:py-6 cursor-pointer list-none select-none"><span class="text-base md:text-lg leading-snug pr-2" style="font-weight:500;">{f.q}</span><span aria-hidden="true" class="shrink-0 w-6 h-6 mt-1 flex items-center justify-center text-gold-deep transition-transform duration-200 group-open:rotate-45"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg></span></summary><p class="pb-5 md:pb-6 pr-10 text-ink/75 leading-relaxed text-[0.95rem]" set:html={renderBold(f.a)} /></details>
        ))}
      </div>
    </div>
  </Section>

  <!-- Cross-links -->
  <Section bg="cream">
    <div class="max-w-4xl mx-auto px-2 text-center">
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
        <a href={`${langPath}/videograf-boda-${town.slug === 'salou' || town.slug === 'cambrils' ? town.slug : 'tarragona-lleida'}`} class="inline-block bg-ink text-white px-6 py-3 text-sm font-semibold hover:bg-gold hover:text-ink transition-colors">{ui.alsoVideo} →</a>
        <a href={venuesPath} class="inline-block border-2 border-ink text-ink px-6 py-3 text-sm font-semibold hover:bg-ink hover:text-white transition-colors">{ui.alsoVenues} →</a>
      </div>
      <h2 class="font-display text-lg md:text-xl font-bold mb-5">{ui.other}</h2>
      <div class="flex flex-wrap justify-center gap-2.5 mb-8">
        {siblings.map((s) => (<a href={s.href} class="inline-block border border-ink/25 px-4 py-2 text-sm font-semibold hover:border-gold hover:text-gold-deep transition-colors">{s.name}</a>))}
      </div>
      <a href={pillarPath} class="inline-block border-b border-gold text-ink font-semibold hover:text-gold transition-colors">{ui.back} →</a>
    </div>
  </Section>

  <!-- Final CTA 3 -->
  <Section>
    <div class="max-w-2xl mx-auto px-2 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-5">{c.finalCta.h2}</h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.finalCta.body}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={waLink} target="_blank" rel="noopener" class="inline-block bg-gold text-ink border-2 border-gold px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors">{c.finalCta.label}</a>
        <a href="#contacte" class="inline-block border-2 border-ink text-ink px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors">{c.formTitle}</a>
      </div>
    </div>
  </Section>

  <StickyMobileCta lang={lang} whatsAppHref={waLink} secondaryHref="#contacte" primaryLabel="WhatsApp" />
</BaseLayout>
