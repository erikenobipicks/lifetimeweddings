  `${PLACE}/2d4f94_692031755d7a4c5f92fc711df6fd3e14~mv2.webp`,
  `${PLACE}/2d4f94_9193908ac3384bb7bfb47a3ce0d213df~mv2.webp`,
];

const heroPhoto = SET[0];
const heroSrc = heroPhoto ? heroPhoto.variants.lg : PLACEHOLDERS[0];
const heroW = heroPhoto?.width ?? 1600;
const heroH = heroPhoto?.height ?? 1067;

type GItem = { src: string; w: number; h: number; portrait: boolean };
const galleryItems: GItem[] = hasReal
  ? SET.filter((i) => i.id !== heroPhoto?.id)
      .slice(0, 15)
      .map((i) => ({ src: i.variants.md, w: i.width, h: i.height, portrait: i.orientation === 'portrait' }))
  : PLACEHOLDERS.map((src) => ({ src, w: 1600, h: 1067, portrait: false }));

const langPath = lang === 'ca' ? '' : `/${lang}`;
const contactoPath = `${langPath}/contacto`;

