  description={c.meta.description}
  canonicalPath="/elopement-siurana"
  jsonLd={jsonLd}
  ogImage={heroSrc}
  ogType="article"
>
  <!-- Hero -->
  <section class="relative h-[78vh] min-h-[520px] overflow-hidden">
    <picture>
      {isJpg(heroSrc) && <source type="image/webp" srcset={toWebp(heroSrc)} />}
      <img
        src={heroSrc}
        alt={c.hero.heroAlt}
        class="absolute inset-0 w-full h-full object-cover"
        style="object-position: center 42%"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width={heroW}
        height={heroH}
