const canonicalUrl = `${SITE.url}${langPath}/elopement-siurana`;

const jsonLd = [
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}${langPath}/` },
    { name: c.breadcrumbCurrent, url: canonicalUrl },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: c.meta.title.split(' | ')[0],
    description: c.meta.description,
    provider: { '@type': 'LocalBusiness', name: 'Lifetime Weddings', url: SITE.url },
    areaServed: { '@type': 'Place', name: 'Siurana, Priorat, Tarragona, Catalonia, Spain' },
    serviceType: 'Elopement photography and videography',
    url: canonicalUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: c.faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];

/** Render a copy snippet that may contain **bold** markers, HTML-escaped first. */
function renderBold(s: string): string {
  const escaped = s.replace(/[<>&]/g, (ch) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[ch] as string));
  return escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}
