---
import { useTranslations, localePath, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 text-white isolate"
>
  <div class="absolute inset-0 -z-10 bg-ink">
    <img
      src="/photos/generic/001-lg.jpg"
      alt=""
      role="presentation"
      class="w-full h-full object-cover opacity-70"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/30 to-black/70"></div>
  </div>

  <img
    src="/logos/logo-triangular-white.png"
    alt=""
    aria-hidden="true"
    width="180"
    height="180"
    class="w-24 md:w-32 h-auto mb-6 opacity-95 drop-shadow"
    loading="eager"
    fetchpriority="high"
  />

  <p class="text-[0.7rem] md:text-xs font-bold tracking-[0.22em] uppercase text-gold mb-4 md:mb-6 px-4">
    {t('hero.eyebrow')}
  </p>

  <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold max-w-4xl leading-[1.1] mb-4 md:mb-5 drop-shadow">
    <span class="block">{t('hero.title')}</span>
    <span class="block italic font-normal mt-1 md:mt-2">{t('hero.title2')}</span>
  </h1>

  <p class="max-w-2xl text-sm md:text-base lg:text-lg opacity-95 mb-8 md:mb-10 font-light leading-relaxed px-2">
    {t('hero.subtitle')}
  </p>

  <div class="flex flex-col sm:flex-row gap-3 md:gap-4 items-stretch sm:items-center">
    <a
      href={localePath(lang, '/quiz')}
      class="inline-block bg-white text-ink border-2 border-white px-8 md:px-12 py-3.5 md:py-4 text-xs md:text-sm font-bold tracking-[0.18em] uppercase hover:bg-gold hover:border-gold hover:text-white transition-colors"
    >
      {t('hero.cta')}
    </a>
    <a
      href="#portfolio"
      class="inline-block border-2 border-white/70 text-white px-8 md:px-12 py-3.5 md:py-4 text-xs md:text-sm font-bold tracking-[0.18em] uppercase hover:bg-white/10 transition-colors"
    >
      {t('hero.cta.secondary')}
    </a>
  </div>
</section>
