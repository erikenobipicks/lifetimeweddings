---
import { useTranslations, localePath, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 text-white isolate"
>
  <div class="absolute inset-0 -z-10 bg-ink">
    <img
      src="/photos/generic/001-lg.jpg"
      alt=""
      role="presentation"
      class="w-full h-full object-cover opacity-70"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/20 to-black/60"></div>
  </div>

  <img
    src="/logos/logo-triangular-white.png"
    alt=""
    aria-hidden="true"
    width="180"
    height="180"
    class="w-32 md:w-40 h-auto mb-8 opacity-95 drop-shadow"
    loading="eager"
    fetchpriority="high"
  />
  <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold max-w-4xl leading-tight mb-5 drop-shadow">
    {t('hero.title')}
  </h1>
  <p class="max-w-2xl text-base md:text-lg opacity-95 mb-4 font-light tracking-wide">{t('hero.subtitle')}</p>
  <p class="font-display italic text-lg md:text-2xl opacity-90 mb-12">{t('hero.tagline')}</p>

  <a
    href={localePath(lang, '/quiz')}
    class="inline-block border-2 border-white px-10 md:px-14 py-4 text-xs md:text-sm font-bold tracking-[0.18em] uppercase hover:bg-white hover:text-ink transition-colors"
  >
    {t('hero.cta')}
  </a>
</section>
