---
import { useTranslations, localePath, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 text-white isolate"
>
  <div class="absolute inset-0 -z-10 bg-ink">
    <img
      src="/photos/generic/001-lg.jpg"
      alt=""
      role="presentation"
      class="w-full h-full object-cover opacity-70"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/30 to-black/70"></div>
  </div>

  <img
    src="/logos/logo-triangular-white.png"
    alt=""
    aria-hidden="true"
    width="180"
    height="180"
    class="w-24 md:w-32 h-auto mb-6 opacity-95 drop-shadow"
    loading="eager"
    fetchpriority="high"
  />

  <p
    class="eyebrow text-gold mb-4 md:mb-6 px-4"
    style="font-size: 0.75rem; letter-spacing: 0.14em; font-weight: 500;"
  >
    {t('hero.eyebrow')}
  </p>

  <h1
    class="font-display font-normal max-w-4xl mb-4 md:mb-5 drop-shadow px-2"
    style="font-size: clamp(1.75rem, 6vw, 4rem); line-height: 1.08; letter-spacing: -0.02em;"
  >
    <span class="block">{t('hero.title')}</span>
    <span class="block italic mt-1 md:mt-2">{t('hero.title2')}</span>
  </h1>

  <p
    class="max-w-2xl opacity-95 mb-8 md:mb-10 leading-relaxed px-2"
    style="font-size: clamp(0.95rem, 1.2vw, 1.125rem); font-weight: 400;"
  >
    {t('hero.subtitle')}
  </p>

  <div class="flex flex-col sm:flex-row gap-3 md:gap-4 items-stretch sm:items-center">
    <a
      href={localePath(lang, '/quiz')}
      class="inline-block bg-white text-ink border-2 border-white px-8 md:px-12 py-3.5 md:py-4 text-[0.8rem] md:text-[0.9rem] font-medium tracking-[0.14em] uppercase hover:bg-gold hover:border-gold hover:text-white transition-colors"
    >
      {t('hero.cta')}
    </a>
    <a
      href="#portfolio"
      class="inline-block border-2 border-white/70 text-white px-8 md:px-12 py-3.5 md:py-4 text-[0.8rem] md:text-[0.9rem] font-medium tracking-[0.14em] uppercase hover:bg-white/10 transition-colors"
    >
      {t('hero.cta.secondary')}
    </a>
  </div>
</section>
