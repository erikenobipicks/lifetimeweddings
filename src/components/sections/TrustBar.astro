---
// Thin horizontal bar with 4 trust signals. Rendered right after the hero so
// the visitor sees credibility before scrolling into the portfolio. The
// rating signal links to our public Google Business Profile so the "5★ on
// Google" claim is verifiable in one click.

import { useTranslations, type Lang } from '~/i18n/ui';
import { SITE } from '~/data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const items: { label: string; href?: string }[] = [
  { label: t('trust.weddings') },
  { label: t('trust.coverage') },
  { label: t('trust.delivery') },
  { label: t('trust.rating'), href: SITE.googleReviewsUrl },
];
---

<section aria-label="Trust" class="bg-cream border-y border-line">
  <div class="max-w-6xl mx-auto px-4 md:px-6 py-4 md:py-5">
    <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 md:gap-x-8 text-[0.65rem] md:text-[0.75rem] font-bold tracking-[0.16em] uppercase text-ink/70">
      {items.map((it, i) => (
        <li class="flex items-center whitespace-nowrap">
          {it.href ? (
            <a href={it.href} target="_blank" rel="noopener" class="hover:text-gold transition-colors underline-offset-2 hover:underline">{it.label}</a>
          ) : (
            it.label
          )}
          {i < items.length - 1 && <span class="ml-4 md:ml-8 text-gold/60" aria-hidden="true">·</span>}
        </li>
      ))}
    </ul>
  </div>
</section>
