---
// Lead-qualifying contact form used across the elopement cluster (pillar +
// locality pages). Captures the fields Eric wants to triage a lead fast:
// session type, guest count, budget, desired location and how they found us —
// on top of name/email/date/message. Posts as JSON to /api/contact (which
// accepts these optional fields). Self-contained per-language copy so it
// drops onto any page without touching the global i18n dictionary.
import Section from '../Section.astro';
import type { Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  /** Prefill the "desired location" field (e.g. "Siurana"). */
  locationPrefill?: string;
  /** Anchor id for in-page CTA links. */
  id?: string;
  /** Section heading + intro. Falls back to per-language defaults. */
  heading?: string;
  intro?: string;
}
const { lang, locationPrefill = '', id = 'contacte', heading, intro } = Astro.props;
const turnstileSitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '';

type FormCopy = {
  heading: string;
  intro: string;
  name: string;
  email: string;
  sessionType: string;
  sessionOptions: string[];
  guests: string;
  guestsOptions: string[];
  budget: string;
  budgetOptions: string[];
  location: string;
  date: string;
  datePlaceholder: string;
  source: string;
  sourceOptions: string[];
  message: string;
  messagePlaceholder: string;
  choose: string;
  consent: string;
  submit: string;
  microcopy: string;
  success: string;
  error: string;
};

