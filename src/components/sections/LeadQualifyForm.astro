const c = COPY[lang];
const selectClass =
  'w-full px-4 py-3 border border-line bg-white focus:border-gold focus:outline-none transition-colors';
---

<Section id={id} bg="cream">
  <div class="max-w-xl mx-auto">
    <div class="text-center mb-8">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{heading ?? c.heading}</h2>
      <p class="text-ink/75 leading-relaxed">{intro ?? c.intro}</p>
    </div>

    <form class="grid gap-5 text-left" data-lead-form action="/api/contact" method="POST" novalidate>
      <input type="hidden" name="_language" value={lang} />
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label for="lq-name" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.name} *</label>
          <input id="lq-name" name="name" type="text" required autocomplete="name" class={selectClass} />
        </div>
        <div>
          <label for="lq-email" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.email} *</label>
          <input id="lq-email" name="email" type="email" required autocomplete="email" class={selectClass} />
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label for="lq-session" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.sessionType}</label>
          <select id="lq-session" name="session_type" class={selectClass}>
            <option value="">{c.choose}</option>
            {c.sessionOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>
        <div>
          <label for="lq-guests" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.guests}</label>
          <select id="lq-guests" name="guests" class={selectClass}>
            <option value="">{c.choose}</option>
            {c.guestsOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label for="lq-budget" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.budget}</label>
          <select id="lq-budget" name="budget" class={selectClass}>
            <option value="">{c.choose}</option>
            {c.budgetOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>
        <div>
          <label for="lq-location" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.location}</label>
          <input id="lq-location" name="location_pref" type="text" value={locationPrefill} class={selectClass} />
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div>
          <label for="lq-date" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.date}</label>
          <input id="lq-date" name="wedding_date" type="text" placeholder={c.datePlaceholder} class={selectClass} />
        </div>
        <div>
          <label for="lq-source" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.source}</label>
          <select id="lq-source" name="source" class={selectClass}>
            <option value="">{c.choose}</option>
            {c.sourceOptions.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>
      </div>

      <div>
        <label for="lq-message" class="block text-xs font-bold tracking-[0.1em] uppercase mb-2">{c.message}</label>
        <textarea id="lq-message" name="message" rows="4" placeholder={c.messagePlaceholder} class={`${selectClass} resize-y`}></textarea>
      </div>

      <label class="flex items-start gap-2 text-sm text-ink/75">
        <input type="checkbox" name="consent" required class="mt-1 accent-gold" />
        <span>{c.consent}</span>
      </label>

      {turnstileSitekey && (
        <div class="cf-turnstile flex justify-center" data-sitekey={turnstileSitekey} data-theme="light" data-size="flexible"></div>
      )}

      <div class="flex flex-col items-center gap-3">
        <button
          type="submit"
          class="border-2 border-ink bg-ink text-white px-14 py-4 text-xs font-bold tracking-[0.18em] uppercase hover:bg-gold hover:text-ink hover:border-gold transition-colors"
        >
          {c.submit}
        </button>
        <p class="text-xs text-ink/70">{c.microcopy}</p>
      </div>

      <p class="hidden text-center font-display italic text-gold-deep" data-lead-success>{c.success}</p>
      <p class="hidden text-center text-red-600" data-lead-error>{c.error}</p>
    </form>
  </div>
</Section>

{turnstileSitekey && (
  <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
)}

<script>
  // Same JSON-POST pattern as ContactForm: intercept submit, POST JSON to
  // /api/contact, swap inline success/error, fire consent-aware tracking.
  const form = document.querySelector<HTMLFormElement>('[data-lead-form]');
  const ok = document.querySelector<HTMLElement>('[data-lead-success]');
  const err = document.querySelector<HTMLElement>('[data-lead-error]');
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    ok?.classList.add('hidden');
    err?.classList.add('hidden');
    if (submitBtn) submitBtn.disabled = true;

    try {
      const payload: Record<string, string> = {};
      for (const [k, v] of new FormData(form).entries()) payload[k] = String(v);

      const tkInput = form.querySelector<HTMLInputElement>('input[name="cf-turnstile-response"]');
      if (tkInput?.value) payload.captchaToken = tkInput.value;
      delete payload['cf-turnstile-response'];

      let metaEventId = '';
      if (typeof (window as any).fbq === 'function') {
        metaEventId =
          window.crypto && 'randomUUID' in window.crypto
            ? window.crypto.randomUUID()
            : String(Date.now()) + '-' + Math.round(Math.random() * 1e9);
        payload.metaEventId = metaEventId;
        payload.eventSourceUrl = location.href;
        const readCookie = (name: string) => {
          const m = document.cookie.match('(?:^|; )' + name + '=([^;]*)');
          return m ? decodeURIComponent(m[1]) : '';
        };
        const fbp = readCookie('_fbp');
        const fbc = readCookie('_fbc');
        if (fbp) payload.fbp = fbp;
        if (fbc) payload.fbc = fbc;
      }

      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const detail = await res.text().catch(() => '');
        throw new Error('HTTP ' + res.status + (detail ? ' ' + detail : ''));
      }
      ok?.classList.remove('hidden');
      (window as any).lwTrack?.('qualify_lead', { source: 'elopement_form' });
      if (metaEventId && typeof (window as any).fbq === 'function') {
        (window as any).fbq('track', 'Lead', {}, { eventID: metaEventId });
      }
      form.reset();
    } catch (error) {
      console.error('[lead] submit failed', error);
      err?.classList.remove('hidden');
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
