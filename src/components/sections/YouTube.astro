---
import Section from '../Section.astro';
import { useTranslations, type Lang } from '~/i18n/ui';
import { SITE } from '~/data/site';
import { getLatestVideos } from '~/lib/youtube';

interface Props {
  lang: Lang;
  /** Fallback video ID when the RSS fetch fails. */
  fallbackVideoId?: string;
}
const { lang, fallbackVideoId = 'Q8mJr2BnfUc' } = Astro.props;
const t = useTranslations(lang);

const videos = await getLatestVideos(1);
const featured = videos[0];
const featuredId = featured?.id ?? fallbackVideoId;
const featuredTitle = featured?.title ?? t('yt.title');
---

<Section id="youtube" bg="ink">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold mb-8 md:mb-10 text-white">
      {t('yt.title')}
    </h2>

    <div class="relative aspect-video bg-black mb-6 shadow-2xl">
      <iframe
        src={`https://www.youtube-nocookie.com/embed/${featuredId}`}
        title={featuredTitle}
        class="absolute inset-0 w-full h-full"
        loading="lazy"
        allowfullscreen
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        referrerpolicy="strict-origin-when-cross-origin"
      ></iframe>
    </div>

    <a
      href={SITE.social.youtube}
      target="_blank"
      rel="noopener"
      class="inline-block text-xs md:text-sm font-bold tracking-[0.18em] uppercase text-gold hover:text-white transition-colors"
    >
      {t('yt.more')}
    </a>
  </div>
</Section>
