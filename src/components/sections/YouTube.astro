---
import Section from '../Section.astro';
import { useTranslations, type Lang } from '~/i18n/ui';
import { SITE } from '~/data/site';
import { getLatestVideos } from '~/lib/youtube';
import { videoEmbed, videoThumb, videoThumbFallback } from '~/data/videos';

interface Props {
  lang: Lang;
  /** Fallback video ID when the RSS fetch fails. */
  fallbackVideoId?: string;
}
const { lang, fallbackVideoId = 'Q8mJr2BnfUc' } = Astro.props;
const t = useTranslations(lang);

const videos = await getLatestVideos(1);
const featured = videos[0];
const featuredId = featured?.id ?? fallbackVideoId;
const featuredTitle = featured?.title ?? t('yt.title');

// Click-to-load: render a thumbnail + play button until the user clicks.
// Saves ~500 KB on every home view and avoids YouTube setting cookies on
// behalf of visitors who never play the video. Same pattern used on /videos.
const playLabel =
  lang === 'es' ? 'Reproducir vídeo' : lang === 'en' ? 'Play video' : 'Reproduir vídeo';
---

<Section id="youtube" bg="ink">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold mb-8 md:mb-10 text-white">
      {t('yt.title')}
    </h2>

    <div
      class="relative aspect-video bg-black mb-6 shadow-2xl overflow-hidden"
      data-yt-embed
      data-yt-id={featuredId}
    >
      <button
        type="button"
        class="absolute inset-0 w-full h-full group focus:outline-none focus:ring-2 focus:ring-gold"
        aria-label={`${playLabel}: ${featuredTitle}`}
        data-yt-toggle
      >
        <img
          src={videoThumb(featuredId)}
          data-fallback={videoThumbFallback(featuredId)}
          alt={featuredTitle}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
          width="1280"
          height="720"
        />
        <span class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-colors"></span>
        <span class="absolute inset-0 flex items-center justify-center">
          <span class="w-16 h-16 md:w-20 md:h-20 bg-white/90 rounded-full flex items-center justify-center group-hover:bg-white transition-colors shadow-lg">
            <svg viewBox="0 0 24 24" class="w-7 h-7 md:w-8 md:h-8 fill-ink ml-1" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </span>
      </button>
    </div>

    <a
      href={SITE.social.youtube}
      target="_blank"
      rel="noopener"
      class="inline-block text-xs md:text-sm font-bold tracking-[0.18em] uppercase text-gold hover:text-white transition-colors"
    >
      {t('yt.more')}
    </a>
  </div>
</Section>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-yt-embed]').forEach((wrap) => {
      const btn = wrap.querySelector('[data-yt-toggle]');
      const img = wrap.querySelector('img[data-fallback]');
      const id = wrap.getAttribute('data-yt-id');
      if (img) {
        img.addEventListener(
          'error',
          () => {
            img.src = img.dataset.fallback;
          },
          { once: true },
        );
      }
      if (!btn || !id) return;
      btn.addEventListener('click', () => {
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.title = btn.getAttribute('aria-label') || 'Video';
        iframe.className = 'absolute inset-0 w-full h-full';
        iframe.setAttribute('frameborder', '0');
        iframe.setAttribute(
          'allow',
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture',
        );
        iframe.setAttribute('allowfullscreen', '');
        iframe.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
        wrap.replaceChildren(iframe);
      });
    });
  })();
</script>
