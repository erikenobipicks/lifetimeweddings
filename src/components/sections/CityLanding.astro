---
// Shared template for the per-city photo & video wedding pages.
//   photo -> /fotograf-boda-<slug>
//   video -> /videograf-boda-<slug>
// Fully data-driven from one CityPage + the service. Video pages embed a real
// YouTube film (click-to-load facade) when the city has a `videoId`.
//
// Honesty: cities without a real on-location gallery use real portfolio
// imagery (PHOTOS['generic']) with neutral alt text and link out to genuine
// real work.

import BaseLayout from '~/layouts/BaseLayout.astro';
import Section from '~/components/Section.astro';
import StickyMobileCta from '~/components/StickyMobileCta.astro';
import LeadQualifyForm from '~/components/sections/LeadQualifyForm.astro';
import { SITE, WHATSAPP_BASE } from '~/data/site';
import { useTranslations, type Lang } from '~/i18n/ui';
import { getGbpRating } from '~/lib/gbp-rating';
import { breadcrumbJsonLd, faqPageJsonLd, webPageJsonLd, cityServiceJsonLd } from '~/lib/seo';
import { PHOTOS } from '~/data/photos.generated';
import { WEDDINGS, weddingCover } from '~/data/weddings';
import { CITIES } from '~/data/cities';
import type { CityPage, Service } from '~/data/cities/types';
import { videoThumb, videoThumbFallback } from '~/data/videos';

interface Props {
  city: CityPage;
  service: Service;
  lang: Lang;
}
const { city, service, lang } = Astro.props;
const t = useTranslations(lang);
const c = city.copy[service][lang];
const rating = await getGbpRating();
const isVideo = service === 'video';

const langPath = lang === 'ca' ? '' : `/${lang}`;
const base = isVideo ? 'videograf-boda' : 'fotograf-boda';
const sisterBase = isVideo ? 'fotograf-boda' : 'videograf-boda';
const canonicalPath = `/${base}-${city.slug}`;
const canonicalUrl = `${SITE.url}${langPath}${canonicalPath}`;

const toWebp = (p: string): string => p.replace(/\.jpe?g$/i, '.webp');
const GEN = PHOTOS['generic']?.images ?? [];
// Video reuses the same city image pool but reversed, so the foto and vídeo
// pages of one city don't open with the same picture.
const idxs = isVideo ? [...city.imageIndices].reverse() : city.imageIndices;
const pics = idxs.map((i) => GEN[i - 1]).filter(Boolean);
const hero = pics[0];
const bandA = pics[1];
const galleryPics = pics.slice(2);

// Cross-links.
const pillarPath = isVideo
  ? `${langPath}/videograf-boda-tarragona-lleida`
  : `${langPath}/fotograf-boda-tarragona-lleida`;
const pillarLabel = isVideo
  ? (lang === 'es' ? 'Vídeo de boda en Tarragona y Lleida' : lang === 'en' ? 'Wedding video in Tarragona & Lleida' : 'Vídeo de boda a Tarragona i Lleida')
  : (lang === 'es' ? 'Fotógrafo de boda en Tarragona y Lleida' : lang === 'en' ? 'Wedding photographer in Tarragona & Lleida' : 'Fotògraf de boda a Tarragona i Lleida');
const sisterPath = `${langPath}/${sisterBase}-${city.slug}`;
const sisterLabel = isVideo
  ? (lang === 'es' ? `Fotografía de boda en ${city.name}` : lang === 'en' ? `Wedding photography in ${city.name}` : `Fotografia de boda a ${city.name}`)
  : (lang === 'es' ? `Vídeo de boda en ${city.name}` : lang === 'en' ? `Wedding video in ${city.name}` : `Vídeo de boda a ${city.name}`);
const venuesPath = `${langPath}/venues`;

const siblings = CITIES.filter((x) => x.slug !== city.slug).map((x) => ({
  name: x.name,
  href: `${langPath}/${base}-${x.slug}`,
}));

const related = city.relatedWeddingSlugs
  .map((slug) => WEDDINGS.find((w) => w.slug === slug))
  .filter((w): w is NonNullable<typeof w> => Boolean(w))
  .map((w) => ({ slug: w.slug, couple: w.couple, cover: weddingCover(w) }))
  .filter((w) => w.cover);

const UI: Record<Lang, { spots: string; realWork: string; realWorkIntro: string; viewGallery: string; other: string; alsoVenues: string; back: string; ctaPrimary: string; ctaSecondary: string; alsoSister: string }> = {
  ca: { spots: c.spots.title, realWork: 'Feines reals nostres', realWorkIntro: 'Bodes reals que hem documentat. Aquesta és la nostra mirada.', viewGallery: 'Veure la galeria', other: 'Altres ciutats', alsoVenues: 'Mireu els millors espais de boda de la zona', back: 'Torna a la guia', ctaPrimary: 'Parla amb nosaltres', ctaSecondary: 'Escriviu-nos', alsoSister: sisterLabel },
  es: { spots: c.spots.title, realWork: 'Trabajo real nuestro', realWorkIntro: 'Bodas reales que hemos documentado. Esta es nuestra mirada.', viewGallery: 'Ver la galería', other: 'Otras ciudades', alsoVenues: 'Ved los mejores espacios de boda de la zona', back: 'Volver a la guía', ctaPrimary: 'Habla con nosotros', ctaSecondary: 'Escribidnos', alsoSister: sisterLabel },
  en: { spots: c.spots.title, realWork: 'Our real work', realWorkIntro: 'Real weddings we have documented. This is how we see.', viewGallery: 'View the gallery', other: 'Other towns', alsoVenues: 'See the best wedding venues in the area', back: 'Back to the guide', ctaPrimary: 'Talk to us', ctaSecondary: 'Write to us', alsoSister: sisterLabel },
};
const ui = UI[lang];

const waLink = `${WHATSAPP_BASE}&text=${encodeURIComponent(c.whatsAppMessage)}`;
const serviceType = isVideo ? 'Wedding videography' : 'Wedding photography';

const jsonLd = [
  webPageJsonLd({
    pageUrl: canonicalUrl,
    name: c.meta.title,
    description: c.meta.description,
    lang,
    primaryImage: hero ? { url: hero.variants.lg, width: hero.width, height: hero.height, caption: c.hero.heroAlt } : undefined,
  }),
  cityServiceJsonLd({
    name: c.meta.title.split(' | ')[0],
    serviceType,
    areaName: city.name,
    areaServed: city.areaServed,
    canonicalUrl,
  }),
  faqPageJsonLd(c.faqs.map((f) => ({ question: f.q, answer: f.a }))),
  breadcrumbJsonLd([
    { name: t('schema.breadcrumb.home'), url: `${SITE.url}${langPath}/` },
    { name: pillarLabel, url: `${SITE.url}${pillarPath}` },
    { name: c.breadcrumbCurrent, url: canonicalUrl },
  ]),
];

function renderBold(s: string): string {
  const escaped = s.replace(/[<>&]/g, (ch) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[ch] as string));
  return escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}
const galleryAlt = (i: number) => `${c.breadcrumbCurrent} · Lifetime Weddings · ${String(i + 1).padStart(2, '0')}`;
---

<BaseLayout
  lang={lang}
  title={c.meta.title}
  description={c.meta.description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  ogImage={hero ? hero.variants.lg : '/og-default.jpg'}
  ogType="article"
>
  <!-- Hero -->
  <section class="relative h-[74vh] min-h-[500px] overflow-hidden">
    {hero && (
      <picture>
        <source type="image/webp" srcset={toWebp(hero.variants.lg)} />
        <img src={hero.variants.lg} alt={c.hero.heroAlt}
             class="absolute inset-0 w-full h-full object-cover" style="object-position:center 42%"
             loading="eager" fetchpriority="high" decoding="async" width={hero.width} height={hero.height} />
      </picture>
    )}
    <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/30 to-black/75"></div>
    <div class="relative z-10 h-full flex flex-col items-center justify-center text-center text-white px-6">
      <p class="text-xs font-bold tracking-[0.24em] uppercase text-gold mb-4">{c.hero.eyebrow}</p>
      <h1 class="font-display text-3xl md:text-5xl font-bold max-w-4xl leading-tight">{c.hero.h1}</h1>
      <p class="mt-5 max-w-2xl text-base md:text-lg leading-relaxed opacity-95">{c.hero.sub}</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a href={waLink} target="_blank" rel="noopener"
           class="inline-block bg-gold text-ink border-2 border-gold px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors">
          {ui.ctaPrimary}
        </a>
        <a href="#contacte"
           class="inline-block border-2 border-white/80 text-white px-8 py-3.5 text-sm font-bold tracking-[0.14em] uppercase hover:bg-white/10 transition-colors">
          {c.formTitle}
        </a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="bg-ink text-white py-6 px-6 border-y border-gold/20">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row gap-4 sm:gap-10 items-center justify-center text-center text-sm">
      <div class="flex items-center gap-2"><span class="text-gold font-bold">{rating.ratingValue.toFixed(1)}★</span><span class="opacity-85">Google · {rating.reviewCount}</span></div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2"><span class="text-gold font-bold">2</span><span class="opacity-85">{lang === 'es' ? 'hermanos · foto + vídeo' : lang === 'en' ? 'brothers · photo + video' : 'germans · foto + vídeo'}</span></div>
      <div class="hidden sm:block w-px h-5 bg-white/20"></div>
      <div class="flex items-center gap-2"><span class="text-gold font-bold">{lang === 'en' ? '1 week' : '1 setmana'}</span><span class="opacity-85">{lang === 'es' ? 'de entrega' : lang === 'en' ? 'delivery' : 'de lliurament'}</span></div>
    </div>
  </section>

  <!-- Intro -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-6">{c.intro.title}</h2>
      {c.intro.paras.map((p) => (<p class="text-ink/80 leading-relaxed mb-4 text-base md:text-lg" set:html={renderBold(p)} />))}
    </div>
  </Section>

  <!-- Editorial band -->
  {bandA && (
    <section class="relative h-[46vh] min-h-[300px] md:h-[62vh] overflow-hidden">
      <picture>
        <source type="image/webp" srcset={toWebp(bandA.variants.lg)} />
        <img src={bandA.variants.lg} alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" width={bandA.width} height={bandA.height} />
      </picture>
    </section>
  )}

  <!-- Spots -->
  <Section bg="cream">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.spots.title}</h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.spots.intro}</p>
      <div class="space-y-7">
        {c.spots.items.map((s) => (
          <div>
            <h3 class="font-display text-lg md:text-xl font-bold text-ink mb-2">{s.name}</h3>
            <p class="text-ink/80 leading-relaxed" set:html={renderBold(s.body)} />
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Area venues / restaurants (optional) — internal links preferred -->
  {c.areaVenues && (
    <Section>
      <div class="max-w-3xl mx-auto px-2">
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.areaVenues.title}</h2>
        <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.areaVenues.intro}</p>
        <div class="space-y-7">
          {c.areaVenues.items.map((v) => (
            <div>
              <h3 class="font-display text-lg md:text-xl font-bold text-ink mb-2">{v.name}</h3>
              <p class="text-ink/80 leading-relaxed" set:html={renderBold(v.body)} />
              {v.href && (
                <p class="mt-2"><a href={`${langPath}${v.href}`} class="inline-block border-b border-gold text-ink font-semibold hover:text-gold transition-colors">{v.name} →</a></p>
              )}
              {!v.href && v.externalUrl && (
                <p class="mt-2"><a href={v.externalUrl} target="_blank" rel="nofollow noopener" class="inline-block border-b border-line text-ink/70 font-semibold hover:text-gold transition-colors">{v.name} ↗</a></p>
              )}
            </div>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Mid-funnel CTA band (optional) -->
  {c.midCta && (
    <section class="relative overflow-hidden bg-ink text-white">
      <div class="max-w-3xl mx-auto px-6 py-16 md:py-20 text-center">
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">{c.midCta.title}</h2>
        <p class="text-white/80 leading-relaxed mb-7 max-w-2xl mx-auto">{c.midCta.body}</p>
        <a href={waLink} target="_blank" rel="noopener" class="inline-block bg-gold text-ink border-2 border-gold px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-white hover:border-white transition-colors">{c.midCta.label}</a>
      </div>
    </section>
  )}

  <!-- Video embed (video pages with a real film) -->
  {isVideo && city.videoId && (
    <Section bg="ink">
      <div class="max-w-4xl mx-auto px-2">
        <div class="relative aspect-video bg-black overflow-hidden shadow-xl" data-yt-embed data-yt-id={city.videoId}>
          <button type="button" class="absolute inset-0 w-full h-full group focus:outline-none focus:ring-2 focus:ring-gold" aria-label={`${c.breadcrumbCurrent}`} data-yt-toggle>
            <img src={videoThumb(city.videoId)} data-fallback={videoThumbFallback(city.videoId)} alt={c.breadcrumbCurrent} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" width="1280" height="720" />
            <span class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-colors"></span>
            <span class="absolute inset-0 flex items-center justify-center"><span class="w-16 h-16 md:w-20 md:h-20 bg-white/90 rounded-full flex items-center justify-center group-hover:bg-white transition-colors shadow-lg"><svg viewBox="0 0 24 24" class="w-7 h-7 md:w-8 md:h-8 fill-ink ml-1" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg></span></span>
          </button>
        </div>
        <div class="text-center mt-8"><a href={SITE.social.youtube} target="_blank" rel="noopener" class="inline-block text-xs md:text-sm font-bold tracking-[0.18em] uppercase text-gold hover:text-white transition-colors">{lang === 'es' ? 'Más vídeos en nuestro canal' : lang === 'en' ? 'More videos on our channel' : 'Més vídeos al nostre canal'} →</a></div>
      </div>
    </Section>
  )}

  <!-- Style / ambience -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-5">{c.style.title}</h2>
      {c.style.paras.map((p) => (<p class="text-ink/80 leading-relaxed mb-4 text-base md:text-lg" set:html={renderBold(p)} />))}
    </div>
  </Section>

  <!-- Approach -->
  <Section bg="cream">
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-6">{c.approach.title}</h2>
      <ul class="space-y-4">
        {c.approach.bullets.map((b) => (
          <li class="flex gap-3"><svg viewBox="0 0 24 24" class="w-5 h-5 mt-0.5 shrink-0 text-gold" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12" /></svg><span class="text-ink/85 leading-relaxed" set:html={renderBold(b)} /></li>
        ))}
      </ul>
    </div>
  </Section>

  <!-- Gallery -->
  {galleryPics.length > 0 && (
    <Section>
      <div class="max-w-6xl mx-auto px-2">
        <div class="max-w-2xl mb-8">
          <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{c.gallery.title}</h2>
          <p class="text-ink/75 leading-relaxed">{c.gallery.intro}</p>
        </div>
        <div class="columns-2 md:columns-3 gap-2 md:gap-3 [&>figure]:mb-2 md:[&>figure]:mb-3">
          {galleryPics.map((g, i) => (
            <figure class="break-inside-avoid overflow-hidden">
              <picture><source type="image/webp" srcset={toWebp(g.variants.md)} /><img src={g.variants.md} alt={galleryAlt(i)} class="w-full h-auto object-cover align-top" loading="lazy" decoding="async" width={g.width} height={g.height} /></picture>
            </figure>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Related real work -->
  {related.length > 0 && (
    <Section bg="cream">
      <div class="max-w-5xl mx-auto px-2">
        <h2 class="font-display text-2xl md:text-3xl font-bold mb-3">{ui.realWork}</h2>
        <p class="text-ink/75 leading-relaxed mb-8 max-w-2xl">{ui.realWorkIntro}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {related.map((w) => (
            <a href={`${langPath}/bodas/${w.slug}`} class="group block">
              <div class="overflow-hidden aspect-[4/3] mb-3"><picture><source type="image/webp" srcset={toWebp(w.cover!)} /><img src={w.cover!} alt={`${w.couple} · Lifetime Weddings`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" decoding="async" width="800" height="600" /></picture></div>
              <p class="font-display font-bold text-ink group-hover:text-gold-deep transition-colors">{w.couple}</p>
              <p class="text-sm text-ink/60">{ui.viewGallery} →</p>
            </a>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Lead-qualifying form -->
  <LeadQualifyForm lang={lang} locationPrefill={city.locationPrefill} heading={c.formTitle} intro={c.formIntro} />

  <!-- FAQ -->
  <Section>
    <div class="max-w-3xl mx-auto px-2">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-8">{c.faqTitle}</h2>
      <div class="divide-y divide-line border-y border-line">
        {c.faqs.map((f) => (
          <details class="group">
            <summary class="flex items-start justify-between gap-4 py-5 md:py-6 cursor-pointer list-none select-none"><span class="text-base md:text-lg leading-snug pr-2" style="font-weight:500;">{f.q}</span><span aria-hidden="true" class="shrink-0 w-6 h-6 mt-1 flex items-center justify-center text-gold-deep transition-transform duration-200 group-open:rotate-45"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg></span></summary>
            <p class="pb-5 md:pb-6 pr-10 text-ink/75 leading-relaxed text-[0.95rem]" set:html={renderBold(f.a)} />
          </details>
        ))}
      </div>
    </div>
  </Section>

  <!-- Cross-links: sister service + venues + other cities + pillar -->
  <Section bg="cream">
    <div class="max-w-4xl mx-auto px-2 text-center">
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
        <a href={sisterPath} class="inline-block bg-ink text-white px-6 py-3 text-sm font-semibold hover:bg-gold hover:text-ink transition-colors">{ui.alsoSister} →</a>
        <a href={venuesPath} class="inline-block border-2 border-ink text-ink px-6 py-3 text-sm font-semibold hover:bg-ink hover:text-white transition-colors">{ui.alsoVenues} →</a>
      </div>
      <h2 class="font-display text-lg md:text-xl font-bold mb-5">{ui.other}</h2>
      <div class="flex flex-wrap justify-center gap-2.5 mb-8">
        {siblings.map((s) => (<a href={s.href} class="inline-block border border-ink/25 px-4 py-2 text-sm font-semibold hover:border-gold hover:text-gold-deep transition-colors">{s.name}</a>))}
      </div>
      <a href={pillarPath} class="inline-block border-b border-gold text-ink font-semibold hover:text-gold transition-colors">{ui.back} →</a>
    </div>
  </Section>

  <!-- Final CTA -->
  <Section>
    <div class="max-w-2xl mx-auto px-2 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-5">{c.finalCta.h2}</h2>
      <p class="text-ink/75 leading-relaxed mb-8 text-base md:text-lg">{c.finalCta.body}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={waLink} target="_blank" rel="noopener" class="inline-block bg-gold text-ink border-2 border-gold px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors">{ui.ctaPrimary}</a>
        <a href="#contacte" class="inline-block border-2 border-ink text-ink px-8 py-4 text-sm font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors">{ui.ctaSecondary}</a>
      </div>
    </div>
  </Section>

  <StickyMobileCta lang={lang} whatsAppHref={waLink} secondaryHref="#contacte" primaryLabel={ui.ctaPrimary} />
</BaseLayout>

{isVideo && city.videoId && (
  <script is:inline define:vars={{ gatedTitle: t('consent.gated.title'), gatedBody: t('consent.gated.body'), gatedCta: t('consent.gated.cta') }}>
    (() => {
      function consentRejected() { try { const raw = localStorage.getItem('lifetime.cookies.v1'); if (!raw) return false; return JSON.parse(raw)?.choice === 'reject'; } catch { return false; } }
      function showGatedMessage(wrap) {
        const div = document.createElement('div');
        div.className = 'absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-ink/90 text-white';
        div.innerHTML = '<p class="font-display text-lg font-bold mb-2">' + gatedTitle + '</p><p class="text-sm text-white/80 max-w-md mb-4">' + gatedBody + '</p><button type="button" data-cookie-reopen class="bg-gold text-ink text-xs font-bold tracking-[0.15em] uppercase px-5 py-2.5 hover:brightness-110 transition">' + gatedCta + '</button>';
        wrap.replaceChildren(div);
        const btn = div.querySelector('[data-cookie-reopen]');
        if (btn) btn.addEventListener('click', () => document.dispatchEvent(new CustomEvent('consent:reopen')));
      }
      document.querySelectorAll('[data-yt-embed]').forEach((wrap) => {
        const btn = wrap.querySelector('[data-yt-toggle]');
        const img = wrap.querySelector('img[data-fallback]');
        const id = wrap.getAttribute('data-yt-id');
        if (img) img.addEventListener('error', () => { img.src = img.dataset.fallback; }, { once: true });
        if (!btn || !id) return;
        btn.addEventListener('click', () => {
          if (consentRejected()) { showGatedMessage(wrap); return; }
          const iframe = document.createElement('iframe');
          iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
          iframe.title = btn.getAttribute('aria-label') || 'Video';
          iframe.className = 'absolute inset-0 w-full h-full';
          iframe.setAttribute('frameborder', '0');
          iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
          iframe.setAttribute('allowfullscreen', '');
          iframe.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
          wrap.replaceChildren(iframe);
        });
      });
    })();
  </script>
)}
