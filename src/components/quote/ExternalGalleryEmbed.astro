---
// "External photo gallery" CTA on /p/<token>.
//
// First version (Nov 2026, PR #124) tried to iframe the gallery and fell
// back to a CTA when the host refused via X-Frame-Options. FotoStudio
// (the only host we use today) always refuses framing, so the iframe
// path never succeeded in production — visitors saw an empty box for 4
// seconds while the watchdog ran, then a small fallback CTA appeared.
//
// This version skips the iframe attempt entirely and renders the visual
// card directly. Less visual jank, a tighter section, and the whole card
// is the link (bigger click target) instead of a discrete button.
//
// If we ever onboard a host that DOES allow framing we can reintroduce
// an iframe-first variant behind a flag — but for now the constant
// fallback is the entire UX.

import { useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  url: string;
}
const { lang, url } = Astro.props;
const t = useTranslations(lang);

const heading = t('quote.gallery.heading');
const newTabLabel = t('quote.gallery.newTab');
const eyebrow = t('quote.gallery.eyebrow');
const description = t('quote.gallery.description');
---

<section class="px-6 md:px-12 py-12 md:py-16 bg-cream text-ink">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-center mb-8">{heading}</h2>

    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="group block bg-ink text-white p-10 md:p-14 text-center hover:bg-gold hover:text-ink transition-colors focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2"
    >
      <span class="inline-flex items-center justify-center w-14 h-14 mb-5 border border-gold/40 group-hover:border-white/40 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-gold group-hover:text-white transition-colors" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="1.5" />
          <circle cx="9" cy="11" r="2" />
          <path d="M3 17l5-5 4 4 3-3 6 6" />
        </svg>
      </span>
      <p class="text-[0.7rem] font-bold tracking-[0.22em] uppercase text-gold group-hover:text-white/80 mb-3 transition-colors">{eyebrow}</p>
      <p class="font-display text-xl md:text-2xl font-bold mb-3">{description}</p>
      <span class="inline-flex items-center gap-2 text-xs font-bold tracking-[0.18em] uppercase border-b border-white/40 pb-1 group-hover:border-white transition-colors">
        {newTabLabel} <span aria-hidden="true">↗</span>
      </span>
    </a>
  </div>
</section>
