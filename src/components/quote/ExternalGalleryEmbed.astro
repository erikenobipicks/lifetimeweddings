---
// Embed an external photo gallery (e.g. FotoStudio) on /p/<token>.
//
// Many gallery hosts ship X-Frame-Options / CSP frame-ancestors headers
// that block iframe embedding from third-party domains. We can't reliably
// detect that ahead of time, so the strategy is:
//
//   1. Render the <iframe> first (works when the host allows framing).
//   2. Render the fallback CTA underneath as a hidden block.
//   3. A tiny client script watches for the iframe's `load` event. If
//      nothing fires within 4 s (the host returned an X-Frame-Options
//      error, the browser silently aborted the load), we hide the
//      iframe and reveal the fallback. JS-disabled users always see
//      both — the iframe gracefully degrades to a "blocked content"
//      box that's just below the CTA, so they have one obvious path.
//
// The CTA itself is also visible to anyone who wants to open the gallery
// in a new tab regardless — many hosts have richer UX (favourites,
// downloads, sharing) that the iframe can't expose.

import { useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  url: string;
}
const { lang, url } = Astro.props;
const t = useTranslations(lang);

// We pre-translate inline so the script can access them via define:vars.
const heading = t('quote.gallery.heading');
const newTabLabel = t('quote.gallery.newTab');
const blockedNote = t('quote.gallery.blocked');
---

<section class="px-6 md:px-12 py-16 md:py-20 bg-cream text-ink">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
      <h2 class="font-display text-2xl md:text-3xl font-bold">{heading}</h2>
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-ink/70 hover:text-gold whitespace-nowrap"
      >
        {newTabLabel} <span aria-hidden="true">↗</span>
      </a>
    </div>

    <!-- Iframe attempt. height ~70vh (clamped to 720px) so it stays
         readable across devices without dominating mobile. -->
    <div
      id="external-gallery-frame-wrap"
      class="relative bg-white border border-ink/10 overflow-hidden"
      style="aspect-ratio: 16 / 10; max-height: 720px"
    >
      <iframe
        id="external-gallery-frame"
        src={url}
        title={heading}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="absolute inset-0 w-full h-full border-0"
        allow="fullscreen"
      ></iframe>
    </div>

    <!-- Fallback CTA. Hidden by default when JS is available; revealed
         either by the watchdog (host blocked the iframe) or shown
         unconditionally to the JS-off audience. -->
    <noscript>
      <p class="mt-4 text-sm text-ink/60">{blockedNote}</p>
    </noscript>
    <div id="external-gallery-fallback" hidden class="mt-6 text-center">
      <p class="text-sm text-ink/70 mb-3">{blockedNote}</p>
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block border-2 border-ink bg-ink text-white px-8 py-3 text-xs font-bold tracking-[0.15em] uppercase hover:bg-gold hover:border-gold transition-colors"
      >
        {newTabLabel} ↗
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const frame = document.getElementById('external-gallery-frame');
    const wrap = document.getElementById('external-gallery-frame-wrap');
    const fallback = document.getElementById('external-gallery-fallback');
    if (!frame || !wrap || !fallback) return;

    let loaded = false;
    const showFallback = () => {
      if (loaded) return; // host loaded fine — leave the iframe in place
      wrap.style.display = 'none';
      fallback.hidden = false;
    };

    frame.addEventListener('load', () => {
      // We can't read across origins, but a `load` event means the
      // browser at least rendered SOMETHING — usually the gallery. If
      // the host refused via X-Frame-Options the browser may still
      // dispatch a load event for the error chrome; the 4 s watchdog
      // covers genuine refusals. False positives (showing fallback
      // when iframe loaded fine) are rare and harmless — the user
      // still sees the CTA AND the iframe.
      loaded = true;
    });
    frame.addEventListener('error', showFallback);
    // 4 s is enough for a slow connection to fetch the gallery shell;
    // if we still haven't seen `load` by then, the host almost
    // certainly blocked framing.
    setTimeout(showFallback, 4000);
  })();
</script>
