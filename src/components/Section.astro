---
interface Props {
  id?: string;
  class?: string;
  bg?: 'white' | 'cream' | 'sand' | 'ink';
  as?: 'section' | 'div';
}

const { id, class: className = '', bg = 'white', as: Tag = 'section' } = Astro.props;

const bgClass =
  bg === 'cream'
    ? 'bg-cream text-ink'
    : bg === 'sand'
      ? 'bg-sand text-ink'
      : bg === 'ink'
        ? 'bg-ink text-white'
        : 'bg-white text-ink';
---

<Tag id={id} class:list={[bgClass, 'py-24 md:py-32 px-6 md:px-12', className]}>
  <slot />
</Tag>
