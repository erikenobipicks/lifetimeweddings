---
// Shared "pricing assistant" for the admin booking forms.
//
// Renders three coupled tools that operate on the surrounding form's pack
// fields (by id): a pack-catalog picker, the catalog extras checkboxes, and
// the payment calculator. Used by BOTH the create form (new.astro) and the
// booking detail/edit page ([id].astro) so old/imported bookings can load a
// pack tariff and generate the reserva + 2n/3r (+ efectiu sense IVA) plan.
//
// It expects these ids to exist in the enclosing <form>:
//   #preferredLanguageField  #packNameField  #packIncludesField
//   #packPriceField  #depositField  #packAddonsField  #paymentTermsField
//
// When `bookingId` is set (the ficha), it also renders a button that dumps
// the calculated tranches into the booking_payments ledger as real rows.
import { PACKS, EXTRAS } from '~/data/packs';
import { buildPackCatalog, buildExtrasCatalog } from '~/lib/admin/packCatalog';

interface Props {
  /** When present, show the "dump tranches to the payments ledger" button. */
  bookingId?: string;
}

const { bookingId } = Astro.props;

const packCatalog = buildPackCatalog();
const extrasCatalog = buildExtrasCatalog();

// Default the dump date to today (Europe/Madrid), matching the payments form.
const todayIso = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Madrid' });
---

<div class="space-y-4" data-pack-payment-tools>
  <div class="bg-cream/60 border border-gold/30 p-4 md:p-5">
    <label class="block">
      <span class="text-xs font-bold tracking-widest uppercase text-ink/70">Carregar des d'un pack del catàleg</span>
      <span class="block text-[11px] text-ink/70 mb-1.5">Omple el nom, els ítems inclosos i el preu/dipòsit (30 %) segons l'idioma de la pàgina. Pots editar-ho després — útil per a packs antics.</span>
      <select id="pack-picker" class="mt-1 w-full px-3 py-2 border border-black/15 bg-white focus:border-gold focus:outline-none">
        <option value="">— Personalitzat (no carregar) —</option>
        {PACKS.map((p) => (
          <option value={p.id}>{p.name.ca} · {p.price}</option>
        ))}
      </select>
    </label>
  </div>

  <div class="bg-cream/60 border border-gold/30 p-4 md:p-5">
    <p class="text-xs font-bold tracking-widest uppercase text-ink/70">Extres del catàleg</p>
    <p class="text-[11px] text-ink/70 mb-3">Marca'n els que vols incloure i s'afegiran sols a la llista d'add-ons. Marca <strong>🎁 Regal</strong> per afegir-lo a cost 0 €.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
      {EXTRAS.map((x) => (
        <div class="flex items-start gap-2 py-1.5 px-2 hover:bg-white">
          <input id={`extra-${x.id}`} type="checkbox" data-extra-id={x.id} class="extra-toggle mt-1 accent-gold cursor-pointer" />
          <label for={`extra-${x.id}`} class="flex-1 text-sm cursor-pointer">
            <span class="text-ink">{x.name.ca}</span>
            <span class="block text-[11px] text-gold font-bold">{x.price}</span>
          </label>
          <label class="gift-toggle-wrap text-[11px] inline-flex items-center gap-1 px-1.5 py-0.5 rounded cursor-pointer select-none border border-transparent hover:border-gold/40" data-gift-wrap-for={x.id}>
            <input type="checkbox" data-gift-id={x.id} class="gift-toggle accent-gold" />
            <span>🎁 Regal</span>
          </label>
        </div>
      ))}
    </div>
  </div>

  <div class="bg-cream/60 border border-gold/30 p-4 md:p-5">
    <p class="text-xs font-bold tracking-widest uppercase text-ink/70 mb-1">💶 Calculadora de pagament</p>
    <p class="text-[11px] text-ink/70 mb-3">Suma automàticament <strong>Inversió total + add-ons</strong>. La part en <strong>efectiu</strong> es queda fora de la factura (estalvi del 21 % sobre aquell tram). Apreta el botó <strong>↻</strong> al costat d'un camp per completar-lo amb el que falta. <em>Inserir text al pla de pagament</em> copia el desglossament al camp de termes de pagament.</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
      <label class="block">
        <span class="text-[11px] font-bold tracking-wide uppercase text-ink/70">Reserva (€)</span>
        <div class="mt-1 flex">
          <input id="paySchedule0" data-pay-slot="0" type="number" min="0" step="1" class="pay-input flex-1 min-w-0 px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
          <button type="button" data-fill-slot="0" title="Completar amb la diferència" class="pay-fill px-2 border border-l-0 border-black/15 bg-cream hover:bg-gold hover:text-ink text-sm transition-colors">↻</button>
        </div>
      </label>
      <label class="block">
        <span class="text-[11px] font-bold tracking-wide uppercase text-ink/70">2n pagament (€)</span>
        <div class="mt-1 flex">
          <input id="paySchedule1" data-pay-slot="1" type="number" min="0" step="1" class="pay-input flex-1 min-w-0 px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
          <button type="button" data-fill-slot="1" title="Completar amb la diferència" class="pay-fill px-2 border border-l-0 border-black/15 bg-cream hover:bg-gold hover:text-ink text-sm transition-colors">↻</button>
        </div>
      </label>
      <label class="block">
        <span class="text-[11px] font-bold tracking-wide uppercase text-ink/70">3r pagament (€)</span>
        <div class="mt-1 flex">
          <input id="paySchedule2" data-pay-slot="2" type="number" min="0" step="1" class="pay-input flex-1 min-w-0 px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
          <button type="button" data-fill-slot="2" title="Completar amb la diferència" class="pay-fill px-2 border border-l-0 border-black/15 bg-cream hover:bg-gold hover:text-ink text-sm transition-colors">↻</button>
        </div>
      </label>
      <label class="block">
        <span class="text-[11px] font-bold tracking-wide uppercase text-ink/70">En efectiu (€)</span>
        <div class="mt-1 flex">
          <input id="payCash" data-pay-slot="cash" type="number" min="0" step="1" class="pay-input flex-1 min-w-0 px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
          <button type="button" data-fill-slot="cash" title="Completar amb la diferència" class="pay-fill px-2 border border-l-0 border-black/15 bg-cream hover:bg-gold hover:text-ink text-sm transition-colors">↻</button>
        </div>
        <span class="block text-[10px] text-ink/45 mt-0.5">tram fora de factura (estalvi IVA)</span>
      </label>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-xs bg-white border border-black/10 p-3">
      <div>
        <p class="text-ink/70">Inversió pack</p>
        <p id="calcPackTotal" class="font-bold text-ink">0 €</p>
      </div>
      <div>
        <p class="text-ink/70">Suma add-ons</p>
        <p id="calcAddonsTotal" class="font-bold text-ink">0 €</p>
      </div>
      <div data-discount-cell hidden>
        <p class="text-ink/70">Descompte</p>
        <p id="calcDiscount" class="font-bold text-gold">0 €</p>
      </div>
      <div>
        <p class="text-ink/70">Total amb IVA</p>
        <p id="calcGrossTotal" class="font-bold text-ink">0 €</p>
      </div>
      <div>
        <p class="text-ink/70">Total a cobrar <span class="text-[10px]">(amb efectiu)</span></p>
        <p id="calcNetTotal" class="font-bold text-gold">0 €</p>
      </div>
      <div class="col-span-2 md:col-span-4 text-[10px] text-ink/70 border-t border-black/5 pt-2">
        Base imposable: <span id="calcBase">0 €</span> · IVA 21 %: <span id="calcVat">0 €</span> · Estalvi efectiu: <span id="calcCashSaving">0 €</span>
        · Pagaments programats: <span id="calcScheduled">0 €</span>
        <span id="calcRemaining" class="ml-2 font-bold"></span>
      </div>
    </div>

    <div class="mt-3 flex flex-wrap items-end gap-3">
      <button type="button" id="insertPaymentPlanBtn" class="inline-block bg-ink text-white px-3 py-2 text-[11px] font-bold tracking-widest uppercase hover:bg-gold hover:text-ink transition-colors">
        Inserir text al pla de pagament
      </button>

      {bookingId && (
        <>
          <label class="block">
            <span class="text-[10px] font-bold tracking-wide uppercase text-ink/70">Data dels pagaments</span>
            <input id="dumpPaidOn" type="date" value={todayIso} class="mt-1 block px-2 py-1.5 border border-black/15 bg-white text-sm focus:border-gold focus:outline-none" />
          </label>
          <button
            type="button"
            id="dumpPaymentPlanBtn"
            data-booking-id={bookingId}
            class="inline-block bg-gold text-ink px-3 py-2 text-[11px] font-bold tracking-widest uppercase hover:bg-ink hover:text-white transition-colors"
            title="Crea una fila al llibre de pagaments per cada tram (reserva / 2n / 3r / efectiu) amb la data indicada"
          >
            ➜ Afegir trams al llibre de pagaments
          </button>
          <span id="dumpPlanStatus" class="text-[11px] text-ink/70 self-center"></span>
        </>
      )}
    </div>
  </div>

  <script id="pack-catalog-data" type="application/json" set:html={JSON.stringify(packCatalog)} />
  <script id="extras-catalog-data" type="application/json" set:html={JSON.stringify(extrasCatalog)} />
</div>

<script>
  // Money math (parsing, discount, VAT, tranche solving) is shared with the
  // server via ~/lib/payments/money — keep this file to DOM wiring only.
  import {
    parseEurosLoose,
    computeDiscountEuros,
    formatEurosAmount,
    paymentBreakdown,
    solveTranche,
    type PaymentInput,
  } from '~/lib/payments/money';

  type Lang = 'ca' | 'es' | 'en';
  interface PackCatalogItem {
    id: string;
    name: Record<Lang, string>;
    includes: Record<Lang, string[]>;
    priceEuros: number;
  }
  interface ExtraCatalogItem {
    id: string;
    name: Record<Lang, string>;
    priceEuros: number;
  }

  const packDataEl = document.getElementById('pack-catalog-data');
  const extrasDataEl = document.getElementById('extras-catalog-data');
  // The component might not be on the page (defensive) — bail quietly.
  if (packDataEl && extrasDataEl) {
    const packs: PackCatalogItem[] = JSON.parse(packDataEl.textContent || '[]');
    const extras: ExtraCatalogItem[] = JSON.parse(extrasDataEl.textContent || '[]');

    const picker = document.getElementById('pack-picker') as HTMLSelectElement | null;
    const langSel = document.getElementById('preferredLanguageField') as HTMLSelectElement | null;
    const nameField = document.getElementById('packNameField') as HTMLInputElement | null;
    const includesField = document.getElementById('packIncludesField') as HTMLTextAreaElement | null;
    const priceField = document.getElementById('packPriceField') as HTMLInputElement | null;
    const depositField = document.getElementById('depositField') as HTMLInputElement | null;
    const addonsField = document.getElementById('packAddonsField') as HTMLTextAreaElement | null;

    function currentLang(): Lang {
      const v = (langSel?.value as Lang) || 'ca';
      return v === 'es' || v === 'en' || v === 'ca' ? v : 'ca';
    }

    // Apply a pack catalog entry to the form. Overwrites Name + Includes +
    // Price + Deposit (defaulting to 30 % rounded to whole euros, matching
    // the FAQ payment plan we publish on /p/<token>).
    function applyPack(packId: string) {
      if (!packId) return;
      const p = packs.find((x) => x.id === packId);
      if (!p) return;
      const lang = currentLang();
      if (nameField) nameField.value = p.name[lang];
      if (includesField) includesField.value = p.includes[lang].join('\n');
      if (priceField) priceField.value = String(p.priceEuros);
      if (depositField) depositField.value = String(Math.round(p.priceEuros * 0.3));
      // Let other listeners (discount preview) and the calculator react.
      priceField?.dispatchEvent(new Event('input', { bubbles: true }));
      recalcPayment();
    }

    picker?.addEventListener('change', () => applyPack(picker.value));
    // Re-trigger the picker when the language flips so the includes get
    // rewritten in the new language without having to re-pick the pack.
    langSel?.addEventListener('change', () => {
      if (picker?.value) applyPack(picker.value);
    });

    // ─── Extras checkboxes ───────────────────────────────────────────────
    // Toggle appends/removes "Name | euros" lines in the add-ons textarea.
    function appendLine(textarea: HTMLTextAreaElement, line: string) {
      const cur = textarea.value.replace(/\s+$/, '');
      textarea.value = cur ? `${cur}\n${line}` : line;
    }

    function removeLine(textarea: HTMLTextAreaElement, predicate: (l: string) => boolean) {
      textarea.value = textarea.value
        .split(/\r?\n/)
        .filter((l) => !predicate(l))
        .join('\n');
    }

    function giftToggleFor(extraId: string): HTMLInputElement | null {
      return document.querySelector<HTMLInputElement>(`input.gift-toggle[data-gift-id="${extraId}"]`);
    }

    function lineFor(x: ExtraCatalogItem, lang: Lang, asGift: boolean): string {
      return asGift ? `🎁 ${x.name[lang]} (regal) | 0` : `${x.name[lang]} | ${x.priceEuros}`;
    }

    // Remove ANY existing line for this extra (gift or not).
    function removeAnyLineFor(textarea: HTMLTextAreaElement, x: ExtraCatalogItem) {
      const paidSuffix = `| ${x.priceEuros}`;
      const giftSuffix = `| 0`;
      const caGiftPrefix = `🎁 ${x.name.ca}`;
      const esGiftPrefix = `🎁 ${x.name.es}`;
      const enGiftPrefix = `🎁 ${x.name.en}`;
      removeLine(textarea, (l) => {
        const t = l.trim();
        if (t.endsWith(paidSuffix)) return true;
        if (
          t.endsWith(giftSuffix) &&
          (t.startsWith(caGiftPrefix) || t.startsWith(esGiftPrefix) || t.startsWith(enGiftPrefix))
        )
          return true;
        return false;
      });
    }

    function applyExtra(extraId: string) {
      if (!addonsField) return;
      const x = extras.find((e) => e.id === extraId);
      if (!x) return;
      const cb = document.querySelector<HTMLInputElement>(`input.extra-toggle[data-extra-id="${extraId}"]`);
      const gift = giftToggleFor(extraId);
      removeAnyLineFor(addonsField, x);
      if (cb?.checked) {
        appendLine(addonsField, lineFor(x, currentLang(), gift?.checked === true));
      }
      recalcPayment();
    }

    document.querySelectorAll<HTMLInputElement>('.extra-toggle').forEach((cb) => {
      cb.addEventListener('change', () => applyExtra(cb.dataset.extraId!));
    });
    document.querySelectorAll<HTMLInputElement>('.gift-toggle').forEach((g) => {
      g.addEventListener('change', () => {
        const id = g.dataset.giftId!;
        const cb = document.querySelector<HTMLInputElement>(`input.extra-toggle[data-extra-id="${id}"]`);
        if (cb && !cb.checked && g.checked) cb.checked = true;
        applyExtra(id);
      });
    });

    // ─── Payment calculator ──────────────────────────────────────────────
    // gross = (pack − discount) + addons (IVA included). The discount comes
    // from the surrounding booking form (percent or absolute euros) and is
    // applied to the pack price before anything else. The cash slice sits
    // OUTSIDE the invoice; the couple saves the 21 % VAT on that tram.
    //   cashSaving = cash * 0.21
    //   net = gross - cashSaving ;  sched0+sched1+sched2+cash = net
    //   ⇒ sched_sum = gross - cash*1.21 ;  cash = (gross - sched_sum)/1.21
    const cashInput = document.getElementById('payCash') as HTMLInputElement | null;
    const sched0 = document.getElementById('paySchedule0') as HTMLInputElement | null;
    const sched1 = document.getElementById('paySchedule1') as HTMLInputElement | null;
    const sched2 = document.getElementById('paySchedule2') as HTMLInputElement | null;
    const elPack = document.getElementById('calcPackTotal');
    const elAddons = document.getElementById('calcAddonsTotal');
    const elGross = document.getElementById('calcGrossTotal');
    const elNet = document.getElementById('calcNetTotal');
    const elBase = document.getElementById('calcBase');
    const elVat = document.getElementById('calcVat');
    const elCashSav = document.getElementById('calcCashSaving');
    const elScheduled = document.getElementById('calcScheduled');
    const elRemaining = document.getElementById('calcRemaining');
    const elDiscount = document.getElementById('calcDiscount');
    const discountCell = document.querySelector<HTMLElement>('[data-discount-cell]');
    const insertBtn = document.getElementById('insertPaymentPlanBtn');
    // Discount fields live in the surrounding booking form (new.astro /
    // [id].astro), not in this shared component — read them the same way we
    // read the pack/price fields.
    const discountValueField = document.getElementById('discountValueField') as HTMLInputElement | null;

    const fmt = formatEurosAmount;

    function sumAddons(): number {
      if (!addonsField) return 0;
      return addonsField.value
        .split(/\r?\n/)
        .map((l) => l.match(/\|\s*(\d+(?:[.,]\d+)?)\s*$/))
        .reduce((acc, m) => acc + (m ? parseEurosLoose(m[1]) : 0), 0);
    }

    // Gather the calculator inputs (euros) into the shared PaymentInput shape.
    function currentInput(): PaymentInput {
      const pack = parseEurosLoose(priceField?.value);
      const typeEl = document.querySelector<HTMLInputElement>('input[name="discountType"]:checked');
      const discount = computeDiscountEuros(typeEl?.value ?? 'amount', discountValueField?.value, pack);
      return {
        packEuros: pack,
        discountEuros: discount,
        addonsEuros: sumAddons(),
        cashEuros: parseEurosLoose(cashInput?.value),
        scheduled: [
          parseEurosLoose(sched0?.value),
          parseEurosLoose(sched1?.value),
          parseEurosLoose(sched2?.value),
        ],
      };
    }

    function recalcPayment() {
      const st = paymentBreakdown(currentInput());
      if (elPack) elPack.textContent = fmt(st.pack);
      if (elAddons) elAddons.textContent = fmt(st.addons);
      if (elDiscount) elDiscount.textContent = `−${fmt(st.discount)}`;
      if (discountCell) discountCell.hidden = st.discount <= 0;
      if (elGross) elGross.textContent = fmt(st.gross);
      if (elNet) elNet.textContent = fmt(st.net);
      if (elBase) elBase.textContent = fmt(st.base);
      if (elVat) elVat.textContent = fmt(st.vat);
      if (elCashSav) elCashSav.textContent = fmt(st.cashSaving);
      if (elScheduled) elScheduled.textContent = fmt(st.scheduled);
      if (elRemaining) {
        const diff = st.net - st.paid;
        if (st.gross === 0) {
          elRemaining.textContent = '';
          elRemaining.className = 'ml-2 font-bold';
        } else if (Math.abs(diff) < 1) {
          elRemaining.textContent = '✓ quadra';
          elRemaining.className = 'ml-2 font-bold text-green-700';
        } else if (diff > 0) {
          elRemaining.textContent = `Falta ${fmt(diff)}`;
          elRemaining.className = 'ml-2 font-bold text-amber-700';
        } else {
          elRemaining.textContent = `Sobra ${fmt(-diff)}`;
          elRemaining.className = 'ml-2 font-bold text-red-700';
        }
      }
    }

    function solveSlot(slot: '0' | '1' | '2' | 'cash'): number {
      return solveTranche(currentInput(), slot);
    }

    function generatePaymentText(): string {
      const input = currentInput();
      const st = paymentBreakdown(input);
      const r = Math.round(input.scheduled[0]);
      const p2 = Math.round(input.scheduled[1]);
      const p3 = Math.round(input.scheduled[2]);
      const cash = Math.round(st.cash);
      const lines: string[] = [];
      if (r > 0) lines.push(`Reserva: ${r} €`);
      if (p2 > 0) lines.push(`2n pagament: ${p2} €`);
      if (p3 > 0) lines.push(`3r pagament: ${p3} €`);
      if (cash > 0) lines.push(`+${cash} € en efectiu (estalvi IVA)`);
      lines.push(`Total: ${Math.round(st.net)} €`);
      return lines.join(' · ');
    }

    [priceField, addonsField, cashInput, sched0, sched1, sched2].forEach((el) => {
      el?.addEventListener('input', recalcPayment);
    });
    // Recalculate when the discount changes too (value or %/€ toggle).
    discountValueField?.addEventListener('input', recalcPayment);
    document
      .querySelectorAll<HTMLInputElement>('input[name="discountType"]')
      .forEach((r) => r.addEventListener('change', recalcPayment));
    document.querySelectorAll<HTMLButtonElement>('.pay-fill').forEach((btn) => {
      btn.addEventListener('click', () => {
        const slot = btn.dataset.fillSlot as '0' | '1' | '2' | 'cash' | undefined;
        if (!slot) return;
        const target = document.querySelector<HTMLInputElement>(`.pay-input[data-pay-slot="${slot}"]`);
        if (!target) return;
        target.value = String(solveSlot(slot));
        recalcPayment();
      });
    });
    insertBtn?.addEventListener('click', () => {
      const target = document.getElementById('paymentTermsField') as HTMLInputElement | null;
      if (target) target.value = generatePaymentText();
    });
    recalcPayment();

    // ─── Dump tranches → payments ledger (ficha only) ────────────────────
    const dumpBtn = document.getElementById('dumpPaymentPlanBtn') as HTMLButtonElement | null;
    const dumpDate = document.getElementById('dumpPaidOn') as HTMLInputElement | null;
    const dumpStatus = document.getElementById('dumpPlanStatus');
    dumpBtn?.addEventListener('click', async () => {
      const bookingId = dumpBtn.dataset.bookingId;
      if (!bookingId) return;
      const input = currentInput();
      const reserva = Math.round(input.scheduled[0]);
      const p2 = Math.round(input.scheduled[1]);
      const p3 = Math.round(input.scheduled[2]);
      const cash = Math.round(input.cashEuros);
      const count = [reserva, p2, p3, cash].filter((n) => n > 0).length;
      if (count === 0) {
        if (dumpStatus) dumpStatus.textContent = 'Omple algun tram primer.';
        return;
      }
      if (
        !confirm(
          `Es crearan ${count} fila(es) al llibre de pagaments amb la data indicada. Pots eliminar-les després. Continuar?`,
        )
      )
        return;
      const original = dumpBtn.textContent;
      dumpBtn.disabled = true;
      dumpBtn.textContent = 'Afegint…';
      try {
        const res = await fetch(`/api/admin/bookings/${bookingId}/payment-plan`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reserva, p2, p3, cash, paidOn: dumpDate?.value || null }),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.error || `HTTP ${res.status}`);
        window.location.assign('?ok=payment:dumped#pagaments');
      } catch (err) {
        console.error('[dump payment plan] failed', err);
        if (dumpStatus) dumpStatus.textContent = 'Error en afegir els pagaments.';
        dumpBtn.textContent = original;
        dumpBtn.disabled = false;
      }
    });
  }
</script>
