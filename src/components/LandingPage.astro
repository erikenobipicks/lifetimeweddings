---
import Section from './Section.astro';
import { PACKS, type Pack } from '~/data/packs';
import { type Landing } from '~/data/landings';
import { useTranslations, localePath, type Lang } from '~/i18n/ui';
import { waLink } from '~/data/site';

interface Props { lang: Lang; landing: Landing }
const { lang, landing } = Astro.props;
const t = useTranslations(lang);
const c = landing.copy[lang];

const recommended: Pack[] = landing.recommendedPackIds
  .map((id) => PACKS.find((p) => p.id === id))
  .filter((p): p is Pack => !!p);

const waHref = waLink(t('wa.message'));
---

<!-- Hero -->
<section class="relative min-h-[70vh] md:min-h-[80vh] flex items-center justify-center px-6 md:px-12 overflow-hidden">
  <img
    src={landing.heroImage}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover"
    fetchpriority="high"
    decoding="async"
  />
  <div class="absolute inset-0 bg-ink/55"></div>
  <div class="relative max-w-3xl mx-auto text-center text-white pt-24 pb-16">
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-4">{c.eyebrow}</p>
    <h1 class="font-display text-4xl md:text-6xl font-bold leading-[1.1] mb-6">{c.h1}</h1>
    <p class="text-white/85 text-base md:text-lg leading-relaxed max-w-2xl mx-auto">{c.intro}</p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a
        href={localePath(lang, '/contacto')}
        class="inline-block bg-white text-ink px-8 py-3.5 text-xs font-bold tracking-[0.18em] uppercase hover:bg-gold hover:text-white transition-colors"
      >
        {t('dossier.cta')}
      </a>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="inline-block border-2 border-white/80 text-white px-8 py-3.5 text-xs font-bold tracking-[0.18em] uppercase hover:bg-white hover:text-ink transition-colors"
      >
        {t('wa.chat')}
      </a>
    </div>
  </div>
</section>

<!-- Deliverables -->
<Section bg="cream">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-center mb-10">{t('landings.deliverables.title')}</h2>
    <ul class="space-y-4">
      {c.deliverables.map((d) => (
        <li class="flex items-start gap-3 text-ink/85">
          <svg viewBox="0 0 24 24" class="w-5 h-5 mt-1 shrink-0 text-gold" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="leading-relaxed">{d}</span>
        </li>
      ))}
    </ul>
  </div>
</Section>

<!-- Gallery strip -->
<Section bg="white">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
      {landing.galleryImages.map((src, i) => (
        <img
          src={src}
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
          class={`w-full object-cover ${i % 3 === 1 ? 'aspect-[3/4]' : 'aspect-[4/3]'}`}
        />
      ))}
    </div>
  </div>
</Section>

<!-- Recommended packs -->
<Section bg="cream">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-center mb-4">{t('landings.packs.title')}</h2>
    <p class="text-ink/75 text-center max-w-2xl mx-auto mb-10 leading-relaxed">{c.packsLead}</p>
    <div class={`grid gap-6 ${recommended.length === 1 ? 'md:grid-cols-1 max-w-md mx-auto' : recommended.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3'}`}>
      {recommended.map((p) => (
        <article class={`bg-white p-7 md:p-8 flex flex-col ${p.highlight === 'star' ? 'ring-2 ring-gold' : ''}`}>
          <h3 class="font-display text-xl font-bold mb-1.5">{p.name[lang]}</h3>
          <p class="text-gold text-lg font-bold mb-5">{p.price}</p>
          <ul class="space-y-2 text-sm text-ink/80 leading-relaxed mb-6 flex-1">
            {p.includes[lang].map((inc) => (
              <li class="flex items-start gap-2">
                <span class="text-gold mt-1" aria-hidden="true">·</span>
                <span>{inc}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</Section>

<!-- Closing CTA -->
<Section bg="ink">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="font-display text-2xl md:text-3xl font-bold text-white mb-5 leading-tight">{c.closing}</h2>
    <div class="mt-6 flex flex-wrap gap-3 justify-center">
      <a
        href={localePath(lang, '/contacto')}
        class="inline-block bg-gold text-white px-8 py-3.5 text-xs font-bold tracking-[0.18em] uppercase hover:brightness-110 transition"
      >
        {t('dossier.cta')}
      </a>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="inline-block border-2 border-white/80 text-white px-8 py-3.5 text-xs font-bold tracking-[0.18em] uppercase hover:bg-white hover:text-ink transition-colors"
      >
        {t('wa.chat')}
      </a>
    </div>
  </div>
</Section>
