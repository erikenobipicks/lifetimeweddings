---
import Section from './Section.astro';
import Icon from './Icon.astro';
import { PACKS, type PackType } from '~/data/packs';
import { useTranslations, localePath, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const groups: { type: PackType; label: string; icon: 'camera' | 'video' | 'diamond' }[] = [
  { type: 'photo', label: t('dossier.type.photo'), icon: 'camera' },
  { type: 'video', label: t('dossier.type.video'), icon: 'video' },
  { type: 'combo', label: t('dossier.type.combo'), icon: 'diamond' },
];

const iconByType = (type: PackType) =>
  type === 'photo' ? 'camera' : type === 'video' ? 'video' : 'diamond';
---

<Section bg="cream" class="pt-32">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('dossier.badge')}</p>
    <h1 class="font-display text-4xl md:text-5xl font-bold mb-5">{t('dossier.title')}</h1>
    <p class="text-ink/75 leading-relaxed">{t('dossier.lead')}</p>
  </div>
</Section>

{groups.map((g) => {
  const items = PACKS.filter((p) => p.type === g.type);
  return (
    <Section bg={g.type === 'video' ? 'cream' : 'white'}>
      <div class="max-w-6xl mx-auto">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-center mb-10">{g.label}</h2>
        <div class:list={[
          'grid gap-6 md:gap-8',
          items.length === 1 ? 'md:grid-cols-1 max-w-xl mx-auto' : items.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-2 lg:grid-cols-4',
        ]}>
          {items.map((p) => (
            <article class:list={[
              'relative bg-white p-8 border border-black/10 flex flex-col',
              p.featured ? 'ring-2 ring-gold' : '',
            ]}>
              {p.featured && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gold text-white text-[0.65rem] font-bold tracking-[0.18em] uppercase px-3 py-1">
                  {t('dossier.featured')}
                </span>
              )}
              <div class="text-gold mb-3"><Icon name={iconByType(p.type)} size={28} /></div>
              <h3 class="font-display text-lg font-bold mb-3">{p.name[lang]}</h3>
              <p class="text-2xl font-display font-bold text-gold mb-5">{p.price}</p>
              <p class="text-xs font-bold tracking-[0.12em] uppercase text-ink/60 mb-3">{t('dossier.includes')}</p>
              <ul class="space-y-2 text-sm text-ink/75 mb-6 flex-1">
                {p.includes[lang].map((it) => (
                  <li class="flex gap-2"><span class="text-gold">✓</span><span>{it}</span></li>
                ))}
              </ul>
              <a
                href={localePath(lang, '/contacto')}
                class="block text-center border-2 border-ink bg-ink text-white px-6 py-3 text-xs font-bold tracking-[0.15em] uppercase hover:bg-gold hover:border-gold transition-colors"
              >
                {t('dossier.cta')}
              </a>
            </article>
          ))}
        </div>
      </div>
    </Section>
  );
})}

<Section bg="ink">
  <div class="max-w-3xl mx-auto text-center text-white">
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3">{t('dossier.offer.title')}</p>
    <p class="text-lg md:text-xl mb-3">{t('dossier.offer.p1')}</p>
    <p class="text-lg md:text-xl mb-8">{t('dossier.offer.p2')}</p>
    <a
      href={localePath(lang, '/contacto')}
      class="inline-block border-2 border-white px-10 py-4 text-xs font-bold tracking-[0.18em] uppercase hover:bg-white hover:text-ink transition-colors"
    >
      {t('dossier.cta')}
    </a>
  </div>
</Section>

<Section>
  <p class="max-w-2xl mx-auto font-display italic text-center text-lg md:text-xl text-ink/80 leading-relaxed">
    {t('dossier.closing')}
  </p>
</Section>
