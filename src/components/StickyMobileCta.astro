---
// Mobile-only sticky bottom CTA bar. Appears after the visitor has
// scrolled past the hero (≈ 60vh) so it doesn't fight with the hero's
// own CTAs in the first viewport. Two side-by-side buttons —
// WhatsApp (primary) + a soft secondary CTA — full-width on phones.
//
// Used on the proposal landing and the venue landings, where the
// scroll path is long, the value prop has been made by section 2-3,
// and the visitor needs an always-visible "do this now" button.
//
// Reserve / quiz / book buttons hand off to the WhatsApp pre-fill that
// already mentions the page they came from (proposal vs venue).

import { useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  /** WhatsApp deep link, already pre-filled by the parent page. */
  whatsAppHref: string;
  /** Secondary CTA href — typically /quiz (or a venue/proposal-specific anchor). */
  secondaryHref: string;
  /** Localised primary label. Default "WhatsApp" but parent can override. */
  primaryLabel?: string;
  /** Localised secondary label, e.g. "Quiz" / "Reservar data". */
  secondaryLabel?: string;
}

const {
  lang,
  whatsAppHref,
  secondaryHref,
  primaryLabel = 'WhatsApp',
  secondaryLabel,
} = Astro.props;
const t = useTranslations(lang);

const defaultSecondary =
  lang === 'es' ? 'Quiz · 1 min'
  : lang === 'en' ? 'Quiz · 1 min'
  : 'Quiz · 1 min';
const secLabel = secondaryLabel ?? defaultSecondary;
---

<div
  data-sticky-cta
  class="md:hidden fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-ink/10 shadow-[0_-4px_12px_rgba(0,0,0,0.06)] px-3 py-3 flex gap-2 opacity-0 translate-y-full pointer-events-none transition-all duration-300"
  aria-hidden="true"
>
  <a
    href={whatsAppHref}
    target="_blank"
    rel="noopener"
    class="flex-1 inline-flex items-center justify-center gap-2 bg-gold text-ink border-2 border-gold px-4 py-3 text-xs font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white hover:border-ink transition-colors"
  >
    <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
      <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01M12.04 20.15c-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.21 8.21 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24a8.18 8.18 0 0 1 5.83 2.41 8.16 8.16 0 0 1 2.41 5.83c0 4.54-3.7 8.24-8.24 8.24m4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.78.97-.15.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43s.17-.25.25-.41c.08-.17.04-.31-.02-.43s-.56-1.34-.76-1.84c-.2-.48-.41-.42-.56-.43-.14-.01-.31-.01-.48-.01-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18s-.22-.16-.47-.28" />
    </svg>
    {primaryLabel}
  </a>
  <a
    href={secondaryHref}
    class="flex-1 inline-flex items-center justify-center bg-white text-ink border-2 border-ink px-4 py-3 text-xs font-bold tracking-[0.14em] uppercase hover:bg-ink hover:text-white transition-colors"
  >
    {secLabel}
  </a>
</div>

<script is:inline>
  (() => {
    const bar = document.querySelector('[data-sticky-cta]');
    if (!bar) return;
    let visible = false;
    const setVisible = (v) => {
      if (v === visible) return;
      visible = v;
      if (v) {
        bar.classList.remove('opacity-0', 'translate-y-full', 'pointer-events-none');
        bar.setAttribute('aria-hidden', 'false');
      } else {
        bar.classList.add('opacity-0', 'translate-y-full', 'pointer-events-none');
        bar.setAttribute('aria-hidden', 'true');
      }
    };
    const onScroll = () => {
      // Show once we're past ~60% of the first viewport — past the hero,
      // before the visitor has invested too much without a clear next step.
      setVisible(window.scrollY > window.innerHeight * 0.6);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
