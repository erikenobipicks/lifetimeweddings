{turnstileSitekey && (
  <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
)}

<style is:global>
  /* Reveal-on-scroll. Gated darrere `.reveal-ready` (afegit per JS) perquè,
     sense JS, res quedi amagat. Desactivat si l'usuari prefereix menys moviment. */
  .reveal-ready [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-ready [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal-ready [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  // ── Reveal-on-scroll: fa aparèixer suaument els blocs marcats amb data-reveal ──
  document.documentElement.classList.add('reveal-ready');
  const revealEls = document.querySelectorAll<HTMLElement>('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const ro = new IntersectionObserver(
      (entries) => {
        for (const en of entries) {
          if (en.isIntersecting) {
            en.target.classList.add('is-visible');
            ro.unobserve(en.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    );
    revealEls.forEach((el) => ro.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add('is-visible'));
  }

  // ── Vídeo facade: carrega l'iframe de YouTube només en fer clic ──
  document.querySelectorAll<HTMLButtonElement>('[data-video-facade]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const embed = btn.getAttribute('data-embed');
      if (!embed) return;
      const iframe = document.createElement('iframe');
      iframe.src = embed;
      iframe.title = 'Vídeo de boda · Lifetime Weddings';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.className = 'absolute inset-0 w-full h-full';
      btn.replaceWith(iframe);
    });
  });

  // ── Lightbox: clic a una foto de la galeria → s'amplia ──
  const overlay = document.querySelector<HTMLElement>('[data-lightbox-overlay]');
  const lbImg = overlay?.querySelector<HTMLImageElement>('[data-lightbox-img]');
  const lbWebp = overlay?.querySelector<HTMLSourceElement>('[data-lightbox-src-webp]');
  const lbCap = overlay?.querySelector<HTMLElement>('[data-lightbox-cap]');

  function openLightbox(full: string, webp: string, cap: string) {
    if (!overlay || !lbImg) return;
    if (lbWebp) lbWebp.srcset = webp;
    lbImg.src = full;
    lbImg.alt = cap;
    if (lbCap) lbCap.textContent = cap;
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    if (!overlay) return;
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    if (lbImg) lbImg.src = '';
    if (lbWebp) lbWebp.srcset = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('[data-lightbox]').forEach((btn) => {
    btn.addEventListener('click', () =>
      openLightbox(
        btn.getAttribute('data-full') ?? '',
        btn.getAttribute('data-full-webp') ?? '',
        btn.getAttribute('data-cap') ?? '',
      ),
    );
  });
  overlay?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target === overlay || target.hasAttribute('data-lightbox-close')) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  // ── Amaga la CTA sticky quan el formulari és visible (ja hi és) ──
  const sticky = document.querySelector<HTMLElement>('[data-sticky-cta]');
  const contact = document.getElementById('contacte');
  if (sticky && contact && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      ([e]) => sticky.classList.toggle('translate-y-full', e.isIntersecting),
      { threshold: 0.15 },
    );
    sticky.classList.add('transition-transform');
    io.observe(contact);
  }

  // ── Enviament del formulari (replica /contacto) + Meta Pixel Lead ──
  const form = document.querySelector<HTMLFormElement>('[data-ads-form]');
  const ok = document.querySelector<HTMLElement>('[data-ads-success]');
  const err = document.querySelector<HTMLElement>('[data-ads-error]');
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    ok?.classList.add('hidden');
    err?.classList.add('hidden');
    if (submitBtn) submitBtn.disabled = true;

    try {
      // JSON, no multipart (Astro security.checkOrigin rebutja multipart
      // darrere de Cloudflare/Railway). Mateix contracte que /contacto.
      const payload: Record<string, string> = {};
      for (const [k, v] of new FormData(form).entries()) payload[k] = String(v);

      const tkInput = form.querySelector<HTMLInputElement>('input[name="cf-turnstile-response"]');
      if (tkInput?.value) payload.captchaToken = tkInput.value;
      delete payload['cf-turnstile-response'];

      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) {
        const detail = await res.text().catch(() => '');
        throw new Error('HTTP ' + res.status + (detail ? ' ' + detail : ''));
      }

      // Conversió: dispara l'esdeveniment Lead del Meta Pixel si està carregat
      // (només quan el visitant ha acceptat cookies — consent-aware).
      if (typeof (window as any).fbq === 'function') {
        (window as any).fbq('track', 'Lead', { content_name: 'bodadslifetime' });
      }

      ok?.classList.remove('hidden');
      ok?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      form.reset();
    } catch (error) {
      console.error('[bodadslifetime] submit failed', error);
      err?.classList.remove('hidden');
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
