---
// One-pager d'embut de vendes per a Facebook / Instagram Ads.
//
// Objectiu únic: que la parella ompli el formulari de contacte (#contacte).
// Una sola CTA ("Demana disponibilitat") repetida al llarg de la pàgina +
// una CTA sticky a baix al mòbil. Sense menú de navegació: la pàgina es
// renderitza amb `chromeless` (cap Header/Footer) des de la pàgina pare.
//
// El formulari replica el de /contacto (mateixos camps, validació i destí):
// POST JSON a /api/contact → es desa el lead, s'avisa per email + Telegram,
// auto-resposta i push al CRM Fotostudio. A més, en enviar-se correctament
// dispara l'esdeveniment Meta Pixel `Lead` (si el pixel està configurat).
//
// Imatges: NOMÉS bodes REALS de Lifetime (no preboda/sessions de parella).
// Font: PHOTOS (photos.generated.ts) + metadades de WEDDINGS. Galeria
// "orientation-aware" (masonry: respecta la proporció real, res deformat),
// amb un MÀXIM de 2 fotos per parella i repartides en round-robin perquè mai
// surtin dues fotos de la mateixa parella de costat. Vídeo: tràilers públics
// de YouTube carregats amb una "facade" lleugera (només al clic) per no
// penalitzar la velocitat — el gruix del trànsit ve de mòbil.

import { SITE, waLink } from '~/data/site';
import { publicVideos, videoThumb, videoThumbFallback, videoEmbed } from '~/data/videos';
import { PHOTOS, type Photo } from '~/data/photos.generated';
import { WEDDINGS } from '~/data/weddings';

// Turnstile (anti-bot). Si no està configurat, el widget se salta i el
// servidor també — el formulari segueix funcionant en dev/staging.
const turnstileSitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '';

// Perfil de Google Business de Lifetime (mateix que el schema sameAs) — per
// enllaçar-hi el "5★ a Google".
const GOOGLE_REVIEWS_URL = 'https://maps.app.goo.gl/rw51XWxVHw6dYehc7';

// ─── Selecció de fotos de boda real ─────────────────────────────────────
// Metadades (nom de parella + lloc) indexades pel slug de fotos.
const META: Record<string, { couple: string; venue: string }> = Object.fromEntries(
  WEDDINGS.filter((w) => w.photoSlug).map((w) => [w.photoSlug as string, { couple: w.couple, venue: w.venue }]),
);

// Ordre de parelles per a la galeria (varietat). Només bodes amb fotos reals.
const ORDER = [
  'vanesa-david',
  'josep-eli',
  'elena-jordi',
  'idoya-pau',
  'jennifer-albert',
  'cristina-daniel',
  'marta-adria',
  'javi-olaya',
  'aaron-marta',
];

const toWebp = (p: string) => p.replace(/\.jpe?g$/, '.webp');

// Hero: una horitzontal forta d'una boda real.
const heroImg =
  (PHOTOS['vanesa-david']?.images ?? []).find((i) => i.orientation === 'landscape') ??
  PHOTOS['vanesa-david']?.images?.[0];

// Fins a 2 fotos per parella, preferint una vertical + una horitzontal per
// donar varietat de formats. Exclou la foto del hero.
function pickForCouple(slug: string, excludeId?: string): Photo[] {
  const imgs = (PHOTOS[slug]?.images ?? []).filter((i) => i.id !== excludeId);
  const portrait = imgs.find((i) => i.orientation === 'portrait');
  const landscape = imgs.find((i) => i.orientation === 'landscape');
  const picks: Photo[] = [];
  if (portrait) picks.push(portrait);
  if (landscape && landscape.id !== portrait?.id) picks.push(landscape);
  for (const i of imgs) {
    if (picks.length >= 2) break;
    if (!picks.includes(i)) picks.push(i);
  }
  return picks.slice(0, 2);
}

const perCouple = ORDER.map((slug) => ({
  slug,
  imgs: pickForCouple(slug, slug === 'vanesa-david' ? heroImg?.id : undefined),
}));

// Round-robin: primera foto de cada parella, després la segona. Així mai hi
// ha dues fotos de la mateixa parella seguides i es maximitza la varietat.
type GalleryItem = { img: Photo; couple: string; venue: string };
const gallery: GalleryItem[] = [];
for (let round = 0; round < 2; round++) {
  for (const c of perCouple) {
    const img = c.imgs[round];
    if (img) gallery.push({ img, couple: META[c.slug]?.couple ?? '', venue: META[c.slug]?.venue ?? '' });
  }
}
const galleryItems = gallery.slice(0, 12);

const caption = (g: GalleryItem) =>
  g.venue && g.venue !== '—' ? `${g.couple} · ${g.venue}` : g.couple;

// Vídeos: fins a 4 tràilers públics. El primer va destacat.
const films = publicVideos.slice(0, 4);
const featuredFilm = films[0];
const otherFilms = films.slice(1);

const waHref = waLink(
  'Hola! Venim de l’anunci i voldríem saber si teniu la nostra data lliure per a la boda 💍',
);

const steps = [
  {
    n: '01',
    title: 'Ens escrius',
    body: 'Omples el formulari amb la data (encara que sigui aproximada) i el lloc. Et responem en menys de 24 h.',
  },
  {
    n: '02',
    title: 'Ens coneixem',
    body: 'Una trobada o videotrucada sense compromís. Ens expliques com us imagineu el dia i t’ensenyem feina real.',
  },
  {
    n: '03',
    title: 'Reserveu la data',
    body: 'Si encaixem, bloquegem el vostre dia. A partir d’aquí, ja us podeu oblidar de la part de les fotos i el vídeo.',
  },
];

const faqs = [
  {
    q: 'Quant costa?',
    a: 'Depèn d’on us caseu, quantes hores voleu cobertura i si voleu foto, vídeo o tots dos. Escriu-nos amb la data i el lloc i t’enviem un pressupost clar, sense lletra petita.',
  },
  {
    q: 'Feu foto i vídeo alhora?',
    a: 'Sí, i és on brillem. Som dos germans: un a la foto i l’altre al vídeo. Un sol equip, coordinat, que no us fa repetir res ni es trepitja. El resultat és coherent perquè el pensem junts.',
  },
  {
    q: 'On treballeu?',
    a: 'Som de Reus (Tarragona) i ens movem per tot Tarragona, Lleida i Barcelona. Si us caseu en un altre lloc, pregunta-ho: viatgem.',
  },
  {
    q: 'Quan rebem les fotos i el vídeo?',
    a: 'Molt abans del que t’imagines. Les fotos editades te les entreguem en una setmana (com a molt, 15 dies) — no els mesos que és habitual al sector. I sol haver-hi un petit avançament de seguida perquè el pugueu compartir a les xarxes mentre encara us dura l’emoció. El vídeo triga una mica més (fins a 5 mesos) perquè el muntem amb cura, com una pel·lícula.',
  },
  {
    q: 'I si encara no tenim tots els detalls tancats?',
    a: 'No passa res. El primer pas és només veure si la data és lliure. La resta ho concretem parlant.',
  },
];

// Ressenyes reals (extretes de testimonials.ts / Google).
const reviews = [
  {
    quote:
      'El vídeo ha estat espectacular, com una pel·lícula. Si algun dia necessitem fotògraf o videògraf, repetim!',
    author: 'Laura & Joel',
  },
  {
    quote:
      'Creatius, professionals i ràpids. Saben plasmar a la perfecció el que volíem. El dia B… increïble, sense paraules.',
    author: 'Jose & Jordina',
  },
  {
    quote:
      'Va capturar cada moment amb una sensibilitat i un estil preciosos. Ens va fer sentir molt còmodes. Un autèntic plaer.',
    author: 'Luis & Craig',
  },
];
---

<!-- ───────────────────────── HERO ───────────────────────── -->
<section class="relative min-h-[88vh] md:min-h-[90vh] flex items-center justify-center px-6 overflow-hidden">
  {heroImg && (
    <picture class="absolute inset-0">
      <source
        type="image/webp"
        srcset={`${toWebp(heroImg.variants.md)} 1200w, ${toWebp(heroImg.variants.lg)} 1920w`}
        sizes="100vw"
      />
      <img
        src={heroImg.variants.lg}
        srcset={`${heroImg.variants.md} 1200w, ${heroImg.variants.lg} 1920w`}
        sizes="100vw"
        alt="Parella el dia de la seva boda fotografiada per Lifetime Weddings"
        class="absolute inset-0 w-full h-full object-cover"
        style="object-position: center 30%"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width={heroImg.width}
        height={heroImg.height}
      />
    </picture>
  )}
  <div class="absolute inset-0 bg-gradient-to-b from-ink/45 via-ink/40 to-ink/75"></div>
  <div class="relative max-w-3xl mx-auto text-center text-white pt-24 pb-24">
    <img
      src="/logos/logo-circle-white.png"
      alt="Lifetime Weddings"
      width="80"
      height="80"
      class="mx-auto mb-6 w-14 h-14 md:w-20 md:h-20 drop-shadow"
      loading="eager"
      decoding="async"
    />
    <p class="text-xs font-bold tracking-[0.24em] uppercase text-gold mb-5">
      Fotografia i vídeo de boda · Tarragona
    </p>
    <h1 class="font-display text-4xl md:text-6xl font-bold leading-[1.08] mb-6">
      El vostre dia passarà volant.<br />Nosaltres el guardem perquè el pugueu reviure.
    </h1>
    <p class="text-white/85 text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
      Fotos i vídeo de boda amb mirada d’autor, gens del reportatge típic. D’aquí 20 anys,
      tornareu a sentir el dia — no a mirar fotos genèriques.
    </p>
    <div class="mt-9 flex flex-col sm:flex-row gap-3 justify-center items-center">
      <a
        href="#contacte"
        data-cta
        class="inline-block bg-gold text-ink px-10 py-4 text-xs font-bold tracking-[0.18em] uppercase hover:brightness-110 transition"
      >
        Demana disponibilitat
      </a>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="inline-block border border-white/70 text-white px-8 py-4 text-xs font-bold tracking-[0.18em] uppercase hover:bg-white hover:text-ink transition-colors"
      >
        Escriu-nos pel WhatsApp
      </a>
    </div>
    <p class="text-white/60 text-xs mt-5">Resposta en menys de 24 h · Consulta gratuïta i sense compromís</p>
  </div>
  <span class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/60 motion-safe:animate-bounce" aria-hidden="true">
    <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
  </span>
</section>

<!-- ──────────────────── PROVA SOCIAL RÀPIDA ──────────────── -->
<section aria-label="Confiança" class="bg-cream border-b border-line">
  <div class="max-w-5xl mx-auto px-6 py-5">
    <ul class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 md:gap-x-10 text-[0.65rem] md:text-[0.75rem] font-bold tracking-[0.16em] uppercase text-ink/70">
      <li>+150 bodes</li>
      <li class="text-gold/60" aria-hidden="true">·</li>
      <li>
        <a href={GOOGLE_REVIEWS_URL} target="_blank" rel="noopener" class="hover:text-gold transition-colors">
          5★ a Google
        </a>
      </li>
      <li class="text-gold/60" aria-hidden="true">·</li>
      <li>Tarragona · Lleida · Barcelona</li>
      <li class="text-gold/60" aria-hidden="true">·</li>
      <li>Fotos en 1 setmana</li>
    </ul>
  </div>
</section>

<!-- ─────────────────── EL QUE SENT LA PARELLA ────────────── -->
<section class="bg-white">
  <div class="max-w-2xl mx-auto px-6 py-16 md:py-24 text-center" data-reveal>
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-4">Ho entenem</p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-8 leading-tight">
      La por de tota parella: que el dia passi i no quedi ben recollit.
    </h2>
    <div class="text-ink/80 text-lg leading-relaxed space-y-4 text-left">
      <p>
        Que us caseu, sigui tot un no parar, i quan voleu adonar-vos-en ja s’ha acabat. Que els
        nervis no us deixin gaudir-lo. Que les fotos us quedin… correctes, però fredes. De catàleg.
      </p>
      <p>
        I que el dia que les vulgueu ensenyar als vostres fills, no hi reconegueu ni l’emoció ni a
        vosaltres mateixos.
      </p>
      <p class="font-display italic text-ink text-xl">
        Per això existim. Perquè el vostre dia és irrepetible, i mereix unes imatges que ho semblin.
      </p>
    </div>
  </div>
</section>

<!-- ──────────────────── COM HO FEM NOSALTRES ─────────────── -->
<section class="bg-ink text-white">
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    <div class="max-w-2xl" data-reveal>
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-4">El nostre estil</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 leading-tight">
        Som dos germans amb una mirada pròpia: el Ferran i l’Eric.
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-8 md:gap-10 mt-10 text-white/80 leading-relaxed">
      <div>
        <h3 class="font-display text-xl text-white mb-2">Estil editorial, no de catàleg</h3>
        <p>
          Llum, composició i moments de veritat. Imatges que semblen tretes d’una revista, però amb
          la vostra història a dins.
        </p>
      </div>
      <div>
        <h3 class="font-display text-xl text-white mb-2">No us fem posar</h3>
        <p>
          Treballem amb naturalitat, respectant el ritme del dia. Us oblidareu que hi som — i això es
          nota a les fotos.
        </p>
      </div>
      <div>
        <h3 class="font-display text-xl text-white mb-2">Foto i vídeo, un sol equip</h3>
        <p>
          Un germà a la foto, l’altre al vídeo. Coordinats, sense trepitjar-nos i sense fer-vos
          repetir res. Resultat coherent.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ─────────────── CONEIX EL FERRAN I L'ERIC ─────────────── -->
<section class="bg-sand">
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-12" data-reveal>
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-4">Qui hi ha darrere</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4 leading-tight">Ens diem Ferran i Eric. Germans.</h2>
      <p class="text-ink-soft leading-relaxed">
        No sou una parella més a l’agenda: el dia de la vostra boda hi serem nosaltres dos, ningú més.
        Ens coneixereu abans i el dia B ja serem cares conegudes. Ens agrada estar al dia, fer pinya
        amb vosaltres i crear imatges que us vindrà de gust tornar a veure — i ensenyar a tothom.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 gap-6 md:gap-10 max-w-3xl mx-auto">
      <figure class="text-center" data-reveal>
        <img
          src="/team/ferran.jpg"
          alt="Ferran, fotògraf de Lifetime Weddings"
          width="900"
          height="900"
          loading="lazy"
          decoding="async"
          class="w-full aspect-square object-cover"
        />
        <figcaption class="mt-4">
          <p class="font-display text-2xl font-bold leading-none">Ferran</p>
          <p class="text-[0.7rem] font-bold tracking-[0.2em] uppercase text-gold-deep mt-1.5">Fotògraf</p>
          <p class="text-ink-soft text-sm leading-relaxed mt-3">
            Fotografio com qui explica una història, no com qui fa un catàleg. Busco la llum de veritat
            i els moments que no es repeteixen.
          </p>
        </figcaption>
      </figure>
      <figure class="text-center" data-reveal>
        <img
          src="/team/eric.jpg"
          alt="Eric, videògraf de Lifetime Weddings"
          width="900"
          height="900"
          loading="lazy"
          decoding="async"
          class="w-full aspect-square object-cover"
        />
        <figcaption class="mt-4">
          <p class="font-display text-2xl font-bold leading-none">Eric</p>
          <p class="text-[0.7rem] font-bold tracking-[0.2em] uppercase text-gold-deep mt-1.5">Videògraf</p>
          <p class="text-ink-soft text-sm leading-relaxed mt-3">
            Una boda són hores de coses petites que no tornen. La meva feina és que, d’aquí anys,
            les pugueu tornar a viure com si hi fóssiu.
          </p>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<!-- ─────────────────────── QUÈ INCLOU ────────────────────── -->
<section class="bg-white">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-12" data-reveal>
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-4">Què t’emportes</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold leading-tight">Tot pensat perquè no us hàgiu de preocupar de res</h2>
    </div>
    <ul class="grid sm:grid-cols-2 gap-x-10 gap-y-5 max-w-3xl mx-auto" data-reveal>
      {[
        'Cobertura completa del dia: dels preparatius fins a l’última cançó',
        'Galeria privada online amb totes les fotos editades',
        'Vídeo de boda editat com una pel·lícula (foto + vídeo, si el voleu)',
        'Els dos germans coordinats: un sol equip, sense fer-vos repetir res',
        'Entrega ràpida de veritat: la galeria completa en 1 setmana (màxim 15 dies), no els mesos de sempre',
        'Un avançament editat de seguida perquè el pugueu compartir a les xarxes mentre encara teniu el subidón',
        'Tracte proper i directe amb nosaltres dos, de principi a fi',
        'Ens movem per Tarragona, Lleida i Barcelona (i on faci falta)',
      ].map((item) => (
        <li class="flex items-start gap-3 text-ink/85 leading-relaxed">
          <svg viewBox="0 0 24 24" class="w-5 h-5 mt-0.5 shrink-0 text-gold" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- ─────────────────────── COM FUNCIONA ──────────────────── -->
<section class="bg-cream">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">
    <h2 class="font-display text-3xl md:text-4xl font-bold text-center mb-12" data-reveal>Com funciona</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {steps.map((s) => (
        <div class="text-center md:text-left">
          <span class="font-display text-5xl text-gold/50 leading-none">{s.n}</span>
          <h3 class="font-display text-xl font-bold mt-3 mb-2">{s.title}</h3>
          <p class="text-ink/75 leading-relaxed">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ───────────────────── GALERIA + VÍDEO ─────────────────── -->
<section class="bg-white">
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-24">
    <div class="text-center max-w-2xl mx-auto mb-12" data-reveal>
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-4">Bodes reals</p>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">Mira-ho tu mateix</h2>
      <p class="text-ink/75 leading-relaxed">
        Res de dir-vos que som bons. Preferim que ho vegeu. Totes aquestes són bodes de veritat que
        hem fotografiat i filmat.
      </p>
    </div>

    {/* Galeria masonry: respecta la proporció real de cada foto (res deformat). */}
    <div class="columns-2 md:columns-3 gap-3 md:gap-4 [&>figure]:mb-3 md:[&>figure]:mb-4">
      {galleryItems.map((g) => (
        <figure class="relative break-inside-avoid overflow-hidden group">
          <button
            type="button"
            data-lightbox
            data-full={g.img.variants.lg}
            data-full-webp={toWebp(g.img.variants.lg)}
            data-cap={caption(g)}
            class="block w-full cursor-zoom-in"
            aria-label={`Ampliar foto de la boda de ${caption(g)}`}
          >
            <picture>
              <source
                type="image/webp"
                srcset={`${toWebp(g.img.variants.sm)} 640w, ${toWebp(g.img.variants.md)} 1200w`}
                sizes="(min-width: 768px) 33vw, 50vw"
              />
              <img
                src={g.img.variants.md}
                srcset={`${g.img.variants.sm} 640w, ${g.img.variants.md} 1200w`}
                sizes="(min-width: 768px) 33vw, 50vw"
                width={g.img.width}
                height={g.img.height}
                loading="lazy"
                decoding="async"
                alt={`Boda de ${caption(g)} · Lifetime Weddings`}
                class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              />
            </picture>
          </button>
          <figcaption class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/75 to-transparent px-3 pb-2.5 pt-10 text-left text-white text-[0.68rem] font-bold tracking-[0.14em] uppercase">
            {caption(g)}
          </figcaption>
        </figure>
      ))}
    </div>

    {featuredFilm && (
      <div class="mt-12 md:mt-16">
        <p class="text-center text-xs font-bold tracking-[0.22em] uppercase text-gold-deep mb-6">
          I el vídeo, com una pel·lícula
        </p>

        {/* Vídeo destacat (facade lleugera: l'iframe es carrega només al clic). */}
        <div class="max-w-4xl mx-auto">
          <button
            type="button"
            data-video-facade
            data-embed={videoEmbed(featuredFilm.youtubeId)}
            class="group relative block w-full aspect-video overflow-hidden bg-ink"
            aria-label={`Reproduir el vídeo de la boda de ${featuredFilm.coupleName}`}
          >
            <img
              src={videoThumb(featuredFilm.youtubeId)}
              onerror={`this.onerror=null;this.src='${videoThumbFallback(featuredFilm.youtubeId)}'`}
              alt={`Tràiler de la boda de ${featuredFilm.coupleName}`}
              loading="lazy"
              decoding="async"
              width="1280"
              height="720"
              class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition"
            />
            <span class="absolute inset-0 flex items-center justify-center">
