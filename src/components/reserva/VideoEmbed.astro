---
// Video embed block for the booking proposal page. Renders a single
// representative wedding trailer with a click-to-load iframe (no YouTube
// network calls until the couple actually plays it, so the page stays
// fast and privacy-friendly).
//
// Default flagship video is hard-coded for now. Future iteration: let
// the admin pick a specific video per booking from src/data/videos.ts.

import { useTranslations, type Lang } from '~/i18n/ui';
import { videoThumb, videoThumbFallback, videoEmbed } from '~/data/videos';

interface Props {
  lang: Lang;
  youtubeId: string;
  /** Couple name to caption the video card. */
  coupleName: string;
  /** Where it was shot — venue + (optional) town. */
  venue: string;
}

const { lang, youtubeId, coupleName, venue } = Astro.props;
const t = useTranslations(lang);

const thumb = videoThumb(youtubeId);
const fallback = videoThumbFallback(youtubeId);
const embed = videoEmbed(youtubeId);
const playLabel =
  lang === 'es' ? 'Reproducir vídeo' : lang === 'en' ? 'Play video' : 'Reproduir vídeo';

// Consent-gate copy — shown if the couple explicitly rejected cookies in
// the banner. The page on /reserva is the booking proposal so the rate of
// this happening is essentially zero, but we keep the gate consistent
// across every click-to-load surface for compliance.
const gatedTitle = t('consent.gated.title');
const gatedBody = t('consent.gated.body');
const gatedCta = t('consent.gated.cta');
---

<section class="px-6 md:px-12 py-20 md:py-28 bg-white text-ink">
  <div class="max-w-4xl mx-auto">
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-3 text-center">
      {t('reserva.video.eyebrow')}
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-bold text-center mb-10">
      {t('reserva.video.heading')}
    </h2>

    <div class="relative aspect-video bg-black overflow-hidden" data-reserva-video>
      <button
        type="button"
        class="absolute inset-0 w-full h-full group focus:outline-none focus:ring-2 focus:ring-gold"
        aria-label={`${playLabel} — ${coupleName}`}
        data-thumb-button
      >
        <img
          src={thumb}
          data-fallback={fallback}
          alt={`${coupleName} · ${venue}`}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
        <span class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-colors"></span>
        <span class="absolute inset-0 flex items-center justify-center">
          <span
            class="w-16 h-16 md:w-20 md:h-20 bg-white/90 rounded-full flex items-center justify-center group-hover:bg-white transition-colors shadow-lg"
          >
            <svg viewBox="0 0 24 24" class="w-7 h-7 md:w-8 md:h-8 fill-ink ml-1" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </span>
      </button>
    </div>

    <p class="text-center text-sm text-ink/60 mt-4">{coupleName} · {venue}</p>
  </div>
</section>

<script is:inline define:vars={{ embed, gatedTitle, gatedBody, gatedCta }}>
  (() => {
    function consentRejected() {
      try {
        const raw = localStorage.getItem('lifetime.cookies.v1');
        if (!raw) return false;
        return JSON.parse(raw)?.choice === 'reject';
      } catch {
        return false;
      }
    }

    function showGatedMessage(wrap) {
      const div = document.createElement('div');
      div.className =
        'absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-ink/90 text-white';
      div.innerHTML =
        '<p class="font-display text-lg font-bold mb-2">' +
        gatedTitle +
        '</p><p class="text-sm text-white/80 max-w-md mb-4">' +
        gatedBody +
        '</p><button type="button" data-cookie-reopen class="bg-gold text-ink text-xs font-bold tracking-[0.15em] uppercase px-5 py-2.5 hover:brightness-110 transition">' +
        gatedCta +
        '</button>';
      wrap.replaceChildren(div);
      const btn = div.querySelector('[data-cookie-reopen]');
      if (btn) {
        btn.addEventListener('click', () => {
          document.dispatchEvent(new CustomEvent('consent:reopen'));
        });
      }
    }

    document.querySelectorAll('[data-reserva-video]').forEach((wrap) => {
      const btn = wrap.querySelector('[data-thumb-button]');
      const img = wrap.querySelector('img[data-fallback]');
      if (img) {
        img.addEventListener('error', () => {
          img.src = img.dataset.fallback;
        }, { once: true });
      }
      if (!btn) return;
      btn.addEventListener('click', () => {
        if (consentRejected()) {
          showGatedMessage(wrap);
          return;
        }
        const iframe = document.createElement('iframe');
        iframe.src = embed;
        iframe.title = 'Wedding trailer';
        iframe.className = 'absolute inset-0 w-full h-full';
        iframe.setAttribute('frameborder', '0');
        iframe.setAttribute(
          'allow',
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture',
        );
        iframe.setAttribute('allowfullscreen', '');
        wrap.replaceChildren(iframe);
      });
    });
  })();
</script>
