---
import { useTranslations, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const qs = [1, 2, 3, 4, 5, 6, 7] as const;
---

<section class="px-6 md:px-12 py-20 md:py-28 bg-white text-ink">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-12 text-center">
      {t('reserva.faq.heading')}
    </h2>
    <div class="divide-y divide-ink/10">
      {qs.map((i) => (
        <details class="group py-6">
          <summary class="cursor-pointer flex justify-between items-center gap-4 list-none">
            <span class="font-display text-lg md:text-xl font-bold leading-snug">
              {t(`reserva.faq.q${i}.q` as any)}
            </span>
            <span
              class="text-2xl text-gold transition-transform group-open:rotate-45 flex-shrink-0"
              aria-hidden="true"
            >+</span>
          </summary>
          <div class="mt-4 text-ink/75 leading-relaxed">
            {t(`reserva.faq.q${i}.a` as any)}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
