---
import { useTranslations, type Lang } from '~/i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="px-6 md:px-12 py-20 md:py-28 bg-white text-ink">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-display text-3xl md:text-4xl font-bold leading-tight mb-8">
      {t('reserva.why.heading')}
    </h2>
    <div class="prose prose-lg max-w-none text-ink/85 leading-relaxed whitespace-pre-line">
      {t('reserva.why.body')}
    </div>
  </div>
</section>
