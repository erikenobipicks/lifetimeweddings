---
// "Let's meet before deciding" block. Lives between FAQ and FinalCTA in
// the booking proposal flow.
//
// Intent contrast vs FinalCTA: the FinalCTA is for couples who are sold
// and want to book now. This is the softer option for couples who are
// still on the fence and would benefit from a face-to-face before
// committing. Two distinct CTAs, two distinct microcopies.
import { useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  /** WhatsApp deep-link with the "videocall" pre-filled message. */
  whatsappLink: string;
}

const { lang, whatsappLink } = Astro.props;
const t = useTranslations(lang);
---

<section class="px-6 md:px-12 py-20 md:py-28 bg-cream text-ink">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-4">
      {t('reserva.videocall.eyebrow')}
    </p>
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-6 leading-tight">
      {t('reserva.videocall.heading')}
    </h2>
    <p class="text-ink/80 leading-relaxed text-base md:text-lg max-w-2xl mx-auto mb-10 whitespace-pre-line">
      {t('reserva.videocall.body')}
    </p>
    <a
      href={whatsappLink}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center justify-center gap-2 bg-ink text-white font-bold px-8 py-4 hover:bg-gold hover:text-ink transition-colors"
    >
      <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true">
        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
      </svg>
      <span>{t('reserva.videocall.cta')}</span>
    </a>
    <p class="text-xs text-ink/50 mt-4">{t('reserva.videocall.subnote')}</p>
  </div>
</section>
