---
// Client tracker for /p/[token] quote pages.
// Heartbeats every 15 s with time-on-page + scroll depth. Also sends one final
// beacon on unload. Uses sessionStorage for a stable session id per tab.

interface Props { token: string }
const { token } = Astro.props;
---

<script define:vars={{ token }}>
  (function () {
    const KEY = 'lt.session.' + token;
    let sid = sessionStorage.getItem(KEY);
    if (!sid) {
      sid = Math.random().toString(36).slice(2) + Date.now().toString(36);
      sessionStorage.setItem(KEY, sid);
    }

    const start = Date.now();
    let maxScroll = 0;

    function scrollPct() {
      const h = document.documentElement;
      const total = h.scrollHeight - h.clientHeight;
      if (total <= 0) return 100;
      return Math.min(100, Math.max(0, Math.round((window.scrollY / total) * 100)));
    }

    window.addEventListener(
      'scroll',
      () => { maxScroll = Math.max(maxScroll, scrollPct()); },
      { passive: true },
    );

    function payload() {
      return JSON.stringify({
        token,
        sessionId: sid,
        timeOnPage: Math.min(86400, Math.round((Date.now() - start) / 1000)),
        maxScroll,
      });
    }

    function send(useBeacon) {
      const data = payload();
      if (useBeacon && navigator.sendBeacon) {
        const blob = new Blob([data], { type: 'application/json' });
        navigator.sendBeacon('/api/track', blob);
      } else {
        fetch('/api/track', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: data,
          keepalive: true,
        }).catch(() => {});
      }
    }

    // Heartbeat every 15 s while the tab is visible.
    let heartbeat = setInterval(() => {
      if (document.visibilityState === 'visible') send(false);
    }, 15000);

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') send(true);
    });
    window.addEventListener('pagehide', () => send(true));
    window.addEventListener('beforeunload', () => send(true));
  })();
</script>
