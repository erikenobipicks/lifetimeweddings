---
// /contrato post-deposit form. Second-step form after /reserva, only
// rendered when the operator has marked the deposit as paid in admin.
//
// Three sections:
//   1. Day-of operational details (language, ceremony/reception locations,
//      type, First Look)
//   2. Publication consent (5 channels — couple ticks which they authorise)
//   3. GDPR consent (mandatory checkbox)
//
// Submit posts JSON to /api/contrato/submit. Fails soft on the client side
// like ReservationForm — full reload on success-with-status banner.

import { useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang);

const turnstileSitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '';

const ceremonyTypes: Array<{ value: 'civil' | 'religious' | 'other'; label: string }> = [
  { value: 'civil', label: t('contrato.opt.ceremony.civil') },
  { value: 'religious', label: t('contrato.opt.ceremony.religious') },
  { value: 'other', label: t('contrato.opt.ceremony.other') },
];

const firstLookOptions: Array<{ value: 'yes' | 'no' | 'not_sure'; label: string }> = [
  { value: 'yes', label: t('contrato.opt.firstLook.yes') },
  { value: 'no', label: t('contrato.opt.firstLook.no') },
  { value: 'not_sure', label: t('contrato.opt.firstLook.not_sure') },
];

const consentChannels: Array<{
  value: 'display' | 'facebook' | 'website' | 'instagram' | 'private_video';
  label: string;
}> = [
  { value: 'display', label: t('contrato.opt.consent.display') },
  { value: 'facebook', label: t('contrato.opt.consent.facebook') },
  { value: 'website', label: t('contrato.opt.consent.website') },
  { value: 'instagram', label: t('contrato.opt.consent.instagram') },
  { value: 'private_video', label: t('contrato.opt.consent.private_video') },
];
---

<section id="contrato" class="px-6 md:px-12 py-16 md:py-24 bg-cream text-ink">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-3">{t('contrato.title')}</h2>
    <p class="text-ink/75 leading-relaxed mb-10 max-w-2xl">{t('contrato.intro')}</p>

    <div id="contrato-status" class="hidden mb-8" role="status" aria-live="polite"></div>

    <form id="contrato-form" novalidate class="space-y-12 bg-white p-6 md:p-10 border border-ink/10">
      <input type="hidden" name="slug" value={slug} />

      <!-- ─── Section 1: Day operational details ──────────────────── -->
      <fieldset class="space-y-6">
        <legend class="font-display text-xl md:text-2xl font-bold mb-2">{t('contrato.section.day.heading')}</legend>
        <p class="text-sm text-ink/60 -mt-1">{t('contrato.section.day.intro')}</p>

        <label class="block">
          <span class="text-sm font-semibold text-ink/70">{t('contrato.field.languageBetween')}</span>
          <span class="block text-xs text-ink/50 mt-0.5">{t('contrato.field.languageBetween.help')}</span>
          <input name="languageBetween" maxlength="80" class="mt-1.5 w-full px-3 py-2.5 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
        </label>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="block">
            <span class="text-sm font-semibold text-ink/70">{t('contrato.field.ceremonyLocation')} *</span>
            <input name="ceremonyLocationText" required maxlength="200" class="mt-1.5 w-full px-3 py-2.5 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
          </label>
          <label class="block">
            <span class="text-sm font-semibold text-ink/70">{t('contrato.field.receptionLocation')} *</span>
            <input name="receptionLocationText" required maxlength="200" class="mt-1.5 w-full px-3 py-2.5 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
          </label>
        </div>

        <div>
          <p class="text-sm font-semibold text-ink/70 mb-2">{t('contrato.field.ceremonyType')} *</p>
          <div class="flex flex-wrap gap-6">
            {ceremonyTypes.map((opt, i) => (
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="ceremonyType" value={opt.value} required class="accent-gold" data-ceremony-type={opt.value} />
                {opt.label}
              </label>
            ))}
          </div>
          <label class="block mt-3 hidden" id="ceremonyTypeOtherField">
            <span class="text-sm font-semibold text-ink/70">{t('contrato.field.ceremonyTypeOther')}</span>
            <input name="ceremonyTypeOther" maxlength="120" class="mt-1.5 w-full md:w-auto md:min-w-[320px] px-3 py-2.5 border border-ink/15 bg-white focus:border-gold focus:outline-none" />
          </label>
        </div>

        <div class="pt-4 border-t border-ink/10">
          <p class="text-sm font-semibold text-ink/70 mb-1">{t('contrato.field.firstLook')} *</p>
          <p class="text-xs text-ink/55 mb-3 leading-relaxed">{t('contrato.field.firstLook.help')}</p>
          <div class="flex flex-wrap gap-6">
            {firstLookOptions.map((opt) => (
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="firstLook" value={opt.value} required class="accent-gold" />
                {opt.label}
              </label>
            ))}
          </div>
        </div>
      </fieldset>

      <!-- ─── Section 2: Publication consent ──────────────────────── -->
      <fieldset class="space-y-4">
        <legend class="font-display text-xl md:text-2xl font-bold mb-2">{t('contrato.section.consent.heading')}</legend>
        <p class="text-sm text-ink/70 leading-relaxed mb-4">{t('contrato.section.consent.intro')}</p>
        <p class="text-sm font-semibold text-ink/70 mb-2">{t('contrato.field.publicationConsent')}</p>
        <div class="space-y-3">
          {consentChannels.map((ch) => (
            <label class="flex items-start gap-3 cursor-pointer">
              <input type="checkbox" name="publicationConsent" value={ch.value} class="h-5 w-5 mt-0.5 accent-gold flex-shrink-0" />
              <span class="text-sm leading-relaxed">{ch.label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- ─── Section 3: GDPR ─────────────────────────────────────── -->
      <fieldset class="space-y-4">
        <legend class="font-display text-xl md:text-2xl font-bold mb-2">{t('contrato.section.gdpr.heading')}</legend>
        <p class="text-xs text-ink/65 leading-relaxed">{t('contrato.field.gdpr.body')}</p>
        <label class="flex items-start gap-3 cursor-pointer pt-2">
          <input type="checkbox" name="gdprAccepted" required class="h-5 w-5 mt-0.5 accent-gold flex-shrink-0" />
          <span class="text-sm font-semibold">{t('contrato.field.gdpr.label')} *</span>
        </label>
      </fieldset>

      {turnstileSitekey && (
        <div class="cf-turnstile pt-2" data-sitekey={turnstileSitekey} data-theme="light" data-size="flexible"></div>
      )}

      <div class="pt-2">
        <button
          type="submit"
          id="contrato-submit"
          class="inline-flex items-center justify-center bg-gold text-ink font-bold px-8 py-4 hover:bg-ink hover:text-white transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {t('contrato.submit')}
        </button>
        <p class="text-sm text-ink/60 mt-4 max-w-xl">{t('contrato.submit.microcopy')}</p>
      </div>
    </form>
  </div>
</section>

{turnstileSitekey && (
  <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
)}

<script
  is:inline
  define:vars={{
    successTitle: t('contrato.success.title'),
    successBody: t('contrato.success.body'),
    errorGeneric: t('contrato.error.generic'),
    errorAlready: t('contrato.error.alreadySubmitted'),
    errorDeposit: t('contrato.error.depositPending'),
    errorRate: t('contrato.error.rateLimited'),
    errorValidation: t('contrato.error.validation'),
    submitting: t('contrato.submitting'),
  }}
>
  (() => {
    const form = document.getElementById('contrato-form');
    const status = document.getElementById('contrato-status');
    const submitBtn = document.getElementById('contrato-submit');
    if (!form || !status || !submitBtn) return;

    // Show/hide the "specify other" text input when "Otros" is selected.
    document.querySelectorAll('[data-ceremony-type]').forEach((el) => {
      el.addEventListener('change', () => {
        const isOther = document.querySelector('[data-ceremony-type="other"]').checked;
        document.getElementById('ceremonyTypeOtherField').classList.toggle('hidden', !isOther);
      });
    });

    function showStatus(kind, title, body) {
      const colors = {
        ok: 'bg-emerald-50 border-emerald-300 text-emerald-900',
        err: 'bg-red-50 border-red-300 text-red-900',
      }[kind];
      status.className = `mb-8 p-5 border ${colors}`;
      status.innerHTML = `<p class="font-display text-lg font-bold mb-2">${title}</p><p class="text-sm leading-relaxed">${body}</p>`;
      status.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();
      if (!form.reportValidity()) return;

      submitBtn.disabled = true;
      const oldLabel = submitBtn.textContent;
      submitBtn.textContent = submitting;

      const fd = new FormData(form);

      // Collect publicationConsent checkboxes into an array.
      const consent = fd.getAll('publicationConsent');

      const obj = {
        slug: fd.get('slug'),
        languageBetween: fd.get('languageBetween') || undefined,
        ceremonyLocationText: fd.get('ceremonyLocationText'),
        receptionLocationText: fd.get('receptionLocationText'),
        ceremonyType: fd.get('ceremonyType'),
        ceremonyTypeOther: fd.get('ceremonyTypeOther') || undefined,
        firstLook: fd.get('firstLook'),
        publicationConsent: consent,
        gdprAccepted: fd.get('gdprAccepted') === 'on',
      };

      const tkInput = form.querySelector('input[name="cf-turnstile-response"]');
      if (tkInput && tkInput.value) obj.captchaToken = tkInput.value;

      try {
        const res = await fetch('/api/contrato/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(obj),
        });
        const data = await res.json().catch(() => ({}));

        if (res.status === 200 && data.ok) {
          form.style.display = 'none';
          showStatus('ok', successTitle, successBody);
          return;
        }
        if (res.status === 409 && data.error === 'already_submitted') {
          showStatus('err', successTitle, errorAlready);
          form.style.display = 'none';
          return;
        }
        if (res.status === 409 && data.error === 'deposit_pending') {
          showStatus('err', '⚠', errorDeposit);
        } else if (res.status === 429) {
          showStatus('err', '⚠', errorRate);
        } else if (res.status === 400) {
          showStatus('err', '⚠', errorValidation);
        } else {
          showStatus('err', '⚠', errorGeneric);
        }
      } catch (e) {
        showStatus('err', '⚠', errorGeneric);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = oldLabel;
      }
    });
  })();
</script>
