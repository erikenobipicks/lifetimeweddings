---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, localePath, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  /** Path without locale prefix; used by LanguageSwitcher */
  path: string;
}

const { lang, path } = Astro.props;
const t = useTranslations(lang);

const home = localePath(lang, '/');
const nav = [
  { href: `${home}#about`, label: t('nav.about') },
  { href: `${home}#portfolio`, label: t('nav.portfolio') },
  { href: `${home}#services`, label: t('nav.services') },
  { href: `${home}#testimonials`, label: t('nav.testimonials') },
  { href: localePath(lang, '/blog'), label: t('nav.blog') },
  { href: localePath(lang, '/contacto'), label: t('nav.contact') },
];
---

<header class="fixed top-0 inset-x-0 z-40 bg-white/95 backdrop-blur-sm border-b border-black/5">
  <div class="flex items-center justify-between px-6 md:px-12 py-4">
    <a href={home} class="flex items-center gap-3" aria-label="Lifetime Weddings — Inicio">
      <img
        src="/logos/logo-circle-color.png"
        alt=""
        aria-hidden="true"
        width="56"
        height="56"
        class="w-12 h-12 md:w-14 md:h-14 object-contain"
        loading="eager"
        decoding="async"
      />
      <span class="font-display text-lg md:text-xl font-bold tracking-wide text-ink hidden sm:inline">
        Lifetime <span class="text-gold">Weddings</span>
      </span>
    </a>

    <nav aria-label="Principal" class="hidden lg:block">
      <ul class="flex items-center gap-8">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-xs font-bold tracking-widest uppercase text-ink hover:text-gold transition-colors"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex items-center gap-4">
      <a
        href={localePath(lang, '/quiz')}
        class="hidden md:inline-block bg-gold text-white px-5 py-2 text-[0.7rem] font-bold tracking-[0.15em] uppercase hover:brightness-110 transition"
      >
        {t('nav.book')}
      </a>
      <LanguageSwitcher current={lang} path={path} />
      <button
        type="button"
        class="lg:hidden flex flex-col gap-1.5 p-1"
        aria-label="Abrir menú"
        data-mobile-toggle
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="w-6 h-0.5 bg-ink"></span>
        <span class="w-6 h-0.5 bg-ink"></span>
        <span class="w-6 h-0.5 bg-ink"></span>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    aria-label="Mobile"
    class="lg:hidden bg-white border-t border-black/5 overflow-hidden max-h-0 transition-[max-height] duration-300 ease-out"
    data-mobile-menu
  >
    <ul class="flex flex-col px-6 py-4">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class="block py-3 text-sm font-bold tracking-widest uppercase text-ink hover:text-gold"
            data-mobile-link
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-mobile-link]');

  function open() {
    if (!menu || !toggle) return;
    menu.style.maxHeight = menu.scrollHeight + 'px';
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    if (!menu || !toggle) return;
    menu.style.maxHeight = '0px';
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? close() : open();
  });
  links.forEach((a) => a.addEventListener('click', close));
</script>
