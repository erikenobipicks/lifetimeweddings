---
import { useTranslations, localePath, type Lang } from '~/i18n/ui';
import { SITE } from '~/data/site';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

// Wedding-photography landing pages by city. Surfaced in the footer so the
// whole geo cluster is one click from every page: this fixes the orphan-page
// problem (nothing else linked to the cluster) and keeps every city landing
// within 2 clicks of the home. Photo landings are the priority keyword
// targets; each city page then links onward to its video sister page, the
// venues hub and the Tarragona/Lleida pillar.
const ZONE_CITIES = [
  { slug: 'tarragona', name: 'Tarragona' },
  { slug: 'reus', name: 'Reus' },
  { slug: 'lleida', name: 'Lleida' },
  { slug: 'cambrils', name: 'Cambrils' },
  { slug: 'salou', name: 'Salou' },
  { slug: 'montblanc', name: 'Montblanc' },
  { slug: 'tortosa', name: 'Tortosa' },
];
const zonesLabel =
  lang === 'ca' ? 'Fotògraf de boda per zones' : lang === 'es' ? 'Fotógrafo de boda por zonas' : 'Wedding photographer by area';
---

<footer class="bg-ink text-white/80 py-10 px-6 text-center text-sm">
  <div class="max-w-5xl mx-auto flex flex-col gap-3">
    <p class="font-display text-white text-lg">Lifetime Weddings</p>

    <p>
      <a href={`mailto:${SITE.email}`} class="text-gold hover:underline">{SITE.email}</a>
      <span class="mx-2 opacity-70" aria-hidden="true">·</span>
      <a href={`tel:${SITE.phone}`} class="text-gold hover:underline">{SITE.phoneDisplay}</a>
    </p>

    <p>
      <a href={SITE.social.instagram} target="_blank" rel="noopener" class="hover:text-gold">Instagram</a>
      <span class="mx-2 opacity-70" aria-hidden="true">·</span>
      <a href={SITE.social.youtube} target="_blank" rel="noopener" class="hover:text-gold">YouTube</a>
      <span class="mx-2 opacity-70" aria-hidden="true">·</span>
      <a href={SITE.social.pinterest} target="_blank" rel="noopener" class="hover:text-gold">Pinterest</a>
    </p>

    <p class="text-xs opacity-90 mt-1">
      {lang === 'ca' ? 'Responem de dl. a dv., de 9 a 19h' : lang === 'es' ? 'Respondemos de L a V, de 9 a 19h' : 'We reply Mon–Fri, 9am–7pm'}
      <span class="mx-2 opacity-70" aria-hidden="true">·</span>
      {lang === 'ca' ? 'Pagament fraccionat disponible' : lang === 'es' ? 'Pago fraccionado disponible' : 'Split payment available'}
    </p>

    <nav aria-label={zonesLabel} class="text-xs opacity-90 mt-1 leading-relaxed">
      <span class="opacity-70">{zonesLabel}:</span>
      {ZONE_CITIES.map((c, i) => (
        <>
          {i > 0 && <span class="mx-1.5 opacity-70" aria-hidden="true">·</span>}
          <a href={localePath(lang, `/fotograf-boda-${c.slug}`)} class="hover:text-gold">{c.name}</a>
        </>
      ))}
    </nav>

    <nav aria-label="Legal" class="text-xs opacity-90">
      <a href={localePath(lang, '/legal')} class="hover:text-gold">{t('footer.legal')}</a>
      <span class="mx-2 opacity-70" aria-hidden="true">·</span>
      <a href={localePath(lang, '/privacidad')} class="hover:text-gold">{t('footer.privacy')}</a>
      <span class="mx-2 opacity-70" aria-hidden="true">·</span>
      <a href={localePath(lang, '/cookies')} class="hover:text-gold">{t('footer.cookies')}</a>
      <span class="mx-2 opacity-70" aria-hidden="true">·</span>
      <button
        type="button"
        data-cookie-reopen
        class="hover:text-gold underline-offset-2 hover:underline cursor-pointer bg-transparent border-0 p-0 font-inherit text-inherit"
      >
        {t('cookies.preferences')}
      </button>
    </nav>

    <p class="opacity-90 text-xs mt-2">© {SITE.copyrightSince}–{year} Lifetime Weddings. {t('footer.rights')}</p>
  </div>
</footer>

<script is:inline>
  // Footer "Preferencias de cookies" button reopens the consent banner so
  // visitors can change their mind after the first choice. The actual banner
  // listens for this event in CookieBanner.astro.
  document.querySelectorAll('[data-cookie-reopen]').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('consent:reopen'));
    });
  });
</script>
