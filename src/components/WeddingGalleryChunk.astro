---
// Reusable photo grid block used by /bodas/<slug> to render one chunk
// of the wedding gallery. Splitting the full gallery into chunks lets
// the page intersperse short copy beats and CTAs between blocks of
// photos — much better pacing than the previous single-grid dump.

import { SITE } from '~/data/site';

interface Photo {
  variants: { sm: string; md: string; lg: string };
  width: number;
  height: number;
  orientation: 'landscape' | 'portrait' | 'square';
}

interface Props {
  /** Photos for this chunk only (already pre-sliced by the parent). */
  photos: Photo[];
  /** Index of `photos[0]` in the full gallery, for accurate alt text. */
  startIndex: number;
  /** Full-page URL — used as the Pinterest pin destination. */
  pageUrl: string;
  /** Localised alt text builder, 1-indexed against the full gallery. */
  galleryAlt: (i: number) => string;
  /** Localised "Photo {n}" label for the lightbox anchor. */
  photoLabel: (i: number) => string;
  /** Localised "Save to Pinterest" aria-label. */
  pinterestLabel: string;
}

const { photos, startIndex, pageUrl, galleryAlt, photoLabel, pinterestLabel } = Astro.props;

const webp = (p: string): string => p.replace(/\.jpe?g$/i, '.webp');
---

<div class="max-w-6xl mx-auto">
  <div class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-3">
    {photos.map((img, k) => {
      const i = startIndex + k;
      const span = img.orientation === 'landscape' ? 'md:col-span-2' : '';
      const description = galleryAlt(i + 1);
      const pinterestUrl = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(pageUrl)}&media=${encodeURIComponent(new URL(img.variants.lg, SITE.url).toString())}&description=${encodeURIComponent(description)}`;
      return (
        <div class:list={['relative overflow-hidden group', span]}>
          <a
            href={img.variants.lg}
            target="_blank"
            rel="noopener"
            class="block"
            aria-label={photoLabel(i + 1)}
          >
            <picture>
              <source
                type="image/webp"
                srcset={`${webp(img.variants.sm)} 640w, ${webp(img.variants.md)} 1200w, ${webp(img.variants.lg)} 1920w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              />
              <img
                src={img.variants.md}
                srcset={`${img.variants.sm} 640w, ${img.variants.md} 1200w, ${img.variants.lg} 1920w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt={description}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading={i < 2 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
                decoding="async"
                width={img.width}
                height={img.height}
              />
            </picture>
          </a>
          <a
            href={pinterestUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={pinterestLabel}
            data-pin-do="none"
            class="absolute top-3 right-3 w-9 h-9 rounded-full bg-white/90 hover:bg-white text-[#E60023] flex items-center justify-center opacity-70 md:opacity-0 md:group-hover:opacity-100 transition-opacity shadow-md"
          >
            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
              <path d="M12 0a12 12 0 0 0-4.37 23.17c-.1-.93-.2-2.36.04-3.38.22-.92 1.4-5.85 1.4-5.85s-.36-.72-.36-1.78c0-1.66.96-2.9 2.16-2.9 1.02 0 1.51.77 1.51 1.69 0 1.03-.66 2.57-1 4-.28 1.2.6 2.17 1.78 2.17 2.13 0 3.77-2.25 3.77-5.5 0-2.88-2.07-4.89-5.02-4.89-3.42 0-5.43 2.57-5.43 5.22 0 1.03.4 2.14.9 2.74.1.12.11.22.08.34l-.34 1.36c-.05.22-.17.27-.4.16-1.5-.7-2.42-2.88-2.42-4.64 0-3.78 2.74-7.25 7.91-7.25 4.15 0 7.38 2.96 7.38 6.92 0 4.13-2.6 7.46-6.21 7.46-1.21 0-2.36-.63-2.75-1.38l-.75 2.86c-.27 1.04-1 2.34-1.49 3.13A12 12 0 1 0 12 0z" />
            </svg>
          </a>
        </div>
      );
    })}
  </div>
</div>
