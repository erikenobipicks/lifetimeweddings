---
// Orchestrator for the rich wedding case page. Composes the individual
// blocks (Hero / Intro / Gallery / Ficha / Testimoni / Similars / Blog /
// CTA) from the legacy Wedding + the Content Collection entry.
//
// The route file decides between this and the simple template based on
// getWeddingCase() result. This component assumes `mode === 'rich'` has
// already been determined and the stub guard has passed.

import type { Wedding } from '~/data/weddings';
import { render, type CollectionEntry } from 'astro:content';
import { weddingGallery, weddingCover } from '~/data/weddings';
import type { Lang } from '~/i18n/ui';

import Hero from './Hero.astro';
import IntroBlock from './IntroBlock.astro';
import GallerySections from './GallerySections.astro';
import FichaDia from './FichaDia.astro';
import Testimoni from './Testimoni.astro';
import BodesSimilars from './BodesSimilars.astro';
import BlogPostLink from './BlogPostLink.astro';
import CTA from './CTA.astro';

interface Props {
  lang: Lang;
  legacy: Wedding;
  /** Full collection entry — we use `entry.data` for frontmatter and
   *  `entry.render()` to emit the optional Markdown body. */
  entry: CollectionEntry<'weddings'>;
}

const { lang, legacy, entry } = Astro.props;
const rich = entry.data;

// Render the (optional) Markdown body. `Content` is empty when the MD file
// has no body — Astro emits nothing in that case, so we always render it
// inside the IntroBlock slot without guarding. Astro 5+ uses the standalone
// `render(entry)` helper from `astro:content`; the older `entry.render()`
// is no longer present.
const { Content } = await render(entry);

const gallery = weddingGallery(legacy);
const cover = weddingCover(legacy);
// Cover: either rich.gallery.cover (photo id) takes precedence, else first image.
let coverLarge = gallery[0]?.variants.lg ?? cover ?? '';
if (rich.gallery?.cover && gallery.length > 0) {
  const idx = parseInt(rich.gallery.cover, 10) - 1;
  if (idx >= 0 && idx < gallery.length) {
    coverLarge = gallery[idx].variants.lg;
  }
}

const intro = rich.content?.intro?.[lang]?.trim() ?? '';
const venueName = rich.venue?.name ?? (legacy.venue !== '—' ? legacy.venue : undefined);
const location = rich.venue?.city ?? (legacy.location !== '—' ? legacy.location : undefined);
const testimonial = rich.testimonial?.[lang];
---

<Hero
  lang={lang}
  couple={rich.couple}
  venueName={venueName}
  location={location}
  coverLarge={coverLarge}
/>

{intro
  ? (
    <IntroBlock lang={lang} intro={intro}>
      <Content />
    </IntroBlock>
  )
  : (
    <!-- No intro paragraph but the MD body may still exist (rare). Render it
         inside its own bare prose container so it doesn't visually attach to
         the hero. -->
    <section class="px-6 md:px-12 pt-20 md:pt-28 pb-12 md:pb-16 bg-white text-ink">
      <div class="max-w-3xl mx-auto prose prose-lg max-w-none text-ink/80 leading-relaxed">
        <Content />
      </div>
    </section>
  )
}

{gallery.length > 0 && (
  <GallerySections
    lang={lang}
    couple={rich.couple}
    venueName={venueName}
    location={location}
    images={gallery}
    sections={rich.gallery?.sections}
  />
)}

<FichaDia
  lang={lang}
  date={rich.date}
  venue={rich.venue}
  details={rich.details}
  suppliers={rich.suppliers}
/>

<Testimoni lang={lang} quote={testimonial ?? undefined} author={rich.couple} />

{rich.related && rich.related.length > 0 && (
  <BodesSimilars lang={lang} slugs={rich.related} currentSlug={legacy.slug} />
)}

<BlogPostLink lang={lang} slug={rich.blogPost} />

<CTA lang={lang} />
