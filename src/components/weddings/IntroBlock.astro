---
// Intro paragraph below the hero. ~400-char narrative from the collection's
// `content.intro[lang]`. Optional long-form body can be rendered below via
// the default slot (MDX from the MD body).
import { useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  intro: string;
}

const { lang, intro } = Astro.props;
const t = useTranslations(lang);
---

<section class="px-6 md:px-12 pt-20 md:pt-28 pb-12 md:pb-16 bg-white text-ink">
  <div class="max-w-3xl mx-auto">
    <h2 class="font-display text-2xl md:text-3xl font-bold mb-6">{t('case.intro.heading')}</h2>
    <div class="prose prose-lg max-w-none text-ink/80 leading-relaxed whitespace-pre-line">
      {intro}
    </div>
    <slot />
  </div>
</section>
