---
// Testimonial block. Only renders when quote is non-empty for this locale.
// Rendered as a highlighted pull-quote between Ficha and Related.
import { useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  lang: Lang;
  quote?: string;
  author: string;
}

const { lang, quote, author } = Astro.props;
const t = useTranslations(lang);
const trimmed = quote?.trim();
const visible = trimmed && trimmed !== '' && !trimmed.toUpperCase().startsWith('TODO');
---

{visible && (
  <section class="px-6 md:px-12 py-20 md:py-28 bg-cream text-ink">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs font-bold tracking-[0.22em] uppercase text-gold mb-4">
        {t('case.testimoni.heading')}
      </p>
      <blockquote class="font-display text-2xl md:text-3xl leading-snug italic text-ink/90">
        “{trimmed}”
      </blockquote>
      <p class="mt-6 text-sm text-ink/60">— {author}</p>
    </div>
  </section>
)}
