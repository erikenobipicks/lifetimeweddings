---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import WhatsAppFloat from '~/components/WhatsAppFloat.astro';
import CookieBanner from '~/components/CookieBanner.astro';
import { ogLocale, useTranslations, type Lang } from '~/i18n/ui';

// Fonts (Cormorant Garamond + Jost) are loaded from Google Fonts via the
// @import at the top of global.css, so a single source covers every page.
// We only add the preconnect hints below for faster handshakes.

interface Props {
  title: string;
  description: string;
  lang: Lang;
  /** Path without locale prefix, starting with '/'. e.g. '/contacto' */
  canonicalPath?: string;
  ogImage?: string;
  /** OpenGraph type. Default 'website'. Use 'article' on blog posts and
   *  wedding galleries to unlock Pinterest Rich Pins + Article Twitter Card. */
  ogType?: 'website' | 'article';
  /** ISO date — emitted as `article:published_time` when `ogType='article'`. */
  articlePublishedTime?: string;
  /** ISO date — emitted as `article:modified_time` when `ogType='article'`. */
  articleModifiedTime?: string;
  /** Display name — emitted as `article:author` when `ogType='article'`. */
  articleAuthor?: string;
  /** JSON-LD objects to inject into <head> */
  jsonLd?: unknown[];
  /** Hide header/footer (e.g. for landing pages) */
  chromeless?: boolean;
  /** Tell search engines not to index this page (e.g. /packs is only shared
   *  privately via email/WhatsApp, never crawled). */
  noindex?: boolean;
  /** Load the site-wide Meta Pixel (929…). Set false on pages that inject
   *  their own pixel (e.g. the /bodadslifetime ads landing uses 715…). */
  metaPixel?: boolean;
}

const {
  title,
  description,
  lang,
  canonicalPath = '/',
  ogImage = '/og-default.jpg',
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  jsonLd,
  chromeless = false,
  noindex = false,
  metaPixel = true,
} = Astro.props;

const t = useTranslations(lang);
const site = Astro.site ?? new URL('https://www.lifetime.photo');
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? '';
// Site-wide Meta Pixel id (public; hardcoded fallback so it works even if the
// env var isn't set at build). The /bodadslifetime ads landing opts out
// (metaPixel={false}) and injects its own separate pixel.
const metaPixelId = import.meta.env.PUBLIC_META_PIXEL_ID || '929985713206331';

function localeHref(l: Lang, p: string): string {
  const base = l === 'ca' ? p : `/${l}${p === '/' ? '' : p}`;
  return new URL(base === '' ? '/' : base, site).toString();
}

const canonical = localeHref(lang, canonicalPath);
const alternates: { hreflang: string; href: string }[] = [
  { hreflang: 'ca', href: localeHref('ca', canonicalPath) },
  { hreflang: 'es', href: localeHref('es', canonicalPath) },
  { hreflang: 'en', href: localeHref('en', canonicalPath) },
  { hreflang: 'x-default', href: localeHref('ca', canonicalPath) },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocale[lang]} />
    <meta property="og:site_name" content="Lifetime Weddings" />

    {/* Pinterest Rich Pins — explicit opt-in. Pinterest already infers
        Rich Pin status from the article:* + og:* tags above; this tag
        makes the intent unambiguous to the validator. */}
    <meta name="pinterest-rich-pin" content="true" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site).toString()} />
    <meta name="twitter:image:alt" content={title} />

    {/* Brand gold. Keep in sync with `--gold` in src/styles/global.css —
        an HTML attribute can't read a CSS custom property. */}
    <meta name="theme-color" content="#a9885f" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    {/* Fonts load from Google Fonts (Cormorant Garamond + Jost) via the
        @import in global.css. Preconnect shaves the TLS handshake off the
        critical path. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {/* Preload the home hero image for an LCP win. Only injected on the
        three locale homes — other routes carry their own LCP candidates
        (or none at all). */}
    {(canonicalPath === '/' || canonicalPath === '') && (
      <link
        rel="preload"
        as="image"
        type="image/webp"
        href="/photos/elena-jordi/006-md.webp"
        imagesrcset="/photos/elena-jordi/006-sm.webp 640w, /photos/elena-jordi/006-md.webp 1200w, /photos/elena-jordi/006-lg.webp 1920w"
        imagesizes="100vw"
        fetchpriority="high"
      />
    )}

    {jsonLd?.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    {/* GA4 — consent-aware. Only loads when the visitor has accepted
        cookies via the CookieBanner. Reads the same localStorage key the
        banner writes to and also listens for the consent:change event so
        a fresh "accept" click activates GA without a page reload. */}
    {gaId && (
      <script is:inline define:vars={{ gaId }}>
        (function() {
          var KEY = 'lifetime.cookies.v1';
          function consentAccepted() {
            try { return JSON.parse(localStorage.getItem(KEY) || '{}').choice === 'accept'; }
            catch (e) { return false; }
          }
          var loaded = false;
          function loadGA() {
            if (loaded) return;
            loaded = true;
            var s = document.createElement('script');
            s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
            s.async = true;
            document.head.appendChild(s);
            window.dataLayer = window.dataLayer || [];
            function gtag() { dataLayer.push(arguments); }
            window.gtag = gtag; // expose so app code can send events
            gtag('js', new Date());
            gtag('config', gaId, { anonymize_ip: true });
          }
          // Consent-aware event helper. Components call window.lwTrack(name, params).
          // No-ops unless analytics consent is accepted AND gtag has loaded, so
          // nothing is ever sent without consent.
          window.lwTrack = function(name, params) {
            if (!consentAccepted() || typeof window.gtag !== 'function') return;
            window.gtag('event', name, params || {});
          };
          if (consentAccepted()) loadGA();
          document.addEventListener('consent:change', function(e) {
            if (e.detail && e.detail.choice === 'accept') loadGA();
          });
        })();
      </script>
    )}

    {/* Site-wide Meta Pixel — consent-aware, same pattern as GA4. Loads only
        after the visitor accepts cookies. PageView fires on load; the Lead
        event is fired by the contact form on success (deduped with the
        server-side Conversions API via a shared eventID). Opted out on the
        ads landing, which injects its own separate pixel. */}
    {metaPixel && metaPixelId && (
      <script is:inline define:vars={{ metaPixelId }}>
        (function () {
          var KEY = 'lifetime.cookies.v1';
          var loaded = false;
          function loadPixel() {
            if (loaded) return;
            loaded = true;
            !(function (f, b, e, v, n, t, s) {
              if (f.fbq) return;
              n = f.fbq = function () {
                n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
              };
              if (!f._fbq) f._fbq = n;
              n.push = n;
              n.loaded = !0;
              n.version = '2.0';
              n.queue = [];
              t = b.createElement(e);
              t.async = !0;
              t.src = v;
              s = b.getElementsByTagName(e)[0];
              s.parentNode.insertBefore(t, s);
            })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
            window.fbq('init', metaPixelId);
            window.fbq('track', 'PageView');
          }
          try {
            var stored = JSON.parse(localStorage.getItem(KEY) || '{}');
            if (stored.choice === 'accept') loadPixel();
          } catch (e) {}
          document.addEventListener('consent:change', function (e) {
            if (e.detail && e.detail.choice === 'accept') loadPixel();
          });
        })();
      </script>
    )}
  </head>
  <body class="bg-cream text-ink font-sans antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-ink focus:text-white focus:px-4 focus:py-2"
    >
      {t('a11y.skipToContent')}
    </a>

    {!chromeless && <Header lang={lang} path={canonicalPath} />}

    <main id="main" class={chromeless ? '' : 'pt-0'}>
      <slot />
    </main>

    {!chromeless && <Footer lang={lang} />}
    {!chromeless && <WhatsAppFloat lang={lang} />}
    {!chromeless && <CookieBanner lang={lang} />}
  </body>
</html>
